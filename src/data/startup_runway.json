  "faq": [
    {
      "question": "How do you calculate startup runway?",
      "answer": "Runway is your cash on hand divided by your net monthly burn (burn minus revenue). Add growth rates to see how runway changes as expenses and revenue scale."
    },
    {
      "question": "How much runway should a startup have?",
      "answer": "Most seed and Series A startups aim for 12-24 months of runway. Plan to start fundraising at least 6 months before cash runs out."
    },
    {
      "question": "What is a good monthly burn rate for an AI agent startup?",
      "answer": "A lean AI agent startup can burn $5,000-20,000/month in early stages, with API spend and engineering salaries as the largest line items."
    },
    {
      "question": "How does revenue growth extend runway?",
      "answer": "Net burn shrinks as revenue grows, which extends runway. Even small monthly improvements in revenue growth can delay the need for a bridge round."
    }
  ]
