---
import Layout from '../layouts/Layout.astro';
import SubscriptionForm from '../components/SubscriptionForm.astro';

const entries = await Astro.glob('../content/directory/*.md');
const financeEntries = entries.filter(e => e.frontmatter.category === 'data-stack');

const products = financeEntries.map(e => ({...e.frontmatter, Content: e.Content}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Investing & Trading Tools | The Ledger",
  "description": "Comparison of trading platforms, charting tools, and brokerage APIs. Affiliate transparency. Built by Mission Freedom.",
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem", "position": i + 1,
    "item": {"@type": "Product", "name": p.name, "description": p.name_full,
      "offers": {"@type": "Offer", "price": p.price, "priceCurrency": "USD"}}
  }))
};
---

<Layout
  title="Investing & Trading Tools | The Ledger"
  description="Trading platforms, charting tools, and brokerage APIs. Based on community benchmarks. Affiliate transparency. Boise, Idaho."
>

<!-- AEO + SEO Schema -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

<!-- Hero -->
<section class="relative py-12 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-brand-gold/10"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 mb-6">
      <span class="text-brand-gold text-sm font-mono">💰 THE LEDGER</span>
    </div>
    
    <h1 class="text-4xl md:text-5xl font-bold mb-4">
      <span class="text-gradient">Invest & Trade</span>
    </h1>
    <p class="text-gray-400 max-w-2xl mx-auto mb-4 text-lg">
      Trading platforms we actually use for bot execution, backtesting, and charting.
    </p>
    
    <!-- Affiliate Disclosure -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-amber-500/10 border border-amber-500/30 mb-8">
      <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span class="text-amber-400 text-xs">FTC Disclosure: Some links are affiliate/referral links. We may earn if you sign up.</span>
    </div>
    
    <div class="flex flex-wrap justify-center gap-3 text-sm">
      <a href="/directory" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-gold/50 transition">← Full Directory</a>
      <a href="/hardware" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-accent/50 transition">Upgrades →</a>
      <a href="/crypto" class="px-4 py-2 rounded-full border border-white/10 hover:border-purple-500/50 transition">The Mine →</a>
      <a href="/invest/compare" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-gold/50 transition">Compare Brokers →</a>
    </div>
  </div>
</section>

<!-- Comparison Table -->
<section class="max-w-6xl mx-auto px-4 pb-8">
  <div class="glass-card rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-white/5 border-b border-white/10">
        <tr>
          <th class="text-left p-4 font-semibold">Tool</th>
          <th class="text-left p-4 font-semibold">Best For</th>
          <th class="text-left p-4 font-semibold">Price</th>
          <th class="text-left p-4 font-semibold">Our Rating</th>
          <th class="text-right p-4 font-semibold">Action</th>
        </tr>
      </thead>
      <tbody>
        {products.map(product => (
          <tr class="border-b border-white/5 hover:bg-white/[0.02] transition">
            <td class="p-4">
              <span class="font-semibold">{product.name}</span>
              <span class="text-xs text-gray-500 ml-2">{product.subcategory}</span>
            </td>
            <td class="p-4 text-gray-400">{product.why_use || product.stack_position}</td>
            <td class="p-4 font-mono">{product.price === 0 ? 'Free' : '$' + product.price}</td>
            <td class="p-4"><span class="text-brand-gold">★★★★★</span></td>
            <td class="p-4 text-right">
              <a href={product.referral_link || product.amazon_link} target="_blank" rel="noopener noreferrer"
                class="inline-block px-4 py-1.5 rounded-lg bg-brand-gold/10 border border-brand-gold/30 text-brand-gold hover:bg-brand-gold/20 transition text-xs font-medium">
                Try It →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- Product Cards -->
<section class="max-w-6xl mx-auto px-4 pb-16">
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {products.map(product => (
      <article class="glass-card rounded-2xl overflow-hidden transition-all hover:border-brand-gold/40 group">
        <div class="p-6">
          <h3 class="text-lg font-semibold mb-1">{product.name}</h3>
          <p class="text-sm text-gray-400 mb-3">{product.name_full}</p>
          
          <div class="flex flex-wrap gap-2 mb-4">
            {product.subcategory && (<span class="text-xs px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent">{product.subcategory}</span>)}
            {product.tags?.map(tag => (
              <span class="text-xs px-2 py-1 rounded-full bg-white/5 text-gray-400">{tag}</span>
            ))}
          </div>
          
          <div class="bg-black/20 rounded-xl p-4 mb-4">
            <h4 class="text-xs font-semibold text-brand-gold uppercase tracking-wider mb-2">Why We Use It</h4>
            <p class="text-sm text-gray-400">{product.why_use}</p>
          </div>
          
          <a href={product.referral_link || product.amazon_link} target="_blank" rel="noopener noreferrer"
            class="block w-full text-center py-2.5 rounded-lg bg-brand-gold/10 border border-brand-gold/30 text-brand-gold font-medium hover:bg-brand-gold/20 transition">
            Try It Free →
          </a>
          
          <p class="text-xs text-gray-600 mt-2 text-center">
            {product.referral_link ? 'Referral link — we may earn' : 'Affiliate link — we may earn'}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- Newsletter CTA -->
<section class="max-w-4xl mx-auto px-4 pb-16">
  <div class="glass-card rounded-2xl p-8 text-center">
    <SubscriptionForm inline={true} />
  </div>
</section>

<!-- Local Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mission Freedom — Trading Tools Directory",
  "description": "Curated trading platforms, charting tools, and brokerage APIs for Boise and remote traders. Affiliate transparency.",
  "url": "https://hermesdispatch.dev/invest",
  "areaServed": {
    "@type": "City",
    "name": "Boise",
    "containedIn": {"@type": "State", "name": "Idaho"}
  },
  "priceRange": "$"
}
</script>

</Layout>