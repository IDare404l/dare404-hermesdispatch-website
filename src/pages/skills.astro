---
import Layout from '../layouts/Layout.astro';

// Mission Freedom v4 Skills — Canonical active skills only
// Excludes archived skills and duplicates

const categories = {
  'Orchestration': {
    icon: '🎯',
    description: 'IGOR core infrastructure and multi-agent coordination',
    skills: [
      { name: 'agent-fleet-management', desc: 'Manage the lifecycle of multi-agent domain agents.', details: 'v4 architecture: spawn, monitor, retire domain agents. Tracks execution logs, audits, and skill health across all 7 agents.' },
      { name: 'learning-system-manager', desc: 'Central controller for Mission Freedom\'s learning ecosystem.', details: 'ASSIGN learning priorities, SUGGEST knowledge gaps, IMPLEMENT curriculum updates, IMPROVE continuous system optimization. EDUCATOR runs this nightly.' },
      { name: 'kanban-orchestrator', desc: 'Decomposition playbook for multi-agent task orchestration.', details: 'Breaks complex projects into bite-sized tasks, assigns to domain agents, tracks completion. Anti-temptation rules prevent scope creep.' },
      { name: 'cron-pipeline-reliability', desc: 'Design and harden multi-stage cron pipelines.', details: 'Stage isolation, retry logic, dead-letter queues, alerting. Built from the newsletter pipeline failures of 2026-06-01.' }
    ]
  },
  'Security \u0026 Audit': {
    icon: '🛡️',
    description: 'SENTINEL domain — credential hygiene and system hardening',
    skills: [
      { name: 'security-agent-management', desc: 'Manage credential hygiene, file permissions, and security policies.', details: 'Centralized .credentials/ directory, credential_manager.py, get_credential() access controls. Full audit trail for all secret access.' },
      { name: 'credential-manager', desc: 'Centralized secret handling for all agents.', details: 'Replaced plaintext .env secrets. All agents pull credentials through get_credential() instead of direct environment reads. File permission monitoring included.' }
    ]
  },
  'Content \u0026 Social': {
    icon: '📰',
    description: 'Newsletter and X/Twitter automation',
    skills: [
      { name: 'newsletter-writer', desc: 'Daily dispatch in Rycen Beans\' voice.', details: 'Boise-based AI automation insights. Action-first, no fluff. Two-stage pipeline: agent researches at 17:00, script emails at 17:15. Manual approval mandatory.' },
      { name: 'newsletter-writing-mastery', desc: 'Dedicated mastery tracker for newsletter quality.', details: '6-category scoring: Structure, Voice, Content, Engagement, SEO, Deliverability. Currently at 72% targeting 95%.' },
      { name: 'x-creator', desc: 'Content creation specialist for X/Twitter.', details: 'Viral hooks, thread frameworks, engagement timing. Cross-promotes newsletter and shop content.' },
      { name: 'x-helper', desc: 'Twitter/X SEO specialist for @Dare__404.', details: 'Masters X algorithm, hashtag performance, reply strategies. Growth-focused with data-backed timing.' }
    ]
  },
  'Development': {
    icon: '💻',
    description: 'Web Developer domain — Astro, Cloudflare, deployment',
    skills: [
      { name: 'website-builder-agent', desc: 'Specialized website creation agent.', details: 'Learns best practices from real design systems. Astro + Cloudflare Pages. AEO-first architecture (FAQ, HowTo, Organization schema).' },
      { name: 'cloudflare-pages-deployment', desc: 'Deploy static sites to Cloudflare Pages.', details: 'Two paths: Git-based (CI/CD) or direct (Wrangler CLI). Domain management, preview deployments, rollbacks.' },
      { name: 'claude-design', desc: 'Design one-off HTML artifacts.', details: 'Landing pages, decks, prototypes. Rapid iteration for newsletter CTAs and campaign pages.' }
    ]
  },
  'E-Commerce': {
    icon: '🛍️',
    description: 'POD Manager domain — Etsy and print-on-demand',
    skills: [
      { name: 'etsy-seo-researcher', desc: 'Etsy SEO and competitor research.', details: 'Cat-themed POD clothing. Trend analysis, listing optimization, competitor intelligence. Feeds into design generation pipeline.' },
      { name: 'etsy-designer', desc: 'Cloud-based AI design agent.', details: 'Transforms SEO research into complete design concepts with prompts, specs, and implementation notes.' },
      { name: 'etsy-pod-orchestrator', desc: 'Master orchestrator for Etsy operations.', details: 'Coordinates SEO research, design generation, listing creation, and social promotion across agents.' }
    ]
  },
  'Learning': {
    icon: '🎓',
    description: 'EDUCATOR domain — continuous learning and knowledge curation',
    skills: [
      { name: 'educator', desc: 'Tracks and guides learning for all content creators.', details: 'School domain runtime. Daily learning scripts across 6 domains. Weekly briefs every Sunday at 09:00.' },
      { name: 'arxiv', desc: 'Search arXiv papers by keyword, author, or ID.', details: 'Academic research integration for AI/ML developments. Feeds into newsletter "Quick Bites" and internal briefs.' },
      { name: 'trend-hunter', desc: 'Multi-platform trend research agent.', details: 'Google Trends, Twitter viral, Etsy patterns. Runs autonomously, reports to IGOR. Feeds design and content systems.' }
    ]
  },
  'Infrastructure': {
    icon: '⚙️',
    description: 'Core tooling and operational systems',
    skills: [
      { name: 'hermes-agent', desc: 'Configure, extend, or contribute to Hermes Agent.', details: 'CLI, config, models, providers, tools, skills, cron. The tool you use to improve the tools.' },
      { name: 'himalaya', desc: 'Himalaya CLI for IMAP/SMTP email.', details: 'Replaces Gmail SMTP and AgentMail. Reliable terminal-based email. Used by all MF communication workflows.' },
      { name: 'obsidian', desc: 'Obsidian knowledge management mastery.', details: 'Vault organization, linking strategies, daily compaction. All agents log to 03-Intelligence/Agents/[domain]/' }
    ]
  }
};

const totalSkills = Object.values(categories).reduce((sum, cat) => sum + cat.skills.length, 0);
---

<Layout title="Skills | Mission Freedom - v4 Agent Arsenal">
  <section class="py-12 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-500/10 border border-orange-500/30 mb-6">
          <span class="w-2 h-2 bg-orange-400 rounded-full animate-pulse"></span>
          <span class="text-orange-400 text-sm font-medium">Mission Freedom v4 Arsenal</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">IGOR + Skills</span>
        </h1>
        
        <p class="text-xl text-neutral-400 max-w-2xl mx-auto mb-6">
          7 domain agents. {totalSkills} canonical skills. Zero duplicates.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <span class="px-3 py-1 rounded-full bg-neutral-800 text-neutral-300">{totalSkills} Active Skills</span>
          <span class="px-3 py-1 rounded-full bg-neutral-800 text-neutral-300">{Object.keys(categories).length} Categories</span>
          <span class="px-3 py-1 rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">7 Domain Agents</span>
          <span class="px-3 py-1 rounded-full bg-slate-500/20 text-slate-400 border border-slate-500/30">AEO-First</span>
        </div>
      </div>

      <!-- Architecture Note -->
      <div class="mb-12 p-6 bg-gradient-to-r from-neutral-900 to-neutral-800 border border-neutral-700 rounded-xl">
        <div class="flex items-start gap-4">
          <div class="text-3xl">🏗️</div>
          <div>
            <h2 class="font-semibold text-lg mb-2">v4 Multi-Agent Architecture</h2>
            <p class="text-neutral-400 text-sm leading-relaxed">
              IGOR orchestrates 7 specialist domain agents: <strong>EDUCATOR</strong> (learning/audits), 
              <strong>Newsletter Writer</strong> (daily dispatch), <strong>Social Media Writer</strong> (X/Twitter), 
              <strong>Web Developer</strong> (sites/deploy), <strong>POD Manager</strong> (Etsy/print-on-demand), 
              and <strong>SENTINEL</strong> (security/hardening). Each agent loads skills, executes, logs to Obsidian.
              No solo orchestrator — coordinated specialization.
            </p>
          </div>
        </div>
      </div>

      <!-- Search -->
      <div class="mb-8">
        <input 
          type="text" 
          id="skillSearch"
          placeholder="Search skills..."
          class="w-full px-4 py-3 bg-neutral-900 border border-neutral-700 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:border-orange-500 transition-colors"
        />
      </div>

      <!-- Skills by Category -->
      <div class="space-y-8">
        {Object.entries(categories).map(([catName, catData]) => (
          <div class="category-section" data-category={catName.toLowerCase()}>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">{catData.icon}</span>
              <div>
                <h2 class="text-xl font-semibold">{catName}</h2>
                <p class="text-sm text-neutral-500">{catData.description}</p>
              </div>
              <span class="ml-auto px-3 py-1 text-xs rounded-full bg-neutral-800 text-neutral-400">
                {catData.skills.length} skills
              </span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {catData.skills.map(skill => (
                <div 
                  class="skill-card group p-4 bg-neutral-900 border border-neutral-800 rounded-xl cursor-pointer hover:border-orange-500/50 transition-all"
                  data-name={skill.name.toLowerCase()}
                  data-desc={skill.desc.toLowerCase()}
                >
                  <div class="flex items-start justify-between mb-2">
                    <h3 class="font-medium text-orange-400 group-hover:text-orange-300 transition-colors">{skill.name}</h3>
                    <svg class="w-5 h-5 text-neutral-600 group-hover:text-orange-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                  <p class="text-sm text-neutral-400 mb-2">{skill.desc}</p>
                  <div class="skill-details hidden mt-3 pt-3 border-t border-neutral-800">
                    <p class="text-sm text-neutral-500 leading-relaxed">{skill.details}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-neutral-900 border border-neutral-800 rounded-xl text-center">
          <div class="text-3xl font-bold text-orange-400">7</div>
          <div class="text-sm text-neutral-500">Domain Agents</div>
        </div>
        <div class="p-4 bg-neutral-900 border border-neutral-800 rounded-xl text-center">
          <div class="text-3xl font-bold text-orange-400">{totalSkills}</div>
          <div class="text-sm text-neutral-500">Canonical Skills</div>
        </div>
        <div class="p-4 bg-neutral-900 border border-neutral-800 rounded-xl text-center">
          <div class="text-3xl font-bold text-orange-400">1</div>
          <div class="text-sm text-neutral-500">Orchestrator (IGOR)</div>
        </div>
        <div class="p-4 bg-neutral-900 border border-neutral-800 rounded-xl text-center">
          <div class="text-3xl font-bold text-orange-400">∞</div>
          <div class="text-sm text-neutral-500">Possibilities</div>
        </div>
      </div>

    </div>
  </section>

  <script>
    // Search functionality
    const searchInput = document.getElementById('skillSearch');
    const skillCards = document.querySelectorAll('.skill-card');
    const categorySections = document.querySelectorAll('.category-section');

    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      
      skillCards.forEach(card => {
        const name = card.dataset.name;
        const desc = card.dataset.desc;
        const matches = name?.includes(query) || desc?.includes(query);
        card.style.display = matches ? 'block' : 'none';
      });

      // Hide empty categories
      categorySections.forEach(section => {
        const visibleCards = section.querySelectorAll('.skill-card[style*="block"], .skill-card:not([style*="none"])');
        section.style.display = visibleCards.length > 0 ? 'block' : 'none';
      });
    });

    // Click to expand skill details
    skillCards.forEach(card => {
      card.addEventListener('click', () => {
        const details = card.querySelector('.skill-details');
        const arrow = card.querySelector('svg');
        
        if (details?.classList.contains('hidden')) {
          details.classList.remove('hidden');
          arrow?.classList.add('rotate-180');
          card.classList.add('border-orange-500/30');
        } else {
          details?.classList.add('hidden');
          arrow?.classList.remove('rotate-180');
          card.classList.remove('border-orange-500/30');
        }
      });
    });
  </script>
  <!-- HowTo Schema (AEO) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Build an AI Agent Automation System",
    "description": "Step-by-step guide to building a multi-agent automation system with Hermes, IGOR orchestration, and modular skills.",
    "step": [
      {
        "@type": "HowToStep",
        "position": 1,
        "name": "Set up IGOR Orchestrator",
        "text": "Configure the Universal Command Router to analyze requests and route to specialist agents. Establish the shared Obsidian logging vault."
      },
      {
        "@type": "HowToStep",
        "position": 2,
        "name": "Create Domain Agents",
        "text": "Spawn specialist agents for each domain: EDUCATOR for learning, Newsletter for content, Social Media for engagement, Web Developer for sites, POD Manager for e-commerce, SENTINEL for security."
      },
      {
        "@type": "HowToStep",
        "position": 3,
        "name": "Install Canonical Skills",
        "text": "Load only the skills each agent needs. Deduplicate overlapping skills. Log all execution to the shared Obsidian vault for auditability."
      },
      {
        "@type": "HowToStep",
        "position": 4,
        "name": "Automate Daily Workflows",
        "text": "Schedule cron jobs for each agent: EDUCATOR audits nightly, Newsletter researches at 17:00, Social posts hourly. Use manual approval gates for newsletters."
      }
    ]
  }
  </script>
</Layout>