---
import Layout from '../layouts/Layout.astro';
import { 
  skillCatalog, 
  categories, 
  tiers, 
  statuses, 
  getSkillsByCategory, 
  getSkillsByTier, 
  getSkillsByStatus,
  categoryIcons,
  categoryLabels 
} from '../data/skills';
const title = "Skill Directory | Mission Freedom";
const description = "Complete catalog of Mission Freedom skills. Reusable automation blocks ready to power your AI agent workflows.";

const tierBadges = {
  core: { label: 'Core', color: 'bg-green-500' },
  pro: { label: 'Pro', color: 'bg-blue-500' },
  enterprise: { label: 'Enterprise', color: 'bg-purple-500' }
};

const statusBadges = {
  'stable': { label: 'Stable', color: 'bg-green-500/20 text-green-400 border-green-500/30' },
  'beta': { label: 'Beta', color: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30' },
  'coming-soon': { label: 'Coming Soon', color: 'bg-slate-500/20 text-slate-400 border-slate-500/30' }
};
---

<Layout title={title} description={description}>
  <main class="min-h-screen bg-slate-950">
    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Skill <span class="bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">Directory</span>
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl mx-auto">
            Reusable automation blocks for your AI agent workflows. 
            From core utilities to enterprise-grade systems.
          </p>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap justify-center gap-6 mt-8">
          <div class="text-center px-6 py-4 bg-slate-800 rounded-xl">
            <span class="block text-3xl font-bold text-white">{skillCatalog.length}</span>
            <span class="text-sm text-slate-400">Total Skills</span>
          </div>
          
          <div class="text-center px-6 py-4 bg-slate-800 rounded-xl">
            <span class="block text-3xl font-bold text-green-400">{getSkillsByStatus('stable').length}</span>
            <span class="text-sm text-slate-400">Stable</span>
          </div>
          
          <div class="text-center px-6 py-4 bg-slate-800 rounded-xl">
            <span class="block text-3xl font-bold text-yellow-400">{getSkillsByStatus('beta').length}</span>
            <span class="text-sm text-slate-400">In Beta</span>
          </div>
          
          <div class="text-center px-6 py-4 bg-slate-800 rounded-xl">
            <span class="block text-3xl font-bold text-purple-400">{categories.length}</span>
            <span class="text-sm text-slate-400">Categories</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Skills Grid -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Category Tabs -->
        <div class="flex flex-wrap justify-center gap-2 mb-12">
          <button class="category-btn active px-4 py-2 rounded-full text-sm font-medium bg-slate-800 text-white border border-slate-700 hover:border-slate-500 transition-colors" data-category="all">
            All Skills
          </button>
          
          {categories.map(category => (
            <button 
              class="category-btn px-4 py-2 rounded-full text-sm font-medium bg-slate-900 text-slate-400 border border-slate-800 hover:border-slate-600 hover:text-white transition-colors" 
              data-category={category}
            >
              {categoryIcons[category]} {categoryLabels[category]}
            </button>
          ))}
        </div>

        <!-- Skills Cards -->
        <div id="skills-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {skillCatalog.map(skill => (
            <article 
              class="skill-card bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-all group"
              data-category={skill.category}
            >
              <!-- Header Row -->
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                  {categoryIcons[skill.category]}
                </div>
                
                <div class="flex flex-col items-end gap-1">
                  <span class={`text-xs px-2 py-0.5 rounded-full border ${tierBadges[skill.tier].color}/20 text-${tierBadges[skill.tier].color.replace('bg-', '')} border-${tierBadges[skill.tier].color.replace('bg-', '')}/30`}>
                    {tierBadges[skill.tier].label}
                  </span>
                  
                  <span class={`text-xs px-2 py-0.5 rounded-full border ${statusBadges[skill.status].color}`}>
                    {statusBadges[skill.status].label}
                  </span>
                </div>
              </div>

              <!-- Content -->
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">
                {skill.name}
              </h3>
              
              <p class="text-slate-400 text-sm mb-4">{skill.description}</p>

              <!-- Agents -->
              <div class="flex flex-wrap gap-2 mb-4">
                {skill.agents.map(agent => (
                  <span class="text-xs px-2 py-1 bg-slate-800 text-slate-300 rounded">
                    {agent}
                  </span>
                ))}
              </div>

              <!-- Features -->
              <div class="border-t border-slate-800 pt-4">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Key Features</p>
                
                <ul class="space-y-1">
                  {skill.features.slice(0, 4).map(feature => (
                    <li class="flex items-start gap-2 text-sm text-slate-300">
                      <span class="text-cyan-400 mt-0.5">✓</span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>              
              </div>

              <!-- Usage Hint -->
              {skill.usage && (
                <div class="mt-4 bg-slate-950 rounded-lg p-3">
                  <p class="text-xs font-mono text-slate-500">{skill.usage}</p>
                </div>
              )}

              <!-- Price -->
              {skill.price && (
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-xs text-slate-500">Pricing:</span>
                  <span class="text-sm font-semibold text-green-400">{skill.price}</span>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Distribution CTA -->
    <section class="py-16 px-6 bg-slate-900">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Skill Marketplace</h2>
        <p class="text-slate-400 mb-8">
          Skills available in Core, Pro, and Enterprise tiers. 
          Documented, tested, and ready to power your automation.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <div class="bg-slate-800 rounded-lg p-6 text-center">
            <span class="block text-2xl mb-2">🏗️</span>
            <span class="block font-semibold text-white">Core</span>
            <span class="text-sm text-slate-400">Free / Open Source</span>
            <span class="block text-xs text-slate-500 mt-2">{getSkillsByTier('core').length} skills</span>
          </div>
          
          <div class="bg-slate-800 rounded-lg p-6 text-center">
            <span class="block text-2xl mb-2">⚡</span>
            <span class="block font-semibold text-white">Pro</span>
            <span class="text-sm text-slate-400">Advanced Workflows</span>
            <span class="block text-xs text-slate-500 mt-2">{getSkillsByTier('pro').length} skills</span>
          </div>
          
          <div class="bg-slate-800 rounded-lg p-6 text-center">
            <span class="block text-2xl mb-2">🚀</span>
            <span class="block font-semibold text-white">Enterprise</span>
            <span class="text-sm text-slate-400">Custom Solutions</span>
            <span class="block text-xs text-slate-500 mt-2">{getSkillsByTier('enterprise').length} skills</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Category filtering
    const categoryBtns = document.querySelectorAll('.category-btn');
    const skillCards = document.querySelectorAll('.skill-card');
    
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        // Update active state
        categoryBtns.forEach(b => {
          b.classList.remove('bg-slate-800', 'text-white');
          b.classList.add('bg-slate-900', 'text-slate-400');
        });
        btn.classList.remove('bg-slate-900', 'text-slate-400');
        btn.classList.add('bg-slate-800', 'text-white');
        
        // Filter cards
        skillCards.forEach(card => {
          if (category === 'all' || card.getAttribute('data-category') === category) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</Layout>
