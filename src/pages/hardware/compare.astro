---
import Layout from '../../layouts/Layout.astro';

const entries = await Astro.glob('../../content/directory/*.md');
const miniPCs = entries
  .filter(e => e.frontmatter.subcategory === 'mini-pc')
  .sort((a, b) => (b.frontmatter.ollama_score || 0) - (a.frontmatter.ollama_score || 0));
const gpus = entries
  .filter(e => e.frontmatter.subcategory === 'gpu')
  .sort((a, b) => (b.frontmatter.ollama_score || 0) - (a.frontmatter.ollama_score || 0));

const products = [...miniPCs, ...gpus].map(e => ({...e.frontmatter, Content: e.Content}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Best AI Inference Hardware Compared",
  "description": "Side-by-side comparison of mini PCs and GPUs for running local LLMs with Ollama. Affiliate transparency.",
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem", "position": i + 1,
    "item": {"@type": "Product", "name": p.name, "description": p.name_full,
      "brand": {"@type": "Brand", "name": p.brand},
      "offers": {"@type": "Offer", "price": p.price, "priceCurrency": "USD"}}
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best mini PC for running local LLMs?",
      "acceptedAnswer": { "@type": "Answer", "text": "The Beelink SER7 Pro is the best value for most users, offering ~42 tok/s on llama3.2 3B. For more headroom, the Geekom A8 with Ryzen 9 8945HS reaches ~52 tok/s." }
    },
    {
      "@type": "Question",
      "name": "Do I need a dedicated GPU for local AI inference?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. Modern AMD Ryzen mini PCs with RDNA 3 integrated graphics can run models up to 7B-13B parameters. A dedicated GPU like the RTX 4090 is only needed for large models or maximum speed." }
    },
    {
      "@type": "Question",
      "name": "How much RAM do I need for Ollama?",
      "acceptedAnswer": { "@type": "Answer", "text": "32GB is the sweet spot for 7B models. 64GB lets you run 13B models comfortably or multiple smaller models at once." }
    }
  ]
};
---

<Layout title="Compare AI Inference Hardware | The Rig" description="Side-by-side comparison of mini PCs and GPUs for local LLMs. Updated benchmarks and affiliate transparency.">

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<section class="relative py-20 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-brand-accent/10"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-accent/10 border border-brand-accent/30 mb-6">
      <span class="text-brand-accent text-sm font-mono">THE RIG — COMPARISON</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4"><span class="text-gradient">Best Local LLM Hardware</span></h1>
    <p class="text-gray-400 max-w-2xl mx-auto mb-4 text-lg">
      Mini PCs vs. GPUs for running Ollama and local AI agents. Benchmarked on llama3.2 3B Q4_K_M.
    </p>
    <div class="max-w-2xl mx-auto mb-8 text-sm text-gray-500 bg-neutral-900/50 border border-neutral-800 rounded-lg p-4 text-left">
      <strong class="text-gray-300">Agent Score (0–100):</strong>
      <p class="mt-1">A practical rating for local-agent inference. 80–100 means desktop-class VRAM and fast CUDA/ROCm throughput. 40–60 means usable for light agents but not for large models or long contexts.</p>
    </div>
  </div>
</section>

<section class="max-w-6xl mx-auto px-4 pb-8">
  <div class="glass-card rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-white/5 border-b border-white/10">
        <tr>
          <th class="text-left p-4 font-semibold">Product</th>
          <th class="text-left p-4 font-semibold">Type</th>
          <th class="text-left p-4 font-semibold">Price</th>
          <th class="text-left p-4 font-semibold">Agent Score</th>
          <th class="text-left p-4 font-semibold">Best For</th>
          <th class="text-right p-4 font-semibold">Action</th>
        </tr>
      </thead>
      <tbody>
        {products.map(product => (
          <tr class="border-b border-white/5 hover:bg-white/[0.02] transition">
            <td class="p-4">
              <span class="font-semibold">{product.name}</span>
              <span class="text-xs text-gray-500 ml-2">{product.brand}</span>
            </td>
            <td class="p-4 text-gray-400 capitalize">{product.subcategory}</td>
            <td class="p-4 font-mono">${product.price}</td>
            <td class="p-4 font-mono text-emerald-400">{product.ollama_score} tok/s</td>
            <td class="p-4 text-gray-400">
              {product.subcategory === 'gpu' ? 'Large models / maximum speed' : 'Entry to mid-range local inference'}
            </td>
            <td class="p-4 text-right">
              <a href={product.amazon_link} target="_blank" rel="noopener noreferrer"
                class="inline-block px-4 py-1.5 rounded-lg bg-brand-gold/10 border border-brand-gold/30 text-brand-gold hover:bg-brand-gold/20 transition text-xs font-medium">
                View →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<section class="max-w-4xl mx-auto px-4 pb-16">
  <h2 class="text-2xl font-bold mb-6"><span class="text-gradient">FAQ</span></h2>
  <div class="space-y-4">
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">What is the best mini PC for running local LLMs?</summary>
      <p class="text-gray-400 mt-3 text-sm">The Beelink SER7 Pro is the best value for most users, offering ~42 tok/s on llama3.2 3B. For more headroom, the Geekom A8 with Ryzen 9 8945HS reaches ~52 tok/s.</p>
    </details>
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">Do I need a dedicated GPU for local AI inference?</summary>
      <p class="text-gray-400 mt-3 text-sm">No. Modern AMD Ryzen mini PCs with RDNA 3 integrated graphics can run models up to 7B-13B parameters. A dedicated GPU like the RTX 4090 is only needed for large models or maximum speed.</p>
    </details>
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">How much RAM do I need for Ollama?</summary>
      <p class="text-gray-400 mt-3 text-sm">32GB is the sweet spot for 7B models. 64GB lets you run 13B models comfortably or multiple smaller models at once.</p>
    </details>
  </div>
</section>

</Layout>
