---
import Layout from '../../layouts/Layout.astro';

const title = "How to Build a Local LLM Rig | The Hermes Dispatch";
const description = "Step-by-step guide to building a local LLM rig: GPU, CPU, RAM, SSD, power supply, and software setup for running large language models at home.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Build a Local LLM Rig",
  "description": description,
  "totalTime": "PT4H",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "2000-4500"
  },
  "supply": [
    { "@type": "HowToSupply", "name": "NVIDIA RTX 4090 or AMD RX 7900 XTX" },
    { "@type": "HowToSupply", "name": "64GB DDR5 RAM" },
    { "@type": "HowToSupply", "name": "2TB NVMe SSD" },
    { "@type": "HowToSupply", "name": "850W+ power supply" }
  ],
  "tool": [
    { "@type": "HowToTool", "name": "Phillips screwdriver" },
    { "@type": "HowToTool", "name": "Anti-static wrist strap" }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Choose your GPU",
      "text": "For local LLMs, VRAM is the bottleneck. The NVIDIA RTX 4090 has 24GB and is the best consumer option. The AMD RX 7900 XTX offers 24GB at a lower price but has weaker CUDA ecosystem support.",
      "url": "https://hermesdispatch.dev/guides/build-local-llm-rig/#step-1"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Select CPU, RAM, and storage",
      "text": "Pair the GPU with a modern 8-core+ CPU, 64GB DDR5 RAM, and a 2TB NVMe SSD. LLM model files are large, so fast storage matters.",
      "url": "https://hermesdispatch.dev/guides/build-local-llm-rig/#step-2"
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Assemble the rig",
      "text": "Install CPU and RAM on the motherboard, mount the NVMe SSD, install the GPU in the top PCIe slot, and connect the PSU cables. Ensure adequate airflow.",
      "url": "https://hermesdispatch.dev/guides/build-local-llm-rig/#step-3"
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Install software",
      "text": "Install Linux or Windows, then install Ollama, LM Studio, or llama.cpp. Download a quantized model like Llama 3 70B Q4 or Mixtral 8x7B Q4.",
      "url": "https://hermesdispatch.dev/guides/build-local-llm-rig/#step-4"
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Benchmark and deploy",
      "text": "Run inference benchmarks, measure tokens per second, and expose the model via API for agent workflows or chat interfaces.",
      "url": "https://hermesdispatch.dev/guides/build-local-llm-rig/#step-5"
    }
  ]
};
---

<Layout title={title} description={description}>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(howToSchema)} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
    
    <header class="mb-12">
      <span class="text-xs font-mono px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent border border-brand-accent/20 mb-4 inline-block">AI Hardware</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">How to Build a Local LLM Rig</h1>
      <p class="text-xl text-gray-400">{description}</p>
    </header>

    <div class="space-y-12">
      <section id="step-1" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">1</span>
          <h2 class="text-2xl font-bold text-white">Choose your GPU</h2>
        </div>
        <p class="text-gray-400 leading-relaxed mb-4">
          For local LLMs, VRAM is the bottleneck. The NVIDIA RTX 4090 has 24GB and is the best consumer option. The AMD RX 7900 XTX offers 24GB at a lower price but has weaker CUDA ecosystem support.
        </p>
        <div class="p-4 rounded-xl bg-brand-gold/5 border border-brand-gold/20">
          <p class="text-sm text-gray-400">
            <strong class="text-brand-gold">Verdict:</strong> For most builders, start with the RTX 4090 for compatibility and ecosystem.
          </p>
        </div>
      </section>

      <section id="step-2" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">2</span>
          <h2 class="text-2xl font-bold text-white">Select CPU, RAM, and storage</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          Pair the GPU with a modern 8-core+ CPU, 64GB DDR5 RAM, and a 2TB NVMe SSD. LLM model files are large, so fast storage matters for loading and context caching.
        </p>
      </section>

      <section id="step-3" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">3</span>
          <h2 class="text-2xl font-bold text-white">Assemble the rig</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          Install CPU and RAM on the motherboard, mount the NVMe SSD, install the GPU in the top PCIe slot, and connect the PSU cables. Ensure adequate airflow; these GPUs pull 450W+ under load.
        </p>
      </section>

      <section id="step-4" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">4</span>
          <h2 class="text-2xl font-bold text-white">Install software</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          Install Linux or Windows, then install Ollama, LM Studio, or llama.cpp. Download a quantized model like Llama 3 70B Q4 or Mixtral 8x7B Q4 to fit within 24GB VRAM.
        </p>
      </section>

      <section id="step-5" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">5</span>
          <h2 class="text-2xl font-bold text-white">Benchmark and deploy</h2>
        </div>
        <p class="text-gray-400 leading-relaxed mb-6">
          Run inference benchmarks, measure tokens per second, and expose the model via API for agent workflows or chat interfaces.
        </p>
        <a href="/hardware/compare" class="inline-block px-6 py-3 bg-brand-gold text-neutral-950 rounded-lg font-semibold hover:bg-brand-amber transition">
          Compare AI Hardware →
        </a>
      </section>
    </div>
  </article>

</Layout>
