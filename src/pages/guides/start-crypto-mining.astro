---
import Layout from '../../layouts/Layout.astro';

const title = "How to Start Crypto Mining at Home | The Hermes Dispatch";
const description = "Step-by-step guide to starting crypto mining at home: choose an ASIC miner, calculate ROI, set up power and cooling, and connect to a mining pool.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Start Crypto Mining at Home",
  "description": description,
  "totalTime": "PT8H",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "2500-8000"
  },
  "supply": [
    { "@type": "HowToSupply", "name": "ASIC miner (Antminer S21 or WhatsMiner M60S)" },
    { "@type": "HowToSupply", "name": "240V power outlet or PDU" },
    { "@type": "HowToSupply", "name": "Ethernet connection" }
  ],
  "tool": [
    { "@type": "HowToTool", "name": "Mining pool account" },
    { "@type": "HowToTool", "name": "Crypto wallet address" }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Pick the right ASIC",
      "text": "Use WhatToMine.com to compare profitability by hashrate and power draw. The Antminer S21 and WhatsMiner M60S are current-generation Bitcoin ASICs with strong efficiency.",
      "url": "https://hermesdispatch.dev/guides/start-crypto-mining/#step-1"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Calculate ROI before buying",
      "text": "Factor in hardware cost, electricity rate, pool fee, and network difficulty. Break-even is usually 12–24 months at residential power rates.",
      "url": "https://hermesdispatch.dev/guides/start-crypto-mining/#step-2"
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Prepare power and cooling",
      "text": "ASICs draw 3500W+ continuously. You need a 240V 20A+ circuit, adequate ventilation, and ideally a dedicated space with exhaust airflow.",
      "url": "https://hermesdispatch.dev/guides/start-crypto-mining/#step-3"
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Connect to a mining pool",
      "text": "Join a pool like Braiins, Foundry USA, or ViaBTC. Enter your pool URL, worker name, and wallet address in the ASIC's web interface.",
      "url": "https://hermesdispatch.dev/guides/start-crypto-mining/#step-4"
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Monitor and optimize",
      "text": "Track uptime, hashrate, and payouts. Adjust power limits and cooling to maximize uptime and minimize downtime during hot weather.",
      "url": "https://hermesdispatch.dev/guides/start-crypto-mining/#step-5"
    }
  ]
};
---

<Layout title={title} description={description}>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(howToSchema)} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
    
    <header class="mb-12">
      <span class="text-xs font-mono px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent border border-brand-accent/20 mb-4 inline-block">Mining</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">How to Start Crypto Mining at Home</h1>
      <p class="text-xl text-gray-400">{description}</p>
    </header>

    <div class="space-y-12">
      <section id="step-1" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">1</span>
          <h2 class="text-2xl font-bold text-white">Pick the right ASIC</h2>
        </div>
        <p class="text-gray-400 leading-relaxed mb-4">
          Use WhatToMine.com to compare profitability by hashrate and power draw. The Antminer S21 and WhatsMiner M60S are current-generation Bitcoin ASICs with strong efficiency.
        </p>
        <div class="p-4 rounded-xl bg-brand-gold/5 border border-brand-gold/20">
          <p class="text-sm text-gray-400">
            <strong class="text-brand-gold">Verdict:</strong> Start with the Antminer S21 if you have cheap power, or WhatsMiner M60S for slightly better noise efficiency.
          </p>
        </div>
      </section>

      <section id="step-2" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">2</span>
          <h2 class="text-2xl font-bold text-white">Calculate ROI before buying</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          Factor in hardware cost, electricity rate, pool fee, and network difficulty. Break-even is usually 12–24 months at residential power rates.
        </p>
      </section>

      <section id="step-3" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">3</span>
          <h2 class="text-2xl font-bold text-white">Prepare power and cooling</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          ASICs draw 3500W+ continuously. You need a 240V 20A+ circuit, adequate ventilation, and ideally a dedicated space with exhaust airflow.
        </p>
      </section>

      <section id="step-4" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">4</span>
          <h2 class="text-2xl font-bold text-white">Connect to a mining pool</h2>
        </div>
        <p class="text-gray-400 leading-relaxed">
          Join a pool like Braiins, Foundry USA, or ViaBTC. Enter your pool URL, worker name, and wallet address in the ASIC's web interface.
        </p>
      </section>

      <section id="step-5" class="glass-card rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-8 rounded-full bg-brand-gold text-neutral-950 flex items-center justify-center font-bold">5</span>
          <h2 class="text-2xl font-bold text-white">Monitor and optimize</h2>
        </div>
        <p class="text-gray-400 leading-relaxed mb-6">
          Track uptime, hashrate, and payouts. Adjust power limits and cooling to maximize uptime and minimize downtime during hot weather.
        </p>
        <a href="/crypto/roi" class="inline-block px-6 py-3 bg-brand-gold text-neutral-950 rounded-lg font-semibold hover:bg-brand-amber transition">
          Calculate Mining ROI →
        </a>
      </section>
    </div>
  </article>

</Layout>
