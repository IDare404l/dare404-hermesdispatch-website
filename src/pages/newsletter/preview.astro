---
import Layout from '../../layouts/Layout.astro';
import { newsletters } from '../../data/newsletters';

const sorted = [...newsletters].filter(n => n.published).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const latest = sorted[0];
const title = latest?.title || 'Latest Newsletter';
const html = latest?.content || '';
---

<Layout title={title} description="Latest Hermes Dispatch newsletter" noindex={true}>
  <section class="py-12 max-w-3xl mx-auto px-4">
    <div class="mb-6">
      <a href="/newsletter" class="text-brand-gold hover:underline text-sm">← Newsletter Archive</a>
    </div>
    <div class="prose prose-invert max-w-none">
      <Fragment set:html={html} />
    </div>
  </section>
</Layout>
