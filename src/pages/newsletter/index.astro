---
import Layout from '../../layouts/Layout.astro';
import { newsletters } from '../../data/newsletters';
import ParticleBackground from '../../components/ParticleBackground.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

const publishedNewsletters = newsletters.filter(n => n.published).reverse();
const featured = publishedNewsletters.find(n => n.featured) || publishedNewsletters[0];
const archive = publishedNewsletters.filter(n => n !== featured);

const title = "Newsletter | Mission Freedom";
const description = "Daily insights on AI agent automation, multi-agent orchestration, and digital entrepreneurship. Mission Freedom Daily, delivered at 06:00 MST.";
---

<Layout title={title} description={description}>
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    <ParticleBackground />
    
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg shadow-brand-gold/30">
        📧
      </div>
      
      <h1 class="display-heading mb-6">
        Mission Freedom<br/>
        <span class="text-gradient">Daily</span>
      </h1>
      
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Daily insights on <span class="text-brand-gold">AI agent automation</span>, multi-agent orchestration, 
        and digital entrepreneurship. Delivered at 06:00 MST.
      </p>
    </div>
  </section>
  
  <!-- Subscribe Section -->
  <section class="relative py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card rounded-2xl p-8 text-center border border-brand-gold/20">
        <p class="text-gray-400 mb-6">
          Join <span class="text-brand-gold">Mission Freedom Daily</span> — get tactical insights delivered to your inbox every weekday.
        </p>
        
        <a 
          href="/subscribe/"
          class="btn-primary inline-block whitespace-nowrap"
        >
          Subscribe via Email
        </a>
        
        <p class="text-gray-500 text-sm mt-4">
          Or manually: send an email to <code class="bg-brand-card px-2 py-1 rounded text-brand-gold">derekkosakura@gmail.com</code> with subject <code class="bg-brand-card px-2 py-1 rounded text-brand-gold">Subscribe</code>
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4 mt-6 text-gray-500 text-sm">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            No spam
          </span>
          <span>•</span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            One-click unsubscribe
          </span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured Issue -->
  {featured && (
    <section class="relative py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-gold/10 border border-brand-gold/30 text-brand-gold text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          Featured Issue
        </span>
        
        <a href={`/newsletter/${featured.slug}`} class="block group">
          <article class="glass-card rounded-2xl p-8 hover:border-brand-gold/50 transition-all">
            <div class="flex flex-wrap items-center gap-4 mb-4 text-sm text-gray-400">
              <time>
                {new Date(featured.date).toLocaleDateString('en-US', { 
                  month: 'long', 
                  day: 'numeric', 
                  year: 'numeric' 
                })}
              </time>
              <span>•</span>
              <span>{featured.readTime}</span>
              <span>•</span>
              <div class="flex flex-wrap gap-2">
                {featured.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-full bg-white/5 text-gray-300 text-xs">{tag}</span>
                ))}
              </div>
            </div>
            
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-brand-gold transition-colors">
              {featured.title}
            </h2>
            
            <p class="text-gray-400 text-lg mb-6">{featured.excerpt}</p>
            
            <span class="inline-flex items-center gap-2 text-brand-gold font-medium group-hover:gap-3 transition-all">
              Read Issue
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </article>
        </a>
      </div>
    </section>
  )}
  
  <!-- Archive -->
  {archive.length > 0 && (
    <section class="relative py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <span class="inline-block px-4 py-1.5 rounded-full bg-brand-card border border-brand-border text-gray-400 text-sm font-medium mb-6">
          Archive
        </span>
        
        <div class="space-y-4">
          {archive.map(issue => (
            <a href={`/newsletter/${issue.slug}`} class="block group">
              <article class="flex items-center justify-between glass-card rounded-xl p-5 hover:border-brand-gold/30 transition-all">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-1">
                    <span class="text-sm text-gray-500">
                      {new Date(issue.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                    <span class="text-gray-600">•</span>
                    <span class="text-sm text-gray-500">{issue.readTime}</span>
                  </div>
                  
                  <h3 class="text-lg font-semibold text-white group-hover:text-brand-gold transition-colors">
                    {issue.title}
                  </h3>
                </div>
                
                <svg class="w-5 h-5 text-gray-600 group-hover:text-brand-gold transition-colors ml-4">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>
