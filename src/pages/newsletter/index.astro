---
import Layout from '../../layouts/Layout.astro';
import { getPublishedNewsletters, getLatestNewsletter } from '../../data/newsletters';

const newsletters = getPublishedNewsletters();
const latest = getLatestNewsletter();
---

<Layout 
  title="Newsletter — The Hermes Dispatch"
  description="Building workflows that build themselves. Newsletter on AI agents, automation, and self-improving systems."
>
  <!-- Hero -->
  <section class="py-16 px-6 border-b border-slate-800">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm mb-6">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        Active Newsletter
      </div>
      
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        The Hermes Dispatch
      </h1>
      
      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-8">
        Building workflows that build themselves. Inside Mission Freedom's AI agent team — 
        what's working, what's breaking, and the patterns that scale.
      </p>

      {latest && (
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 text-left max-w-2xl mx-auto">
          <div class="flex items-center gap-2 text-blue-400 text-sm mb-2">
            <span>Latest Issue</span>
            <span>•</span>
            <span>{latest.date}</span>
          </div>
          <h2 class="text-xl font-semibold text-white mb-2">{latest.title}</h2>
          <p class="text-slate-400 mb-4">{latest.excerpt}</p>
          <a 
            href={`/newsletter/${latest.slug}`}
            class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors"
          >
            Read Issue
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Subscribe -->
  <section class="py-16 px-6 border-b border-slate-800">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Subscribe</h2>
      <p class="text-slate-400 mb-8">New issues delivered. No spam. Unsubscribe anytime.</p>
      
      <form 
        id="subscribe-form"
        class="flex flex-col sm:flex-row gap-3"
      >
        <input 
          type="email" 
          name="email" 
          placeholder="you@example.com" 
          required
          class="flex-1 px-4 py-3 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
        />
        <button 
          type="submit"
          class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg transition-colors"
        >
          Subscribe
        </button>
      </form>
      
      <p class="text-slate-600 text-sm mt-4">
        Self-hosted on AWS SES. <a href="/privacy" class="text-slate-500 hover:text-slate-400">Privacy Policy</a>
      </p>
    </div>
  </section>

  <!-- Archive -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-8">Archive</h2>
      
      <div class="space-y-6">
        {newsletters.map((issue) => (
          <article class="bg-slate-800/30 border border-slate-700/50 rounded-xl p-6 hover:border-slate-600 transition-colors">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-3">
              <div>
                <div class="flex items-center gap-2 text-slate-500 text-sm mb-2">
                  <span>{issue.date}</span>
                  <span>•</span>
                  <span>{issue.readTime} read</span>
                </div>
                <h3 class="text-lg font-semibold text-white">
                  <a href={`/newsletter/${issue.slug}`} class="hover:text-blue-400 transition-colors">
                    {issue.title}
                  </a>
                </h3>
              </div>
              {issue.featured && (
                <span class="self-start px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs rounded">
                  Featured
                </span>
              )}
            </div>
            
            <p class="text-slate-400 mb-4">{issue.excerpt}</p>
            
            <div class="flex flex-wrap gap-2">
              {issue.tags.map(tag => (
                <span class="px-2 py-1 bg-slate-800 text-slate-400 text-xs rounded">
                  #{tag}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
      
      {newsletters.length === 0 && (
        <p class="text-slate-500 text-center py-12">
          No issues published yet. Coming soon.
        </p>
      )}
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-slate-800">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">
        © 2026 dare404 · The Hermes Dispatch · Self-hosted
      </p>
      <div class="flex gap-4 text-sm">
        <a href="/" class="text-slate-500 hover:text-slate-300 transition-colors">Home</a>
        <a href="/archive" class="text-slate-500 hover:text-slate-300 transition-colors">Archive</a>
      </div>
    </div>
  </footer>

  <script>
    // Google Apps Script Web App for newsletter subscriptions
    const API_URL = 'https://script.google.com/macros/s/AKfycbwzVQGuQI5EJ0xatSahwwDKxhsngKH7Qitn7Bi0L_T0zq1_HpYgqgsnfIUrWJixByky/exec';
    
    const form = document.getElementById('subscribe-form');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = form.querySelector('input[name="email"]')?.value;
      const button = form.querySelector('button[type="submit"]');
      
      if (!email || !button) return;
      
      button.textContent = 'Subscribing...';
      button.disabled = true;
      
      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({ email, referrer: document.referrer || 'direct', source: 'hermesdispatch.dev' })
        });
        
        const data = await res.json();
        
        if (data.success) {
          button.textContent = '✓ Subscribed!';
          button.classList.remove('bg-blue-600', 'hover:bg-blue-500');
          button.classList.add('bg-green-600');
          form.querySelector('input').value = '';
        } else {
          throw new Error(data.message);
        }
      } catch (err) {
        button.textContent = 'Failed - try again';
        button.disabled = false;
        console.error(err);
      }
    });
  </script>
</Layout>
