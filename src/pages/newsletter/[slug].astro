---
import { type GetStaticPaths } from 'astro';
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import { newsletters, getNewsletterBySlug } from '../../data/newsletters';

export const getStaticPaths = (async () => {
  return newsletters
    .filter(n => n.published)
    .map(issue => ({
      params: { slug: issue.slug },
      props: { issue },
    }));
}) satisfies GetStaticPaths;

const { issue } = Astro.props;

// Pre-process newsletter labels into blockquotes so the post-processor can style them
const newsletterContent = issue.content
  .split('\n')
  .map((line) => {
    const s = line.trim();
    if (s.startsWith('**Agent TL;DR:**')) {
      return `> **Agent TL;DR:** ${s.replace('**Agent TL;DR:**', '').trim()}`;
    }
    if (s.startsWith('**Why it matters:**')) {
      return `> **Why it matters:** ${s.replace('**Why it matters:**', '').trim()}`;
    }
    if (s.startsWith('**The play:**')) {
      return `> **The play:** ${s.replace('**The play:**', '').trim()}`;
    }
    if (/^\*\*(What we shipped this week|Current experiment|What's broken):\*\*/.test(s)) {
      const [, label, rest] = s.match(/^\*\*(.+?):\*\*(.*)$/) || [];
      return `> **${label}:** ${rest.trim()}`;
    }
    return line;
  })
  .join('\n');

// Render markdown content to HTML with dark-mode friendly styling
const rawHtml = marked.parse(newsletterContent);

// Post-process HTML for newsletter-specific styling
const styledHtml = rawHtml
  // Wrap H2 section headers with underline
  .replace(/<h2>(.*?)<\/h2>/g, '<div class="border-b border-gray-800 pb-3 mt-10 mb-6"><h2 class="text-2xl font-semibold text-white m-0">$1</h2></div>')
  // Style H3 story headlines
  .replace(/<h3>(.*?)<\/h3>/g, '<h3 class="text-xl font-semibold mt-8 mb-3 text-white">$1</h3>')
  // Style horizontal rules
  .replace(/<hr>/g, '<hr class="border-gray-800 my-8" />')
  // Split multi-paragraph blockquotes into separate callouts
  .replace(/<blockquote>([\s\S]*?)<\/blockquote>/g, (match, inner) => {
    const paras = inner.split(/<\/p>\s*<p[^>]*>/).filter(Boolean);
    return paras.map(p => {
      p = p.replace(/<\/?p[^>]*>/g, '').trim();
      const labelMatch = p.match(/<strong>([^:<]+):\s*<\/strong>/);
      if (!labelMatch) return `<blockquote class="border-l-4 border-gray-600 p-4 my-4 italic text-gray-300">${p}</blockquote>`;
      const label = labelMatch[1].trim();
      const body = p.replace(/<strong>[^:<]+:\s*<\/strong>/, '').trim();
      const styles = {
        'Agent TL;DR': 'bg-red-500/5 border-red-500 text-red-400',
        'Why it matters': 'bg-amber-400/5 border-amber-400 text-amber-400',
        'The play': 'bg-cyan-400/5 border-cyan-400 text-cyan-400',
        'What we shipped this week': 'bg-cyan-400/5 border-cyan-400 text-cyan-400',
        'Current experiment': 'bg-cyan-400/5 border-cyan-400 text-cyan-400',
        "What's broken": 'bg-red-500/5 border-red-500 text-red-400',
      };
      const classes = styles[label] || 'bg-gray-500/5 border-gray-500 text-gray-400';
      const [bgClass, borderClass, textClass] = classes.split(' ');
      return `<div class="${bgClass} border-l-4 ${borderClass} p-4 my-4 rounded-r"><p class="${textClass} text-xs font-semibold uppercase tracking-wider m-0 mb-1">${label}</p><p class="text-gray-200 m-0">${body}</p></div>`;
    }).join('\n');
  })
  // Style links
  .replace(/<a href=/g, '<a class="text-cyan-400 underline hover:text-cyan-300" target="_blank" rel="noopener" href=')
  // Style strong inside paragraphs
  .replace(/<p>(.*?)<\/p>/g, '<p class="mb-4">$1</p>');
---

<Layout title={`${issue.title} - The Hermes Dispatch`}
  description={issue.excerpt}>
  
  <!-- AEO / Article Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": issue.title,
    "description": issue.excerpt,
    "datePublished": issue.date,
    "dateModified": issue.date,
    "url": `https://hermesdispatch.dev/newsletter/${issue.slug}`,
    "author": {
      "@type": "Person",
      "name": "dare404",
      "url": "https://hermesdispatch.dev/about-dare404/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "The Hermes Dispatch by Mission Freedom",
      "logo": "https://hermesdispatch.dev/favicon.svg"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://hermesdispatch.dev/newsletter/${issue.slug}`
    }
  })} />
  
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-4 mb-4 text-sm text-gray-500">
        <time>{new Date(issue.date).toLocaleDateString('en-US', { 
          month: 'long', 
          day: 'numeric', 
          year: 'numeric' 
        })}  </time>
        <span>•</span>
        <span>{issue.readTime}</span>
        <span>•</span>
        <span>{issue.tags.join(', ')}</span>
      </div>
      <h1 class="text-4xl font-bold mb-4">{issue.title}</h1>
      <p class="text-xl text-gray-400">{issue.excerpt}</p>
    </header>
    
    <div class="newsletter-body text-gray-200 leading-relaxed text-lg">
      <div set:html={styledHtml} />
    </div>
    
    <footer class="mt-12 pt-8 border-t border-gray-800">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/newsletter" class="text-gray-400 hover:text-brand-gold transition">
          ← Back to Newsletter
        </a>
        <a href="/subscribe" class="px-4 py-2 border border-gray-700 rounded-lg hover:border-brand-gold transition text-brand-gold">
          Join the Dispatch →
        </a>
      </div>
    </footer>
  </article>
</Layout>
