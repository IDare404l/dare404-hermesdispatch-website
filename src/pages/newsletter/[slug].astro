---
import { type GetStaticPaths } from 'astro';
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import { newsletters, getNewsletterBySlug } from '../../data/newsletters';

export const getStaticPaths = (async () => {
  return newsletters
    .filter(n => n.published)
    .map(issue => ({
      params: { slug: issue.slug },
      props: { issue },
    }));
}) satisfies GetStaticPaths;

const { issue } = Astro.props;

// Render markdown content to HTML with dark-mode friendly styling
const rawHtml = marked.parse(issue.content);

// Post-process HTML for newsletter-specific styling
const styledHtml = rawHtml
  // Wrap H2 section headers with underline
  .replace(/<h2>(.*?)<\/h2>/g, '<div class="border-b border-gray-800 pb-3 mt-10 mb-6"><h2 class="text-2xl font-semibold text-white m-0">$1</h2></div>')
  // Style H3 story headlines
  .replace(/<h3>(.*?)<\/h3>/g, '<h3 class="text-xl font-semibold mt-8 mb-3 text-white">$1</h3>')
  // Style horizontal rules
  .replace(/<hr>/g, '<hr class="border-gray-800 my-8" />')
  // Style blockquotes based on label
  .replace(/<blockquote>\s*<p><strong>Agent TL;DR:<\/strong>(.*?)<\/p>\s*<\/blockquote>/g, '<div class="bg-red-500/5 border-l-4 border-red-500 p-4 my-4 rounded-r"><p class="text-red-400 text-xs font-semibold uppercase tracking-wider m-0 mb-1">Agent TL;DR</p><p class="text-gray-200 m-0">$1</p></div>')
  .replace(/<blockquote>\s*<p><strong>Why it matters:<\/strong>(.*?)<\/p>\s*<\/blockquote>/g, '<div class="bg-amber-400/5 border-l-4 border-amber-400 p-4 my-4 rounded-r"><p class="text-amber-400 text-xs font-semibold uppercase tracking-wider m-0 mb-1">Why it matters</p><p class="text-gray-200 m-0">$1</p></div>')
  .replace(/<blockquote>\s*<p><strong>The play:<\/strong>(.*?)<\/p>\s*<\/blockquote>/g, '<div class="bg-cyan-400/5 border-l-4 border-cyan-400 p-4 my-4 rounded-r"><p class="text-cyan-400 text-xs font-semibold uppercase tracking-wider m-0 mb-1">The play</p><p class="text-gray-200 m-0">$1</p></div>')
  // Style links
  .replace(/<a href=/g, '<a class="text-cyan-400 underline hover:text-cyan-300" target="_blank" rel="noopener" href=')
  // Style strong inside paragraphs
  .replace(/<p>(.*?)<\/p>/g, '<p class="mb-4">$1</p>');
---

<Layout title={`${issue.title} - The Hermes Dispatch`}
  description={issue.excerpt}>
  
  <!-- AEO / Article Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": issue.title,
    "description": issue.excerpt,
    "datePublished": issue.date,
    "dateModified": issue.date,
    "url": `https://hermesdispatch.dev/newsletter/${issue.slug}`,
    "author": {
      "@type": "Person",
      "name": "dare404",
      "url": "https://hermesdispatch.dev/about-dare404/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "The Hermes Dispatch by Mission Freedom",
      "logo": "https://hermesdispatch.dev/favicon.svg"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://hermesdispatch.dev/newsletter/${issue.slug}`
    }
  })} />
  
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-4 mb-4 text-sm text-gray-500">
        <time>{new Date(issue.date).toLocaleDateString('en-US', { 
          month: 'long', 
          day: 'numeric', 
          year: 'numeric' 
        })}  </time>
        <span>•</span>
        <span>{issue.readTime}</span>
        <span>•</span>
        <span>{issue.tags.join(', ')}</span>
      </div>
      <h1 class="text-4xl font-bold mb-4">{issue.title}</h1>
      <p class="text-xl text-gray-400">{issue.excerpt}</p>
    </header>
    
    <div class="newsletter-body text-gray-200 leading-relaxed text-lg">
      <div set:html={styledHtml} />
    </div>
    
    <footer class="mt-12 pt-8 border-t border-gray-800">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/newsletter" class="text-gray-400 hover:text-brand-gold transition">
          ← Back to Newsletter
        </a>
        <a href="/subscribe" class="px-4 py-2 border border-gray-700 rounded-lg hover:border-brand-gold transition text-brand-gold">
          Join the Dispatch →
        </a>
      </div>
    </footer>
  </article>
</Layout>
