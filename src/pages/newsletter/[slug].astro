---
import Layout from '../../layouts/Layout.astro';
import { getNewsletterBySlug, newsletters } from '../../data/newsletters.ts';
import { marked } from 'marked';

export function getStaticPaths() {
  return newsletters.map(n => ({ params: { slug: n.slug }, props: { newsletter: n } }));
}

const { newsletter } = Astro.props;
if (!newsletter) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const html = marked(newsletter.content);
const title = `${newsletter.title} | Hermes Dispatch`;
const description = newsletter.excerpt;
const issueUrl = `https://hermesdispatch.dev/newsletter/${newsletter.slug}/`;
---

<Layout title={title} description={description}>
  <section class="relative py-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-cyan-900/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-cyan-400">Home</a><span class="mx-1">/</span></li>
          <li><a href="/newsletter" class="hover:text-cyan-400">Newsletter</a><span class="mx-1">/</span></li>
          <li aria-current="page" class="text-gray-300">{newsletter.date}</li>
        </ol>
      </nav>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="px-2 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-xs">{newsletter.date}</span>
          <span class="text-gray-500 text-sm">{newsletter.readTime}</span>
          {newsletter.featured && (
            <span class="px-2 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-xs">Featured</span>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{newsletter.title}</h1>
        <p class="text-xl text-gray-400">{newsletter.excerpt}</p>
      </div>

      <!-- Content -->
      <article class="prose prose-invert prose-lg max-w-none mb-12">
        <div set:html={html} />
      </article>

      <!-- Subscribe CTA -->
      <div class="rounded-2xl border border-cyan-500/20 bg-cyan-500/5 p-8 mb-12">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div>
            <h2 class="text-2xl font-bold text-white mb-2">Get the next dispatch</h2>
            <p class="text-gray-400">Daily AI/tech insights from dare404. One email, no spam.</p>
          </div>
          <a href="/subscribe" class="btn-primary inline-flex items-center gap-2 whitespace-nowrap">
            <span>Subscribe</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Issue Article schema -->
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        headline: newsletter.title,
        description: newsletter.excerpt,
        datePublished: newsletter.date,
        url: issueUrl,
        author: { "@type": "Person", name: "dare404" },
        publisher: { "@type": "Organization", name: "Hermes Dispatch", url: "https://hermesdispatch.dev" }
      })} />
    </div>
  </section>
</Layout>
