---
import Layout from '../../layouts/Layout.astro';
import { getPublishedNewsletters, getNewsletterBySlug } from '../../data/newsletters';

export function getStaticPaths() {
  const newsletters = getPublishedNewsletters();
  return newsletters.map(issue => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const newsletters = getPublishedNewsletters();
const currentIndex = newsletters.findIndex(n => n.slug === issue.slug);
const prevIssue = newsletters[currentIndex + 1];
const nextIssue = newsletters[currentIndex - 1];
---

<Layout 
  title={`${issue.title} — The Hermes Dispatch`}
  description={issue.excerpt}
>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <a href="/newsletter" class="text-slate-500 hover:text-slate-300 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Newsletter
      </a>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-2 text-slate-500 text-sm mb-4">
        <span>Issue #{currentIndex + 1}</span>
        <span>•</span>
        <span>{issue.date}</span>
        <span>•</span>
        <span>{issue.readTime} read</span>
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">{issue.title}</h1>
      
      <p class="text-xl text-slate-400">{issue.excerpt}</p>
    </header>

    <!-- Content -->
    <div class="prose prose-invert prose-slate max-w-none">
      <div set:html={issue.content} />
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-slate-800">
      {issue.tags.map(tag => (
        <span class="px-3 py-1 bg-slate-800 text-slate-400 text-sm rounded-full">
          #{tag}
        </span>
      ))}
    </div>

    <!-- Subscribe CTA -->
    <div class="mt-16 p-8 bg-slate-800/50 border border-slate-700 rounded-xl text-center">
      <h3 class="text-xl font-semibold text-white mb-3">Subscribe to The Hermes Dispatch</h3>
      <p class="text-slate-400 mb-6">Get new issues delivered. No spam. Unsubscribe anytime.</p>
      
      <form id="subscribe-form-cta" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input 
          type="email" 
          name="email" 
          placeholder="you@example.com" 
          required
          class="flex-1 px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none"
        />
        <button type="submit" id="subscribe-btn-cta" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg transition-colors">
          Subscribe
        </button>
      </form>
      <script>
        const formCTA = document.getElementById('subscribe-form-cta');
        const btnCTA = document.getElementById('subscribe-btn-cta');
        const GAS_URL = 'https://script.google.com/macros/s/AKfycbwzVQGuQI5EJ0xatSahwwDKxhsngKH7Qitn7Bi0L_T0zq1_HpYgqgsnfIUrWJixByky/exec';
        formCTA?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = formCTA.querySelector('input[name="email"]')?.value;
          if (!email || !email.includes('@')) return;
          btnCTA.textContent = 'Subscribing...';
          btnCTA.disabled = true;
          try {
            const res = await fetch(GAS_URL, {
              method: 'POST',
              headers: { 'Content-Type': 'text/plain' },
              body: JSON.stringify({ email, referrer: document.referrer || 'direct', source: 'hermesdispatch.dev/newsletter' })
            });
            const data = await res.json();
            if (data.success) {
              btnCTA.textContent = '✓ Subscribed!';
              btnCTA.classList.replace('bg-blue-600', 'bg-green-600');
              formCTA.querySelector('input').value = '';
            } else {
              throw new Error(data.message || 'Failed');
            }
          } catch (err) {
            btnCTA.textContent = 'Error. Try again.';
          } finally {
            setTimeout(() => { btnCTA.textContent = 'Subscribe'; btnCTA.disabled = false; btnCTA.classList.replace('bg-green-600', 'bg-blue-600'); }, 3000);
          }
        });
      </script>
    </div>

    <!-- Navigation -->
    <div class="mt-12 flex justify-between items-center">
      {prevIssue ? (
        <a href={`/newsletter/${prevIssue.slug}`} class="text-slate-500 hover:text-slate-300 transition-colors max-w-[45%]">
          <div class="flex items-center gap-1 mb-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Previous
          </div>
          <div class="font-medium truncate">{prevIssue.title}</div>
        </a>
      ) : <div />}
      
      {nextIssue ? (
        <a href={`/newsletter/${nextIssue.slug}`} class="text-slate-500 hover:text-slate-300 transition-colors max-w-[45%] text-right">
          <div class="flex items-center gap-1 mb-1 ml-auto justify-end">
            Next
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
          <div class="font-medium truncate">{nextIssue.title}</div>
        </a>
      ) : <div />}
    </div>
  </article>
</Layout>
