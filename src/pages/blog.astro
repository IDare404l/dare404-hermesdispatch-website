---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    slug: 'issue-001-automated-etsy',
    title: 'How I Built an Automated Etsy Business with Hermes',
    excerpt: 'From manual listing creation to fully automated daily reports. The complete breakdown of the Tabby system.',
    date: '2026-05-20',
    author: 'Rycen Beans',
    category: 'Case Study',
    readTime: '8 min'
  },
];
---

<Layout title="Blog">
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="text-3xl font-bold mb-4">Blog</h1>
        <p class="text-neutral-400 max-w-2xl">Long-form articles, case studies, and deep dives into AI automation. Subscribe to the newsletter for daily updates.</p>
      </div>
      
      <div class="space-y-6">
        {posts.map(post => (
          <article class="card card-glow">
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-4">
              <span class="badge-orange">{post.category}</span>
              <span class="text-sm text-neutral-500">{post.date} · {post.readTime} read</span>
            </div>
            
            <h2 class="text-xl font-semibold mb-3 hover:text-orange-400 transition-colors">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h2>
            
            <p class="text-neutral-400 mb-4">{post.excerpt}</p>
            
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-xs font-bold text-white">R</div>
              <span class="text-sm text-neutral-400">{post.author}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>