---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="The Journey | HermesDispatch"
  description="Built automated systems for digital entrepreneurship with modular skill blocks. One person + AI skills, data-driven results toward Mission Freedom.">
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 text-brand-gold text-sm font-medium mb-6">
        The Journey
      </span>
      
      <h1 class="display-heading mb-6">
        Hermes<span class="text-gradient">Dispatch</span>
      </h1>
      
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        One person + AI skills. Building automated systems for digital entrepreneurship. 
        The newsletter documenting the Mission Freedom journey.
      </p>
    </div>
  </section>
  
  <!-- Philosophy -->
  <section class="relative py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/30 text-brand-accent text-sm font-medium mb-4">
          Philosophy
        </span>
        <h2 class="text-3xl font-bold text-white mb-4">What We Believe</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">Three principles guiding the HermesDispatch journey.</p>
      </div>
      
