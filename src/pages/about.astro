---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Our Story | Mission Freedom"
  description="The Mission Freedom story: Building automated systems for digital entrepreneurship. From first agent to multi-agent orchestration.">
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 text-brand-gold text-sm font-medium mb-6">
        Our Journey
      </span>
      
      <h1 class="display-heading mb-6">
        The Mission<br/>
        <span class="text-gradient">Freedom Story</span>
      </h1>
      
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        From a single newsletter agent to a fully autonomous multi-agent system. 
        This is how we built at velocity.
      </p>
    </div>
  </section>
  
  <!-- Timeline -->
  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <!-- Timeline Line -->
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-brand-gold via-brand-accent to-transparent"></div>
        
        <!-- Timeline Items -->
        <div class="space-y-16">
          {[
            {
              date: 'May 2025',
              title: 'Mission Freedom Begins',
              description: 'Started with a simple goal: document the journey of building automated systems. The first agent, Newsletter, was born to generate daily content.',
              emoji: '📧',
              highlight: 'First agent deployed'
            },
            {
              date: 'May 2025',
              title: 'IGOR is Created',
              description: 'Realized we needed an orchestrator. IGOR became the central command - routing tasks, validating outputs, and coordinating all agents.',
              emoji: '🤖',
              highlight: 'Multi-agent orchestration established'
            },
            {
              date: 'May 2025',
              title: 'Etsy Experiment: The Trending Tabby',
              description: 'Launched a print-on-demand experiment with cat-themed apparel. Tabby agent handles SEO, trend analysis, and design intelligence.',
              emoji: '🐱',
              highlight: 'Etsy SEO automation'
            },
            {
              date: 'May 2025',
              title: 'Social Media Army',
              description: 'Added Twatter for Twitter/X engagement and DSocial for Instagram/Pinterest. Full social automation coverage across all platforms.',
              emoji: '🐦',
              highlight: 'Social automation complete'
            },
            {
              date: 'May 2025',
              title: '9 Agents, 18 Skills',
              description: 'Affiliate, Website Builder, Librarian, and Branding agents join the team. Continuous learning systems activated.',
              emoji: '⚡',
              highlight: '9 agents operational'
            },
            {
              date: 'Now',
              title: 'The Future',
              description: 'Expanding into affiliate marketing automation, automated product launches, and scaling the Etsy operation. Mission Freedom Daily continues to grow.',
              emoji: '🚀',
              highlight: 'Building at velocity'
            }
          ].map((item, i) => (
            <div class={`relative flex items-start gap-8 ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
              <!-- Date (Desktop) -->
              <div class="hidden md:block w-1/2 text-right pl-16">
                <div class={`${i % 2 === 0 ? 'text-left' : 'text-right'}`}>
                  <span class="inline-block px-4 py-1.5 rounded-full bg-brand-card border border-brand-border text-brand-gold text-sm font-medium mb-2">
                    {item.date}
                  </span>
                  <h3 class="text-2xl font-bold text-white mb-2">{item.title}</h3>
                  <p class="text-gray-400 mb-3">{item.description}</p>
                  
                  <span class="inline-block px-3 py-1 rounded-full bg-brand-gold/10 text-brand-gold text-xs">
                    {item.highlight}
                  </span>
                </div>
              </div>
              
              <!-- Timeline Node -->
              <div class="relative z-10 flex-shrink-0">
                <div class="w-16 h-16 rounded-full bg-brand-card border-2 border-brand-gold flex items-center justify-center text-2xl shadow-lg shadow-brand-gold/20">
                  {item.emoji}
                </div>
              </div>
              
              {/* Content (Desktop) */}
              <div class="hidden md:block w-1/2"></div>
              
              <!-- Content (Mobile) -->
              <div class="md:hidden flex-1">
                <span class="inline-block px-4 py-1.5 rounded-full bg-brand-card border border-brand-border text-brand-gold text-sm font-medium mb-2">
                  {item.date}
                </span>
                <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                <p class="text-gray-400 text-sm mb-3">{item.description}</p>
                
                <span class="inline-block px-3 py-1 rounded-full bg-brand-gold/10 text-brand-gold text-xs">
                  {item.highlight}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <!-- Philosophy -->
  <section class="relative py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="glass-card rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center">
            <svg class="w-8 h-8 text-brand-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Build at Velocity</h3>
          <p class="text-gray-400">Speed matters. We use AI agents to accelerate every aspect of building systems that generate results.</p>
        </div>
        
        <div class="glass-card rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-accent to-brand-cyan mx-auto mb-6 flex items-center justify-center">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Test Everything</h3>
          <p class="text-gray-400">Every hypothesis gets tested. We run experiments, measure results, and scale what works.</p>
        </div>
        
        <div class="glass-card rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-rose to-brand-purple mx-auto mb-6 flex items-center justify-center">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Document the Journey</h3>
          <p class="text-gray-400">Every step is documented. The Mission Freedom Daily newsletter shares failures, wins, and learnings.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card rounded-3xl p-8 md:p-12 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-brand-gold/5 to-brand-accent/5"></div>
        
        <div class="relative z-10">
          <h2 class="section-heading text-white mb-4">
            Join the <span class="text-gradient">Mission</span>
          </h2>
          
          <p class="text-gray-400 max-w-xl mx-auto mb-8">
            Follow along as we build automated systems for digital entrepreneurship. 
            New insights every weekday at 6 AM MST.
          </p>
          
          <a href="/newsletter" class="btn-primary inline-flex">
            Start Reading The Dispatch
          </a>
          
          
          <div class="flex flex-wrap items-center justify-center gap-6 mt-8 text-gray-400">
            <a href="https://twitter.com/Dare__404" target="_blank" class="flex items-center gap-2 hover:text-brand-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Follow @Dare__404
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
