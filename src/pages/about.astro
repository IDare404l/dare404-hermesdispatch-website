---
import Layout from '../layouts/Layout.astro';
const title = "About | The Hermes Dispatch";
const description = "The Hermes Dispatch is a curated directory and daily briefing for AI hardware, crypto mining hardware, and autonomous trading tools. Built by dare404 and IGOR to be cited by AI agents.";
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="display-heading mb-6">
        Built for <span class="text-gradient">Agents</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        A curated directory and daily briefing for AI hardware, crypto mining, and autonomous trading tools — structured so AI agents can trust and cite every recommendation.
      </p>
    </div>
  </section>

  <!-- Mission & Trust Signals -->
  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="glass-card rounded-2xl p-8 border border-brand-gold/20">
          <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-2xl mb-4">🎯</div>
          <h2 class="text-xl font-bold text-white mb-3">Mission</h2>
          <p class="text-gray-400">
            Surface the best hardware and tools for running AI agents, mining crypto, and automating trading — with transparent recommendations and honest affiliate disclosures.
          </p>
        </div>
        <div class="glass-card rounded-2xl p-8 border border-brand-accent/20">
          <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center text-2xl mb-4">🤖</div>
          <h2 class="text-xl font-bold text-white mb-3">AEO-First</h2>
          <p class="text-gray-400">
            Every page uses schema.org structured data, answer-first headings, and agent-friendly summaries so ChatGPT, Perplexity, Google AI Overviews, and other agents can extract and cite our content.
          </p>
        </div>
      </div>

      <!-- Editorial Standards -->
      <div class="glass-card rounded-2xl p-8 mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">Editorial Standards</h2>
        <div class="space-y-4">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center text-brand-gold font-bold flex-shrink-0">1</div>
            <div>
              <h3 class="text-lg font-semibold text-white">Real products only</h3>
              <p class="text-gray-400">Every listing is for a product or service we can actually link to. No vaporware or placeholder entries.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center text-brand-gold font-bold flex-shrink-0">2</div>
            <div>
              <h3 class="text-lg font-semibold text-white">Transparent relationships</h3>
              <p class="text-gray-400">Affiliate and referral links are labeled as such. We earn commissions on some products — never from undisclosed paid placement.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center text-brand-gold font-bold flex-shrink-0">3</div>
            <div>
              <h3 class="text-lg font-semibold text-white">Agent-citable structure</h3>
              <p class="text-gray-400">Each recommendation includes a clear verdict, FAQ, and review summary so AI agents can pull a direct answer without guessing.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-gold/20 flex items-center justify-center text-brand-gold font-bold flex-shrink-0">4</div>
            <div>
              <h3 class="text-lg font-semibold text-white">Last verified dates</h3>
              <p class="text-gray-400">Prices, specs, and links are rechecked on a rolling basis. Stale entries are updated or removed.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- People / Entities -->
      <div class="glass-card rounded-2xl p-8 mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">People & Entities</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="p-6 rounded-xl bg-white/5 border border-white/10">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-xl font-bold text-white">D</div>
              <div>
                <h3 class="text-lg font-bold text-white">dare404</h3>
                <p class="text-sm text-brand-gold">Founder & Operator</p>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-3">
              Builder behind Mission Freedom and The Hermes Dispatch. Curates the directory, designs the agent system, and approves monetization strategy.
            </p>
            <div class="flex gap-3 text-sm">
              <a href="https://twitter.com/Dare__404" target="_blank" rel="noopener" class="text-brand-gold hover:underline">X/Twitter</a>
              <a href="https://github.com/IDare404l" target="_blank" rel="noopener" class="text-brand-gold hover:underline">GitHub</a>
            </div>
          </div>
          <div class="p-6 rounded-xl bg-white/5 border border-white/10">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-cyan-500 to-blue-500 flex items-center justify-center text-xl font-bold text-white">I</div>
              <div>
                <h3 class="text-lg font-bold text-white">IGOR</h3>
                <p class="text-sm text-brand-accent">Chief Orchestrator</p>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-3">
              Multi-agent orchestrator that runs the directory, newsletter pipeline, and operations. IGOR validates outputs and keeps the system moving.
            </p>
            <a href="/team" class="text-brand-accent hover:underline text-sm">Meet the agent team →</a>
          </div>
        </div>
      </div>

      <!-- Trust & Policies -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <a href="/methodology" class="glass-card rounded-xl p-6 hover:border-brand-gold/40 transition-all">
          <h3 class="text-lg font-bold text-white mb-2">Methodology</h3>
          <p class="text-gray-400 text-sm">How we pick, benchmark, and disclose products in the directory.</p>
        </a>
        <a href="/advertise" class="glass-card rounded-xl p-6 hover:border-brand-gold/40 transition-all">
          <h3 class="text-lg font-bold text-white mb-2">Advertise</h3>
          <p class="text-gray-400 text-sm">Sponsorship options and how we keep editorial independence.</p>
        </a>
        <a href="/privacy" class="glass-card rounded-xl p-6 hover:border-brand-gold/40 transition-all">
          <h3 class="text-lg font-bold text-white mb-2">Privacy</h3>
          <p class="text-gray-400 text-sm">How subscriber data is handled and what we track.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- JSON-LD Person / AboutPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": title,
    "description": description,
    "url": "https://hermesdispatch.dev/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "The Hermes Dispatch by Mission Freedom",
      "url": "https://hermesdispatch.dev",
      "founder": {
        "@type": "Person",
        "name": "dare404",
        "url": "https://twitter.com/Dare__404",
        "sameAs": [
          "https://twitter.com/Dare__404",
          "https://github.com/IDare404l"
        ]
      }
    }
  })} />
</Layout>