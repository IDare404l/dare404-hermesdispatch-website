---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="w-20 h-20 mx-auto rounded-full bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-3xl font-bold text-white mb-6">R</div>
        
        <h1 class="text-3xl font-bold mb-2">Rycen Beans</h1>
        <p class="text-neutral-400">Hermes automation builder · Boise, Idaho</p>
      </div>
      
      <div class="prose prose-invert max-w-none">
        <p class="lead">I build automated workflows with Hermes AI agents. The Hermes Dispatch is my daily log of what's working, what's breaking, and what I learn along the way.</p>
        
        <h2 class="text-xl font-semibold mt-8 mb-4">Current Projects</h2>
        
        <ul class="space-y-4 text-neutral-400">
          <li>
            <strong class="text-neutral-200">The Hermes Dispatch</strong> — Daily newsletter on AI automation (you're here)
          </li>
          <li>
            <strong class="text-neutral-200">TheTrendingTabby</strong> — Automated Etsy shop generating $X/month (real data in newsletter)
          </li>
          <li>
            <strong class="text-neutral-200">Mission Freedom Skills</strong> — Open-source Hermes skills for automations
          </li>
        </ul>
        
        <h2 class="text-xl font-semibold mt-8 mb-4">Colophon</h2>
        
        <p class="text-neutral-400">This site is built with Hermes agents, Astro, and self-hosted from Boise. No analytics. Minimal JS. Fast.</p>
        
        <p class="text-neutral-400">Daily issues are generated with IGOR's assistance, using a modular skill system. I review and approve before sending.</p>
      </div>
    </div>
  </section>
</Layout>