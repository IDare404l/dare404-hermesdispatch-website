---
import Layout from '../layouts/Layout.astro';

const entries = await Astro.glob('../content/directory/*.md');
const hardwareEntries = entries.filter(e => e.frontmatter.category === 'hardware-grid');

const products = hardwareEntries.map(e => ({...e.frontmatter, Content: e.Content}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI Hardware Upgrades | Mission Freedom",
  "description": "Curated local AI inference rigs and components for Hermes agents. Benchmarked and linked with affiliate transparency.",
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem", "position": i + 1,
    "item": {"@type": "Product", "name": p.name, "description": p.name_full,
      "brand": {"@type": "Brand", "name": p.brand || p.name.split(' ')[0]},
      "offers": {"@type": "Offer", "price": p.price, "priceCurrency": "USD"}}
  }))
};
---

<Layout title="AI Hardware Upgrades | Mission Freedom" description="Curated AI inference hardware for local LLMs. Benchmarked rigs, components, and affiliate links.">

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

<!-- Hero -->
<section class="relative py-12 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-brand-accent/10"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-accent/10 border border-brand-accent/30 mb-6">
      <span class="text-brand-accent text-sm font-mono">UPGRADES & BUILDS</span>
    </div>
    
    <h1 class="text-4xl md:text-5xl font-bold mb-4">
      <span class="text-gradient">The Hardware Grid</span>
    </h1>
    <p class="text-gray-400 max-w-2xl mx-auto mb-8 text-lg">
      Inference rigs and components we actually use to run local AI. Benchmarked. Honest. Upgradable.
    </p>
    
    <div class="flex flex-wrap justify-center gap-3 text-sm">
      <a href="/directory" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-gold/50 transition">← Full Directory</a>
      <a href="/hardware/compare" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-accent/50 transition">Compare AI Hardware →</a>
      <a href="/crypto" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-accent/50 transition">The Mine →</a>
      <a href="/invest" class="px-4 py-2 rounded-full border border-white/10 hover:border-brand-gold/50 transition">The Ledger →</a>
    </div>
  </div>
</section>

<!-- Grid -->
<section class="max-w-6xl mx-auto px-4 pb-16">
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {products.map(product => (
      <article class="glass-card rounded-2xl overflow-hidden transition-all hover:border-brand-gold/40 group">
        <div class="relative h-48 overflow-hidden bg-black/20">
          <img src={product.image} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4">
            <span class="text-brand-gold text-xs font-mono">{product.brand || product.name.split(' ')[0]}</span>
          </div>
        </div>
        
        <div class="p-5">
          <h3 class="text-lg font-semibold mb-1">{product.name}</h3>
          <p class="text-sm text-gray-400 mb-3">{product.name_full}</p>
          
          <div class="flex flex-wrap gap-2 mb-4">
            {product.subcategory && (<span class="text-xs px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent">{product.subcategory}</span>)}
            {product.ollama_score && product.ollama_score !== 'N/A (enabler)' && (
              <span class="text-xs px-2 py-1 rounded-full bg-emerald-500/10 text-emerald-400">{product.ollama_score} tok/s</span>
            )}
          </div>
          
          <a href={product.amazon_link} target="_blank" rel="noopener noreferrer"
            class="block w-full text-center py-2.5 rounded-lg bg-brand-gold/10 border border-brand-gold/30 text-brand-gold font-medium hover:bg-brand-gold/20 transition">
            View on Amazon →
          </a>
          
          <p class="text-xs text-gray-600 mt-2 text-center">{product.source}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- Boise Local SEO -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mission Freedom — AI Hardware Directory",
  "description": "Curated AI inference hardware and local LLM rigs, serving Boise and remote builders.",
  "url": "https://hermesdispatch.dev/hardware",
  "areaServed": {
    "@type": "City",
    "name": "Boise",
    "containedIn": {"@type": "State", "name": "Idaho"}
  },
  "priceRange": "$"
}
</script>

</Layout>