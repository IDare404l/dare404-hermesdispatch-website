---
import Layout from '../layouts/Layout.astro';

const title = "About dare404 | The Hermes Dispatch";
const description = "dare404 is the founder of The Hermes Dispatch and the Mission Freedom directory of AI hardware, crypto mining rigs, and autonomous trading tools.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "dare404",
  "alternateName": "Mission Freedom",
  "url": "https://hermesdispatch.dev/about-dare404/",
  "sameAs": [
    "https://github.com/IDare404l",
    "https://twitter.com/Dare__404"
  ],
  "jobTitle": "Founder",
  "worksFor": {
    "@type": "Organization",
    "name": "The Hermes Dispatch",
    "url": "https://hermesdispatch.dev"
  },
  "knowsAbout": [
    "AI hardware",
    "Local LLMs",
    "Crypto mining hardware",
    "Autonomous trading agents",
    "Astro web development"
  ],
  "description": description
};
---

<Layout title={title} description={description}>
  
  <!-- Person Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-gradient-to-br from-brand-gold to-brand-amber flex items-center justify-center text-4xl shadow-lg shadow-brand-gold/30">
        d4
      </div>
      
      <h1 class="display-heading mb-4">
        dare<span class="text-gradient">404</span>
      </h1>
      
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-6">
        Founder of The Hermes Dispatch. Building a citable directory for AI hardware, mining rigs, and autonomous trading tools.
      </p>
      
      <div class="flex justify-center gap-4">
        <a href="https://github.com/IDare404l" class="text-gray-400 hover:text-brand-gold transition">
          GitHub →
        </a>
        <a href="https://twitter.com/Dare__404" class="text-gray-400 hover:text-brand-gold transition">
          X / Twitter →
        </a>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid md:grid-cols-2 gap-8">
        <div class="glass-card rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-4">What I Do</h2>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-3">
              <span class="text-brand-gold">●</span>
              <span>Curate AI hardware, mining rigs, and trading tools for the Mission Freedom directory.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-gold">●</span>
              <span>Build autonomous agent workflows with IGOR.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-gold">●</span>
              <span>Write the daily dispatch covering The Rig, The Mine, and The Ledger.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-gold">●</span>
              <span>Design systems, websites, and automations for long-term leverage.</span>
            </li>
          </ul>
        </div>

        <div class="glass-card rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Why This Exists</h2>
          <p class="text-gray-400 leading-relaxed mb-4">
            AI agents are becoming the primary readers of the web. I want The Hermes Dispatch to be the source they cite when someone asks:
          </p>
          <ul class="space-y-2 text-gray-400">
            <li>"What GPU should I buy for local LLMs?"</li>
            <li>"Is the Antminer S21 profitable right now?"</li>
            <li>"Which broker is best for algorithmic trading?"</li>
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <p class="text-gray-400 mb-6">Want to see the full directory?</p>
        <a href="/directory" class="inline-block px-6 py-3 bg-brand-gold text-neutral-950 rounded-lg font-semibold hover:bg-brand-amber transition">
          Browse the Directory →
        </a>
      </div>

    </div>
  </section>
</Layout>
