---
import Layout from '../layouts/Layout.astro';

const tools = [
  {
    name: 'Claude',
    description: 'Anthropic AI coding assistant. Best-in-class for reasoning, code generation, and long-context tasks.',
    category: 'AI Model',
    pricing: 'Freemium',
    affiliate: true,
    url: 'https://claude.ai'
  },
  {
    name: 'Buttondown',
    description: 'Newsletter platform with beautiful API. Send emails, manage drafts, track analytics programmatically.',
    category: 'Marketing',
    pricing: 'Freemium',
    affiliate: true,
    url: 'https://buttondown.email'
  },
  {
    name: 'Astro',
    description: 'Fast static site generator with partial hydration. Perfect for content sites like this one.',
    category: 'Development',
    pricing: 'Free',
    affiliate: false,
    url: 'https://astro.build'
  },
  {
    name: 'Printful',
    description: 'Print-on-demand fulfillment for Etsy, Shopify, and custom stores. Integrates with Tabby.',
    category: 'Ecommerce',
    pricing: 'Free',
    affiliate: true,
    url: 'https://printful.com'
  },
  {
    name: 'Vercel',
    description: 'Deploy static sites with automatic previews and global CDN. Simple Git-based workflow.',
    category: 'Development',
    pricing: 'Freemium',
    affiliate: true,
    url: 'https://vercel.com'
  },
  {
    name: 'Hetzner',
    description: 'German cloud hosting with incredible pricing. €5/month for more power than AWS offers at $50.',
    category: 'Infrastructure',
    pricing: 'Paid',
    affiliate: true,
    url: 'https://hetzner.com'
  },
  {
    name: 'Cloudflare',
    description: 'CDN, DNS, tunnels, and security. Free tier is generous. Essential for self-hosting.',
    category: 'Infrastructure',
    pricing: 'Freemium',
    affiliate: true,
    url: 'https://cloudflare.com'
  },
  {
    name: 'Obsidian',
    description: 'Local-first markdown note-taking. The knowledge base for Mission Freedom agents.',
    category: 'Productivity',
    pricing: 'Freemium',
    affiliate: true,
    url: 'https://obsidian.md'
  },
];

const categories = ['All', 'AI Model', 'Development', 'Marketing', 'Ecommerce', 'Infrastructure', 'Productivity'];
---

<Layout title="AI Tools Directory">
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="text-3xl font-bold mb-4">Tools Directory</h1>
        <p class="text-neutral-400 max-w-2xl">AI tools we actually use and recommend. Some links are affiliate links — using them supports the newsletter at no cost to you.</p>
      </div>
      
      <!-- Filter -->
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map(cat => (
          <span class="badge border-neutral-700 hover:border-neutral-600 cursor-pointer transition-colors">{cat}</span>
        ))}
      </div>
      
      <!-- Tools Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {tools.map(tool => (
          <a href={tool.url} target="_blank" rel="noopener noreferrer" class="card group">
            <div class="flex items-start justify-between mb-4">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="font-semibold group-hover:text-orange-400 transition-colors">{tool.name}</h3>
                  <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </div>
                <p class="text-sm text-neutral-400 mb-3">{tool.description}</p>
              </div>
            </div>
            
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="badge-blue">{tool.category}</span>
                <span class="text-xs text-neutral-500">{tool.pricing}</span>
              </div>
              
              {tool.affiliate && (
                <span class="text-xs text-orange-400/60">Affiliate</span>
              )}
            </div>
          </a>
        ))}
      </div>
      
      <!-- Sponsored Section -->
      <div class="mt-16 card border-orange-500/30">
        <div class="flex items-center justify-between mb-4">
          <div>
            <span class="badge-orange mb-2">Sponsored</span>
            <h3 class="text-xl font-semibold">Advertise Here</h3>
          </div>
        </div>
        
        <p class="text-neutral-400 mb-4">Reach AI builders and automation enthusiasts. Sponsored listings get featured placement in the tools directory.</p>
        
        <a href="mailto:hello@hermesmissionfreedom.ai" class="btn-secondary text-sm">
          Inquire About Placement
        </a>
      </div>
    </div>
  </section>
</Layout>