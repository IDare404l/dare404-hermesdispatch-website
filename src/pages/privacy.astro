---
import Layout from '../layouts/Layout.astro';

const title = "Privacy Policy | Mission Freedom";
const description = "Mission Freedom privacy policy: how we handle subscriber data, affiliate disclosures, and your rights under U.S. law.";
---

<Layout title={title} description={description}>

<section class="relative pt-32 pb-16">
  <div class="max-w-3xl mx-auto px-4">
    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 text-brand-gold text-sm font-medium mb-6">
      Legal
    </span>
    
    <h1 class="text-4xl font-bold mb-8">Privacy Policy & Disclosures</h1>
    
    <p class="text-gray-400 mb-8">Last updated: June 8, 2026. Built by dare404 in Boise, Idaho.</p>
    
    <div class="space-y-8">
      <div>
        <h2 class="text-xl font-semibold text-white mb-3">1. Affiliate Disclosure (FTC 16 CFR § 255)</h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          Mission Freedom publishes curated product directories with affiliate links. We may earn a commission 
          if you click through and purchase or sign up. Our affiliate relationships include:
        </p>
        <ul class="text-gray-400 text-sm mt-2 space-y-1 list-disc pl-5">
          <li>Amazon Associates — tag: dare404-20</li>
          <li>TradingView Partner Program — aff_id: 167461</li>
        </ul>
        <p class="text-gray-400 text-sm mt-2">We do not accept paid reviews. All product selections are based on community benchmarks or manufacturer specs. See each entry for sourcing details.</p>
      </div>
      
      <div>
        <h2 class="text-xl font-semibold text-white mb-3">2. Newsletter Privacy (CAN-SPAM Act)</h2>
        <ul class="text-gray-400 text-sm space-y-2 list-disc pl-5">
          <li>Your email is collected via our subscribe page and stored securely.</li>
          <li>We send one daily newsletter ("The Ledger") at approximately 06:00 MST.</li>
          <li>Every email includes an unsubscribe link. Unsubscribe requests honored within 10 business days.</li>
          <li>We do not sell, rent, or share email addresses with third parties.</li>
          <li>Physical address:  Boise, Idaho (provided in newsletter footer per CAN-SPAM § 7704(a)(5)).</li>
        </ul>
      </div>
      
      <div>
        <h2 class="text-xl font-semibold text-white mb-3">3. Cookies & Tracking</h2>
        <p class="text-gray-400 text-sm">
          We use Cloudflare Analytics for aggregated traffic data. No third-party advertising cookies. 
          No personal tracking beyond server logs.
        </p>
      </div>
      
      <div>
        <h2 class="text-xl font-semibold text-white mb-3">4. Data Rights</h2>
        <p class="text-gray-400 text-sm">
          You may request deletion of your email from our subscriber list at any time. 
          Contact: dare404 (via Telegram @dare404l).
        </p>
      </div>
    </div>
  </div>
</section>

</Layout>