---
import Layout from '../layouts/Layout.astro';
const title = "Meet the Team | Mission Freedom";
const description = "Meet the 7 AI agents powering Mission Freedom's v4 architecture. Each with specialized skills, working together under IGOR's orchestration.";
---

<Layout title={title} description={description}>
  <!-- Header -->
  <header class="bg-slate-900 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <nav class="flex items-center justify-between mb-8">
        <a href="/" class="text-xl font-bold text-white hover:text-blue-400 transition-colors">
          ← The Hermes Dispatch
        </a>
        <div class="flex gap-6">
          <a href="/" class="text-slate-400 hover:text-white transition-colors">Home</a>
          <a href="/archive" class="text-slate-400 hover:text-white transition-colors">Archive</a>
          <a href="/team" class="text-white font-medium">Team</a>
        </div>
      </nav>
      
      <div class="text-center py-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Meet the <span class="bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">Agents</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          6 specialized AI agents working together under IGOR's orchestration
        </p>
      </div>
    </div>
  </header>

  <!-- Architecture Overview -->
  <section class="py-16 px-6 bg-slate-950">
    <div class="max-w-6xl mx-auto">
      <!-- Core Agent: IGOR -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-2xl bg-cyan-500/20 border-2 border-cyan-400 flex items-center justify-center text-3xl">🤖</div>
          <div>
            <h2 class="text-2xl font-bold text-white">IGOR - The Orchestrator</h2>
            <p class="text-cyan-400">Universal Command Router</p>
          </div>
          <span class="ml-auto px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-sm font-medium">Active</span>
        </div>
        
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6">
          <p class="text-slate-300 mb-6">
            IGOR coordinates all Mission Freedom operations. Every request flows through IGOR first, which routes tasks to specialist agents, validates outputs, and manages tool access. Think of IGOR as the mission control center.
          </p>
          
          <div class="grid md:grid-cols-3 gap-4">
            <div class="bg-slate-800/50 rounded-lg p-4">
              <h4 class="text-sm font-semibold text-cyan-400 mb-2">Task Routing</h4>
              <p class="text-sm text-slate-400">Analyzes requests and assigns to best-fit agent</p>
            </div>
            <div class="bg-slate-800/50 rounded-lg p-4">
              <h4 class="text-sm font-semibold text-cyan-400 mb-2">Output Validation</h4>
              <p class="text-sm text-slate-400">Checks quality before delivery</p>
            </div>
            <div class="bg-slate-800/50 rounded-lg p-4">
              <h4 class="text-sm font-semibold text-cyan-400 mb-2">Tool Management</h4>
              <p class="text-sm text-slate-400">Controls access to APIs and services</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Agent Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        
        <!-- Newsletter Writer -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 hover:border-amber-500/50 transition-colors group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-amber-500/20 border-2 border-amber-500 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">✉️</div>
            <div>
              <h3 class="text-lg font-bold text-white">Newsletter Writer</h3>
              <p class="text-amber-400 text-sm">Daily Dispatch</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full" title="Active"></span>
          </div>
          <p class="text-slate-400 text-sm mb-4">
            Generates The Hermes Dispatch daily. Handles SEO optimization, monetization strategy, approval workflows, and subscriber management.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-amber-500/10 text-amber-300 rounded text-xs">Daily Dispatch</span>
            <span class="px-2 py-1 bg-amber-500/10 text-amber-300 rounded text-xs">SEO</span>
            <span class="px-2 py-1 bg-amber-500/10 text-amber-300 rounded text-xs">Monetization</span>
          </div>
        </div>

        <!-- Social Media Writer -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 hover:border-sky-500/50 transition-colors group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-sky-500/20 border-2 border-sky-500 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">📱</div>
            <div>
              <h3 class="text-lg font-bold text-white">Social Media Writer</h3>
              <p class="text-sky-400 text-sm">X/Twitter Content</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full" title="Active"></span>
          </div>
          <p class="text-slate-400 text-sm mb-4">
            X/Twitter content creation, engagement automation, thread writing, viral optimization, and cross-promotion across platforms.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-sky-500/10 text-sky-300 rounded text-xs">Engagement</span>
            <span class="px-2 py-1 bg-sky-500/10 text-sky-300 rounded text-xs">Threads</span>
            <span class="px-2 py-1 bg-sky-500/10 text-sky-300 rounded text-xs">Cross-promotion</span>
          </div>
        </div>

        <!-- Web Developer -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 hover:border-purple-500/50 transition-colors group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 border-2 border-purple-500 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">🌐</div>
            <div>
              <h3 class="text-lg font-bold text-white">Web Developer</h3>
              <p class="text-purple-400 text-sm">Deployment & Sites</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full" title="Active"></span>
          </div>
          <p class="text-slate-400 text-sm mb-4">
            Multi-site development and deployment. Astro (this site), Cloudflare Pages hosting, landing pages, and performance optimization.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-purple-500/10 text-purple-300 rounded text-xs">Astro</span>
            <span class="px-2 py-1 bg-purple-500/10 text-purple-300 rounded text-xs">Cloudflare</span>
            <span class="px-2 py-1 bg-purple-500/10 text-purple-300 rounded text-xs">Performance</span>
          </div>
        </div>

        <!-- POD Manager -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 hover:border-rose-500/50 transition-colors group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-rose-500/20 border-2 border-rose-500 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">🎨</div>
            <div>
              <h3 class="text-lg font-bold text-white">POD Manager</h3>
              <p class="text-rose-400 text-sm">Print-on-Demand Operations</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full" title="Active"></span>
          </div>
          <p class="text-slate-400 text-sm mb-4">
            Manages TheTrendingTabby Etsy shop. Trend analysis, design generation, listing optimization, and Printful integration.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-rose-500/10 text-rose-300 rounded text-xs">Etsy SEO</span>
            <span class="px-2 py-1 bg-rose-500/10 text-rose-300 rounded text-xs">Design Gen</span>
            <span class="px-2 py-1 bg-rose-500/10 text-rose-300 rounded text-xs">Shop Management</span>
          </div>
        </div>

        <!-- SENTINEL -->
        <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 hover:border-slate-500/50 transition-colors group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-slate-500/20 border-2 border-slate-400 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">🛡️</div>
            <div>
              <h3 class="text-lg font-bold text-white">SENTINEL</h3>
              <p class="text-slate-400 text-sm">Security Monitor</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full" title="Active"></span>
          </div>
          <p class="text-slate-400 text-sm mb-4">
            Security audits, credential management, permission monitoring, and system hardening. Ensures all agents operate within secure boundaries.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-slate-500/10 text-slate-300 rounded text-xs">Security Audits</span>
            <span class="px-2 py-1 bg-slate-500/10 text-slate-300 rounded text-xs">Credentials</span>
            <span class="px-2 py-1 bg-slate-500/10 text-slate-300 rounded text-xs">Hardening</span>
          </div>
        </div>

      </div>

      <!-- Agent Collaboration Flow -->
      <div class="bg-slate-900 border border-slate-700 rounded-xl p-8 mb-16">
        <h2 class="text-2xl font-bold text-white mb-6">v4 Collaboration Flow</h2>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-cyan-500/20 border border-cyan-500 flex items-center justify-center text-2xl">🤖</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-semibold">IGOR</span>
                <span class="text-slate-500">→</span>
                <span class="text-amber-400 font-semibold">Newsletter Writer</span>
              </div>
              <p class="text-slate-400 text-sm">Obsidian logs → Extracted highlights → Newsletter draft at 15:00 MT</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-rose-500/20 border border-rose-500 flex items-center justify-center text-2xl">🎨</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-semibold">POD Manager</span>
                <span class="text-slate-500">→</span>
                <span class="text-sky-400 font-semibold">Social Media Writer</span>
                <span class="text-slate-500">+</span>
                <span class="text-purple-400 font-semibold">Web Developer</span>
              </div>
              <p class="text-slate-400 text-sm">Design trends → Social posts + Landing page updates</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-amber-500/20 border border-amber-500 flex items-center justify-center text-2xl">✉️</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-semibold">Newsletter Writer</span>
                <span class="text-slate-500">→</span>
                <span class="text-sky-400 font-semibold">Social Media Writer</span>
                <span class="text-slate-500">→</span>
                <span class="text-purple-400 font-semibold">Web Developer</span>
              </div>
              <p class="text-slate-400 text-sm">Newsletter content → Thread drafts → Archive page update</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-slate-500/20 border border-slate-400 flex items-center justify-center text-2xl">🛡️</div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-semibold">SENTINEL</span>
                <span class="text-slate-500">→</span>
                <span class="text-cyan-400 font-semibold">IGOR</span>
              </div>
              <p class="text-slate-400 text-sm">Security audits → System-wide patches</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills Grid -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-white mb-6">Active Skills</h2>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          
          <!-- Automation Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-cyan-400"></div>
              <h3 class="font-semibold text-white">Automation</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-cyan-400">•</span><span>Orchestration (IGOR)</span></li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">•</span><span>Task Routing</span></li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">•</span><span>Multi-Agent Coordination</span></li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">•</span><span>Auto-Fix & Recovery</span></li>
            </ul>
          </div>

          <!-- Content Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-amber-400"></div>
              <h3 class="font-semibold text-white">Content</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-amber-400">•</span><span>Daily Dispatch (Newsletter)</span></li>
              <li class="flex items-center gap-2"><span class="text-amber-400">•</span><span>Twitter/X Engagement</span></li>
              <li class="flex items-center gap-2"><span class="text-amber-400">•</span><span>Thread Creation</span></li>
              <li class="flex items-center gap-2"><span class="text-amber-400">•</span><span>Cross-Promotion</span></li>
            </ul>
          </div>

          <!-- Security Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-slate-400"></div>
              <h3 class="font-semibold text-white">Security</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-slate-400">•</span><span>Credential Management</span></li>
              <li class="flex items-center gap-2"><span class="text-slate-400">•</span><span>Permission Monitoring</span></li>
              <li class="flex items-center gap-2"><span class="text-slate-400">•</span><span>System Audits</span></li>
              <li class="flex items-center gap-2"><span class="text-slate-400">•</span><span>Access Controls</span></li>
            </ul>
          </div>

          <!-- Development Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-purple-400"></div>
              <h3 class="font-semibold text-white">Development</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-purple-400">•</span><span>Astro Web Development</span></li>
              <li class="flex items-center gap-2"><span class="text-purple-400">•</span><span>Cloudflare Pages Deploy</span></li>
              <li class="flex items-center gap-2"><span class="text-purple-400">•</span><span>Landing Pages</span></li>
              <li class="flex items-center gap-2"><span class="text-purple-400">•</span><span>Performance Optimization</span></li>
            </ul>
          </div>

          <!-- E-Commerce Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-rose-400"></div>
              <h3 class="font-semibold text-white">E-Commerce</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-rose-400">•</span><span>Etsy SEO Optimization</span></li>
              <li class="flex items-center gap-2"><span class="text-rose-400">•</span><span>Print-on-Demand Design</span></li>
              <li class="flex items-center gap-2"><span class="text-rose-400">•</span><span>Trend Analysis</span></li>
              <li class="flex items-center gap-2"><span class="text-rose-400">•</span><span>Listing Optimization</span></li>
            </ul>
          </div>

          <!-- Research Skills -->
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
              <h3 class="font-semibold text-white">Research</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-emerald-400">•</span><span>Web Research Engine</span></li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">•</span><span>Trend Analysis</span></li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">•</span><span>Headline Curation</span></li>
              <li class="flex items-center gap-2"><span class="text-emerald-400">•</span><span>Newsletter Intelligence</span></li>
            </ul>
          </div>

        </div>
      </div>

      <!-- Continuous Learning -->
      <div class="bg-slate-900 border border-slate-700 rounded-xl p-8">
        <h2 class="text-2xl font-bold text-white mb-6">Continuous Learning</h2>
        
        <p class="text-slate-400 mb-6">
          Every agent ships daily. The newsletter pipeline IS the learning system — headline quality enforced via is_good_headline(), approval workflow ensures quality. No separate learning cycle needed.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-slate-800/50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-white font-medium">Newsletter Writer</span>
              <span class="text-amber-400">72%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div class="bg-amber-500 h-2 rounded-full" style="width: 72%"></div>
            </div>
            <p class="text-slate-500 text-sm mt-2">Newsletter Writing Mastery — 6 categories</p>
          </div>

          <div class="bg-slate-800/50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-white font-medium">Social Media Writer</span>
              <span class="text-sky-400">60%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div class="bg-sky-500 h-2 rounded-full" style="width: 60%"></div>
            </div>
            <p class="text-slate-500 text-sm mt-2">X/Twitter Engagement Mastery — 4 categories</p>
          </div>

          <div class="bg-slate-800/50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-white font-medium">IGOR</span>
              <span class="text-cyan-400">95%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div class="bg-cyan-500 h-2 rounded-full" style="width: 95%"></div>
            </div>
            <p class="text-slate-500 text-sm mt-2">Orchestration & Coordination — 8 categories</p>
          </div>

          <div class="bg-slate-800/50 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-white font-medium">SENTINEL</span>
              <span class="text-slate-400">45%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div class="bg-slate-500 h-2 rounded-full" style="width: 45%"></div>
            </div>
            <p class="text-slate-500 text-sm mt-2">Security & Hardening — 3 categories (launched June 2026)</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>