---
import Layout from '../../layouts/Layout.astro';

const entries = await Astro.glob('../../content/directory/*.md');
const brokers = entries.filter(e => e.frontmatter.subcategory === 'broker' || e.frontmatter.subcategory === 'charting');
const products = brokers.map(e => ({...e.frontmatter, Content: e.Content}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Best Trading Tools and Brokerages Compared",
  "description": "Comparison of trading platforms, charting tools, and brokerages for automated and discretionary traders. Affiliate transparency.",
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem", "position": i + 1,
    "item": {"@type": "Product", "name": p.name, "description": p.name_full,
      "offers": {"@type": "Offer", "price": p.price, "priceCurrency": "USD"}}
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best brokerage for automated trading?",
      "acceptedAnswer": { "@type": "Answer", "text": "Interactive Brokers is the standard for automated trading because of its robust IB API, low margin rates, and direct market access." }
    },
    {
      "@type": "Question",
      "name": "What is the best free charting tool?",
      "acceptedAnswer": { "@type": "Answer", "text": "TradingView offers the best free charting with Pine Script backtesting, alerts, and webhook integrations." }
    },
    {
      "@type": "Question",
      "name": "How much does the Interactive Brokers referral program pay?",
      "acceptedAnswer": { "@type": "Answer", "text": "Interactive Brokers pays up to $1,000 per funded referral depending on account size and activity." }
    }
  ]
};
---

<Layout title="Compare Trading Tools | The Ledger" description="Side-by-side comparison of brokerages, charting tools, and trading APIs. Affiliate transparency.">

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<section class="relative py-20 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-brand-gold/10"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 mb-6">
      <span class="text-brand-gold text-sm font-mono">THE LEDGER — COMPARISON</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4"><span class="text-gradient">Trading Tools Compared</span></h1>
    <p class="text-gray-400 max-w-2xl mx-auto mb-8 text-lg">
      Brokerages and charting tools for automated trading, backtesting, and execution.
    </p>
  </div>
</section>

<section class="max-w-6xl mx-auto px-4 pb-8">
  <div class="glass-card rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-white/5 border-b border-white/10">
        <tr>
          <th class="text-left p-4 font-semibold">Tool</th>
          <th class="text-left p-4 font-semibold">Category</th>
          <th class="text-left p-4 font-semibold">Price</th>
          <th class="text-left p-4 font-semibold">Best For</th>
          <th class="text-left p-4 font-semibold">Referral Payout</th>
          <th class="text-right p-4 font-semibold">Action</th>
        </tr>
      </thead>
      <tbody>
        {products.map(product => (
          <tr class="border-b border-white/5 hover:bg-white/[0.02] transition">
            <td class="p-4">
              <span class="font-semibold">{product.name}</span>
            </td>
            <td class="p-4 text-gray-400 capitalize">{product.subcategory}</td>
            <td class="p-4 font-mono">{product.price === 0 ? 'Free' : '$' + product.price}</td>
            <td class="p-4 text-gray-400">{product.why_use}</td>
            <td class="p-4 text-gray-400">{product.referral_link ? 'Up to $1,000 (IBKR)' : 'N/A'}</td>
            <td class="p-4 text-right">
              <a href={product.referral_link || product.amazon_link} target="_blank" rel="noopener noreferrer"
                class="inline-block px-4 py-1.5 rounded-lg bg-brand-gold/10 border border-brand-gold/30 text-brand-gold hover:bg-brand-gold/20 transition text-xs font-medium">
                Try →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<section class="max-w-4xl mx-auto px-4 pb-16">
  <h2 class="text-2xl font-bold mb-6"><span class="text-gradient">FAQ</span></h2>
  <div class="space-y-4">
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">What is the best brokerage for automated trading?</summary>
      <p class="text-gray-400 mt-3 text-sm">Interactive Brokers is the standard for automated trading because of its robust IB API, low margin rates, and direct market access.</p>
    </details>
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">What is the best free charting tool?</summary>
      <p class="text-gray-400 mt-3 text-sm">TradingView offers the best free charting with Pine Script backtesting, alerts, and webhook integrations.</p>
    </details>
    <details class="glass-card rounded-xl p-4 group">
      <summary class="font-semibold cursor-pointer">How much does the Interactive Brokers referral program pay?</summary>
      <p class="text-gray-400 mt-3 text-sm">Interactive Brokers pays up to $1,000 per funded referral depending on account size and activity.</p>
    </details>
  </div>
</section>

</Layout>
