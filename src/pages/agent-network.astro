---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Agent Network Map | Mission Freedom">
  <section class="relative overflow-hidden py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-sm text-emerald-400">Live System</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-4">
          Agent <span class="text-gradient">Network Map</span>
        </h1>
        <p class="text-neutral-400 max-w-2xl">
          Interactive visualization of Mission Freedom's AI agent ecosystem. 
          Click nodes to explore agent details, skills, and connections.
        </p>
      </div>
    </div>
  </section>

  <!-- Fullscreen Visualization -->
  <section class="px-4 sm:px-6 lg:px-8 mb-12">
    <div class="border border-neutral-800 rounded-xl overflow-hidden bg-secondary">
      <div class="flex items-center justify-between px-4 py-3 border-b border-neutral-800 bg-neutral-900">
        <div class="flex items-center gap-3">
          <span class="text-xl">🤖</span>
          <span class="font-medium">Agent Graph</span>
        </div>
        <div class="flex items-center gap-4 text-sm text-neutral-400">
          <span>Click nodes to view details</span>
          <span class="px-2 py-1 bg-neutral-800 rounded">Drag to rearrange</span>
          <span class="px-2 py-1 bg-neutral-800 rounded">Scroll to zoom</span>
        </div>
      </div>
      <iframe 
        src="/agent-network/interactive-agent-map.html" 
        class="w-full"
        style="height: 70vh; min-height: 500px; border: none;"
        title="Mission Freedom Agent Network"
      ></iframe>
    </div>
  </section>

  <!-- Stats & Info -->
  <section class="py-12 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card">
          <div class="text-3xl mb-3">1</div>
          <h3 class="font-semibold text-orange-400 mb-2">Solo Orchestrator</h3>
          <p class="text-sm text-neutral-400">
            dare404 (you) + IGOR + an arsenal of 18+ on-demand skills. No agent bloat.
          </p>
        </div>
        
        <div class="card">
          <div class="text-3xl mb-3">50+</div>
          <h3 class="font-semibold text-orange-400 mb-2">Skills Available</h3>
          <p class="text-sm text-neutral-400">
            Hermes skills for automation, email, web research, and platform integrations.
          </p>
        </div>
        
        <div class="card">
          <div class="text-3xl mb-3">5</div>
          <h3 class="font-semibold text-orange-400 mb-2">Categories</h3>
          <p class="text-sm text-neutral-400">
            From e-commerce workflows to creative content generation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Legend -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold mb-6">Agent Categories</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #34d399;"></div>
          <span class="text-sm">E-Commerce</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #22d3ee;"></div>
          <span class="text-sm">Social Media</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #a78bfa;"></div>
          <span class="text-sm">Orchestration</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #fbbf24;"></div>
          <span class="text-sm">Marketing</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #fb7185;"></div>
          <span class="text-sm">Creative</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #1db954;"></div>
          <span class="text-sm">Media</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-secondary rounded-lg">
          <div class="w-3 h-3 rounded-full" style="background: #94a3b8;"></div>
          <span class="text-sm">Archived</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .text-gradient {
    background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
