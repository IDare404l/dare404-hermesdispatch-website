---
// Server-rendered so query params work at request time
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const email = Astro.url.searchParams.get('email') || '';
---

<Layout
  title="Unsubscribe | The Hermes Dispatch"
  description="Unsubscribe from The Hermes Dispatch in one click."
  noindex={true}
>
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark to-brand-accent/10"></div>
    <div class="relative z-10 max-w-md mx-auto px-4 text-center">
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-gray-600 to-gray-700 mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg">
        ✉️
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Unsubscribe
      </h1>
      <p class="text-gray-400 mb-8">
        Click the button below and we'll remove you from The Hermes Dispatch immediately. No email required.
      </p>

      {email ? (
        <p class="text-gray-300 mb-6 bg-brand-card rounded-lg p-3 border border-brand-border">
          Removing: <strong class="text-white">{email}</strong>
        </p>
      ) : null}

      <form id="unsub-form" class="space-y-4" data-email={email}>
        {!email && (
          <input
            type="email"
            name="email"
            id="email-input"
            value={email}
            placeholder="you@example.com"
            required
            class="w-full px-6 py-4 rounded-xl bg-brand-card border border-brand-border text-white placeholder-gray-500 focus:outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold transition-all"
          />
        )}
        <button
          type="submit"
          id="unsub-btn"
          class="btn-primary w-full"
        >
          Unsubscribe Me
        </button>
      </form>

      <div id="unsub-success" class="hidden">
        <div class="w-16 h-16 rounded-full bg-emerald-500/20 mx-auto mb-4 flex items-center justify-center text-3xl">✅</div>
        <h2 class="text-xl font-bold text-white mb-2">You're Unsubscribed</h2>
        <p class="text-gray-300">You will no longer receive The Hermes Dispatch. If you change your mind, you can always resubscribe on the homepage.</p>
        <a href="/" class="btn-primary inline-block mt-6">Back to Home</a>
      </div>

      <div id="unsub-error" class="hidden">
        <div class="w-16 h-16 rounded-full bg-red-500/20 mx-auto mb-4 flex items-center justify-center text-3xl">⚠️</div>
        <h2 class="text-xl font-bold text-white mb-2">Something Went Wrong</h2>
        <p id="error-message" class="text-gray-300">Please try again in a moment.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var form = document.getElementById('unsub-form');
      var btn = document.getElementById('unsub-btn');
      var success = document.getElementById('unsub-success');
      var error = document.getElementById('unsub-error');
      var errorMsg = document.getElementById('error-message');
      var emailInput = document.getElementById('email-input');
      var prefillEmail = form?.dataset.email || '';

      function show(id) {
        [form, success, error].forEach(function(el) {
          if (el) el.classList.add('hidden');
        });
        var el = document.getElementById(id);
        if (el) el.classList.remove('hidden');
      }

      form?.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = prefillEmail || (emailInput ? emailInput.value.trim() : '');
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          if (errorMsg) errorMsg.textContent = 'Please enter a valid email address.';
          show('unsub-error');
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Processing...';

        fetch('/api/unsubscribe/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email })
        }).then(function(r) {
          if (!r.ok) throw new Error('Server error ' + r.status);
          return r.json();
        }).then(function(data) {
          if (data.success) {
            show('unsub-success');
          } else {
            throw new Error(data.error || 'Unsubscribe failed');
          }
        }).catch(function(err) {
          if (errorMsg) errorMsg.textContent = err.message || 'Something went wrong. Please try again.';
          show('unsub-error');
          btn.disabled = false;
          btn.textContent = 'Unsubscribe Me';
        });
      });
    })();
  </script>

  <style>
    .hidden { display: none !important; }
  </style>
</Layout>
