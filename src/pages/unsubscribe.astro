---
import Layout from '../layouts/Layout.astro';

const GAS_URL = 'https://script.google.com/macros/s/AKfycbwzVQGuQI5EJ0xatSahwwDKxhsngKH7Qitn7Bi0L_T0zq1_HpYgqgsnfIUrWJixByky/exec';
---

<Layout title="Unsubscribe - HermesDispatch">

  <div class="pt-32 pb-24 bx relative overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-rose-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-xl mx-auto px-4 relative">

      <!-- Unsubscribe form card -->
      <div class="bx rounded-2xl p-8 md:p-12 border border-white/[0.06] hover:border-rose-500/20 transition-all duration-500 relative group overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-rose-500/[0.03] via-transparent to-purple-500/[0.03] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative">
          <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-rose-500 to-pink-600 flex items-center justify-center shadow-lg shadow-rose-500/25">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-white mb-2">Unsubscribe from HermesDispatch</h2>
            <p class="text-gray-400">Enter your email address to unsubscribe from our newsletter.</p>
          </div>

          <form id="unsubscribe-form" class="space-y-4">
            <div>
              <input
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-5 py-4 rounded-xl bg-slate-800/50 border border-slate-700 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-500/20 text-white placeholder:text-slate-500 transition-all duration-300"
              />
            </div>
            <button
              type="submit"
              id="unsubscribe-btn"
              class="w-full py-4 px-6 rounded-xl font-bold text-white transition-all duration-300 bg-gradient-to-r from-rose-500 to-pink-600 hover:from-rose-600 hover:to-pink-700 shadow-lg shadow-rose-500/25 hover:shadow-rose-500/40"
            >
              Unsubscribe
            </button>
          </form>

          <div id="unsubscribe-status" class="mt-6 text-center min-h-[1.5rem]"></div>
        </div>
      </div>

      <!-- Alternative -->
      <div class="mt-8 text-center">
        <p class="text-gray-400 text-sm">
          Changed your mind? 
          <a href="/" class="text-rose-400 hover:text-rose-300 transition-colors">Back to homepage</a>
          <span class="mx-2 text-gray-600">•</span>
          <a href="/newsletter" class="text-rose-400 hover:text-rose-300 transition-colors">View archives</a>
        </p>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ GAS_URL }}>
  const form = document.getElementById('unsubscribe-form');
  const btn = document.getElementById('unsubscribe-btn');
  const statusEl = document.getElementById('unsubscribe-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[name="email"]')?.value;
    
    if (!email || !email.includes('@')) {
      statusEl.innerHTML = '<span class="text-rose-400">Please enter a valid email address.</span>';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Processing...';
    statusEl.textContent = '';

    try {
      const url = GAS_URL + '?action=unsubscribe&email=' + encodeURIComponent(email);
      const response = await fetch(url);
      const data = await response.json();

      if (data.success) {
        statusEl.innerHTML = `<span class="text-emerald-400 font-medium">✓ ${data.message}</span>`;
        form.style.display = 'none';
      } else {
        statusEl.innerHTML = `<span class="text-rose-400">✗ ${data.error || data.message || 'Something went wrong.'}</span>`;
        btn.disabled = false;
        btn.textContent = 'Unsubscribe';
      }
    } catch (err) {
      statusEl.innerHTML = `<span class="text-rose-400">✗ ${String(err)}</span>`;
      btn.disabled = false;
      btn.textContent = 'Unsubscribe';
    }
  });
</script>
