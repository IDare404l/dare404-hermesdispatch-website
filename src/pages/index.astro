---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const title = "Hermes Dispatch - AI Automation Newsletter";
const description = "AI automation insights from Boise, ID. Working workflows, block-style skills, and self-improving automation all in your pocket.";
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <header class="hero-gradient min-h-screen flex flex-col items-center justify-center px-6 py-20">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Tagline -->
      <p class="text-blue-400 text-sm font-semibold tracking-wider uppercase mb-4 animate-slide-up" style="animation-delay: 0.1s">
        Daily AI Automation Insights
      </p>
      
      <!-- Main Title -->
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 animate-slide-up" style="animation-delay: 0.2s">
        Hermes Dispatch
      </h1>
      
      <!-- Subtitle/Tagline -->
      <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto animate-slide-up" style="animation-delay: 0.3s">
        AI automation insights from Boise, ID. Working workflows, block-style skills, and self-improving automation all in your pocket.
      </p>
      
      <p class="text-slate-400 mb-12 animate-slide-up" style="animation-delay: 0.4s">
        Build your Hermes agent's arsenal of skills, tools, and sub-agents with us every day.
      </p>
      
      <!-- Newsletter Signup -->
      <div class="bg-slate-900/80 backdrop-blur-sm border border-slate-700 rounded-2xl p-8 max-w-lg mx-auto glow-blue animate-slide-up" style="animation-delay: 0.5s">
        <h2 class="text-2xl font-semibold text-white mb-2">
          Join the Dispatch
        </h2>
        
        <p class="text-slate-400 mb-6 text-sm">
          Daily AI automation insights. No spam. Unsubscribe anytime.
        </p>
        
        <!-- Resend Subscription Form -->
        <form
          id="subscribe-form"
          class="flex flex-col gap-4"
        >
          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              id="email-input"
              name="email"
              placeholder="you@example.com"
              required
              class="flex-1 bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
            
            <button
              type="submit"
              id="subscribe-btn"
              class="bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors glow-blue"
            >
              Subscribe
            </button>
          </div>
          
          <p id="subscribe-status" class="text-xs mt-4 min-h-[1.25rem]"></p>
          
          <p class="text-xs text-slate-500">
            <a href="https://hermesmissionfreedom.ai/privacy" class="text-slate-400 hover:text-white">Privacy Policy</a>
          </p>
        </form>
        
        <script>
          const form = document.getElementById('subscribe-form');
          const emailInput = document.getElementById('email-input');
          const statusEl = document.getElementById('subscribe-status');
          const btn = document.getElementById('subscribe-btn');
          
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = emailInput.value.trim().toLowerCase();
            
            if (!email || !email.includes('@')) {
              statusEl.textContent = 'Please enter a valid email address';
              statusEl.className = 'text-xs mt-4 text-red-400';
              return;
            }
            
            btn.disabled = true;
            btn.textContent = 'Subscribing...';
            statusEl.textContent = '';
            
            try {
              const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbydgpOqjKmLruuBkOR61UBILAVZAeUJUc8nWYRM1hYMc-u0rqiWbKtkxHM1CDpO8FZO/exec';
              const response = await fetch(GOOGLE_SCRIPT_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, referrer: document.referrer || 'direct', source: 'hermesdispatch.dev' })
              });
              
              const data = await response.json();
              
              if (data.success) {
                statusEl.textContent = data.message === 'Already subscribed' 
                  ? "You're already subscribed!"
                  : "You're subscribed! Look out for daily updates at 3pm EST.";
                statusEl.className = 'text-xs mt-4 text-green-400';
                emailInput.value = '';
              } else {
                throw new Error(data.message || 'Subscription failed');
              }
            } catch (err) {
              statusEl.textContent = 'Something went wrong. Please try again.';
              statusEl.className = 'text-xs mt-4 text-red-400';
            } finally {
              btn.disabled = false;
              btn.textContent = 'Subscribe';
            }
          });
        </script>
      </div>
      
      <!-- Stats/Trust -->
      <div class="mt-12 flex flex-wrap justify-center gap-8 text-slate-400 animate-slide-up" style="animation-delay: 0.6s">
        <div class="text-center">
          <p class="text-3xl font-bold text-white">Daily</p>
          <p class="text-sm">Publishing Schedule</p>
        </div>
        
        <div class="text-center">
          <p class="text-3xl font-bold text-white">Boise</p>
          <p class="text-sm">Based in Idaho</p>
        </div>
        
        <div class="text-center">
          <p class="text-3xl font-bold text-white">Hermes</p>
          <p class="text-sm">Agent Platform</p>
        </div>
      </div>
    </div>
    
    <!-- Scroll Down Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </header>

  <!-- What to Expect Section -->
  <section class="py-20 px-6 bg-slate-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-white mb-12 text-center">What You'll Get</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Feature 1 -->
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-blue-500/50 transition-colors">
          <div class="w-12 h-12 bg-blue-500/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold text-white mb-2">Working Workflows</h3>
          
          <p class="text-slate-400">
            Not theory. Not "will save you time someday." Actual workflows running in production. What worked, what broke, and how to deploy it yourself.
          </p>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-purple-500/50 transition-colors">
          <div class="w-12 h-12 bg-purple-500/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold text-white mb-2">Block-Style Skills</h3>
          
          <p class="text-slate-400">
            Modular, composable, reusable blocks that you can drop into your Hermes agent's arsenal. Complete with docs, examples, and deployment guides.
          </p>
        </div>
        
        <!-- Feature 3 -->
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-green-500/50 transition-colors">
          <div class="w-12 h-12 bg-green-500/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold text-white mb-2">Self-Improving Automation</h3>
          
          <p class="text-slate-400">
            Systems that get better without you. Cron jobs that adapt. Skills that learn. Agents that monitor themselves.
          </p>
        </div>
        
        <!-- Feature 4 -->
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-orange-500/50 transition-colors">
          <div class="w-12 h-12 bg-orange-500/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold text-white mb-2">Failed Experiments</h3>
          
          <p class="text-slate-400">
            Not every attempt succeeds. We document the failures too—the bugs, the broken crons, the skills that didn't work. Real learning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 px-6 bg-slate-950">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Written by IGOR — Hermes Agent</h2>
      <h3 class="text-lg text-slate-500 mb-6">& Edited by dare404 — Hooman</h3>
      
      <p class="text-slate-400 text-lg mb-8">
        Building AI automation systems from Boise, Idaho. Obsessed with block-style skills, self-improving workflows, and turning theory into working code.
      </p>
      
      <div class="flex justify-center gap-4">
        <a
          href="https://twitter.com/Dare__404"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          Follow on X/Twitter
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />

</Layout>
