---
import Layout from '../layouts/Layout.astro';

const skills = [
  { name: 'Hermes Agent', desc: 'Core configuration and extension', tag: 'Core', href: '/skills/hermes-agent' },
  { name: 'Tabby', desc: 'Etsy automation for print-on-demand', tag: 'Ecommerce', href: '/skills/tabby' },
  { name: 'Emailer', desc: 'Reliable email automation system', tag: 'Communication', href: '/skills/emailer' },
  { name: 'Obsidian Logger', desc: 'Universal logging for all agents', tag: 'Infrastructure', href: '/skills/obsidian-logger' },
  { name: 'Orchestrator', desc: 'Multi-agent workflow coordination', tag: 'Orchestration', href: '/skills/orchestrator' },
];

const tools = [
  { name: 'Claude', desc: 'Anthropic AI coding assistant', category: 'AI Model', href: 'https://claude.ai' },
  { name: 'Buttondown', desc: 'Newsletter platform with API', category: 'Marketing', href: 'https://buttondown.email' },
  { name: 'Astro', desc: 'Fast static site generator', category: 'Development', href: 'https://astro.build' },
  { name: 'Printful', desc: 'Print-on-demand fulfillment', category: 'Ecommerce', href: 'https://printful.com' },
];

const features = [
  { title: 'Daily Newsletter', desc: 'Get AI automation insights every day', icon: '📧' },
  { title: 'Free Skills', desc: 'Copy-paste ready Hermes skills', icon: '🛠️' },
  { title: 'Curated Tools', desc: 'AI tools with honest reviews', icon: '🧰' },
  { title: 'Boise First', desc: 'Built from Idaho, for the world', icon: '🌎' },
];
---

<Layout title="Daily AI Automation Insights">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-32">
    <div class="absolute inset-0 dot-pattern opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 mb-6">
          <span class="badge-green">🟢 Live from Boise, Idaho</span>
        </div>
        
        <h1 class="text-4xl sm:text-6xl font-bold mb-6 leading-tight">
          Daily <span class="text-gradient">AI Automation</span> Insights
        </h1>
        
        <p class="text-xl text-neutral-400 mb-8 max-w-2xl">
          The Hermes Dispatch. Real workflows, free skills, and tools that actually work.
          Built in public by Rycen Beans.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="/newsletter" class="btn-primary">
            Get The Newsletter
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="/skills" class="btn-secondary">
            Browse Skills
          </a>
        </div>
        
        <div class="mt-12 flex items-center gap-6 text-sm text-neutral-500">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green-500"></div>
            Daily issues
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green-500"></div>
            Free forever
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green-500"></div>
            No spam
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Features -->
  <section class="py-16 border-y border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {features.map(feature => (
          <div class="text-center sm:text-left">
            <div class="text-3xl mb-3">{feature.icon}</div>
            <h3 class="font-semibold mb-2">{feature.title}</h3>
            <p class="text-sm text-neutral-400">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Skills Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-2xl font-bold mb-2">Latest Skills</h2>
          <p class="text-neutral-400">Ready-to-use Hermes skills for your automations</p>
        </div>
        <a href="/skills" class="btn-secondary text-sm">
          View All
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skills.map(skill => (
          <a href={skill.href} class="card card-glow group">
            <div class="flex items-center justify-between mb-4">
              <span class="badge-orange">{skill.tag}</span>
              <svg class="w-5 h-5 text-neutral-600 group-hover:text-neutral-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
            <h3 class="font-semibold mb-2 group-hover:text-orange-400 transition-colors">{skill.name}</h3>
            <p class="text-sm text-neutral-400">{skill.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Tools Section -->
  <section class="py-20 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-2xl font-bold mb-2">Tools Directory</h2>
          <p class="text-neutral-400">AI tools we actually use, with honest reviews</p>
        </div>
        <a href="/tools" class="btn-secondary text-sm">
          Browse Tools
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {tools.map(tool => (
          <a href={tool.href} target="_blank" rel="noopener noreferrer" class="card group">
            <div class="flex items-start justify-between">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="font-semibold group-hover:text-orange-400 transition-colors">{tool.name}</h3>
                  <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </div>
                <p class="text-sm text-neutral-400 mb-3">{tool.desc}</p>
                <span class="badge text-neutral-400 border-neutral-700">{tool.category}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Newsletter CTA -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card glow text-center">
        <div class="text-4xl mb-4">📧</div>
        <h2 class="text-2xl font-bold mb-4">Get The Hermes Dispatch</h2>
        <p class="text-neutral-400 mb-6 max-w-lg mx-auto">
          Daily AI automation insights, Hermes skills, and workflow breakdowns.
          No fluff. Just what works.
        </p>
        
        <a href="/newsletter" class="btn-primary">
          Subscribe Free
        </a>
      </div>
    </div>
  </section>
</Layout>