---
import Layout from "../../layouts/Layout.astro";
import benchmarkData from "../../data/gpu_benchmarks.json";

const gpus = Object.entries(benchmarkData.gpus).map(([name, d]) => ({ name, ...d }));
const pageTitle = "Find the Right GPU for Your Local LLM | Hermes Dispatch";
const pageDescription = "Pick a model size and budget. We recommend the best GPU or mini PC for running Ollama and vLLM locally.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Find Your <span class="text-brand-gold">Local LLM GPU</span>
      </h1>
      <p class="text-text-secondary text-lg">
        Match a model size + budget to the best hardware we track.
      </p>
    </div>

    <form id="recommender" class="space-y-6 bg-brand-card border border-brand-border rounded-2xl p-6 md:p-8 mb-12">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="model" class="block text-sm font-medium text-gray-300 mb-2">Model size you want to run</label>
          <select id="model" name="model" class="w-full rounded-xl bg-brand-bg border border-brand-border text-white px-4 py-3">
            <option value="llama-3.1-8b">Llama 3.1 8B (fast chat / coding)</option>
            <option value="qwen2.5-7b">Qwen 2.5 7B</option>
            <option value="llama-3.1-70b">Llama 3.1 70B (requires 40+ GB VRAM)</option>
          </select>
        </div>

        <div>
          <label for="budget" class="block text-sm font-medium text-gray-300 mb-2">Budget ceiling (USD)</label>
          <select id="budget" name="budget" class="w-full rounded-xl bg-brand-bg border border-brand-border text-white px-4 py-3">
            <option value="600">$600 — mini PC / used GPU</option>
            <option value="1000">$1,000</option>
            <option value="1600">$1,600 — high-end GPU</option>
            <option value="4000">$4,000 — workstation / Mac Studio</option>
            <option value="999999">No limit</option>
          </select>
        </div>
      </div>

      <div>
        <label class="flex items-center gap-3 text-gray-300">
          <input type="checkbox" id="low-power" class="w-5 h-5 rounded border-brand-border bg-brand-bg text-brand-gold">
          <span>Prefer low power / quiet (mini PC or Apple Silicon)</span>
        </label>
      </div>

      <button type="submit" class="btn-primary w-full">Find hardware →</button>
    </form>

    <div id="results" class="hidden space-y-4">
      <h2 class="text-2xl font-bold text-white mb-4">Top picks for you</h2>
      <div id="cards" class="grid md:grid-cols-2 gap-4"></div>
    </div>
  </main>

  <script define:vars={{ gpus }} type="module">
    const form = document.getElementById('recommender');
    const results = document.getElementById('results');
    const cards = document.getElementById('cards');

    const MSRP = {
      "NVIDIA GeForce RTX 5090": 1999,
      "NVIDIA GeForce RTX 4090": 1599,
      "NVIDIA GeForce RTX 4080": 1199,
      "NVIDIA GeForce RTX 4070 Ti": 799,
      "NVIDIA GeForce RTX 3090": 1499,
      "NVIDIA GeForce RTX 3090 Ti": 1999,
      "Apple Mac Studio M4 Max": 3999,
      "Apple Mac Studio M3 Max": 3999,
      "Apple Mac Studio M2 Ultra": 3999,
      "Geekom A8 (Ryzen 9 8945HS, Radeon 780M)": 599,
      "GMKtec NucBox K8+ (Ryzen 7 8845HS, Radeon 780M)": 459,
    };

    function slugify(name) {
      return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const model = document.getElementById('model').value;
      const budget = parseInt(document.getElementById('budget').value, 10);
      const lowPower = document.getElementById('low-power').checked;

      const minVram = model.includes('70b') ? 40 : 8;
      const scored = gpus.map(g => {
        const price = MSRP[g.name] || 999999;
        const tps = g.ollama_tps?.[model] || 0;
        const fitsBudget = price <= budget;
        const fitsModel = g.vram_gb >= minVram;
        let score = 0;
        // Hard requirement: must fit budget and model
        if (!fitsBudget || !fitsModel) return { ...g, price, tps, fitsBudget, fitsModel, score: -999999 };
        score += 1000;
        score += tps * 10;
        if (lowPower && g.tdp_w <= 100) score += 200;
        return { ...g, price, tps, fitsBudget, fitsModel, score };
      }).sort((a, b) => b.score - a.score);

      const top = scored.slice(0, 3);

      if (top.length === 0 || top[0].score < 0) {
        cards.innerHTML = `
          <div class="col-span-full p-6 rounded-2xl bg-brand-card border border-red-500/30 text-center">
            <h3 class="text-lg font-semibold text-white mb-2">No matches at this budget</h3>
            <p class="text-gray-400">Bump your budget or pick a smaller model. Running ${model} needs at least ${minVram} GB VRAM / unified memory.</p>
          </div>
        `;
      } else {
        cards.innerHTML = top.map(g => `
          <div class="p-6 rounded-2xl bg-brand-card border border-brand-gold/50">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-lg font-semibold text-white">${g.name}</h3>
              <span class="text-brand-gold font-mono">$${g.price}</span>
            </div>
            <div class="text-sm text-gray-400 mb-3">${g.vram_gb} GB ${g.memory_type} • ${g.tdp_w} W • ${g.tps.toFixed(1)} tok/s on ${model}</div>
            ${g.notes ? `<p class="text-sm text-gray-400 mb-3">${g.notes}</p>` : ''}
            <a href={`/go/${slugify(g.name)}?url=${encodeURIComponent(g.source || '')}&source=compare-recommend`} class="inline-flex items-center px-3 py-1.5 rounded-lg bg-brand-gold/10 text-brand-gold text-sm hover:bg-brand-gold/20 transition-colors">See deals →</a>
          </div>
        `).join('');
      }

      results.classList.remove('hidden');
      results.scrollIntoView({ behavior: 'smooth' });
    });
  </script>
</Layout>
