---
import Layout from '../layouts/Layout.astro';

const SUBSCRIBE_EMAIL = 'derekkosakura@gmail.com';
const MAILTO_LINK = `mailto:${SUBSCRIBE_EMAIL}?subject=Subscribe%20to%20The%20Hermes%20Dispatch&body=Please%20subscribe%20me%20to%20the%20Mission%20Freedom%20Dispatch.%0A%0AEmail%3A%20`;
---

<Layout title="The Hermes Dispatch - Daily Newsletter">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-12">
        <div class="text-5xl mb-6">📧</div>
        <h1 class="text-4xl font-bold mb-4">The Hermes Dispatch</h1>
        <p class="text-xl text-neutral-400">Daily AI automation insights from dare404</p>
      </div>
      
      <!-- Subscribe Card -->
      <div class="card glow mb-16">
        <h2 class="text-xl font-semibold mb-4">Subscribe Free</h2>
        <p class="text-neutral-400 mb-6">Get daily automation insights, Hermes skills, and workflow breakdowns delivered to your inbox.</p>
        
        <!-- API-Free Mailto Subscribe -->
        <a 
          href={MAILTO_LINK}
          class="btn-primary inline-block whitespace-nowrap"
        >
          Get The Newsletter
        </a>
        
        <p class="text-sm text-neutral-500 mt-4">
          Or manually: email <code class="bg-neutral-800 px-2 py-1 rounded text-orange-400">{SUBSCRIBE_EMAIL}</code>
          with subject <code class="bg-neutral-800 px-2 py-1 rounded text-orange-400">Subscribe</code>
        </p>
        
        <p class="text-xs text-neutral-600 mt-2">API-free. No external services. Your email client handles it.</p>
      </div>
      
      <!-- What to expect -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <div class="card">
          <div class="text-2xl mb-3">🛠️</div>
          <h3 class="font-semibold mb-2">Real Workflows</h3>
          <p class="text-sm text-neutral-400">Not theory. Actual automations I'm building with Hermes agents.</p>
        </div>
        
        <div class="card">
          <div class="text-2xl mb-3">📦</div>
          <h3 class="font-semibold mb-2">Free Skills</h3>
          <p class="text-sm text-neutral-400">Copy-paste Hermes skills for your own automations.</p>
        </div>
        
        <div class="card">
          <div class="text-2xl mb-3">⚡</div>
          <h3 class="font-semibold mb-2">AI Updates</h3>
          <p class="text-sm text-neutral-400">What changed in Hermes and the AI landscape today.</p>
        </div>
      </div>
      
      <!-- Newsletter Archive -->
      <div class="card">
        <h2 class="text-xl font-semibold mb-4">Latest Issues</h2>
        
        <div class="space-y-4">
          <div class="flex items-center justify-between py-4 border-b border-neutral-800">
            <div>
              <p class="text-sm text-neutral-500">June 6, 2026</p>
              <h3 class="font-medium">DOC-MF-20260606-001: Gemma 4 QAT, Microsoft Scout, HN Quick Bites</h3>
            </div>
            <a href="/newsletter/issue-001" class="text-orange-400 hover:text-orange-300 text-sm">Read →</a>
          </div>
          
          <div class="text-center py-8">
            <p class="text-neutral-500">Archive populates as new issues are approved and sent</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
