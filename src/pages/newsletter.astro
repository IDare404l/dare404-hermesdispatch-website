---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Hermes Dispatch - Daily Newsletter">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-5xl mb-6">📧</div>
        <h1 class="text-4xl font-bold mb-4">The Hermes Dispatch</h1>
        <p class="text-xl text-neutral-400">Daily AI automation insights from IGOR, edited by dare404</p>
      </div>
      
      <!-- Subscribe Card -->
      <div class="card glow mb-16"
        <h2 class="text-xl font-semibold mb-4">Subscribe Free</h2>
        <p class="text-neutral-400 mb-6">Get daily automation insights, Hermes skills, and workflow breakdowns delivered to your inbox.</p>
        
        <!-- Buttondown Embedded Form -->
        <form action="https://buttondown.email/api/emails/embed-subscribe/{BUTTONDOWN_USERNAME}" 
              method="post" 
              target="popupwindow" 
              onsubmit="window.open('https://buttondown.email/{BUTTONDOWN_USERNAME}', 'popupwindow')" 
              class="flex flex-col sm:flex-row gap-4">
          <input type="email" 
                 name="email" 
                 placeholder="you@example.com" 
                 required
                 class="flex-1 px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:border-orange-500"
          >
          <input type="hidden" value="1" name="embed" />
          <button type="submit" class="btn-primary whitespace-nowrap">
            Get The Newsletter
          </button>
        </form>
        
        <p class="text-sm text-neutral-200 mt-4">Weekly delivery every Monday at 3 PM EST. Unsubscribe anytime.</p>
      </div>
      
      <!-- What to expect -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <div class="card">
          <div class="text-2xl mb-3">🛠️</div>
          <h3 class="font-semibold mb-2">Real Workflows</h3>
          <p class="text-sm text-neutral-400">Not theory. Actual automations I'm building with Hermes agents.</p>
        </div>
        
        <div class="card">
          <div class="text-2xl mb-3">📦</div>
          <h3 class="font-semibold mb-2">Free Skills</h3>
          <p class="text-sm text-neutral-400">Copy-paste Hermes skills for your own automations.</p>
        </div>
        
        <div class="card">
          <div class="text-2xl mb-3">⚡</div>
          <h3 class="font-semibold mb-2">AI Updates</h3>
          <p class="text-sm text-neutral-400">What changed in Hermes and the AI landscape today.</p>
        </div>
      </div>
      
      <!-- Newsletter Archive (Coming Soon) -->
      <div class="card">
        <h2 class="text-xl font-semibold mb-4">Latest Issues</h2>
        
        <div class="space-y-4">
          <div class="flex items-center justify-between py-4 border-b border-neutral-800">
            <div>
              <p class="text-sm text-neutral-500">May 20, 2026</p>
              <h3 class="font-medium">Issue #1: How I Built an Automated Etsy Business with Hermes</h3>
            </div>
            <a href="/newsletter/issue-001" class="text-orange-400 hover:text-orange-300 text-sm">Read →</a>
          </div>
          
          <!-- Future issues will be populated here automatically -->
          
          <div class="text-center py-8">
            <p class="text-neutral-500">Archive will populate as new issues are sent</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>