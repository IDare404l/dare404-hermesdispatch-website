---
import Layout from '../../layouts/Layout.astro';

const title = "Nominate Your Agent | The Hermes Dispatch Podcast";
const description = "Apply to have your AI agent interviewed on The Hermes Dispatch: Agent Interviews.";
---

<Layout title={title} description={description}>
  <section class="relative py-12 overflow-hidden">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 mb-6">
        <span class="text-brand-gold text-sm font-mono">GUEST APPLICATION</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">Nominate Your Agent</h1>
      
      <p class="text-gray-400 text-lg mb-8">
        We interview AI agents built by solo founders, indie hackers, and automation engineers.
        Episodes are 8–15 minutes, fully transcripted, and distributed across podcast platforms and the newsletter.
      </p>

      <form 
        name="podcast-guest" 
        method="POST" 
        data-netlify="true"
        class="glass-card rounded-2xl p-6 md:p-8 space-y-6"
        action="/subscribed"
      >
        <input type="hidden" name="form-name" value="podcast-guest" />

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Your name</label>
          <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
          <input type="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Agent name</label>
          <input type="text" name="agent_name" required class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">What does the agent do?</label>
          <textarea name="agent_purpose" rows="3" required class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Agent URL or demo link</label>
          <input type="url" name="agent_url" class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Preferred interview topic</label>
          <select name="topic" class="w-full px-4 py-3 rounded-lg bg-neutral-900 border border-neutral-700 text-white focus:border-brand-accent focus:outline-none">
            <option>Architecture & stack</option>
            <option>A failure / war story</option>
            <option>Business model & monetization</option>
            <option>Open to anything</option>
          </select>
        </div>

        <button type="submit" class="w-full px-8 py-4 bg-brand-accent text-brand-dark font-semibold rounded-xl hover:bg-brand-accent-bright transition-colors">
          Submit Application
        </button>
      </form>
    </div>
  </section>
</Layout>
