---
import Layout from '../layouts/Layout.astro';
import { reviews, getAggregateRating } from '../data/reviews';

// Get all directory entries
const entries = await Astro.glob('../content/directory/*.md');

const products = entries.map(e => ({
  ...e.frontmatter,
  slug: e.frontmatter.name?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || '',
  Content: e.Content
}));

const title = "Reviews | The Hermes Dispatch";
const description = "Community reviews for AI hardware, crypto mining rigs, and trading tools curated by The Hermes Dispatch.";

const aggregateSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directory Reviews",
  "description": description,
  "itemListElement": products.filter(p => getAggregateRating(p.slug)).map((p, i) => {
    const agg = getAggregateRating(p.slug)!;
    return {
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.name,
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": agg.ratingValue,
          "reviewCount": agg.reviewCount
        }
      }
    };
  })
};
---

<Layout title={title} description={description}>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(aggregateSchema)} />

  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="display-heading mb-4">
        Community <span class="text-gradient">Reviews</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Curated community reviews for AI hardware, mining rigs, and trading tools.
      </p>
    </div>
  </section>

  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        {products.filter(p => getAggregateRating(p.slug)).map(p => {
          const agg = getAggregateRating(p.slug)!;
          const productReviews = reviews.filter(r => r.productSlug === p.slug);
          return (
            <article id={p.slug} class="glass-card rounded-2xl p-8">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
                <div>
                  <h2 class="text-2xl font-bold text-white">{p.name}</h2>
                  <p class="text-gray-500">{p.verdict}</p>
                </div>
                <div class="text-right">
                  <div class="text-3xl font-bold text-brand-gold">{agg.ratingValue}</div>
                  <div class="text-sm text-gray-500">{agg.reviewCount} review{agg.reviewCount !== 1 ? 's' : ''}</div>
                </div>
              </div>

              <div class="space-y-4">
                {productReviews.map(r => (
                  <div class="border-t border-neutral-800 pt-4">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-brand-gold">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</span>
                      <span class="text-sm text-gray-500">{r.author} • {r.date}{r.verified ? ' • Verified' : ''}</span>
                    </div>
                    <h3 class="font-semibold text-white mb-1">{r.title}</h3>
                    <p class="text-gray-400 text-sm">{r.body}</p>
                  </div>
                ))}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

</Layout>
