---
import Layout from '../layouts/Layout.astro';
import { agents, agentDetails, skillCategories } from '../data/agents-new';
---

<Layout 
  title="AI Agents | Mission Freedom - Multi-Agent Orchestration"
  description="Meet the 7 AI agents powering Mission Freedom. Specialized AI agent skills for orchestration, security, content, social media, development, and e-commerce.">
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-brand-cyan/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-cyan/10 border border-brand-cyan/30 text-brand-cyan text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        7 Active Agents
      </span>
      
      <h1 class="display-heading mb-6">
        Meet the <br/>
        <span class="text-gradient-cool">Agents</span>
      </h1>
      
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        7 specialized AI agents working together under <span class="text-brand-cyan">IGOR's</span> orchestration.
        Multi-agent orchestration at work.
      </p>
    </div>
  </section>
  
  <!-- IGOR Section -->
  <section class="relative py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card rounded-3xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-4xl shadow-lg shadow-cyan-500/30">
                🤖
              </div>
              <div>
                <h2 class="text-3xl font-bold text-white">IGOR</h2>
                <span class="text-cyan-400">The Orchestrator</span>
              </div>
              <span class="ml-auto status-badge status-active"><span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>Active</span>
            </div>
            
            <p class="text-gray-400 text-lg mb-6">
              IGOR is the Universal Command Router at the heart of Mission Freedom. Every request flows through IGOR first, 
              which routes tasks to specialist agents, validates outputs, and manages tool access.
            </p>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                <h4 class="text-cyan-400 font-semibold mb-1">Task Routing</h4>
                <p class="text-gray-400 text-sm">Analyzes requests and assigns to best-fit agent</p>
              </div>
              <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                <h4 class="text-cyan-400 font-semibold mb-1">Output Validation</h4>
                <p class="text-gray-400 text-sm">Checks quality before delivery</p>
              </div>
              <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                <h4 class="text-cyan-400 font-semibold mb-1">Tool Management</h4>
                <p class="text-gray-400 text-sm">Controls access to APIs and services</p>
              </div>
              <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                <h4 class="text-cyan-400 font-semibold mb-1">Learning Coordination</h4>
                <p class="text-gray-400 text-sm">Manages continuous improvement</p>
              </div>
            </div>
          </div>
          
          <!-- Architecture Visual -->
          <div class="relative">
            <div class="aspect-square rounded-2xl bg-gradient-to-br from-brand-card to-black/50 border border-brand-border p-8 flex items-center justify-center">
              <!-- Center -->
              <div class="relative w-48 h-48">
                <!-- Orbit rings -->
                <div class="absolute inset-0 border border-cyan-500/20 rounded-full animate-pulse-slow"></div>
                <div class="absolute -inset-4 border border-cyan-500/10 rounded-full"></div>
                <div class="absolute -inset-8 border border-cyan-500/5 rounded-full"></div>
                
                <!-- Center node -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-3xl shadow-lg shadow-cyan-500/30">
                    🤖
                  </div>
                </div>
                
                <!-- Orbiting agents -->
                {[
                  { emoji: '🎓', color: 'text-emerald-400', delay: '0s' },
                  { emoji: '✉️', color: 'text-amber-400', delay: '2s' },
                  { emoji: '📱', color: 'text-sky-400', delay: '4s' },
                  { emoji: '🌐', color: 'text-purple-400', delay: '6s' },
                  { emoji: '🎨', color: 'text-rose-400', delay: '8s' },
                  { emoji: '🛡️', color: 'text-slate-400', delay: '10s' }
                ].map((agent) => (
                  <div class="absolute inset-0 animate-spin-slow" style={`animation-delay: ${agent.delay}`}>
                    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                      <div class="w-10 h-10 rounded-xl bg-brand-card border border-white/10 flex items-center justify-center text-xl shadow-lg">
                        {agent.emoji}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTERACTIVE SKILL DIAGRAM - MERGED FROM SKILLS PAGE -->
  <section class="relative py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-gold/10 border border-brand-gold/30 text-brand-gold text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          Interactive Skill Diagram
        </span>
        
        <h2 class="section-heading text-white mb-4">
          Modular <span class="text-gradient">Skills Ecosystem</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Click any skill to explore its capabilities. Each modular skill represents 
          specialized AI capabilities that can be orchestrated together.
        </p>
        
        <!-- Search -->
        <div class="max-w-md mx-auto mt-8">
          <div class="relative">
            <svg class="w-5 h-5 text-gray-500 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
              type="text" 
              id="skillSearch"
              placeholder="Search skills..."
              class="w-full pl-12 pr-4 py-3 bg-brand-card border border-brand-border rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-brand-gold transition-colors"
            >
          </div>
        </div>
      </div>

      <!-- SKILL DIAGRAM - Interactive Cards -->
      <div class="grid lg:grid-cols-2 xl:grid-cols-4 gap-6" id="skillsDiagram">
        {skillCategories.map((category, catIndex) => (
          <div class="skill-category-group" data-category={category.name.toLowerCase()}>
            <div class="flex items-center gap-3 mb-4">
              <div class={`w-3 h-3 rounded-full bg-${category.color}-400`}></div>
              <h3 class="text-lg font-bold text-white">{category.name}</h3>
              <span class="ml-auto text-xs text-gray-500">{category.skills.length}</span>
            </div>
            
            <div class="space-y-3">
              {category.skills.map((skill, skillIndex) => (
                <div class="skill-node group"
                  data-skill={skill.name.toLowerCase()}
                  data-category={category.name.toLowerCase()}
                  data-agents={JSON.stringify(skill.agents)}
                  style={`--delay: ${(catIndex * 0.1) + (skillIndex * 0.05)}s;`}
                >
                  <div class={`p-4 rounded-xl bg-brand-card border border-white/10 hover:border-${category.color}-400/50 hover:bg-white/5 transition-all cursor-pointer relative overflow-hidden`}>
                    <!-- Glow effect on hover -->
                    <div class={`absolute inset-0 bg-${category.color}-500/5 opacity-0 group-hover:opacity-100 transition-opacity`}></div>
                    
                    <div class="relative z-10">
                      <div class="flex items-start gap-3">
                        <div class={`w-10 h-10 rounded-lg bg-${category.color}-500/10 border border-${category.color}-500/30 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform`}>
                          <svg class={`w-5 h-5 text-${category.color}-400`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <Fragment set:html={skill.icon} />
                          </svg>
                        </div>
                        
                        <div class="flex-1 min-w-0">
                          <h4 class="font-semibold text-white group-hover:text-brand-gold transition-colors text-sm">{skill.name}</h4>
                          <p class="text-gray-400 text-xs mt-1 line-clamp-2">{skill.description}</p>
                          
                          <div class="flex flex-wrap gap-1 mt-2">
                            {skill.agents.slice(0, 2).map((agent) => (
                              <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-gray-400">{agent}</span>
                            ))}
                            {skill.agents.length > 2 && (
                              <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-gray-400">+{skill.agents.length - 2}</span>
                            )}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONNECTIONS VISUALIZATION -->
  <section class="relative py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card rounded-3xl p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-brand-purple/5 rounded-full blur-3xl"></div>
        
        <div class="relative z-10">
          <h3 class="text-center text-2xl font-bold text-white mb-8">
            Agent <span class="text-gradient-cool">Collaboration Flow</span>
          </h3>
          
          <div class="grid md:grid-cols-3 gap-4">
            {[
              { 
                from: '✉️', 
                name: 'Newsletter Writer', 
                to: ['🌐', '📱'], 
                action: 'Generates content → Website + Social'
              },
              { 
                from: '🎨', 
                name: 'POD Manager', 
                to: ['📱', '🌐'], 
                action: 'Design trends → Social + Landing pages'
              },
              { 
                from: '🛡️', 
                name: 'SENTINEL', 
                to: ['🤖', '🎓'], 
                action: 'Security audits → IGOR + EDUCATOR'
              }
            ].map((flow) => (
              <div class="p-4 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                <div class="flex items-center justify-center gap-2 mb-3">
                  <span class="text-2xl">{flow.from}</span>
                  <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                  <div class="flex gap-1">
                    {flow.to.map((emoji) => (
                      <span class="text-xl">{emoji}</span>
                    ))}
                  </div>
                </div>
                <div class="text-center">
                  <span class="text-brand-gold text-sm font-medium">{flow.name}</span>
                  <p class="text-gray-400 text-xs mt-1">{flow.action}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Agent Grid (Condensed) -->
  <section class="relative py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-white">
          Specialist <span class="text-gradient">Agents</span>
        </h2>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {agentDetails.slice(1).map((agent) => (
          <div class="glass-card rounded-2xl p-6 hover-lift group relative overflow-hidden">
            <div class={`absolute top-0 right-0 w-32 h-32 bg-${agent.color}-500/10 rounded-full blur-xl`}></div>
            
            <div class="relative z-10">
              <div class="flex items-start justify-between mb-4">
                <div class={`w-14 h-14 rounded-2xl bg-${agent.color}-500/20 border-2 border-${agent.color}-400 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform`}>
                  {agent.emoji}
                </div>
                
                <span class={`status-badge ${agent.status === 'active' ? 'status-active' : agent.status === 'learning' ? 'status-learning' : 'status-planning'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${agent.status === 'active' ? 'bg-emerald-400' : agent.status === 'learning' ? 'bg-amber-400' : 'bg-blue-400'}`}></span>
                  {agent.status}
                </span>
              </div>
              
              <h3 class="text-xl font-bold text-white mb-1">{agent.name}</h3>
              <span class={`text-${agent.color}-400 text-sm font-medium`}>{agent.role}</span>
              
              <p class="text-gray-400 text-sm mt-3 mb-4">{agent.description}</p>
              
              <div class="flex flex-wrap gap-2">
                {agent.skills.slice(0, 3).map((skill) => (
                  <span class={`px-2 py-1 rounded bg-${agent.color}-500/10 text-${agent.color}-300 text-xs`}>
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SKILL MODAL -->
  <div id="skillModal" class="modal-overlay">
    <div class="modal max-w-lg">
      <div class="modal-header">
        <div class="flex items-center gap-3">
          <div id="modalIcon" class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"></div>
          <div>
            <h3 id="modalTitle" class="text-xl font-bold text-white"></h3>
            <p id="modalCategory" class="text-sm text-gray-400"></p>
          </div>
        </div>
        <button class="modal-close" onclick="closeModal()">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="modal-body">
        <p id="modalDescription" class="text-gray-400 mb-6"></p>
        
        <h4 class="text-sm font-semibold text-white mb-3">Used By Agents:</h4>
        <div id="modalAgents" class="flex flex-wrap gap-2 mb-6"></div>
        
        <!-- Related Skills Preview -->
        <h4 class="text-sm font-semibold text-white mb-3">Related in Category:</h4>
        <div id="modalRelated" class="space-y-2"></div>
      </div>
      
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closeModal()">Close</button>
        <button class="btn-primary" id="runSkillBtn">View Documentation</button>
      </div>
    </div>
  </div>

  <style>
    /* Modal Styles */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .modal-overlay.active {
      display: flex;
    }

    .modal {
      background: #12121a;
      border: 1px solid #2a2a3a;
      border-radius: 24px;
      width: 100%;
      max-height: 80vh;
      overflow-y: auto;
      animation: modalIn 0.3s ease;
    }

    @keyframes modalIn {
      from {
        opacity: 0;
        transform: scale(0.95) translateY(20px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }

    .modal-header {
      padding: 1.5rem;
      border-bottom: 1px solid #2a2a3a;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-close {
      background: none;
      border: none;
      color: #8a8a9a;
      cursor: pointer;
      padding: 0.5rem;
      line-height: 1;
      transition: color 0.2s;
    }

    .modal-close:hover {
      color: #fff;
    }

    .modal-body {
      padding: 1.5rem;
    }

    .modal-footer {
      padding: 1rem 1.5rem 1.5rem;
      display: flex;
      gap: 1rem;
    }

    .btn-primary, .btn-secondary {
      flex: 1;
      padding: 0.75rem 1rem;
      border-radius: 12px;
      font-weight: 500;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }

    .btn-primary {
      background: #6366f1;
      color: white;
    }

    .btn-primary:hover {
      background: #818cf8;
    }

    .btn-secondary {
      background: transparent;
      color: #e8e8f0;
      border: 1px solid #2a2a3a;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: #6366f1;
    }

    /* Skill node animations */
    .skill-node {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 0.5s ease forwards;
      animation-delay: var(--delay);
    }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Line clamp */
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <script>
    // Skill search functionality
    const searchInput = document.getElementById('skillSearch');
    const skillNodes = document.querySelectorAll('.skill-node');
    const categoryGroups = document.querySelectorAll('.skill-category-group');

    // Store all skill data for modal
    const skillsData = {};
    
    skillNodes.forEach(node => {
      const name = node.querySelector('h4').textContent;
      const desc = node.querySelector('p').textContent;
      const category = node.dataset.category;
      const agents = JSON.parse(node.dataset.agents || '[]');
      const color = node.querySelector('svg').classList[0]?.replace('text-', '').replace('-400', '') || 'brand';
      
      skillsData[node.dataset.skill] = { name, desc, category, agents, color };
    });

    // Search
    searchInput?.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      
      skillNodes.forEach(node => {
        const skillName = node.dataset.skill;
        const skillData = skillsData[skillName];
        const matches = skillName?.includes(term) || 
                       skillData?.name.toLowerCase().includes(term) ||
                       skillData?.desc.toLowerCase().includes(term);
        
        if (matches) {
          node.style.display = 'block';
        } else {
          node.style.display = 'none';
        }
      });
      
      // Hide empty categories
      categoryGroups.forEach(group => {
        const visibleNodes = group.querySelectorAll('.skill-node[style*="block"], .skill-node:not([style*="none"])');
        group.style.display = visibleNodes.length ? 'block' : 'none';
      });
    });

    // Modal functionality
    const modal = document.getElementById('skillModal');
    
    skillNodes.forEach(node => {
      node.addEventListener('click', () => {
        const skillName = node.dataset.skill;
        const data = skillsData[skillName];
        if (!data) return;
        
        document.getElementById('modalTitle').textContent = data.name;
        document.getElementById('modalCategory').textContent = data.category;
        document.getElementById('modalDescription').textContent = data.desc;
        
        // Set icon color
        const iconDiv = document.getElementById('modalIcon');
        iconDiv.className = `w-10 h-10 rounded-xl bg-${data.color}-500/20 border border-${data.color}-400 flex items-center justify-center text-xl`;
        iconDiv.innerHTML = node.querySelector('.w-10')?.innerHTML || '⚡';
        
        // Set agents
        const agentsDiv = document.getElementById('modalAgents');
        agentsDiv.innerHTML = data.agents.map(agent => 
          `<span class="px-3 py-1 rounded-full bg-white/5 text-brand-gold text-sm border border-white/10">${agent}</span>`
        ).join('');
        
        // Find related skills
        const related = Object.values(skillsData).filter(s => 
          s.category === data.category && s.name !== data.name
        ).slice(0, 3);
        
        const relatedDiv = document.getElementById('modalRelated');
        relatedDiv.innerHTML = related.map(s => 
          `<div class="p-2 rounded bg-white/5 border border-white/5 text-sm text-gray-400">${s.name}</div>`
        ).join('') || '<p class="text-gray-500 text-sm">No related skills</p>';
        
        modal.classList.add('active');
      });
    });

    function closeModal() {
      modal.classList.remove('active');
    }

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Close on overlay click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  </script>
</Layout>
