---
import Layout from '../layouts/Layout.astro';

// Get all directory entries
const entries = await Astro.glob('../content/directory/*.md');

const allFaqs = entries.flatMap(e =>
  (e.frontmatter.faq_schema || []).map((f: any) => ({
    name: e.frontmatter.name,
    slug: e.frontmatter.name?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
    category: e.frontmatter.category,
    verdict: e.frontmatter.verdict,
    question: f.question,
    answer: f.answer
  }))
);

const title = "Answers | The Hermes Dispatch";
const description = "Concise answers about AI hardware, crypto mining rigs, and autonomous trading tools. Built to be cited by AI agents.";

// FAQPage schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": title,
  "description": description,
  "mainEntity": allFaqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="display-heading mb-6">
        Agent <span class="text-gradient">Answers</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Concise, citable answers pulled directly from our directory of AI hardware, mining rigs, and trading tools.
      </p>
    </div>
  </section>

  <!-- FAQ List -->
  <section class="relative py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="mb-8">
        <span class="text-sm text-gray-500">{allFaqs.length} answers across {entries.length} products</span>
      </div>

      <div class="space-y-6">
        {allFaqs.map((faq) => (
          <article class="glass-card rounded-2xl p-6 hover:border-brand-gold/30 transition-all">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-mono px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent border border-brand-accent/20">
                {faq.category?.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) || 'Directory'}
              </span>
              <a href={`/directory#${faq.slug}`} class="text-xs text-gray-500 hover:text-brand-gold transition">
                {faq.name}
              </a>
            </div>
            
            <h2 class="text-xl font-bold text-white mb-3">{faq.question}</h2>
            
            <p class="text-gray-400 leading-relaxed mb-4">{faq.answer}</p>
            
            {faq.verdict && (
              <div class="p-4 rounded-xl bg-brand-gold/5 border border-brand-gold/20">
                <p class="text-sm text-gray-400">
                  <strong class="text-brand-gold">Verdict:</strong> {faq.verdict}
                </p>
              </div>
            )}
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <p class="text-gray-400 mb-4">Want the full directory with benchmarks and affiliate links?</p>
        <a href="/directory" class="inline-block px-6 py-3 bg-brand-gold text-neutral-950 rounded-lg font-semibold hover:bg-brand-amber transition">
          Browse the Directory →
        </a>
      </div>
    </div>
  </section>
</Layout>