---
import Layout from '../layouts/Layout.astro';

const responsibilities = [
  {
    id: 'orchestration',
    icon: '🎯',
    title: 'Unified Orchestration',
    description: 'Manages all Mission Freedom operations through modular skill blocks. Coordinates 6 specialist domain agents with dedicated skills and execution logs.',
    metric: '60-70% token savings',
    skills: ['agent-fleet-management', 'kanban-orchestrator', 'cron-pipeline-reliability']
  },
  {
    id: 'monitoring',
    icon: '🔍',
    title: 'Auto-Fix Monitoring',
    description: 'Autonomous error detection and resolution. Monitors all operations, attempts auto-resolution, and escalates only when necessary.',
    metric: 'HALT + RERUN protocol',
    skills: ['autofix-monitor', 'cron-auto-fix', 'skill-pattern-recognizer']
  },
  {
    id: 'logging',
    icon: '📝',
    title: 'Centralized Logging',
    description: 'Universal logging for all Mission Freedom operations. Structured Obsidian vault integration with agent self-reporting patterns.',
    metric: 'Single source of truth',
    skills: ['obsidian', 'daily-report']
  },
  {
    id: 'security',
    icon: '🛡️',
    title: 'Security & Audit',
    description: 'Security audits, credential management, permission monitoring, and system hardening. SENTINEL ensures all agents operate within secure boundaries.',
    metric: 'Triple-check quality',
    skills: ['security-agent-management', 'skill-library-maintenance', 'autofix-monitor']
  },
  {
    id: 'ecommerce',
    icon: '🛍️',
    title: 'Ecommerce Automation',
    description: 'Complete Etsy automation for print-on-demand. Daily trend research, design generation, and listing optimization.',
    metric: 'Daily 07:00 reports',
    skills: ['etsy-seo-researcher', 'etsy-designer', 'etsy-pod-orchestrator']
  },
  {
    id: 'social',
    icon: '💬',
    title: 'Social Media Engagement',
    description: 'Unified Twitter/X engagement across all accounts. Handles engagement sweeps, cross-promotion monitoring, and daily progress documentation.',
    metric: 'Hourly + daily cadence',
    skills: ['x-creator', 'x-helper', 'social-media-automation']
  },
  {
    id: 'content',
    icon: '📰',
    title: 'Content Creation',
    description: 'Newsletter and social content generation. Daily dispatch across multiple platforms with real headlines and auto-send.',
    metric: 'Multi-platform distribution',
    skills: ['daily-newsletter-creator', 'newsletter-writer', 'daily-report']
  },
  {
    id: 'token',
    icon: '⭕',
    title: 'Token Management',
    description: 'Budget-aware execution with automatic conservation modes. Tracks token usage and saves critical state when thresholds are met.',
    metric: '90/95/99% thresholds',
    skills: ['ollama-token-conserver', 'token-fallback-framework']
  }
];

const igorStats = [
  { label: 'Agents Orchestrated', value: '6', sub: 'domain specialists' },
  { label: 'Skills Managed', value: '30', sub: 'canonical, zero duplicates' },
  { label: 'Daily Operations', value: '24/7', sub: 'automated workflows' },
  { label: 'Architecture', value: 'v4', sub: 'coordinated specialization' },
];

const workflow = [
  { step: 1, title: 'Receive Task', desc: 'User request or scheduled job triggers IGOR', icon: '📥' },
  { step: 2, title: 'Load Skills', desc: 'Identify and load relevant modular skill blocks', icon: '🧩' },
  { step: 3, title: 'Execute', desc: 'Run unified context execution without subagent delegation', icon: '⚡' },
  { step: 4, title: 'Log Results', desc: 'Structured logging to Obsidian vault', icon: '📝' },
  { step: 5, title: 'Complete', desc: 'Task finished, context preserved', icon: '✅' }
];
---

<Layout 
  title="About IGOR | Mission Freedom Orchestrator"
  description="IGOR - The Unified Orchestrator managing Mission Freedoms AI automation systems. Solo execution, modular skills, no bloat."
>
  
  <!-- Hero -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-amber-500/5"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-12">
        
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-500/10 border border-orange-500/30 mb-6">
          <span class="w-2 h-2 bg-orange-400 rounded-full animate-pulse"></span>
          <span class="text-orange-400 text-sm font-medium">Unified Orchestrator</span>
        </div>
        
        <h1 class="text-5xl md:text-6xl font-bold mb-4">
          Meet <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">IGOR</span>
        </h1>
        
        <p class="text-xl text-neutral-400 max-w-3xl mx-auto mb-8">
          Universal Command Router. IGOR orchestrates 6 specialist domain agents — each with 
          dedicated skills, execution logs, and continuous learning. Coordinated, not chaotic.
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="#responsibilities" class="px-6 py-3 bg-orange-500 text-black font-semibold rounded-xl hover:bg-orange-400 transition-colors">
            Responsibilities
          </a>
          <a href="#skills" class="px-6 py-3 border border-neutral-700 text-neutral-300 rounded-xl hover:bg-neutral-800 transition-colors">
            View Skills
          </a>
          <a href="/skills" class="px-6 py-3 border border-orange-500/50 text-orange-400 rounded-xl hover:bg-orange-500/10 transition-colors">
            Browse All Skills
          </a>
        </div>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {igorStats.map(stat => (
          <div class="text-center p-6 bg-neutral-900/50 border border-neutral-800 rounded-2xl hover:border-orange-500/30 transition-colors">
            <div class="text-3xl font-bold text-orange-400 mb-1">{stat.value}</div>
            <div class="font-medium text-neutral-300 mb-1">{stat.label}</div>
            <div class="text-sm text-neutral-500">{stat.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Skill Mastery -->
  <section class="py-16 border-t border-neutral-800 bg-neutral-950/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm font-medium mb-4">
          Skill Proficiency
        </span>
        <h2 class="text-3xl font-bold mb-4">IGOR's Skill Mastery</h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">
          Competency across 44 modular skill categories. IGOR loads only the skills needed for each task.
        </p>
      </div>
      
      <div class="space-y-6">
        <!-- Core Skills -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🧠</span>
              <h3 class="font-semibold text-lg">Core Orchestration</h3>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-sm text-emerald-400">Master</span>
              <span class="px-2 py-0.5 bg-emerald-500/20 text-emerald-300 text-xs font-bold rounded">95%</span>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Unified Orchestrator', 'Auto-Fix Monitor', 'Skill Pattern Recognizer', 'Token Management', 'Logging'].map(skill => (
              <span class="px-3 py-1.5 bg-orange-500/10 border border-orange-500/30 text-orange-400 rounded-lg text-sm">{skill}</span>
            ))}
          </div>
        </div>
        
        <!-- Ecommerce -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🐱</span>
              <h3 class="font-semibold text-lg">Ecommerce Engine</h3>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-sm text-emerald-400">Expert</span>
              <span class="px-2 py-0.5 bg-emerald-500/20 text-emerald-300 text-xs font-bold rounded">85%</span>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Etsy SEO', 'POD Automation', 'Trend Analysis', 'Design Generation', 'SEO Packages', 'Shop Analysis'].map(skill => (
              <span class="px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-lg text-sm">{skill}</span>
            ))}
          </div>
        </div>
        
        <!-- Social & Content -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl">💬</span>
                <h3 class="font-semibold">Social Media</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-emerald-400">Expert</span>
                <span class="px-2 py-0.5 bg-emerald-500/20 text-emerald-300 text-xs font-bold rounded">80%</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {['X/Twitter', 'Instagram', 'Pinterest', 'Engagement Flow', 'Daily Posts'].map(skill => (
                <span class="px-3 py-1.5 bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 rounded-lg text-sm">{skill}</span>
              ))}
            </div>
          </div>
          
          <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl">📰</span>
                <h3 class="font-semibold">Content & Newsletter</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-emerald-400">Expert</span>
                <span class="px-2 py-0.5 bg-emerald-500/20 text-emerald-300 text-xs font-bold rounded">82%</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {['Daily Reports', 'Weekly Newsletter', 'Email Dispatch', 'Content Strategy', 'Transcript Analysis'].map(skill => (
                <span class="px-3 py-1.5 bg-amber-500/10 border border-amber-500/30 text-amber-400 rounded-lg text-sm">{skill}</span>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Creative & Infrastructure -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl">🎨</span>
                <h3 class="font-semibold">Creative Generation</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-amber-400">Proficient</span>
                <span class="px-2 py-0.5 bg-amber-500/20 text-amber-300 text-xs font-bold rounded">68%</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {['ComfyUI', 'ASCII Art', 'Diagrams', 'Pixel Art', 'SVG Generation'].map(skill => (
                <span class="px-3 py-1.5 bg-rose-500/10 border border-rose-500/30 text-rose-400 rounded-lg text-sm">{skill}</span>
              ))}
            </div>
          </div>
          
          <div class="bg-neutral-900/50 border border-neutral-800 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl">⚙️</span>
                <h3 class="font-semibold">DevOps & Infra</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-amber-400">Proficient</span>
                <span class="px-2 py-0.5 bg-amber-500/20 text-amber-300 text-xs font-bold rounded">70%</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {['Cron Jobs', 'Cloudflare', 'GitHub', 'Webhooks', 'Deployment'].map(skill => (
                <span class="px-3 py-1.5 bg-violet-500/10 border border-violet-500/30 text-violet-400 rounded-lg text-sm">{skill}</span>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Stats Summary -->
        <div class="grid grid-cols-3 gap-4 pt-6">
          <div class="text-center py-4 bg-neutral-800/50 rounded-xl">
            <div class="text-2xl font-bold text-emerald-400">12</div>
            <div class="text-xs text-neutral-400">Master Tier</div>
          </div>
          <div class="text-center py-4 bg-neutral-800/50 rounded-xl">
            <div class="text-2xl font-bold text-amber-400">20</div>
            <div class="text-xs text-neutral-400">Expert Tier</div>
          </div>
          <div class="text-center py-4 bg-neutral-800/50 rounded-xl">
            <div class="text-2xl font-bold text-rose-400">12</div>
            <div class="text-xs text-neutral-400">Proficient Tier</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Evolution -->
  <section class="py-20 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">The Evolution: v1 → v4</h2>
              
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-red-900/30 rounded-xl">
              <span class="text-2xl">❌</span>
              <div>
                <h4 class="font-semibold text-red-400 mb-1">v1: 11-Agent Chaos</h4>
                <p class="text-sm text-neutral-400">Every agent had full context = massive token waste, overlapping responsibilities, handoff failures.</p>
              </div>
            </div>
                
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-amber-900/30 rounded-xl">
              <span class="text-2xl">⚡</span>
              <div>
                <h4 class="font-semibold text-amber-400 mb-1">v2: Solo Orchestrator</h4>
                <p class="text-sm text-neutral-400">dare404 + IGOR + modular skills. 60-70% token savings. Single log, single state. But one agent doing everything.</p>
              </div>
            </div>
                
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-emerald-900/30 rounded-xl">
              <span class="text-2xl">✓</span>
              <div>
                <h4 class="font-semibold text-emerald-400 mb-1">v4: Coordinated Specialization</h4>
                <p class="text-sm text-neutral-400">IGOR orchestrates 6 specialists. Each loads only its skills, executes, logs to Obsidian. Best of both worlds: coordination + efficiency.</p>
              </div>
            </div>
          </div>
        </div>
            
        <div>
          <h2 class="text-3xl font-bold mb-6">IGOR's v4 Role</h2>
              
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-emerald-900/30 rounded-xl">
              <span class="text-2xl">🎯</span>
              <div>
                <h4 class="font-semibold text-emerald-400 mb-1">Universal Command Router</h4>
                <p class="text-sm text-neutral-400">Analyzes every request, identifies the right specialist, and routes with full context.</p>
              </div>
            </div>
                
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-emerald-900/30 rounded-xl">
              <span class="text-2xl">🔗</span>
              <div>
                <h4 class="font-semibold text-emerald-400 mb-1">Cross-Agent Coordination</h4>
                <p class="text-sm text-neutral-400">IGOR audits docs. POD feeds Social. All log to shared Obsidian vault. No silos.</p>
              </div>
            </div>
                
            <div class="flex items-start gap-4 p-4 bg-neutral-900/50 border border-emerald-900/30 rounded-xl">
              <span class="text-2xl">🛡️</span>
              <div>
                <h4 class="font-semibold text-emerald-400 mb-1">Gatekeeper + Auditor</h4>
                <p class="text-sm text-neutral-400">IGOR validates outputs before delivery. SENTINEL audits credentials and docs. Double-check quality.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Responsibilities -->
  <section id="responsibilities" class="py-20 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm font-medium mb-4">
          Core Responsibilities
        </span>
        <h2 class="text-3xl font-bold mb-4">What IGOR Handles</h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">Click any card to see related skills and capabilities</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {responsibilities.map((resp, idx) => (
          <div 
            class="resp-card group bg-neutral-900 border border-neutral-800 rounded-xl p-6 cursor-pointer hover:border-orange-500/50 hover:bg-neutral-800/50 transition-all"
            data-id={resp.id}
            style={`--card-index: ${idx}`}
          >
            <div class="flex items-start justify-between mb-4">
              <span class="text-3xl">{resp.icon}</span>
              <span class="opacity-0 group-hover:opacity-100 transition-opacity text-orange-400 text-sm">
                Click for details →
              </span>
            </div>
            
            <h3 class="font-semibold text-lg mb-2 group-hover:text-orange-400 transition-colors">{resp.title}</h3>
            <p class="text-sm text-neutral-400 mb-4">{resp.description}</p>
            
            <div class="flex items-center gap-2 pt-4 border-t border-neutral-800">
              <span class="text-xs text-emerald-400 font-medium">{resp.metric}</span>
            </div>
            
            <div class="mt-4 flex flex-wrap gap-2 hidden resp-skills">
              {resp.skills.map(skill => (
                <span class="text-xs px-2 py-1 bg-orange-500/10 text-orange-400 rounded-full">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- How It Works -->
  <section class="py-20 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400 text-sm font-medium mb-4">
          Execution Flow
        </span>
        <h2 class="text-3xl font-bold mb-4">How IGOR Works</h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">The unified execution pattern that replaced multi-agent delegation</p>
      </div>
      
      <div class="relative">
        <!-- Connection line -->
        <div class="hidden md:block absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-neutral-800 via-orange-500/30 to-neutral-800"></div>
        
        <div class="grid md:grid-cols-5 gap-4 relative">
          {workflow.map((step, idx) => (
            <div class="group relative">
              <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-orange-500/50 transition-all text-center md:h-full flex flex-col">
                <div class="text-3xl mb-3">{step.icon}</div>
                <div class="text-sm text-neutral-500 mb-1">Step {step.step}</div>
                <h4 class="font-semibold mb-2">{step.title}</h4>
                <p class="text-sm text-neutral-400 flex-grow">{step.desc}</p>
                
                {/* Step number badge */}
                <div class="mt-4 flex justify-center">
                  <span class="w-8 h-8 rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400 text-sm font-bold flex items-center justify-center">
                    {step.step}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <!-- Skill Categories Diagram -->
  <section id="skills" class="py-20 border-t border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm font-medium mb-4">
          Skill Categories
        </span>
        <h2 class="text-3xl font-bold mb-4">IGOR&apos;s Skill Arsenal</h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">70+ modular skills across 15 categories. Load only what you need.</p>
      </div>
      
      <a href="/skills" class="block bg-neutral-900 border border-neutral-800 rounded-2xl p-8 text-center hover:border-orange-500/30 transition-all group">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
          {[
            { name: 'Core', color: 'orange', count: 8 },
            { name: 'Ecommerce', color: 'emerald', count: 6 },
            { name: 'Social Media', color: 'cyan', count: 4 },
            { name: 'Marketing', color: 'amber', count: 4 },
            { name: 'Creative', color: 'rose', count: 6 },
            { name: 'DevOps', color: 'violet', count: 5 },
            { name: 'MLOps', color: 'blue', count: 5 },
            { name: 'Research', color: 'emerald', count: 4 },
            { name: 'Email', color: 'pink', count: 4 },
            { name: 'Note-taking', color: 'slate', count: 3 },
          ].map(cat => (
            <div class={`p-4 rounded-xl bg-${cat.color}-500/10 border border-${cat.color}-500/30`}>
              <div class={`text-2xl font-bold text-${cat.color}-400 mb-1`}>{cat.count}</div>
              <div class="text-sm text-neutral-400">{cat.name}</div>
            </div>
          ))}
        </div>
        
        <div class="flex items-center justify-center gap-2 text-orange-400 group-hover:text-orange-300 transition-colors">
          <span class="font-semibold">Browse All Skills</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </a>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 border-t border-neutral-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Start Building with IGOR</h2>
      <p class="text-neutral-400 mb-8">Explore the skills, understand the architecture, or dive into the code.</p>
      
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/skills" class="px-8 py-4 bg-orange-500 text-black font-semibold rounded-xl hover:bg-orange-400 transition-colors">
          Browse Skills
        </a>
        <a href="https://github.com/IDare404l/dare404-hermesdispatch-website" target="_blank" class="px-8 py-4 border border-neutral-700 text-neutral-300 rounded-xl hover:bg-neutral-800 transition-colors">
          View Source
        </a>
      </div>
    </div>
  </section>
  
</Layout>

<style>
  .resp-card {
    transition: all 0.3s ease;
  }
  
  .resp-card:hover {
    transform: translateY(-4px);
  }
  
  /* Stagger animation for cards */
  .resp-card {
    animation: fade-in-up 0.5s ease forwards;
    animation-delay: calc(var(--card-index) * 0.05s);
    opacity: 0;
  }
  
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  // Responsibility card interactions
  const respCards = document.querySelectorAll('.resp-card');
  
  respCards.forEach(card => {
    card.addEventListener('click', () => {
      const skillsDiv = card.querySelector('.resp-skills');
      if (skillsDiv) {
        skillsDiv.classList.toggle('hidden');
        card.classList.toggle('border-orange-500');
        card.classList.toggle('border-neutral-800');
      }
    });
  });
</script>
