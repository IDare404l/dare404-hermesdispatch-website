---
import Layout from '../layouts/Layout.astro';
import ParticleBackground from '../components/ParticleBackground.astro';

const title = "Subscribed | Mission Freedom";
const description = "You're subscribed to Mission Freedom Daily. Welcome to the Dispatch.";
---

<Layout title={title} description={description}>
  <section class="relative pt-32 pb-16 overflow-hidden min-h-screen">
    <div class="absolute inset-0 animated-gradient"></div>
    <div class="grid-overlay"></div>
    <ParticleBackground />
    
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-brand-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="glass-card rounded-3xl p-8 md:p-12 text-center border border-emerald-500/20">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg shadow-emerald-500/30 animate-bounce">
          ✅
        </div>
        
        <h1 class="display-heading text-white mb-4">
          You're <span class="text-emerald-400">In</span>
        </h1>
        
        <p class="text-gray-300 text-lg mb-2">
          Your subscription is confirmed. Welcome to the Dispatch.
        </p>
        
        <p class="text-brand-gold text-base mb-8">
          📬 You'll receive your first edition soon at 3 PM MST.
        </p>
        
        <div class="bg-brand-card rounded-xl p-6 mb-8 text-left">
          <p class="text-sm text-gray-400 mb-3 font-semibold">What you'll receive:</p>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-start gap-3">
              <span class="text-brand-gold text-lg">📦</span>
              <div>
                <p class="font-medium">The Rig</p>
                <p class="text-gray-500">AI hardware benchmarks and deployment guides</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-accent text-lg">⛏️</span>
              <div>
                <p class="font-medium">The Mine</p>
                <p class="text-gray-500">Crypto mining strategies and profitability analysis</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-purple-400 text-lg">💰</span>
              <div>
                <p class="font-medium">The Ledger</p>
                <p class="text-gray-500">Trading tools, finance automation, and market insights</p>
              </div>
            </li>
          </ul>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          <div class="bg-brand-card rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-brand-gold">Daily</p>
            <p class="text-xs text-gray-500">Delivery</p>
          </div>
          <div class="bg-brand-card rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-brand-accent">3 PM</p>
            <p class="text-xs text-gray-500">MST Timezone</p>
          </div>
          <div class="bg-brand-card rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-emerald-400">1-click</p>
            <p class="text-xs text-gray-500">Unsubscribe</p>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn-primary inline-block">
            Back to Home
          </a>
          <a href="/directory/" class="px-6 py-3 border border-brand-border rounded-xl text-gray-400 hover:text-white hover:border-brand-gold transition-colors inline-block">
            Explore Directory →
          </a>
        </div>
        
      </div>
      
    </div>
  </section>
</Layout>
