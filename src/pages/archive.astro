---
import Layout from '../layouts/Layout.astro';
import NewsletterTimeline from '../components/NewsletterTimeline.astro';
---

<Layout 
  title="Newsletter Archive | The Hermes Dispatch"
  description="Past issues of The Hermes Dispatch - AI automation insights from Boise, ID"
>
  <main class="archive-container">
    <header class="archive-header">
      <a href="/" class="back-link">← Back to home</a>
      <h1>Archive</h1>
      <p class="subtitle">Past dispatches from the Mission Freedom journey</p>
    </header>

    <section class="timeline-section">
      <NewsletterTimeline />
    </section>

    <footer class="archive-footer">
      <p>Built with block-style skills in Boise, ID</p>
      <p class="powered-by">Delivered via <a href="https://resend.com" target="_blank">Resend</a></p>
    </footer>
  </main>
</Layout>

<style>
  .archive-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .archive-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #6366f1;
  }

  .archive-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem 0;
    background: linear-gradient(90deg, #fff 0%, #888 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #666;
    font-size: 1.1rem;
    margin: 0;
  }

  .timeline-section {
    margin-bottom: 4rem;
  }

  .archive-footer {
    text-align: center;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .archive-footer p {
    color: #555;
    font-size: 0.85rem;
    margin: 0.25rem 0;
  }

  .powered-by {
    margin-top: 0.5rem;
  }

  .archive-footer a {
    color: #6366f1;
    text-decoration: none;
  }

  .archive-footer a:hover {
    text-decoration: underline;
  }
</style>
