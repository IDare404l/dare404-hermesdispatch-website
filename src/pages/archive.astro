---
import Layout from '../layouts/Layout.astro';
import versionData from '../config/version.json';
---

<Layout title="Archive | Agent Dispatch">
	<main class="container mx-auto px-4 py-8"
		<div class="max-w-4xl mx-auto"
			<!-- Header -->
			<header class="mb-12 text-center"
				<div class="inline-block p-2 bg-accent/10 rounded-full mb-4"
					<span class="text-4xl"
						📮
					</span>
				</div>
				<h1 class="text-4xl md:text-5xl font-bold text-primary mb-4"
					The Archive
				</h1>
				<p class="text-secondary text-lg max-w-2xl mx-auto"
					Every dispatch from the Mission Freedom system. Organized by month, tagged by topic.
				</p>
			</header>

			<!-- Stats -->
			<div class="grid grid-cols-3 gap-4 mb-12"
				<div class="bg-surface p-6 rounded-lg border border-border text-center"
					<span class="text-3xl font-bold text-primary block"1</span>
					<span class="text-sm text-secondary"
						Total Issues
					</span>
				</div
				<div class="bg-surface p-6 rounded-lg border border-border text-center"
					<span class="text-3xl font-bold text-accent block">May</span
					<span class="text-sm text-secondary"
						Current Month
					</span
				</div;
				<div class="bg-surface p-6 rounded-lg border border-border text-center"
					<span class="text-3xl font-bold text-success block">2026</span
					<span class="text-sm text-secondary"
						Since Launch
					</span
				</div>
			</div>

			<!-- Archive -->
			<div class="space-y-8"
				<!-- May 2026 -->
				<section class="bg-surface rounded-lg border border-border p-6"
					<div class="flex items-baseline gap-4 mb-6 border-b border-border pb-4"
						<h2 class="text-2xl font-bold text-primary"
							May 2026
						</h2
						<span class="text-sm text-secondary"
							1 issue
						</span>
					</div

					<div class="grid gap-4"
						<!-- Issue #001 -->
						<a href="/newsletters/issue-001" class="group block p-4 bg-muted/30 rounded-lg border border-border hover:border-accent hover:bg-muted/50 transition-all"
							<div class="flex items-start justify-between gap-4"
								<div
									<span class="text-xs font-mono text-accent"
										Issue #001
									</span
									<h3 class="text-lg font-semibold text-primary group-hover:text-accent transition-colors mt-1"
										A Website Worth Deploying
									</h3
									<div class="flex items-center gap-4 mt-2 text-sm text-secondary"
										<span>
											📅 May 19, 2026
										</span
										<span class="text-muted">•</span
										<span>
											👁 5 min read
										</span>
									</div>
									<p class="text-sm text-secondary mt-3 line-clamp-2"
										We built and deployed our first modular agent visualization system. Not a mockup — a working system where agents can be added, removed, and tracked via JSON files...
									</p>
									<div class="flex gap-2 mt-3"
										<span class="text-xs px-2 py-1 bg-primary/10 text-primary rounded-full"
											deployment
										</span
										<span class="text-xs px-2 py-1 bg-accent/10 text-accent rounded-full"
											visualization
										</span>
										<span class="text-xs px-2 py-1 bg-success/10 text-success rounded-full"
											automation
										</span
									</div>
								</div
								<div class="text-muted group-hover:text-accent transition-colors"
									→
								</div>
							</div>
						</a>
					</div>
				</section>

				<!-- Subscribe CTA -->
				<div class="bg-gradient-to-r from-primary/10 to-accent/10 rounded-lg border border-border p-8 text-center">
					<h3 class="text-xl font-bold text-primary mb-2"
						Get Dispatches in Your Inbox
					</h3
					<p class="text-secondary mb-4"
						Daily insights on AI automation, block-style workflows, and Mission Freedom updates.
					</p
					<a href="/subscribe" class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors"
						Subscribe
					</a>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
