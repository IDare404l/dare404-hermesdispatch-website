---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/llm_fine_tuning_cost.json';

const title = "LLM Fine-Tuning Cost Calculator | Hermes Dispatch";
const description = "Estimate training and hosting cost to fine-tune an LLM across OpenAI, Together AI, Fireworks, Replicate, Google, and local GPU routes.";
const providers = data.providers;
const localGpus = data.local_gpus;
const scenarios = data.scenarios;
const defaults = data.defaults;

const faqs = [
  { q: "What does this calculator estimate?", a: "It estimates the one-time training cost and ongoing usage/hosting cost to fine-tune a large language model on a managed API or a local/cloud GPU." },
  { q: "Which is cheaper: managed API or local GPU?", a: "Managed APIs win for small, infrequent jobs and low monthly usage. Local GPU becomes cheaper when you train repeatedly or serve many requests, but only if utilization is high enough to amortize hardware or rental cost." },
  { q: "Does training output cost apply?", a: "Most providers only charge for training input tokens. We model usage input/output separately after the model is hosted." },
  { q: "How is local GPU cost calculated?", a: "We divide total training tokens by the GPU's estimated training tokens per hour to get rental hours, then multiply by the hourly rental rate. We add electricity only if you select owned hardware; otherwise the cloud hourly rate already covers power." },
  { q: "What about data preparation and labeling?", a: "Those costs are excluded. Use the AI Agent Data Labeling Cost Calculator and Synthetic Data Generator Cost Calculator to budget training data creation." },
  { q: "How do I reduce fine-tuning cost?", a: "Shorten examples, reduce epochs, use a smaller base model, cache repeated context, batch requests, and prefer lower-cost providers like GPT-4o mini or Gemini Flash for narrow tasks." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="LLM Fine-Tuning Cost Calculator" description={description} url="https://hermesdispatch.dev/tools/llm-fine-tuning-cost-calculator/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🎓</div>
      <h1 class="display-heading mb-4">LLM Fine-Tuning Cost Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate training and hosting cost to fine-tune an LLM across managed APIs and local/cloud GPU routes.</p>
    </div>

    <!-- Scenario presets -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario presets</h2>
      <div class="flex flex-wrap gap-3">
        {scenarios.map(s => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)}>
            {s.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Inputs -->
    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Training & usage workload</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <label class="block">
          <span class="text-neutral-400 text-sm">Training examples</span>
          <input id="examples" type="number" min="1" step="100" value={defaults.examples} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Tokens per example</span>
          <input id="tokensPerExample" type="number" min="1" step="10" value={defaults.tokens_per_example} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Epochs</span>
          <input id="epochs" type="number" min="1" max="20" step="1" value={defaults.epochs} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Monthly usage requests</span>
          <input id="monthlyRequests" type="number" min="0" step="1000" value={defaults.monthly_requests} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Usage input tokens / request</span>
          <input id="usageInputTokens" type="number" min="0" step="10" value={defaults.input_tokens_per_request} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Usage output tokens / request</span>
          <input id="usageOutputTokens" type="number" min="0" step="10" value={defaults.output_tokens_per_request} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Managed provider</span>
          <select id="provider" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            {providers.map(p => <option value={JSON.stringify(p)} selected={p.slug === defaults.provider}>{p.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Local GPU route</span>
          <select id="localGpu" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            {localGpus.map(g => <option value={JSON.stringify(g)} selected={g.slug === defaults.local_gpu}>{g.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Electricity rate ($/kWh)</span>
          <input id="electricityRate" type="number" min="0" step="0.01" value={defaults.electricity_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Local GPU utilization (%)</span>
          <input id="utilization" type="number" min="0" max="100" step="5" value={defaults.utilization * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Projection (months)</span>
          <input id="projectionMonths" type="number" min="1" max="120" step="1" value={defaults.projection_months} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
      </div>
      <p class="text-neutral-500 text-sm mt-6">Estimates are directional. Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <!-- Summary cards -->
    <section id="summary" class="grid md:grid-cols-4 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Total training tokens</p>
        <p id="trainingTokens" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Managed training cost</p>
        <p id="managedTrainingCost" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Monthly managed usage</p>
        <p id="managedMonthlyUsage" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">First-period managed total</p>
        <p id="managedPeriodTotal" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
    </section>

    <!-- Secondary metrics -->
    <section class="grid md:grid-cols-3 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Local training cost</p>
        <p id="localTrainingCost" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Local GPU period total</p>
        <p id="localPeriodTotal" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Cheapest managed provider</p>
        <p id="cheapestProvider" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Training hours on local GPU</p>
        <p id="trainingHours" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Cost per 1k usage requests</p>
        <p id="costPer1kRequests" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Break-even vs cheapest managed</p>
        <p id="breakevenMonths" class="text-xl font-semibold text-white">—</p>
      </div>
    </section>

    <!-- Provider comparison -->
    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Managed provider comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[700px]">
          <thead>
            <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
              <th class="py-3 pr-4">Provider</th>
              <th class="py-3 pr-4 text-right">Training cost</th>
              <th class="py-3 pr-4 text-right">Monthly usage</th>
              <th class="py-3 pr-4 text-right">Period total</th>
              <th class="py-3 pr-4">Note</th>
            </tr>
          </thead>
          <tbody id="providerTable" class="text-neutral-200">
            <!-- populated -->
          </tbody>
        </table>
      </div>
    </section>

    <!-- Verdict -->
    <section id="verdict" class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-2 text-brand-gold">Verdict</h2>
      <p id="verdictText" class="text-lg text-neutral-200">—</p>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/agent-api-pricing-comparator/" class="btn-primary text-sm">API Pricing Comparator →</a>
      <a href="/tools/prompt-cache-savings-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Prompt Cache Savings Calc →</a>
      <a href="/tools/local-llm-roi-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Local LLM ROI Calc →</a>
      <a href="/tools/agent-synthetic-data-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Synthetic Data Cost Calc →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ providers: JSON.stringify(providers), localGpus: JSON.stringify(localGpus), scenarios: JSON.stringify(scenarios) }}>
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 3 });
    const fmtMoney2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const fmtMoney0 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtNum = n => n.toLocaleString('en-US', { maximumFractionDigits: 1 });
    const fmtInt = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    function getProvider() { return JSON.parse(document.getElementById('provider').value); }
    function getLocalGpu() { return JSON.parse(document.getElementById('localGpu').value); }

    function getInputs() {
      return {
        examples: Math.max(1, Number(document.getElementById('examples').value) || 1),
        tokensPerExample: Math.max(1, Number(document.getElementById('tokensPerExample').value) || 1),
        epochs: Math.max(1, Number(document.getElementById('epochs').value) || 1),
        monthlyRequests: Math.max(0, Number(document.getElementById('monthlyRequests').value) || 0),
        usageInputTokens: Math.max(0, Number(document.getElementById('usageInputTokens').value) || 0),
        usageOutputTokens: Math.max(0, Number(document.getElementById('usageOutputTokens').value) || 0),
        electricityRate: Math.max(0, Number(document.getElementById('electricityRate').value) || 0),
        utilization: Math.min(100, Math.max(0, Number(document.getElementById('utilization').value) || 0)) / 100,
        projectionMonths: Math.max(1, Number(document.getElementById('projectionMonths').value) || 1),
      };
    }

    function setInputs(obj) {
      if (obj.examples !== undefined) document.getElementById('examples').value = obj.examples;
      if (obj.tokens_per_example !== undefined) document.getElementById('tokensPerExample').value = obj.tokens_per_example;
      if (obj.epochs !== undefined) document.getElementById('epochs').value = obj.epochs;
      if (obj.monthly_requests !== undefined) document.getElementById('monthlyRequests').value = obj.monthly_requests;
      if (obj.input_tokens_per_request !== undefined) document.getElementById('usageInputTokens').value = obj.input_tokens_per_request;
      if (obj.output_tokens_per_request !== undefined) document.getElementById('usageOutputTokens').value = obj.output_tokens_per_request;
      if (obj.provider !== undefined) {
        const sel = document.getElementById('provider');
        for (let i = 0; i < sel.options.length; i++) {
          const opt = JSON.parse(sel.options[i].value);
          if (opt.slug === obj.provider) { sel.selectedIndex = i; break; }
        }
      }
      if (obj.local_gpu !== undefined) {
        const sel = document.getElementById('localGpu');
        for (let i = 0; i < sel.options.length; i++) {
          const opt = JSON.parse(sel.options[i].value);
          if (opt.slug === obj.local_gpu) { sel.selectedIndex = i; break; }
        }
      }
      if (obj.projection_months !== undefined) document.getElementById('projectionMonths').value = obj.projection_months;
    }

    function compute() {
      const inps = getInputs();
      const provider = getProvider();
      const gpu = getLocalGpu();
      const providerList = JSON.parse(providers);
      const gpuList = JSON.parse(localGpus);

      const trainingTokens = inps.examples * inps.tokensPerExample * inps.epochs;
      const managedTrainingCost = Math.max(provider.min_cost, (trainingTokens / 1000) * provider.training_input_cost_per_1k);
      const monthlyManagedUsage = inps.monthlyRequests * ((inps.usageInputTokens / 1000) * provider.usage_input_cost_per_1k + (inps.usageOutputTokens / 1000) * provider.usage_output_cost_per_1k);
      const managedPeriodTotal = managedTrainingCost + monthlyManagedUsage * inps.projectionMonths;

      const trainingHours = trainingTokens / gpu.training_tokens_per_hour;
      const localTrainingRental = trainingHours * gpu.cloud_hourly;
      const localTrainingElectricity = trainingHours * (gpu.power_w / 1000) * inps.electricityRate;
      const localTrainingCost = localTrainingRental + localTrainingElectricity;

      const effectiveUtilization = Math.max(0.05, inps.utilization);
      const monthlyLocalUsageHours = (inps.monthlyRequests * (inps.usageInputTokens + inps.usageOutputTokens)) / (gpu.training_tokens_per_hour * effectiveUtilization);
      const monthlyLocalUsageCost = monthlyLocalUsageHours * gpu.cloud_hourly;
      const localPeriodTotal = localTrainingCost + monthlyLocalUsageCost * inps.projectionMonths;

      const costPer1kRequests = monthlyManagedUsage > 0 ? (monthlyManagedUsage / inps.monthlyRequests) * 1000 : 0;

      // Provider comparison
      const rows = providerList.map(p => {
        const tCost = Math.max(p.min_cost, (trainingTokens / 1000) * p.training_input_cost_per_1k);
        const uCost = inps.monthlyRequests * ((inps.usageInputTokens / 1000) * p.usage_input_cost_per_1k + (inps.usageOutputTokens / 1000) * p.usage_output_cost_per_1k);
        return { name: p.name, training: tCost, monthlyUsage: uCost, period: tCost + uCost * inps.projectionMonths, note: p.note };
      }).sort((a, b) => a.period - b.period);
      const cheapest = rows[0];

      document.getElementById('trainingTokens').textContent = fmtInt(trainingTokens);
      document.getElementById('managedTrainingCost').textContent = fmtMoney2(managedTrainingCost);
      document.getElementById('managedMonthlyUsage').textContent = fmtMoney2(monthlyManagedUsage);
      document.getElementById('managedPeriodTotal').textContent = fmtMoney0(managedPeriodTotal);
      document.getElementById('localTrainingCost').textContent = fmtMoney2(localTrainingCost);
      document.getElementById('localPeriodTotal').textContent = fmtMoney0(localPeriodTotal);
      document.getElementById('cheapestProvider').textContent = cheapest.name;
      document.getElementById('trainingHours').textContent = fmtNum(trainingHours) + ' hr';
      document.getElementById('costPer1kRequests').textContent = fmtMoney2(costPer1kRequests);

      const monthlySavingsVsCheapest = cheapest.monthlyUsage - monthlyManagedUsage;
      const breakeven = monthlySavingsVsCheapest > 0 ? Math.ceil(managedTrainingCost / monthlySavingsVsCheapest) : Infinity;
      const breakevenText = breakeven === Infinity || breakeven > inps.projectionMonths ? `>${inps.projectionMonths} mo` : `${breakeven} mo`;
      document.getElementById('breakevenMonths').textContent = breakevenText;

      const tbody = document.getElementById('providerTable');
      tbody.innerHTML = rows.map((r, idx) => {
        const badge = idx === 0 ? '<span class="ml-2 text-xs bg-brand-gold text-neutral-950 px-2 py-0.5 rounded font-semibold">Cheapest</span>' : '';
        return `<tr class="border-b border-neutral-800/50 ${idx === 0 ? 'text-brand-gold' : ''}">
          <td class="py-3 pr-4">${r.name}${badge}</td>
          <td class="py-3 pr-4 text-right font-mono">${fmtMoney2(r.training)}</td>
          <td class="py-3 pr-4 text-right font-mono">${fmtMoney2(r.monthlyUsage)}</td>
          <td class="py-3 pr-4 text-right font-mono">${fmtMoney0(r.period)}</td>
          <td class="py-3 pr-4 text-sm text-neutral-400">${r.note}</td>
        </tr>`;
      }).join('');

      let verdict = '';
      if (trainingTokens === 0) {
        verdict = "Set a training workload to see cost estimates.";
      } else if (managedPeriodTotal < localPeriodTotal) {
        verdict = `Managed API is cheaper for this workload (${fmtMoney0(managedPeriodTotal)} vs ${fmtMoney0(localPeriodTotal)} local). Best if you train once and serve moderate traffic.`;
      } else if (localPeriodTotal < managedPeriodTotal * 0.7) {
        verdict = `Local GPU is substantially cheaper (${fmtMoney0(localPeriodTotal)} vs ${fmtMoney0(managedPeriodTotal)} managed). Great if you can keep utilization above ${Math.round(effectiveUtilization * 100)}% or run repeated training jobs.`;
      } else {
        verdict = `Costs are close (${fmtMoney0(managedPeriodTotal)} managed vs ${fmtMoney0(localPeriodTotal)} local). Pick managed for speed/simplicity, local for control, data privacy, or repeated fine-tuning.`;
      }
      document.getElementById('verdictText').textContent = verdict;
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const s = JSON.parse(btn.dataset.scenario);
          setInputs(s);
          compute();
        });
      });

      ['provider','localGpu'].forEach(id => {
        document.getElementById(id).addEventListener('change', compute);
      });

      ['examples','tokensPerExample','epochs','monthlyRequests','usageInputTokens','usageOutputTokens','electricityRate','utilization','projectionMonths'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.addEventListener('input', compute); el.addEventListener('change', compute); }
      });

      compute();
    });
  </script>
</Layout>
