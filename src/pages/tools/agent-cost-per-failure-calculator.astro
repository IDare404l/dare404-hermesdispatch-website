---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_cost_per_failure.json';

const title = "AI Agent Cost Per Failure / Resolution Cost Calculator | Hermes Dispatch";
const description = "Estimate the all-in cost of each failed or escalated AI agent task, including retries, human review, reputation, churn, and lost opportunity.";
const scenarios = data.scenarios;
const severities = data.severity_presets;
const channels = data.resolution_channels;
const providers = data.llm_providers;
const defaults = data.defaults;

const faqs = [
  { q: "What counts as an AI agent failure?", a: "Any task where the agent output is wrong, incomplete, unsafe, or requires human takeover. Includes incorrect answers, hallucinations, missed escalations, failed tool calls, and compliance/policy violations." },
  { q: "Why include reputation and churn cost?", a: "Direct retry and labor costs are small. The bigger hit is often a damaged customer relationship, support surge, refund, or churn. This calculator surfaces those hidden costs so reliability investments get prioritized correctly." },
  { q: "How is cost per failure calculated?", a: "It sums API retry cost, human review cost, incident response labor, customer goodwill, opportunity cost, and a churn/reputation charge proportional to the customer base, MRR, and LTV." },
  { q: "Can I use this for internal-only agents?", a: "Yes. Set MRR and LTV to zero, keep opportunity cost and reviewer rates, and the calculator isolates the rework and lost-productivity cost." },
  { q: "How do I reduce cost per failure?", a: "Lower failure rate first. Then choose the cheapest channel that still resolves safely, improve cached-input share, and reduce response time to limit reputation damage." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Cost Per Failure / Resolution Cost Calculator" description={description} url="https://hermesdispatch.dev/tools/agent-cost-per-failure-calculator/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🚨</div>
      <h1 class="display-heading mb-4">AI Agent Cost Per Failure / Resolution Cost Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate the all-in cost of each failed or escalated AI agent task, including retries, human review, reputation, churn, and lost opportunity.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario preset</h2>
      <div class="flex flex-wrap gap-3" id="scenario-buttons">
        {scenarios.map((s, i) => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)} data-index={i}>
            {s.name}
          </button>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold flex items-center gap-2"><span>📊</span> Workload</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Monthly tasks</span><input id="monthlyTasks" type="number" min="1" step="100" value={defaults.monthly_tasks} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Failure rate (%)</span><input id="failureRate" type="number" min="0" max="100" step="0.1" value={defaults.failure_rate_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Input tokens per task</span><input id="inputsPerTask" type="number" min="0" step="10" value={defaults.inputs_per_task} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Output tokens per task</span><input id="outputsPerTask" type="number" min="0" step="10" value={defaults.outputs_per_task} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Cached input (%)</span><input id="cachedInputPct" type="number" min="0" max="100" step="1" value={defaults.cached_input_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">LLM provider</span>
            <select id="provider" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {providers.map(p => <option value={JSON.stringify(p)} selected={p.name === defaults.provider}>{p.name}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">Projection months</span><input id="projectionMonths" type="number" min="1" max="60" step="1" value={defaults.projection_months} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>
      </div>

      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold flex items-center gap-2"><span>🩹</span> Failure impact</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Severity preset</span>
            <select id="severity" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {severities.map(s => <option value={JSON.stringify(s)} selected={s.name === defaults.severity}>{s.name}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">Resolution channel</span>
            <select id="channel" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {channels.map(c => <option value={JSON.stringify(c)} selected={c.name === defaults.channel}>{c.name}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">API retry rate on failure (%)</span><input id="apiRetryRate" type="number" min="0" max="100" step="1" value={severities.find(s=>s.name===defaults.severity).api_retry_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Human review / takeover rate (%)</span><input id="humanReviewRate" type="number" min="0" max="100" step="1" value={severities.find(s=>s.name===defaults.severity).human_review_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Human review minutes per failure</span><input id="humanReviewMinutes" type="number" min="0" step="0.5" value={defaults.human_review_minutes} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Reviewer hourly rate ($)</span><input id="reviewerRate" type="number" min="0" step="5" value={defaults.reviewer_hourly_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Incident response hours per failure</span><input id="incidentHours" type="number" min="0" step="0.1" value={severities.find(s=>s.name===defaults.severity).incident_response_hours} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Incident response hourly rate ($)</span><input id="incidentRate" type="number" min="0" step="5" value={defaults.incident_response_hourly_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Customer goodwill per failure ($)</span><input id="goodwill" type="number" min="0" step="5" value={severities.find(s=>s.name===defaults.severity).customer_goodwill_per_failure} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">MRR per affected customer ($)</span><input id="mrr" type="number" min="0" step="10" value={defaults.mrr_per_customer} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Customers at risk (%)</span><input id="customersAtRisk" type="number" min="0" max="100" step="1" value={defaults.customers_at_risk_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">LTV per customer ($)</span><input id="ltv" type="number" min="0" step="100" value={defaults.ltv_per_customer} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Opportunity cost per failure ($)</span><input id="opportunity" type="number" min="0" step="5" value={defaults.opportunity_cost_per_failure} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Reputation / churn hit per failure (% of LTV)</span><input id="reputationPct" type="number" min="0" max="100" step="0.01" value={severities.find(s=>s.name===defaults.severity).reputation_hit_per_failure_pct * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Churn lift per failure (%)</span><input id="churnLift" type="number" min="0" max="100" step="0.01" value={severities.find(s=>s.name===defaults.severity).churn_lift_pct * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>
      </div>
    </section>

    <section id="summary" class="grid md:grid-cols-4 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Failures / month</p><p id="failuresMonth" class="text-2xl font-bold text-white">—</p><p id="failuresProjection" class="text-sm text-neutral-400 mt-1">—</p></div>
      <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Cost per failure</p><p id="costPerFailure" class="text-2xl font-bold text-brand-gold">—</p><p id="costPerFailurePct" class="text-sm text-neutral-400 mt-1">—</p></div>
      <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Monthly failure cost</p><p id="monthlyCost" class="text-2xl font-bold text-white">—</p><p id="monthlyCostPct" class="text-sm text-neutral-400 mt-1">—</p></div>
      <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Projected failure cost</p><p id="projectionCost" class="text-2xl font-bold text-white">—</p><p id="projectionCostPct" class="text-sm text-neutral-400 mt-1">—</p></div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Cost breakdown per failure</h2>
      <div class="h-72 w-full" id="chart-container"><canvas id="breakdownChart" class="w-full h-full"></canvas></div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">How to use these numbers</h2>
      <ul class="list-disc pl-5 text-neutral-300 space-y-2">
        <li>Compare cost per failure against the cost of a prevention or monitoring investment.</li>
        <li>Prioritize the agent with the highest <em>monthly</em> failure cost, not just the highest failure rate.</li>
        <li>Regulated or customer-facing agents usually justify stricter guardrails and higher human-review rates.</li>
        <li>Update failure-rate and review-time assumptions with real post-launch data every month.</li>
      </ul>
    </section>

    <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-neutral-900/50 rounded-xl border border-neutral-800">
            <summary class="p-4 cursor-pointer font-medium text-neutral-200 flex justify-between items-center">{f.q}<span class="text-brand-gold group-open:rotate-180 transition-transform">▼</span></summary>
            <p class="p-4 pt-0 text-neutral-400">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ scenarios, severities, channels, providers, defaults }}>
    function $(id) { return document.getElementById(id); }
    function val(id) { return parseFloat($(id).value) || 0; }
    const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtPct = new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 1, maximumFractionDigits: 1 });

    function getProvider() { return JSON.parse($('provider').value); }
    function getSeverity() { return JSON.parse($('severity').value); }
    function getChannel() { return JSON.parse($('channel').value); }

    function calc() {
      const monthlyTasks = Math.max(1, val('monthlyTasks'));
      const failureRate = Math.min(100, Math.max(0, val('failureRate'))) / 100;
      const failures = Math.round(monthlyTasks * failureRate);
      const months = Math.max(1, val('projectionMonths'));
      const p = getProvider();
      const inputs = val('inputsPerTask');
      const outputs = val('outputsPerTask');
      const cachedPct = Math.min(100, Math.max(0, val('cachedInputPct'))) / 100;
      const inputCost = (inputs * cachedPct * p.cached_input_per_1k + inputs * (1 - cachedPct) * p.input_per_1k) / 1000;
      const outputCost = outputs * p.output_per_1k / 1000;
      const baseApiCost = inputCost + outputCost;
      const retryRate = Math.min(100, Math.max(0, val('apiRetryRate'))) / 100;
      const apiRetryCost = baseApiCost * retryRate;
      const reviewRate = Math.min(100, Math.max(0, val('humanReviewRate'))) / 100;
      const reviewMinutes = val('humanReviewMinutes');
      const reviewerRate = val('reviewerRate');
      const humanReviewCost = reviewRate * (reviewMinutes / 60) * reviewerRate;
      const incidentHours = val('incidentHours');
      const incidentRate = val('incidentRate');
      const incidentCost = incidentHours * incidentRate;
      const goodwill = val('goodwill');
      const opportunity = val('opportunity');
      const reputationPct = Math.min(100, Math.max(0, val('reputationPct'))) / 100;
      const churnLift = Math.min(100, Math.max(0, val('churnLift'))) / 100;
      const ltv = val('ltv');
      const mrr = val('mrr');
      const customersAtRisk = Math.min(100, Math.max(0, val('customersAtRisk'))) / 100;
      const churnCost = failures > 0 ? (churnLift * ltv * customersAtRisk) / failures : 0;
      const reputationCost = (reputationPct * ltv * customersAtRisk) / (failures || 1);
      const costPerFailure = apiRetryCost + humanReviewCost + incidentCost + goodwill + opportunity + churnCost + reputationCost;
      const monthlyCost = costPerFailure * failures;
      const projectedCost = monthlyCost * months;

      $('failuresMonth').textContent = failures.toLocaleString();
      $('failuresProjection').textContent = (failures * months).toLocaleString() + ' over ' + months + ' mo';
      $('costPerFailure').textContent = fmt.format(costPerFailure);
      $('costPerFailurePct').textContent = fmtPct.format(failureRate) + ' failure rate';
      $('monthlyCost').textContent = fmt.format(monthlyCost);
      $('monthlyCostPct').textContent = fmtPct.format(monthlyCost / (monthlyTasks * baseApiCost || 1)) + ' of base API spend';
      $('projectionCost').textContent = fmt.format(projectedCost);
      $('projectionCostPct').textContent = fmt.format(monthlyCost) + '/mo';

      drawBreakdown(apiRetryCost, humanReviewCost, incidentCost, goodwill, opportunity, churnCost, reputationCost);
    }

    function drawBreakdown(apiRetry, humanReview, incident, goodwill, opportunity, churn, reputation) {
      const canvas = $('breakdownChart');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const w = rect.width, h = rect.height;
      ctx.clearRect(0, 0, w, h);
      const items = [
        { label: 'API retry', value: apiRetry, color: '#f59e0b' },
        { label: 'Human review', value: humanReview, color: '#06b6d4' },
        { label: 'Incident response', value: incident, color: '#8b5cf6' },
        { label: 'Goodwill', value: goodwill, color: '#ef4444' },
        { label: 'Opportunity', value: opportunity, color: '#10b981' },
        { label: 'Churn', value: churn, color: '#ec4899' },
        { label: 'Reputation', value: reputation, color: '#6366f1' }
      ];
      const total = items.reduce((a, b) => a + b.value, 0) || 1;
      let x = 0;
      const barH = 32;
      const y = h / 2 - barH / 2;
      items.forEach(item => {
        const bw = (item.value / total) * w;
        ctx.fillStyle = item.color;
        ctx.fillRect(x, y, bw, barH);
        if (bw > 50) {
          ctx.fillStyle = '#fff';
          ctx.font = '12px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText(item.label, x + bw / 2, y + barH / 2 + 4);
        }
        x += bw;
      });
    }

    function applyScenario(s) {
      $('monthlyTasks').value = s.monthly_tasks;
      $('failureRate').value = s.failure_rate_pct;
      $('inputsPerTask').value = s.inputs_per_task;
      $('outputsPerTask').value = s.outputs_per_task;
      $('cachedInputPct').value = s.cached_input_pct;
      $('provider').value = JSON.stringify(providers.find(p => p.name === s.provider) || providers[0]);
      $('projectionMonths').value = s.projection_months;
      $('humanReviewMinutes').value = s.human_review_minutes;
      $('reviewerRate').value = s.reviewer_hourly_rate;
      $('incidentRate').value = s.incident_response_hourly_rate;
      $('mrr').value = s.mrr_per_customer;
      $('customersAtRisk').value = s.customers_at_risk_pct;
      $('ltv').value = s.ltv_per_customer;
      $('opportunity').value = s.opportunity_cost_per_failure;
      $('severity').value = JSON.stringify(severities.find(x => x.name === s.severity) || severities[0]);
      $('channel').value = JSON.stringify(channels.find(x => x.name === s.channel) || channels[0]);
      applySeverity();
      applyChannel();
      document.querySelectorAll('.scenario-btn').forEach((b, i) => {
        const active = JSON.parse(b.dataset.scenario).name === s.name;
        b.classList.toggle('bg-brand-gold/20', active);
        b.classList.toggle('border-brand-gold', active);
        b.classList.toggle('text-brand-gold', active);
        b.classList.toggle('bg-neutral-800', !active);
        b.classList.toggle('border-neutral-700', !active);
      });
      calc();
    }

    function applySeverity() {
      const s = getSeverity();
      $('apiRetryRate').value = s.api_retry_rate;
      $('humanReviewRate').value = s.human_review_rate;
      $('incidentHours').value = s.incident_response_hours;
      $('goodwill').value = s.customer_goodwill_per_failure;
      $('reputationPct').value = s.reputation_hit_per_failure_pct * 100;
      $('churnLift').value = s.churn_lift_pct * 100;
      calc();
    }

    function applyChannel() {
      const c = getChannel();
      $('humanReviewRate').value = c.human_takeover_rate;
      calc();
    }

    document.querySelectorAll('.scenario-btn').forEach(btn => {
      btn.addEventListener('click', () => applyScenario(JSON.parse(btn.dataset.scenario)));
    });
    $('severity').addEventListener('change', applySeverity);
    $('channel').addEventListener('change', applyChannel);
    document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', calc));
    window.addEventListener('resize', calc);

    // select first scenario visually
    const firstBtn = document.querySelector('.scenario-btn');
    if (firstBtn) applyScenario(JSON.parse(firstBtn.dataset.scenario));
  </script>
</Layout>
