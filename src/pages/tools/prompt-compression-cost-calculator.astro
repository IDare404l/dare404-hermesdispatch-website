---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/prompt_compression_cost.json';

const title = "AI Agent Prompt Compression / Token Optimization Cost Calculator | Hermes Dispatch";
const description = "Estimate how much LLM API spend you can save by compressing prompts with summarization, RAG retrieval, caching, truncation, or prompt rewriting. Compare compression cost, quality impact, and break-even timeline.";
const providers = data.providers;
const strategies = data.strategies;
const scenarios = data.scenarios;
const defaults = data.defaults;

const faqs = [
  { q: "What does prompt compression save?", a: "It reduces the number of input tokens sent to the main LLM by summarizing context, retrieving only relevant chunks, truncating old turns, or rewriting verbose prompts. Fewer input tokens means lower API cost and often faster response time." },
  { q: "Does compression always improve quality?", a: "No. Truncation can lose long-range context. Summarization can drop nuance. RAG retrieval usually improves accuracy by focusing on relevant context, but requires a good embedding and chunking setup." },
  { q: "What is the compression ratio?", a: "It is the ratio of compressed input tokens to original input tokens. A ratio of 0.45 means the compressed prompt is 45% as long as the original, cutting input tokens by 55%." },
  { q: "How are compressor costs counted?", a: "Some strategies require a separate cheap-model call to summarize or rewrite the prompt before the main LLM call. The calculator adds that per-request compressor cost and any monthly infrastructure fee." },
  { q: "When is prompt caching better than compression?", a: "Caching is best when a large part of the prompt is identical across requests, such as a system message, few-shot examples, or grounding documents. It gives a discount without losing context, but does not reduce token count." },
  { q: "How is break-even calculated?", a: "Break-even months = one-time setup cost divided by monthly savings net of compression and review costs. If setup cost is zero, the result is immediate." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Prompt Compression / Token Optimization Cost Calculator" description={description} url="https://hermesdispatch.dev/tools/prompt-compression-cost-calculator/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🗜️</div>
      <h1 class="display-heading mb-4">AI Agent Prompt Compression / Token Optimization Cost Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate how much LLM API spend you can save by compressing prompts with summarization, RAG retrieval, caching, truncation, or prompt rewriting.</p>
    </div>

    <!-- Scenario presets -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario presets</h2>
      <div class="flex flex-wrap gap-3">
        {scenarios.map(s => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)}>
            {s.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Inputs -->
    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Workload and compression settings</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <label class="block">
          <span class="text-neutral-400 text-sm">LLM provider</span>
          <select id="provider" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            {providers.map(p => <option value={JSON.stringify(p)} selected={p.slug === defaults.provider}>{p.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Compression strategy</span>
          <select id="strategy" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            {strategies.map(s => <option value={JSON.stringify(s)} selected={s.slug === defaults.strategy}>{s.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Monthly requests</span>
          <input id="monthlyRequests" type="number" min="1" step="1000" value={defaults.monthly_requests} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Input tokens / request</span>
          <input id="inputTokens" type="number" min="1" step="100" value={defaults.input_tokens} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Output tokens / request</span>
          <input id="outputTokens" type="number" min="0" step="50" value={defaults.output_tokens} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Cached input (%)</span>
          <input id="cachedInputPct" type="number" min="0" max="100" step="5" value={defaults.cached_input_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Compression ratio</span>
          <input id="compressionRatio" type="number" min="0.1" max="1" step="0.05" value={defaults.compression_ratio} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Human review rate (%)</span>
          <input id="reviewRate" type="number" min="0" max="100" step="1" value={defaults.review_rate_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Reviewer hourly cost ($)</span>
          <input id="reviewerHourly" type="number" min="0" step="5" value={defaults.reviewer_hourly} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Review minutes / request</span>
          <input id="reviewMinutes" type="number" min="0" step="0.25" value={defaults.review_minutes} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Setup hours</span>
          <input id="setupHours" type="number" min="0" step="1" value={0} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Setup hourly rate ($)</span>
          <input id="setupHourlyRate" type="number" min="0" step="5" value={defaults.setup_hourly} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Projection (months)</span>
          <input id="projectionMonths" type="number" min="1" max="60" value={defaults.projection_months} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
      </div>
      <p class="text-neutral-500 text-sm mt-6">Estimates are directional. Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <!-- Summary cards -->
    <section id="summary" class="grid md:grid-cols-4 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Uncompressed monthly cost</p>
        <p id="uncompressedCost" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Compressed monthly cost</p>
        <p id="compressedCost" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Monthly savings</p>
        <p id="monthlySavings" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Savings percentage</p>
        <p id="savingsPct" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
    </section>

    <!-- Secondary metrics -->
    <section class="grid md:grid-cols-3 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Compressor cost / month</p>
        <p id="compressorCost" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Review cost / month</p>
        <p id="reviewCost" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Infra cost / month</p>
        <p id="infraCost" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Setup cost (one-time)</p>
        <p id="setupCost" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Period net savings</p>
        <p id="periodSavings" class="text-xl font-semibold text-white">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <p class="text-xs text-neutral-500 uppercase mb-1">Break-even (months)</p>
        <p id="breakEven" class="text-xl font-semibold text-white">—</p>
      </div>
    </section>

    <!-- Cost breakdown table -->
    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Monthly cost breakdown</h2>
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
            <th class="py-3 pr-4">Cost line</th>
            <th class="py-3 pr-4 text-right">Uncompressed</th>
            <th class="py-3 pr-4 text-right">Compressed</th>
            <th class="py-3 pr-4 text-right">Delta</th>
          </tr>
        </thead>
        <tbody class="text-neutral-200">
          <tr class="border-b border-neutral-800/50">
            <td class="py-3 pr-4">LLM input tokens</td>
            <td id="uncompressedInput" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="compressedInput" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="inputDelta" class="py-3 pr-4 text-right font-mono">—</td>
          </tr>
          <tr class="border-b border-neutral-800/50">
            <td class="py-3 pr-4">LLM output tokens</td>
            <td id="uncompressedOutput" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="compressedOutput" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="outputDelta" class="py-3 pr-4 text-right font-mono">—</td>
          </tr>
          <tr class="border-b border-neutral-800/50">
            <td class="py-3 pr-4">Compressor calls</td>
            <td class="py-3 pr-4 text-right font-mono text-neutral-500">—</td>
            <td id="compressorCell" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="compressorDelta" class="py-3 pr-4 text-right font-mono">—</td>
          </tr>
          <tr class="border-b border-neutral-800/50">
            <td class="py-3 pr-4">Human review</td>
            <td class="py-3 pr-4 text-right font-mono text-neutral-500">—</td>
            <td id="reviewCell" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="reviewDelta" class="py-3 pr-4 text-right font-mono">—</td>
          </tr>
          <tr class="border-b border-neutral-800/50">
            <td class="py-3 pr-4">Compression infra</td>
            <td class="py-3 pr-4 text-right font-mono text-neutral-500">—</td>
            <td id="infraCell" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="infraDelta" class="py-3 pr-4 text-right font-mono">—</td>
          </tr>
          <tr class="border-b border-neutral-700 font-semibold">
            <td class="py-3 pr-4">Total monthly</td>
            <td id="totalUncompressed" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="totalCompressed" class="py-3 pr-4 text-right font-mono">—</td>
            <td id="totalDelta" class="py-3 pr-4 text-right font-mono font-semibold text-brand-gold">—</td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- Verdict -->
    <section id="verdict" class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-2 text-brand-gold">Verdict</h2>
      <p id="verdictText" class="text-lg text-neutral-200">—</p>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/prompt-cache-savings-calculator/" class="btn-primary text-sm">Prompt Cache Savings Calc →</a>
      <a href="/tools/context-window-budgeter/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Context Window Budgeter →</a>
      <a href="/tools/agent-api-pricing-comparator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">API Pricing Comparator →</a>
      <a href="/tools/agent-workflow-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Workflow Cost Calc →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ scenarios: JSON.stringify(scenarios) }}>
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtMoney2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const fmtMoney4 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 4 });
    const fmtNum = n => n.toLocaleString('en-US', { maximumFractionDigits: 1 });
    const fmtInt = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    function getProvider() { return JSON.parse(document.getElementById('provider').value); }
    function getStrategy() { return JSON.parse(document.getElementById('strategy').value); }

    function getInputs() {
      return {
        monthlyRequests: Number(document.getElementById('monthlyRequests').value) || 1,
        inputTokens: Number(document.getElementById('inputTokens').value) || 0,
        outputTokens: Number(document.getElementById('outputTokens').value) || 0,
        cachedInputPct: Number(document.getElementById('cachedInputPct').value) || 0,
        compressionRatio: Number(document.getElementById('compressionRatio').value) || 1,
        reviewRate: Number(document.getElementById('reviewRate').value) || 0,
        reviewerHourly: Number(document.getElementById('reviewerHourly').value) || 0,
        reviewMinutes: Number(document.getElementById('reviewMinutes').value) || 0,
        setupHours: Number(document.getElementById('setupHours').value) || 0,
        setupHourlyRate: Number(document.getElementById('setupHourlyRate').value) || 0,
        projectionMonths: Number(document.getElementById('projectionMonths').value) || 1,
      };
    }

    function setInputs(obj) {
      if (obj.provider !== undefined) {
        const sel = document.getElementById('provider');
        for (let i = 0; i < sel.options.length; i++) {
          const opt = JSON.parse(sel.options[i].value);
          if (opt.slug === obj.provider) { sel.selectedIndex = i; break; }
        }
      }
      if (obj.strategy !== undefined) {
        const sel = document.getElementById('strategy');
        for (let i = 0; i < sel.options.length; i++) {
          const opt = JSON.parse(sel.options[i].value);
          if (opt.slug === obj.strategy) { sel.selectedIndex = i; break; }
        }
      }
      if (obj.monthly_requests !== undefined) document.getElementById('monthlyRequests').value = obj.monthly_requests;
      if (obj.input_tokens !== undefined) document.getElementById('inputTokens').value = obj.input_tokens;
      if (obj.output_tokens !== undefined) document.getElementById('outputTokens').value = obj.output_tokens;
      if (obj.cached_input_pct !== undefined) document.getElementById('cachedInputPct').value = obj.cached_input_pct;
      if (obj.compression_ratio !== undefined) document.getElementById('compressionRatio').value = obj.compression_ratio;
      if (obj.review_rate_pct !== undefined) document.getElementById('reviewRate').value = obj.review_rate_pct;
      if (obj.reviewer_hourly !== undefined) document.getElementById('reviewerHourly').value = obj.reviewer_hourly;
      if (obj.review_minutes !== undefined) document.getElementById('reviewMinutes').value = obj.review_minutes;
      if (obj.projection_months !== undefined) document.getElementById('projectionMonths').value = obj.projection_months;
      if (obj.setup_hourly !== undefined) document.getElementById('setupHourlyRate').value = obj.setup_hourly;
    }

    function llmCost(provider, inputTokens, outputTokens, cachedInputPct) {
      const cached = inputTokens * (cachedInputPct / 100);
      const uncached = inputTokens - cached;
      return (uncached / 1000) * provider.input_per_1k + (cached / 1000) * provider.cached_input_per_1k + (outputTokens / 1000) * provider.output_per_1k;
    }

    function compute() {
      const inps = getInputs();
      const provider = getProvider();
      const strategy = getStrategy();

      const uncompressedMonthly = llmCost(provider, inps.inputTokens, inps.outputTokens, inps.cachedInputPct) * inps.monthlyRequests;

      const compressedInputTokens = Math.round(inps.inputTokens * inps.compressionRatio);
      const compressedOutputTokens = inps.outputTokens; // output unchanged by input compression
      const compressedLlmMonthly = llmCost(provider, compressedInputTokens, compressedOutputTokens, inps.cachedInputPct) * inps.monthlyRequests;

      const compressorCostPerReq = (inps.inputTokens / 1000) * strategy.compressor_input_per_1k + (compressedInputTokens / 1000) * strategy.compressor_output_per_1k;
      const compressorMonthly = compressorCostPerReq * inps.monthlyRequests;

      const reviewHours = inps.monthlyRequests * (inps.reviewRate / 100) * (inps.reviewMinutes / 60);
      const reviewMonthly = reviewHours * inps.reviewerHourly;

      const infraMonthly = strategy.monthly_infra;
      const setupCost = inps.setupHours * inps.setupHourlyRate + strategy.setup_hours * inps.setupHourlyRate;
      const compressedMonthly = compressedLlmMonthly + compressorMonthly + reviewMonthly + infraMonthly;

      const monthlySavings = uncompressedMonthly - compressedMonthly;
      const savingsPct = uncompressedMonthly > 0 ? (monthlySavings / uncompressedMonthly) * 100 : 0;
      const periodSavings = monthlySavings * inps.projectionMonths - setupCost;
      const breakEven = monthlySavings > 0 ? setupCost / monthlySavings : Infinity;

      document.getElementById('uncompressedCost').textContent = fmtMoney(uncompressedMonthly);
      document.getElementById('compressedCost').textContent = fmtMoney(compressedMonthly);
      document.getElementById('monthlySavings').textContent = fmtMoney(monthlySavings);
      document.getElementById('savingsPct').textContent = fmtNum(savingsPct) + '%';
      document.getElementById('compressorCost').textContent = fmtMoney(compressorMonthly);
      document.getElementById('reviewCost').textContent = fmtMoney(reviewMonthly);
      document.getElementById('infraCost').textContent = fmtMoney(infraMonthly);
      document.getElementById('setupCost').textContent = fmtMoney(setupCost);
      document.getElementById('periodSavings').textContent = fmtMoney(periodSavings);
      document.getElementById('breakEven').textContent = breakEven === Infinity ? '∞' : (breakEven <= 0 ? 'Immediate' : fmtNum(breakEven) + ' mo');

      document.getElementById('uncompressedInput').textContent = fmtMoney((inps.inputTokens / 1000) * provider.input_per_1k * inps.monthlyRequests);
      document.getElementById('compressedInput').textContent = fmtMoney((compressedInputTokens / 1000) * provider.input_per_1k * inps.monthlyRequests);
      document.getElementById('inputDelta').textContent = fmtMoney(((inps.inputTokens - compressedInputTokens) / 1000) * provider.input_per_1k * inps.monthlyRequests);

      document.getElementById('uncompressedOutput').textContent = fmtMoney((inps.outputTokens / 1000) * provider.output_per_1k * inps.monthlyRequests);
      document.getElementById('compressedOutput').textContent = fmtMoney((compressedOutputTokens / 1000) * provider.output_per_1k * inps.monthlyRequests);
      document.getElementById('outputDelta').textContent = '$0.00';

      document.getElementById('compressorCell').textContent = fmtMoney(compressorMonthly);
      document.getElementById('compressorDelta').textContent = fmtMoney(-compressorMonthly);
      document.getElementById('reviewCell').textContent = fmtMoney(reviewMonthly);
      document.getElementById('reviewDelta').textContent = fmtMoney(-reviewMonthly);
      document.getElementById('infraCell').textContent = fmtMoney(infraMonthly);
      document.getElementById('infraDelta').textContent = fmtMoney(-infraMonthly);

      document.getElementById('totalUncompressed').textContent = fmtMoney(uncompressedMonthly);
      document.getElementById('totalCompressed').textContent = fmtMoney(compressedMonthly);
      document.getElementById('totalDelta').textContent = fmtMoney(monthlySavings);

      let verdict = '';
      if (strategy.slug === 'none') {
        verdict = `Baseline: ${fmtMoney(uncompressedMonthly)}/mo with no compression. Pick a strategy above to see potential savings.`;
      } else if (monthlySavings <= 0) {
        verdict = `${strategy.name} does not save money at this workload (${fmtMoney(compressedMonthly)}/mo vs ${fmtMoney(uncompressedMonthly)}/mo). The compressor/infra/review costs outweigh the token savings. Try a higher compression ratio, a cheaper compressor model, or a strategy with lower infra cost.`;
      } else if (breakEven <= 0) {
        verdict = `${strategy.name} saves ${fmtMoney(monthlySavings)}/mo (${fmtNum(savingsPct)}%) with no setup cost. Net benefit over ${inps.projectionMonths} months is ${fmtMoney(periodSavings)}. Quality impact estimate: ${fmtNum(strategy.quality_impact * 100)}%.`;
      } else if (breakEven <= 3) {
        verdict = `${strategy.name} pays back in ${fmtNum(breakEven)} months and saves ${fmtMoney(monthlySavings)}/mo (${fmtNum(savingsPct)}%). Net benefit over ${inps.projectionMonths} months is ${fmtMoney(periodSavings)}. Extra latency is ~${strategy.extra_latency_ms} ms per request.`;
      } else if (breakEven <= 12) {
        verdict = `${strategy.name} saves ${fmtMoney(monthlySavings)}/mo (${fmtNum(savingsPct)}%) but break-even is ${fmtNum(breakEven)} months due to setup and compressor costs. Net benefit over ${inps.projectionMonths} months is ${fmtMoney(periodSavings)}. Worth it if the agent runs longer than the break-even period.`;
      } else {
        verdict = `${strategy.name} saves ${fmtMoney(monthlySavings)}/mo (${fmtNum(savingsPct)}%), but the setup/compressor cost pushes break-even beyond ${fmtNum(breakEven)} months. Consider only if this is a long-running workload or the quality/latency gains are strategically important.`;
      }
      document.getElementById('verdictText').textContent = verdict;
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const s = JSON.parse(btn.dataset.scenario);
          setInputs(s);
          compute();
        });
      });

      ['provider','strategy','monthlyRequests','inputTokens','outputTokens','cachedInputPct','compressionRatio','reviewRate','reviewerHourly','reviewMinutes','setupHours','setupHourlyRate','projectionMonths'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.addEventListener('input', compute); el.addEventListener('change', compute); }
      });

      compute();
    });
  </script>
</Layout>
