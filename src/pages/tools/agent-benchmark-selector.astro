---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_benchmarks.json';

const title = "AI Agent Performance Benchmark Selector — Pick the Right Eval";
const description = "Pick the right benchmark for coding, reasoning, web, desktop, multi-agent, and domain-specific AI agents. See effort level, cost, and fit.";

const categories = Object.values(data.categories);
const benchmarks = data.benchmarks;

const faqs = [
  { q: "Which benchmark is best for a coding agent?", a: "Start with HumanEval or MBPP for quick, cheap signal. For realistic repo-level work, move to SWE-bench, which tests actual GitHub issue resolution." },
  { q: "How do I benchmark an agent that browses the web?", a: "Use WebArena for end-to-end web task completion, WebVoyager if your agent relies on screenshots and visual UI understanding, or Mind2Web for broad domain coverage." },
  { q: "What benchmark measures multi-agent teamwork?", a: "AgentBench covers multi-environment decision making, while BenchMAX focuses on negotiation and collaboration between multiple agents." },
  { q: "How much should I budget for a single evaluation run?", a: "Simple multiple-choice benchmarks cost $5–$100. Realistic web, desktop, or security benchmarks can cost $500–$10,000+ per run depending on model choice and retry count." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Performance Benchmark Selector" description={description} url="https://hermesdispatch.dev/tools/agent-benchmark-selector/" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">📊</div>
      <h1 class="display-heading mb-4">AI Agent Performance Benchmark Selector</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Pick an agent category to see the right benchmarks, what they test, effort level, typical cost, and best-fit scenario.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">What kind of agent are you evaluating?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map((c) => (
          <button type="button" data-slug={c.slug} class="category-card glass-card rounded-xl p-5 text-left hover:border-brand-gold/50 transition-all">
            <div class="text-2xl mb-2">{c.icon}</div>
            <h3 class="font-semibold text-white">{c.name}</h3>
            <p class="text-sm text-neutral-400 mt-1">{c.description}</p>
          </button>
        ))}
      </div>
    </section>

    <section id="results" class="hidden">
      <div class="flex items-center gap-3 mb-6">
        <div id="catIcon" class="text-3xl"></div>
        <div>
          <h2 id="catName" class="text-2xl font-bold text-white"></h2>
          <p id="catDesc" class="text-neutral-400 text-sm"></p>
        </div>
      </div>
      <div id="benchGrid" class="grid md:grid-cols-2 gap-6"></div>
    </section>

    <section class="glass-card rounded-2xl p-6 mt-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group">
            <summary class="font-semibold cursor-pointer text-white">{f.q}</summary>
            <p class="text-neutral-400 text-sm mt-2">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mt-10 border border-brand-gold/20 text-center">
      <h2 class="text-xl font-bold mb-3 text-brand-gold">Build the stack and budget the eval</h2>
      <p class="text-neutral-400 mb-6">Once you know the benchmark, pick the right components and estimate API cost.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/tools/agent-stack-builder/" class="btn-primary text-sm">Build the stack →</a>
        <a href="/tools/llm-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Estimate API cost →</a>
        <a href="/tools/agent-task-fit-selector/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Find task fit →</a>
      </div>
    </section>
  </main>

  <script define:vars={{ categoriesJson: JSON.stringify(categories), benchmarksJson: JSON.stringify(benchmarks) }}>
    const categories = JSON.parse(categoriesJson);
    const benchmarks = JSON.parse(benchmarksJson);
    const cards = document.querySelectorAll('.category-card');
    const results = document.getElementById('results');
    const catName = document.getElementById('catName');
    const catDesc = document.getElementById('catDesc');
    const catIcon = document.getElementById('catIcon');
    const benchGrid = document.getElementById('benchGrid');

    function effortBadge(effort) {
      const map = {
        'Low': 'bg-green-500/20 text-green-300 border-green-500/30',
        'Medium': 'bg-yellow-500/20 text-yellow-300 border-yellow-500/30',
        'High': 'bg-orange-500/20 text-orange-300 border-orange-500/30',
        'Very High': 'bg-red-500/20 text-red-300 border-red-500/30'
      };
      return map[effort] || 'bg-neutral-700 text-neutral-300 border-neutral-600';
    }

    function render(slug) {
      const category = categories.find(c => c.slug === slug);
      const matches = benchmarks.filter(b => b.category === slug);
      if (!category || !matches.length) return;

      catName.textContent = category.name;
      catDesc.textContent = category.description;
      catIcon.textContent = category.icon;

      benchGrid.innerHTML = matches.map(b => `
        <div class="glass-card rounded-xl p-5 border border-brand-gold/10 hover:border-brand-gold/30 transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-lg font-bold text-white">${b.name}</h3>
            <span class="px-2 py-1 rounded text-xs font-medium border ${effortBadge(b.effort)}">${b.effort}</span>
          </div>
          <p class="text-sm text-neutral-300 mb-4">${b.tests}</p>
          <div class="space-y-2 text-sm mb-4">
            <p><span class="text-brand-gold font-semibold">Best fit:</span> <span class="text-neutral-300">${b.fit}</span></p>
            <p><span class="text-green-400 font-semibold">Pros:</span> <span class="text-neutral-300">${b.pros}</span></p>
            <p><span class="text-red-400 font-semibold">Cons:</span> <span class="text-neutral-300">${b.cons}</span></p>
          </div>
          <div class="flex flex-wrap items-center justify-between gap-3 pt-4 border-t border-neutral-800">
            <span class="text-xs text-neutral-500">Typical cost: <span class="text-neutral-300 font-medium">${b.cost}</span></span>
            <a href="${b.url}" target="_blank" rel="noopener" class="text-sm text-brand-gold hover:underline">Learn more →</a>
          </div>
        </div>
      `).join('');

      results.classList.remove('hidden');
      results.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('border-brand-gold/50', 'bg-brand-gold/5'));
        card.classList.add('border-brand-gold/50', 'bg-brand-gold/5');
        render(card.dataset.slug);
      });
    });
  </script>
</Layout>
