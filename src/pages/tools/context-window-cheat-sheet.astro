---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/context_window_cheat_sheet.json';

const title = "AI Model Context Window Cheat Sheet | Hermes Dispatch";
const description = "Compare LLM context windows and max output token limits across OpenAI, Anthropic, Google, DeepSeek, Meta, Qwen, Mistral, Cohere, and xAI models.";
const { models, categories, faq, note, last_updated } = data;

const categoriesBySlug = Object.fromEntries(categories.map(c => [c.slug, c]));
const allCategories = categories.map(c => c.slug);

function fmtTokens(n) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(0)}K`;
  return n.toLocaleString();
}
function fmtPrice(n) {
  if (n === 0) return "—";
  return `$${n.toFixed(2)}`;
}
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Model Context Window Cheat Sheet" description={description} url="https://hermesdispatch.dev/tools/context-window-cheat-sheet/" applicationCategory="ReferenceApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(f => ({"@type": "Question", "name": f.question, "acceptedAnswer": {"@type": "Answer", "text": f.answer}}))
  })} />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">📏</div>
      <h1 class="display-heading mb-4">AI Model Context Window Cheat Sheet</h1>
      <p class="text-xl text-neutral-400 max-w-3xl mx-auto">Compare input context limits and max output tokens across frontier, balanced, fast, reasoning, and open-weight LLMs.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Filter by category</h2>
      <div class="flex flex-wrap gap-3" id="category-buttons">
        <button type="button" class="cat-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors bg-brand-gold/20 border-brand-gold/50 text-brand-gold" data-category="all">All</button>
        {categories.map(c => (
          <button type="button" class="cat-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-category={c.slug}>{c.name}</button>
        ))}
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20 overflow-x-auto">
      <table class="w-full text-sm" id="model-table">
        <thead>
          <tr class="text-left text-neutral-500 border-b border-neutral-800">
            <th class="py-3 pr-4 cursor-pointer select-none" data-sort="provider">Provider <span class="text-xs">⇅</span></th>
            <th class="py-3 pr-4 cursor-pointer select-none" data-sort="name">Model <span class="text-xs">⇅</span></th>
            <th class="py-3 pr-4 cursor-pointer select-none text-right" data-sort="context_tokens">Context <span class="text-xs">⇅</span></th>
            <th class="py-3 pr-4 cursor-pointer select-none text-right" data-sort="max_output_tokens">Max output <span class="text-xs">⇅</span></th>
            <th class="py-3 pr-4">Category</th>
            <th class="py-3 pr-4 text-right cursor-pointer select-none" data-sort="api_pricing_per_1m_input_tokens">Input / 1M <span class="text-xs">⇅</span></th>
            <th class="py-3 text-right cursor-pointer select-none" data-sort="api_pricing_per_1m_output_tokens">Output / 1M <span class="text-xs">⇅</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-800" id="model-tbody">
          {models.map(m => (
            <tr class="model-row" data-categories={JSON.stringify([m.category.toLowerCase().replace(/\s+/g, '-')])}>
              <td class="py-3 pr-4 text-neutral-300">{m.provider}</td>
              <td class="py-3 pr-4 font-semibold text-white">
                {m.name}
                {m.notes && <p class="text-xs text-neutral-500 font-normal mt-0.5">{m.notes}</p>}
              </td>
              <td class="py-3 pr-4 text-right tabular-nums">{fmtTokens(m.context_tokens)}</td>
              <td class="py-3 pr-4 text-right tabular-nums">{fmtTokens(m.max_output_tokens)}</td>
              <td class="py-3 pr-4"><span class="inline-flex px-2 py-1 rounded-md bg-neutral-800 text-neutral-300 text-xs">{m.category}</span></td>
              <td class="py-3 pr-4 text-right tabular-nums">{fmtPrice(m.api_pricing_per_1m_input_tokens)}</td>
              <td class="py-3 text-right tabular-nums">{fmtPrice(m.api_pricing_per_1m_output_tokens)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-4 text-brand-gold">Key rules of thumb</h2>
        <ul class="list-disc pl-5 text-neutral-300 space-y-2">
          <li><strong>System prompt + tools + RAG + history</strong> must fit inside the context window. Reserve ~10-20% as a safety buffer.</li>
          <li><strong>Max output tokens</strong> limits how long the model's response can be. Reasoning models often have larger output budgets.</li>
          <li><strong>1M-token contexts</strong> (OpenAI GPT-4.1, Google Gemini 2.5) fit entire codebases, long documents, or multi-turn sessions.</li>
          <li><strong>200K contexts</strong> (Claude 4) still cover most enterprise use cases with strong retrieval quality.</li>
          <li><strong>Open-weight models</strong> (Llama 4, Qwen 3) are often limited by local GPU VRAM rather than the model's theoretical context.</li>
        </ul>
      </div>

      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-4 text-brand-gold">Token budget planner</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">System prompt tokens</span><input id="sysTokens" type="number" min="0" step="10" value="500" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Tool definitions tokens</span><input id="toolTokens" type="number" min="0" step="10" value="1200" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">RAG / retrieved chunks tokens</span><input id="ragTokens" type="number" min="0" step="100" value="4000" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Conversation history tokens</span><input id="histTokens" type="number" min="0" step="100" value="2000" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Desired output tokens</span><input id="outTokens" type="number" min="0" step="100" value="2000" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>
        <div class="mt-6 p-4 rounded-xl bg-neutral-900/50 border border-neutral-800">
          <p class="text-sm text-neutral-400">Total required context</p>
          <p id="totalBudget" class="text-2xl font-bold text-brand-gold tabular-nums">—</p>
          <p id="budgetVerdict" class="text-sm text-neutral-400 mt-1">—</p>
        </div>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faq.map(f => (
          <details class="group bg-neutral-900/50 rounded-xl border border-neutral-800">
            <summary class="p-4 cursor-pointer font-medium text-neutral-200 flex justify-between items-center">{f.question}<span class="text-brand-gold group-open:rotate-180 transition-transform">▼</span></summary>
            <p class="p-4 pt-0 text-neutral-400">{f.answer}</p>
          </details>
        ))}
      </div>
      <p class="text-neutral-500 text-sm mt-6">Last updated: {last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/tools/context-window-budgeter/" class="btn-primary text-sm">AI Agent Context Window Budgeter →</a>
      <a href="/tools/agent-memory-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Agent Memory / RAG Cost Calc →</a>
      <a href="/tools/agent-benchmark-selector/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Agent Benchmark Selector →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm mt-10">{note}</p>
  </main>

  <script is:inline define:vars={{ models: models.map(m => ({...m, categorySlug: m.category.toLowerCase().replace(/\s+/g, '-')})), fmtTokens }}>
    const fmtNum = n => n.toLocaleString('en-US');

    let currentCategory = 'all';
    let sortKey = null;
    let sortAsc = true;

    function renderRows() {
      const tbody = document.getElementById('model-tbody');
      let rows = models.slice();
      if (currentCategory !== 'all') {
        rows = rows.filter(m => m.categorySlug === currentCategory);
      }
      if (sortKey) {
        rows.sort((a, b) => {
          const av = a[sortKey] ?? 0;
          const bv = b[sortKey] ?? 0;
          return sortAsc ? (av - bv) : (bv - av);
        });
      }
      tbody.innerHTML = rows.map(m => `
        <tr class="model-row">
          <td class="py-3 pr-4 text-neutral-300">${m.provider}</td>
          <td class="py-3 pr-4 font-semibold text-white">${m.name}${m.notes ? `<p class="text-xs text-neutral-500 font-normal mt-0.5">${m.notes}</p>` : ''}</td>
          <td class="py-3 pr-4 text-right tabular-nums">${fmtTokens(m.context_tokens)}</td>
          <td class="py-3 pr-4 text-right tabular-nums">${fmtTokens(m.max_output_tokens)}</td>
          <td class="py-3 pr-4"><span class="inline-flex px-2 py-1 rounded-md bg-neutral-800 text-neutral-300 text-xs">${m.category}</span></td>
          <td class="py-3 pr-4 text-right tabular-nums">${m.api_pricing_per_1m_input_tokens ? '$'+m.api_pricing_per_1m_input_tokens.toFixed(2) : '—'}</td>
          <td class="py-3 text-right tabular-nums">${m.api_pricing_per_1m_output_tokens ? '$'+m.api_pricing_per_1m_output_tokens.toFixed(2) : '—'}</td>
        </tr>
      `).join('');
    }

    document.querySelectorAll('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('bg-brand-gold/20', 'border-brand-gold/50', 'text-brand-gold'));
        btn.classList.add('bg-brand-gold/20', 'border-brand-gold/50', 'text-brand-gold');
        currentCategory = btn.dataset.category;
        renderRows();
      });
    });

    document.querySelectorAll('#model-table th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const key = th.dataset.sort;
        if (sortKey === key) sortAsc = !sortAsc;
        else { sortKey = key; sortAsc = true; }
        renderRows();
      });
    });

    function calcBudget() {
      const inputs = ['sysTokens','toolTokens','ragTokens','histTokens','outTokens'];
      const vals = inputs.map(id => parseFloat(document.getElementById(id).value) || 0);
      const total = vals.reduce((a, b) => a + b, 0);
      const buffer = Math.ceil(total * 0.2);
      const needed = total + buffer;
      const totalEl = document.getElementById('totalBudget');
      const verdictEl = document.getElementById('budgetVerdict');
      totalEl.textContent = `${fmtNum(total)} tokens (use ~${fmtNum(needed)} with 20% buffer)`;
      const fits1M = needed <= 1000000;
      const fits200K = needed <= 200000;
      const fits128K = needed <= 128000;
      const fits64K = needed <= 64000;
      if (fits64K) verdictEl.textContent = 'Fits almost every major model, including fast/cheap options.';
      else if (fits128K) verdictEl.textContent = 'Fits most frontier, balanced, and open-weight models. Some fast/cheap models may not fit.';
      else if (fits200K) verdictEl.textContent = 'Fits Claude 4 (200K) and Gemini 2.5 / GPT-4.1 (1M). Many budget models will not fit.';
      else if (fits1M) verdictEl.textContent = 'Requires a 1M-token model such as GPT-4.1 or Gemini 2.5.';
      else verdictEl.textContent = 'Budget exceeds 1M tokens. You must truncate, chunk, or summarize inputs.';
    }

    ['sysTokens','toolTokens','ragTokens','histTokens','outTokens'].forEach(id => {
      document.getElementById(id).addEventListener('input', calcBudget);
    });

    renderRows();
    calcBudget();
  </script>
</Layout>
