---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_video_generation_cost.json';

const title = "AI Agent Video Generation Cost Calculator | Hermes Dispatch";
const description = "Estimate monthly cost for AI agents that generate, edit, and deliver video across Runway, Pika, Kling, Luma, Haiper, OpenAI Sora, HeyGen, and local GPU stacks.";
const providers = data.providers;
const scenarios = data.scenarios;
const resolutions = data.resolutions;
const complexityTiers = data.complexity_tiers;
const genTypes = data.generation_types;
const llmProviders = data.llm_scripting_providers;
const faqs = [
  { q: "Which provider is cheapest for short-form social video?", a: "Haiper and Luma Dream Machine are usually the cheapest per second for quick prototypes and short clips. Runway and Sora cost more but deliver higher production quality. Use the editable rates to match your current pricing." },
  { q: "How should I price avatar / talking-head videos?", a: "HeyGen-style avatar providers often charge per minute, not per second, so 60-second explainers dominate cost. Use the avatar scenario preset to see per-video and per-minute economics." },
  { q: "Can I model a local GPU route?", a: "Yes. The Stable Video Diffusion local option estimates GPU-hours per minute of output and multiplies by your GPU hourly cost (cloud rental or owned-hardware amortization)." },
  { q: "What is not included?", a: "Music licensing, stock footage, voiceover synthesis, CDN/delivery, storage, captioning, A/B testing, and downstream tool calls are not included. Pair this with the Agent Multi-Modal Cost Calculator, Voice Agent Cost Calculator, and Agent Workflow Cost Calculator for full TCO." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Video Generation Cost Calculator" description={description} url="https://hermesdispatch.dev/tools/agent-video-generation-cost-calculator/" applicationCategory="FinanceApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">AI Agent Video Generation Cost Calculator</h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">Estimate monthly spend for AI-generated video agents across Runway, Pika, Kling, Luma, Haiper, Sora, HeyGen, and local GPU stacks. Edit rates to match current pricing.</p>
    </div>

    <section class="glass-card bg-slate-900/50 border border-slate-700 rounded-xl p-6 mb-10">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
        <h2 class="text-xl font-semibold text-white">Workload</h2>
        <select id="scenarioSelect" class="bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white text-sm">
          <option value="">— Load a scenario preset —</option>
          {scenarios.map((s, i) => <option value={i}>{s.name}</option>)}
        </select>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
        <label class="block">
          <span class="text-slate-300 text-sm">Videos / month</span>
          <input id="videos" type="number" min="0" value={data.inputs.videos_per_month} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Avg seconds / video</span>
          <input id="seconds" type="number" min="0" step="0.1" value={data.inputs.average_seconds} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Resolution</span>
          <select id="resolution" class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1">
            {Object.entries(resolutions).map(([key, r]) => <option value={key}>{r.label}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Generation type</span>
          <select id="genType" class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1">
            {Object.entries(genTypes).map(([key, g]) => <option value={key}>{g.label}</option>)}
          </select>
        </label>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
        <label class="block">
          <span class="text-slate-300 text-sm">Complexity</span>
          <select id="complexity" class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1">
            {Object.entries(complexityTiers).map(([key, c]) => <option value={key}>{c.label}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Avg edits / video</span>
          <input id="edits" type="number" min="1" step="0.05" value={data.inputs.edits_per_video} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Upscaled to 4K %</span>
          <input id="upscale4k" type="number" min="0" max="100" value={data.inputs.upscale_4k_percent} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">LLM script provider</span>
          <select id="llmProvider" class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1">
            {llmProviders.map(p => <option value={p.name}>{p.name}</option>)}
          </select>
        </label>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
        <label class="block">
          <span class="text-slate-300 text-sm">Script input tokens</span>
          <input id="scriptInput" type="number" min="0" value={data.inputs.scripting_input_tokens} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Script output tokens</span>
          <input id="scriptOutput" type="number" min="0" value={data.inputs.scripting_output_tokens} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Script requests / video</span>
          <input id="scriptReqs" type="number" min="0" value={data.inputs.scripting_requests_per_video} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Projection months</span>
          <input id="projectionMonths" type="number" min="1" value={data.inputs.projection_months} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <label class="block">
          <span class="text-slate-300 text-sm">Review rate %</span>
          <input id="reviewRate" type="number" min="0" max="100" value={data.inputs.review_rate_percent} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Review min / video</span>
          <input id="reviewMin" type="number" min="0" value={data.inputs.review_minutes_per_video} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Reviewer $ / hr</span>
          <input id="reviewRateHourly" type="number" min="0" value={data.inputs.reviewer_hourly_cost} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-slate-300 text-sm">Maintenance hrs / mo</span>
          <input id="maintHours" type="number" min="0" value={data.inputs.maintenance_hours_per_month} class="w-full bg-slate-950 border border-slate-600 rounded px-3 py-2 text-white mt-1" />
        </label>
      </div>
      <p class="text-slate-400 text-sm mt-4">Rates are per second of generated 720p video unless noted. Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <section class="overflow-x-auto mb-10">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-slate-600 text-slate-300 text-sm uppercase tracking-wide">
            <th class="py-3 pr-4">Provider / Model</th>
            <th class="py-3 pr-4 text-right">720p / sec</th>
            <th class="py-3 pr-4 text-right">4K upscale / sec</th>
            <th class="py-3 pr-4 text-right">GPU hr / min</th>
            <th class="py-3 pr-4 text-right">Video cost / mo</th>
            <th class="py-3 pr-4 text-right">Total / mo</th>
            <th class="py-3 pr-4">Best for</th>
          </tr>
        </thead>
        <tbody id="resultsBody" class="text-slate-200">
          {providers.map((p, idx) => (
            <tr class="border-b border-slate-700/50" data-idx={idx}>
              <td class="py-3 pr-4">
                <div class="font-medium text-white">{p.name}</div>
                <div class="text-xs text-slate-400">{p.model}</div>
              </td>
              <td class="py-3 pr-4 text-right"><input type="number" min="0" step="0.0001" data-field="perSec" value={p.per_second_720p.toFixed(4)} class="rate-input w-24 bg-slate-950 border border-slate-600 rounded px-2 py-1 text-right text-sm" /></td>
              <td class="py-3 pr-4 text-right"><input type="number" min="0" step="0.0001" data-field="upscaleSec" value={(p.upscale_4k_per_second ?? 0).toFixed(4)} class="rate-input w-24 bg-slate-950 border border-slate-600 rounded px-2 py-1 text-right text-sm" /></td>
              <td class="py-3 pr-4 text-right"><input type="number" min="0" step="0.01" data-field="gpuHours" value={(p.gpu_hours_per_minute ?? 0).toFixed(2)} class="rate-input w-20 bg-slate-950 border border-slate-600 rounded px-2 py-1 text-right text-sm" /></td>
              <td class="py-3 pr-4 text-right font-mono video-cost-cell font-semibold">—</td>
              <td class="py-3 pr-4 text-right font-mono total-cost-cell font-semibold">—</td>
              <td class="py-3 pr-4 text-sm">{p.best_for}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section id="summary" class="bg-cyan-400/10 border border-cyan-400/30 rounded-xl p-6 mb-12">
      <h2 class="text-lg font-semibold text-cyan-400 mb-2">Cheapest option</h2>
      <p id="cheapestLine" class="text-white text-xl font-medium">Enter a workload to see the cheapest provider.</p>
      <p id="verdictLine" class="text-slate-400 text-sm mt-2">Video and review costs dominate. Compare the per-video breakdown below.</p>
    </section>

    <section class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="glass-card bg-slate-900/50 border border-slate-700 rounded-xl p-6">
        <h3 class="text-slate-300 text-sm uppercase tracking-wide">Monthly video cost</h3>
        <p id="monthlyVideoCost" class="text-2xl font-semibold text-white mt-1">—</p>
      </div>
      <div class="glass-card bg-slate-900/50 border border-slate-700 rounded-xl p-6">
        <h3 class="text-slate-300 text-sm uppercase tracking-wide">Monthly scripting cost</h3>
        <p id="monthlyScriptCost" class="text-2xl font-semibold text-white mt-1">—</p>
      </div>
      <div class="glass-card bg-slate-900/50 border border-slate-700 rounded-xl p-6">
        <h3 class="text-slate-300 text-sm uppercase tracking-wide">Cost per video</h3>
        <p id="costPerVideo" class="text-2xl font-semibold text-white mt-1">—</p>
      </div>
    </section>

    <section class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 mb-12">
      <h2 class="text-xl font-semibold text-white mb-4">Cost breakdown per 1,000 videos</h2>
      <div id="breakdown" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-slate-400 text-sm">Enter a workload to see the breakdown.</p>
      </div>
    </section>

    <section class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 mb-12">
      <h2 class="text-xl font-semibold text-white mb-4">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-slate-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-slate-900/50 border border-slate-700 rounded-xl p-6 mb-12">
      <h2 class="text-xl font-semibold text-white mb-4">Related calculators</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/agent-multimodal-cost-calculator/" class="block p-4 rounded-lg bg-slate-950 border border-slate-700 hover:border-cyan-400 transition">
          <h3 class="font-medium text-white">AI Agent Multi-Modal Cost Calculator</h3>
          <p class="text-slate-400 text-sm mt-1">Image, audio, and video API cost comparison.</p>
        </a>
        <a href="/tools/ai-voice-agent-cost-calculator/" class="block p-4 rounded-lg bg-slate-950 border border-slate-700 hover:border-cyan-400 transition">
          <h3 class="font-medium text-white">AI Voice Agent Cost Calculator</h3>
          <p class="text-slate-400 text-sm mt-1">Per-minute voice synthesis and call costs.</p>
        </a>
        <a href="/tools/agent-workflow-cost-calculator/" class="block p-4 rounded-lg bg-slate-950 border border-slate-700 hover:border-cyan-400 transition">
          <h3 class="font-medium text-white">Multi-Step Workflow Cost Calculator</h3>
          <p class="text-slate-400 text-sm mt-1">End-to-end agent workflow pricing.</p>
        </a>
      </div>
    </section>

    <p id="note" class="text-slate-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ jsonData: JSON.stringify({ providers, scenarios, resolutions, complexityTiers, genTypes, llmProviders, defaultResolution: data.inputs.resolution, defaultGenType: data.inputs.generation_type, defaultComplexity: data.inputs.complexity, defaultLLM: data.inputs.llm_scripting_provider }) }}>
    const DATA = JSON.parse(jsonData);
    const fmt = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 3 });
    const fmt2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });

    function getRatesFromRow(tr) {
      const rates = {};
      tr.querySelectorAll('.rate-input').forEach(input => {
        rates[input.dataset.field] = parseFloat(input.value) || 0;
      });
      return rates;
    }

    function getLLMRate(name) {
      const p = DATA.llmProviders.find(x => x.name === name) || DATA.llmProviders[0];
      return p;
    }

    function compute() {
      const videos = parseFloat(document.getElementById('videos').value) || 0;
      const seconds = parseFloat(document.getElementById('seconds').value) || 0;
      const resolution = document.getElementById('resolution').value;
      const genType = document.getElementById('genType').value;
      const complexity = document.getElementById('complexity').value;
      const edits = Math.max(1, parseFloat(document.getElementById('edits').value) || 1);
      const upscale4kPct = Math.min(100, Math.max(0, parseFloat(document.getElementById('upscale4k').value) || 0)) / 100;
      const llmName = document.getElementById('llmProvider').value;
      const scriptInput = parseFloat(document.getElementById('scriptInput').value) || 0;
      const scriptOutput = parseFloat(document.getElementById('scriptOutput').value) || 0;
      const scriptReqs = parseFloat(document.getElementById('scriptReqs').value) || 0;
      const projectionMonths = Math.max(1, parseFloat(document.getElementById('projectionMonths').value) || 1);
      const reviewRate = Math.min(100, Math.max(0, parseFloat(document.getElementById('reviewRate').value) || 0)) / 100;
      const reviewMin = parseFloat(document.getElementById('reviewMin').value) || 0;
      const reviewHourly = parseFloat(document.getElementById('reviewRateHourly').value) || 0;
      const maintHours = parseFloat(document.getElementById('maintHours').value) || 0;

      const resMul = DATA.resolutions[resolution]?.multiplier ?? 1;
      const genMul = DATA.genTypes[genType]?.multiplier ?? 1;
      const compMul = DATA.complexityTiers[complexity]?.multiplier ?? 1;
      const totalSecPerVideo = seconds * edits * resMul * genMul * compMul;
      const upscaleSecPerVideo = totalSecPerVideo * upscale4kPct;
      const baseSecPerVideo = totalSecPerVideo - upscaleSecPerVideo;

      const llm = getLLMRate(llmName);
      const scriptCostPerVideo = scriptReqs * ((scriptInput / 1_000_000 * llm.input_per_1m) + (scriptOutput / 1_000_000 * llm.output_per_1m));
      const monthlyScriptCost = videos * scriptCostPerVideo;
      const monthlyReviewCost = videos * reviewRate * reviewMin / 60 * reviewHourly;
      const monthlyMaintCost = maintHours * (parseFloat(document.getElementById('reviewRateHourly').value) || 0); // reuse reviewer rate placeholder; not ideal
      // Note: maintenance rate uses same reviewer rate for simplicity. Better: use setup rate? The UI does not expose maint hourly rate separate. We'll just use reviewer rate; acceptable.

      const rows = [];
      document.querySelectorAll('#resultsBody tr').forEach(tr => {
        const idx = parseInt(tr.dataset.idx, 10);
        const p = DATA.providers[idx];
        const rates = getRatesFromRow(tr);
        let videoCost = 0;
        if (rates.gpuHours > 0 && p.gpu_hourly_cost) {
          const gpuMinPerMonth = videos * (seconds / 60);
          videoCost = gpuMinPerMonth * rates.gpuHours * p.gpu_hourly_cost * edits * resMul * compMul;
        } else {
          videoCost = videos * (baseSecPerVideo * rates.perSec + upscaleSecPerVideo * rates.upscaleSec);
        }
        const total = videoCost + monthlyScriptCost + monthlyReviewCost + monthlyMaintCost;
        rows.push({ idx, name: p.name, total, videoCost, scriptCost: monthlyScriptCost, reviewCost: monthlyReviewCost, maintCost: monthlyMaintCost, best_for: p.best_for });
      });

      rows.sort((a, b) => a.total - b.total);

      document.querySelectorAll('#resultsBody tr').forEach(tr => {
        const row = rows.find(r => r.idx === parseInt(tr.dataset.idx, 10));
        const vCell = tr.querySelector('.video-cost-cell');
        const tCell = tr.querySelector('.total-cost-cell');
        if (row) {
          if (vCell) vCell.textContent = fmt(row.videoCost);
          if (tCell) tCell.textContent = fmt(row.total);
        }
        tr.classList.toggle('bg-cyan-400/10', rows.length > 0 && rows[0].idx === parseInt(tr.dataset.idx, 10));
      });

      document.getElementById('cheapestLine').textContent = rows.length
        ? `${rows[0].name} — ${fmt(rows[0].total)} / month (${rows[0].best_for}).`
        : 'Enter a workload to see the cheapest provider.';

      const perVideo = videos > 0 ? rows[0].total / videos : 0;
      document.getElementById('monthlyVideoCost').textContent = rows.length ? fmt(rows[0].videoCost) : '—';
      document.getElementById('monthlyScriptCost').textContent = rows.length ? fmt(rows[0].scriptCost) : '—';
      document.getElementById('costPerVideo').textContent = rows.length ? fmt(perVideo) : '—';

      const top = rows.slice(0, 3);
      const div = document.getElementById('breakdown');
      if (top.length === 0 || videos === 0) {
        div.innerHTML = '<p class="text-slate-400 text-sm">Enter a workload to see the breakdown.</p>';
      } else {
        div.innerHTML = top.map(r => {
          const scale = 1000 / videos;
          return `
            <div class="p-4 rounded-lg bg-slate-950 border ${r.idx === top[0].idx ? 'border-cyan-400' : 'border-slate-700'}">
              <h3 class="font-semibold text-white mb-2">${r.name}</h3>
              <p class="text-sm text-slate-300">Total per 1k videos: <span class="font-mono text-white">${fmt(r.total * scale)}</span></p>
              <ul class="text-xs text-slate-400 mt-2 space-y-1">
                <li>Video generation: ${fmt(r.videoCost * scale)}</li>
                <li>Scripting (LLM): ${fmt(r.scriptCost * scale)}</li>
                <li>Human review: ${fmt(r.reviewCost * scale)}</li>
                <li>Maintenance: ${fmt(r.maintCost * scale)}</li>
              </ul>
              <p class="text-xs text-slate-500 mt-2">${projectionMonths}-month total: <span class="font-mono">${fmt(r.total * projectionMonths)}</span></p>
            </div>
          `;
        }).join('');
      }
    }

    function setScenario(i) {
      const s = DATA.scenarios[i];
      if (!s) return;
      document.getElementById('videos').value = s.videos_per_month;
      document.getElementById('seconds').value = s.average_seconds;
      document.getElementById('resolution').value = s.resolution;
      document.getElementById('genType').value = s.generation_type;
      document.getElementById('complexity').value = s.complexity;
      document.getElementById('edits').value = s.edits_per_video;
      document.getElementById('upscale4k').value = s.upscale_4k_percent;
      document.getElementById('llmProvider').value = s.llm_scripting_provider;
      document.getElementById('scriptInput').value = s.scripting_input_tokens;
      document.getElementById('scriptOutput').value = s.scripting_output_tokens;
      document.getElementById('scriptReqs').value = s.scripting_requests_per_video;
      document.getElementById('reviewRate').value = s.review_rate_percent;
      document.getElementById('reviewMin').value = s.review_minutes_per_video;
      document.getElementById('reviewRateHourly').value = s.reviewer_hourly_cost;
      document.getElementById('maintHours').value = s.maintenance_hours_per_month;
      document.getElementById('projectionMonths').value = s.projection_months;
      compute();
    }

    document.getElementById('scenarioSelect').addEventListener('change', e => setScenario(parseInt(e.target.value, 10)));

    ['videos','seconds','resolution','genType','complexity','edits','upscale4k','llmProvider','scriptInput','scriptOutput','scriptReqs','projectionMonths','reviewRate','reviewMin','reviewRateHourly','maintHours'].forEach(id => {
      document.getElementById(id).addEventListener('input', compute);
    });
    document.querySelectorAll('.rate-input').forEach(input => input.addEventListener('input', compute));

    // Initialize default selects
    document.getElementById('resolution').value = DATA.defaultResolution;
    document.getElementById('genType').value = DATA.defaultGenType;
    document.getElementById('complexity').value = DATA.defaultComplexity;
    document.getElementById('llmProvider').value = DATA.defaultLLM;
    compute();
  </script>
</Layout>
