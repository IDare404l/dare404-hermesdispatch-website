---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/crypto_tax_loss_harvester.json';

const title = "Crypto Tax Loss Harvesting Calculator | Hermes Dispatch";
const description = "Estimate how much tax you can save by harvesting crypto losses against short-term and long-term gains, plus leftover ordinary income offsets. Model wash-sale risk if rules change.";
const defaults = data.defaults;
const scenarios = data.scenarios;

const faqs = [
  { q: "What is tax loss harvesting for crypto?", a: "You sell assets that have lost value to realize a capital loss, then use that loss to offset capital gains and up to $3,000 of ordinary income per year. Any remaining loss carries forward to future tax years." },
  { q: "Does crypto have a wash-sale rule?", a: "In the US, crypto currently is not subject to the wash-sale rule because it is treated as property rather than a security. This means you can sell at a loss and immediately rebuy. Legislation has been proposed to close this loophole, so the calculator shows what changes if a wash-sale rule is applied." },
  { q: "Should I harvest short-term or long-term losses first?", a: "Short-term losses offset short-term gains first, which are taxed at your ordinary income rate. That usually gives the biggest immediate tax benefit. Long-term losses offset long-term gains, which are taxed at lower capital-gains rates." },
  { q: "What if my losses are bigger than my gains?", a: "First, losses offset gains of the same character. Then net losses can offset up to $3,000 of ordinary income per year for US taxpayers. Anything left carries forward indefinitely to future years." },
  { q: "Is this tax advice?", a: "No. This is an educational estimator. Tax rules, rates, and wash-sale treatment differ by jurisdiction and change often. Consult a qualified tax professional before making trades." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="Crypto Tax Loss Harvesting Calculator" description={description} url="https://hermesdispatch.dev/tools/crypto-tax-loss-harvester/" applicationCategory="FinanceApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🌾</div>
      <h1 class="display-heading mb-4">Crypto Tax Loss Harvesting Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate how much tax you can save by harvesting crypto losses against short-term and long-term gains, plus leftover ordinary income offsets.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario preset</h2>
      <div class="flex flex-wrap gap-3" id="scenario-buttons">
        {scenarios.map((s, i) => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)} data-index={i}>
            {s.name}
          </button>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold flex items-center gap-2"><span>📈</span> Realized gains this year</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Short-term capital gains ($)</span><input id="shortGains" type="number" min="0" step="100" value={defaults.realized_short_term_gains} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Long-term capital gains ($)</span><input id="longGains" type="number" min="0" step="100" value={defaults.realized_long_term_gains} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>

        <h2 class="text-xl font-bold mt-8 mb-4 text-brand-gold flex items-center gap-2"><span>💸</span> Tax rates</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Federal short-term capital gains rate (%)</span><input id="shortRate" type="number" min="0" max="100" step="0.01" value={defaults.federal_short_term_rate * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Federal long-term capital gains rate (%)</span><input id="longRate" type="number" min="0" max="100" step="0.01" value={defaults.federal_long_term_rate * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">State tax rate (%)</span><input id="stateRate" type="number" min="0" max="100" step="0.01" value={defaults.state_rate * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Net Investment Income Tax rate (%)</span><input id="niiRate" type="number" min="0" max="100" step="0.01" value={defaults.nii_rate * 100} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="subjectToNii" type="checkbox" checked={defaults.subject_to_nii} class="w-4 h-4 rounded bg-neutral-900 border-neutral-700 text-brand-gold" />
            <span class="text-neutral-400 text-sm">Gains subject to NII tax</span>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">Annual ordinary income offset limit ($)</span><input id="ordinaryLimit" type="number" min="0" step="100" value={defaults.ordinary_income_offset_limit} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>

        <h2 class="text-xl font-bold mt-8 mb-4 text-brand-gold flex items-center gap-2"><span>🔁</span> Rebuy assumptions</h2>
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="planToRebuy" type="checkbox" checked={defaults.plan_to_rebuy} class="w-4 h-4 rounded bg-neutral-900 border-neutral-700 text-brand-gold" />
          <span class="text-neutral-400 text-sm">Plan to immediately rebuy the same crypto</span>
        </label>
        <p id="washSaleWarning" class="text-sm text-amber-400 mt-2 hidden">If US crypto becomes subject to a wash-sale rule, you would need to wait 30 days to rebuy, or buy a different asset, to claim the loss.</p>
      </div>

      <div class="space-y-6">
        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-brand-gold">Unrealized loss positions</h2>
            <button id="addRow" type="button" class="px-3 py-1.5 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm">+ Add position</button>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-neutral-500 border-b border-neutral-800">
                  <th class="py-2 pr-2">Symbol</th>
                  <th class="py-2 pr-2">Qty</th>
                  <th class="py-2 pr-2">Cost basis</th>
                  <th class="py-2 pr-2">Price</th>
                  <th class="py-2 pr-2 text-right">Unrealized P/L</th>
                  <th class="py-2 pl-2 text-center">Harvest</th>
                  <th class="py-2 pl-2"></th>
                </tr>
              </thead>
              <tbody id="holdingsTable"></tbody>
            </table>
          </div>
          <p class="text-neutral-500 text-sm mt-4">Check the <strong>Harvest</strong> column to include a position. The calculator optimizes losses against short-term gains first.</p>
        </section>

        <section id="summary" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Total harvestable loss</p><p id="totalLoss" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Tax savings this year</p><p id="taxSavings" class="text-2xl font-bold text-brand-gold">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Short-term gain offset</p><p id="stOffset" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Long-term gain offset</p><p id="ltOffset" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Ordinary income offset</p><p id="ordinaryOffset" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Loss carried forward</p><p id="carryForward" class="text-2xl font-bold text-white">—</p></div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">Verdict</h2>
          <p id="verdictText" class="text-neutral-300">—</p>
        </section>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">How the math works</h2>
      <ul class="list-disc pl-5 text-neutral-300 space-y-2">
        <li>Harvested short-term losses first offset short-term gains, which are taxed at the highest rate.</li>
        <li>Remaining losses then offset long-term gains at the long-term rate.</li>
        <li>If net losses remain, up to the ordinary-income offset limit reduces ordinary income.</li>
        <li>Any loss still left carries forward to future years.</li>
        <li>State tax savings are estimated by applying the state rate to the same total offset. NII tax is added only if selected.</li>
      </ul>
      <p class="text-neutral-500 text-sm mt-6">Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-neutral-900/50 rounded-xl border border-neutral-800">
            <summary class="p-4 cursor-pointer font-medium text-neutral-200 flex justify-between items-center">{f.q}<span class="text-brand-gold group-open:rotate-180 transition-transform">▼</span></summary>
            <p class="p-4 pt-0 text-neutral-400">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <p id="note" class="text-neutral-500 text-sm mt-10">{data.note}</p>
  </main>

  <script is:inline define:vars={{ defaults, scenarios }}>
    function $(id) { return document.getElementById(id); }
    function val(id) { return parseFloat($(id).value) || 0; }
    function pct(id) { return Math.min(100, Math.max(0, val(id) / 100)); }
    function checked(id) { return $(id).checked; }
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtMoney2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });

    let holdings = JSON.parse(JSON.stringify(defaults.holdings));

    function renderTable() {
      const tbody = $('holdingsTable');
      tbody.innerHTML = '';
      holdings.forEach((h, i) => {
        const loss = (h.quantity * h.current_price) - (h.quantity * h.cost_basis_per_unit);
        const tr = document.createElement('tr');
        tr.className = 'border-b border-neutral-800/50';
        tr.innerHTML = `
          <td class="py-2 pr-2"><input type="text" data-idx="${i}" data-field="symbol" value="${h.symbol}" class="w-20 bg-neutral-900 border border-neutral-700 rounded px-2 py-1 text-white text-sm" /></td>
          <td class="py-2 pr-2"><input type="number" data-idx="${i}" data-field="quantity" value="${h.quantity}" min="0" step="any" class="w-24 bg-neutral-900 border border-neutral-700 rounded px-2 py-1 text-white text-sm" /></td>
          <td class="py-2 pr-2"><input type="number" data-idx="${i}" data-field="cost_basis_per_unit" value="${h.cost_basis_per_unit}" min="0" step="any" class="w-28 bg-neutral-900 border border-neutral-700 rounded px-2 py-1 text-white text-sm" /></td>
          <td class="py-2 pr-2"><input type="number" data-idx="${i}" data-field="current_price" value="${h.current_price}" min="0" step="any" class="w-28 bg-neutral-900 border border-neutral-700 rounded px-2 py-1 text-white text-sm" /></td>
          <td class="py-2 pr-2 text-right font-mono text-sm ${loss < 0 ? 'text-red-400' : 'text-emerald-400'}">${fmtMoney2(loss)}</td>
          <td class="py-2 pl-2 text-center"><input type="checkbox" data-idx="${i}" data-field="harvest" ${h.harvest !== false ? 'checked' : ''} class="w-4 h-4 rounded bg-neutral-900 border-neutral-700 text-brand-gold" /></td>
          <td class="py-2 pl-2"><button type="button" data-del="${i}" class="text-neutral-500 hover:text-red-400 text-sm">×</button></td>
        `;
        tbody.appendChild(tr);
      });

      tbody.querySelectorAll('input').forEach(input => {
        input.addEventListener('input', e => {
          const i = parseInt(e.target.dataset.idx);
          const field = e.target.dataset.field;
          if (field === 'symbol') holdings[i][field] = e.target.value;
          else if (field === 'harvest') holdings[i][field] = e.target.checked;
          else holdings[i][field] = parseFloat(e.target.value) || 0;
          calc();
          if (field === 'symbol') renderTable();
        });
      });

      tbody.querySelectorAll('button[data-del]').forEach(btn => {
        btn.addEventListener('click', () => {
          holdings.splice(parseInt(btn.dataset.del), 1);
          renderTable();
          calc();
        });
      });
    }

    function addRow(h = { symbol: 'NEW', quantity: 1, cost_basis_per_unit: 0, current_price: 0, harvest: true }) {
      holdings.push(h);
      renderTable();
      calc();
    }

    function calc() {
      const shortGains = Math.max(0, val('shortGains'));
      const longGains = Math.max(0, val('longGains'));
      const shortRate = pct('shortRate');
      const longRate = pct('longRate');
      const stateRate = pct('stateRate');
      const niiRate = pct('niiRate');
      const subjectToNii = checked('subjectToNii');
      const ordinaryLimit = Math.max(0, val('ordinaryLimit'));
      const planRebuy = checked('planToRebuy');

      $('washSaleWarning').classList.toggle('hidden', !planRebuy);

      let stLoss = 0;
      let ltLoss = 0;
      holdings.filter(h => h.harvest !== false && (h.quantity * h.current_price) < (h.quantity * h.cost_basis_per_unit)).forEach(h => {
        const loss = (h.quantity * h.cost_basis_per_unit) - (h.quantity * h.current_price);
        // Assume all crypto held under 1 year is short-term; over 1 year is long-term for estimator.
        // User can model by splitting symbols; we bucket 60/40 short/long as a default.
        stLoss += loss * 0.6;
        ltLoss += loss * 0.4;
      });
      stLoss = Math.max(0, stLoss);
      ltLoss = Math.max(0, ltLoss);
      const totalLoss = stLoss + ltLoss;

      // Apply losses: ST losses -> ST gains, LT losses -> LT gains. Then net ST/LT against each other.
      const stNet = Math.max(0, shortGains - stLoss);
      const remainingStLoss = Math.max(0, stLoss - shortGains);
      const ltNet1 = Math.max(0, longGains - ltLoss);
      const remainingLtLoss = Math.max(0, ltLoss - longGains);

      // Cross-offset remaining losses against opposite character gains
      const stLossVsLt = Math.min(remainingStLoss, longGains - (longGains - ltLoss));
      // Simpler: after initial same-character offset, compute net gain/loss per character.
      let netStGain = shortGains - stLoss;
      let netLtGain = longGains - ltLoss;
      let netLoss = 0;
      if (netStGain < 0 && netLtGain > 0) {
        const absorb = Math.min(-netStGain, netLtGain);
        netStGain += absorb;
        netLtGain -= absorb;
      } else if (netLtGain < 0 && netStGain > 0) {
        const absorb = Math.min(-netLtGain, netStGain);
        netLtGain += absorb;
        netStGain -= absorb;
      }
      const stOffset = shortGains - Math.max(0, netStGain);
      const ltOffset = longGains - Math.max(0, netLtGain);
      netLoss = -(Math.min(0, netStGain) + Math.min(0, netLtGain));

      const ordinaryOffset = Math.min(Math.max(0, netLoss), ordinaryLimit);
      const carryForward = Math.max(0, netLoss - ordinaryOffset);

      // Tax savings = offset amounts * blended federal rate + state + nii if applicable.
      const blendedFederalRate = totalLoss > 0 ? ((stOffset * shortRate) + (ltOffset * longRate)) / totalLoss : 0;
      const baseSavings = (stOffset * shortRate) + (ltOffset * longRate) + (ordinaryOffset * shortRate);
      const stateSavings = (stOffset + ltOffset + ordinaryOffset) * stateRate;
      const niiSavings = subjectToNii ? (stOffset + ltOffset) * niiRate : 0;
      const taxSavings = baseSavings + stateSavings + niiSavings;

      $('totalLoss').textContent = fmtMoney(totalLoss);
      $('taxSavings').textContent = fmtMoney(taxSavings);
      $('stOffset').textContent = fmtMoney(stOffset);
      $('ltOffset').textContent = fmtMoney(ltOffset);
      $('ordinaryOffset').textContent = fmtMoney(Math.max(0, ordinaryOffset));
      $('carryForward').textContent = fmtMoney(Math.max(0, carryForward));

      let verdict = '';
      if (totalLoss <= 0) {
        verdict = 'No harvestable losses on the selected positions. Add positions trading below cost basis to see potential tax savings.';
      } else {
        verdict = `Harvesting ${fmtMoney(totalLoss)} in losses could save approximately ${fmtMoney(taxSavings)} in taxes this year. `;
        if (taxSavings > 0) {
          const effectiveRate = totalLoss > 0 ? (taxSavings / totalLoss * 100).toFixed(1) : 0;
          verdict += `That is an effective tax benefit of about ${effectiveRate}% of every dollar harvested. `;
        }
        if (carryForward > 0) {
          verdict += `After the current-year offsets, ${fmtMoney(carryForward)} carries forward to future years. `;
        }
        if (planRebuy) {
          verdict += 'Because you plan to rebuy immediately, remember that a future US wash-sale rule could disallow the loss unless you wait 30 days or buy a different asset.';
        }
      }
      $('verdictText').textContent = verdict;
    }

    function applyScenario(s) {
      $('shortGains').value = s.realized_short_term_gains;
      $('longGains').value = s.realized_long_term_gains;
      $('shortRate').value = s.federal_short_term_rate * 100;
      $('longRate').value = s.federal_long_term_rate * 100;
      $('stateRate').value = s.state_rate * 100;
      $('niiRate').value = s.nii_rate * 100;
      $('subjectToNii').checked = s.subject_to_nii;
      $('ordinaryLimit').value = s.ordinary_income_offset_limit;
      $('planToRebuy').checked = s.plan_to_rebuy;
      holdings = JSON.parse(JSON.stringify(s.holdings)).map(h => ({ ...h, harvest: true }));
      renderTable();
      calc();
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          applyScenario(JSON.parse(btn.dataset.scenario));
          document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('bg-brand-gold', 'text-neutral-950', 'border-brand-gold'));
          btn.classList.add('bg-brand-gold', 'text-neutral-950', 'border-brand-gold');
        });
      });

      $('addRow').addEventListener('click', () => addRow());

      ['shortGains','longGains','shortRate','longRate','stateRate','niiRate','subjectToNii','ordinaryLimit','planToRebuy'].forEach(id => {
        $(id).addEventListener('input', calc);
      });

      renderTable();
      calc();
    });
  </script>
</Layout>
