---
import Layout from '../../layouts/Layout.astro';
import data from '../../data/startup_runway.json';
import AgentCodeBlock from '../../components/AgentCodeBlock.astro';

const title = "Startup Runway Calculator — Months of Cash, Zero-Cash Date, Fundraising Signal";
const description = "Calculate how many months your startup can operate before cash runs out. Model burn, revenue growth, fundraising target, and zero-cash date.";
const defaults = data.defaults;
const scenarios = data.scenarios;
const milestones = data.milestones;
const faq = data.faq;
---

<Layout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(q => ({
      "@type": "Question",
      "name": q.question,
      "acceptedAnswer": { "@type": "Answer", "text": q.answer }
    }))
  })} />

  <section class="relative pt-24 pb-12 overflow-hidden">
    <div class="absolute inset-0 animated-gradient opacity-50"></div>
    <div class="grid-overlay"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🛫</div>
        <h1 class="display-heading mb-4">Startup Runway Calculator</h1>
        <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
          Model your cash, burn, revenue growth, and next round. Know exactly when the tank hits empty — and when to start fundraising.
        </p>
      </div>

      <!-- Scenarios -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-8">
        {scenarios.map(s => (
          <button type="button" class="scenario-btn glass-card rounded-xl p-4 text-left hover:border-brand-gold/50 transition-all" data-slug={s.slug}>
            <div class="text-2xl mb-2">{s.icon}</div>
            <h3 class="font-semibold text-sm">{s.name}</h3>
          </button>
        ))}
      </div>

      <div class="grid lg:grid-cols-3 gap-6 mb-8">
        <!-- Inputs -->
        <div class="lg:col-span-2 glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-5 text-brand-gold">Startup inputs</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Cash on hand ($)</label>
              <input id="cash" type="number" min="0" step="1000" value={defaults.cash_on_hand} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Monthly burn ($)</label>
              <input id="burn" type="number" min="0" step="100" value={defaults.monthly_burn} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Monthly revenue ($)</label>
              <input id="revenue" type="number" min="0" step="100" value={defaults.monthly_revenue} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Fundraising target ($)</label>
              <input id="fundraise" type="number" min="0" step="1000" value={defaults.fundraising_target} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
              <p class="text-xs text-neutral-500 mt-1">Leave 0 to ignore.</p>
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Burn growth (%/month)</label>
              <input id="burnGrowth" type="number" step="0.1" value={defaults.burn_growth_rate_pct_per_month} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
              <p class="text-xs text-neutral-500 mt-1">Negative = cost cutting.</p>
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Revenue growth (%/month)</label>
              <input id="revenueGrowth" type="number" step="0.1" value={defaults.revenue_growth_rate_pct_per_month} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Target runway (months)</label>
              <input id="targetRunway" type="number" min="1" step="1" value={defaults.target_runway_months} class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
            </div>
            <div>
              <label class="block text-sm text-neutral-400 mb-1">Fundraise closes in (months)</label>
              <input id="fundraiseMonths" type="number" min="0" max="36" step="1" value="0" class="w-full px-3 py-2 rounded-lg bg-neutral-800 border border-neutral-700 text-white" />
              <p class="text-xs text-neutral-500 mt-1">When the round lands, if planned.</p>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <button id="calcBtn" type="button" class="btn-primary">Update runway</button>
            <button id="resetBtn" type="button" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Reset</button>
          </div>
        </div>

        <!-- Outputs -->
        <div class="space-y-4">
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20">
            <p class="text-xs text-neutral-500 uppercase mb-1">Net monthly burn</p>
            <p id="netBurn" class="text-2xl font-bold text-brand-gold">—</p>
          </div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20">
            <p class="text-xs text-neutral-500 uppercase mb-1">Projected runway</p>
            <p id="runway" class="text-3xl font-bold text-brand-gold">—</p>
            <p id="runwayVerdict" class="text-sm text-neutral-400 mt-1">—</p>
          </div>
          <div class="glass-card rounded-2xl p-5 text-center border border-red-500/20">
            <p class="text-xs text-neutral-500 uppercase mb-1">Zero-cash date</p>
            <p id="zeroDate" class="text-2xl font-bold text-red-400">—</p>
          </div>
          <div class="glass-card rounded-2xl p-5 text-center border border-emerald-500/20">
            <p class="text-xs text-neutral-500 uppercase mb-1">After planned raise</p>
            <p id="afterRaise" class="text-2xl font-bold text-emerald-400">—</p>
          </div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20">
            <p class="text-xs text-neutral-500 uppercase mb-1">Start fundraising by</p>
            <p id="startFundraiseBy" class="text-lg font-bold">—</p>
          </div>
        </div>
      </div>

      <!-- Chart table -->
      <div class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
          <h2 class="text-xl font-bold">Monthly cash forecast</h2>
          <div class="text-sm text-neutral-400">
            <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-emerald-500/20 border border-emerald-500/30 inline-block"></span> Safe</span>
            <span class="inline-flex items-center gap-1 ml-4"><span class="w-3 h-3 rounded-sm bg-amber-500/20 border border-amber-500/30 inline-block"></span> {milestones.cash_low_warning_months}-month warning</span>
            <span class="inline-flex items-center gap-1 ml-4"><span class="w-3 h-3 rounded-sm bg-red-500/20 border border-red-500/30 inline-block"></span> Critical</span>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-neutral-500 border-b border-neutral-800">
              <tr>
                <th class="text-left py-2">Month</th>
                <th class="text-right py-2">Burn</th>
                <th class="text-right py-2">Revenue</th>
                <th class="text-right py-2">Net burn</th>
                <th class="text-right py-2">Cash end</th>
                <th class="text-left py-2 pl-4">Status</th>
              </tr>
            </thead>
            <tbody id="forecastTable" class="divide-y divide-neutral-800">
              <tr><td colspan="6" class="py-4 text-neutral-500 text-center">Click "Update runway" to generate forecast.</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Explanations -->
      <div class="grid md:grid-cols-2 gap-6">
        <div class="glass-card rounded-2xl p-6">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">How this calculator works</h2>
          <ul class="space-y-2 text-neutral-300 text-sm">
            <li><strong class="text-white">Net burn</strong> = monthly burn minus monthly revenue.</li>
            <li><strong class="text-white">Growth rates</strong> compound month over month for burn and revenue.</li>
            <li><strong class="text-white">Runway</strong> is how many months until cash hits zero, capped at 120 months.</li>
            <li><strong class="text-white">Fundraising</strong> adds the target amount to cash when the round closes.</li>
            <li><strong class="text-white">Start fundraising by</strong> is {milestones.fundraise_start_months_before_zero} months before zero-cash date.</li>
          </ul>
        </div>
        <div class="glass-card rounded-2xl p-6">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">What to do next</h2>
          <ul class="space-y-2 text-neutral-300 text-sm">
            <li>• Pair with the <a href="/tools/ai-startup-cost-calculator/" class="text-brand-gold hover:underline">AI Startup Cost Calculator</a> to build a detailed burn model.</li>
            <li>• Use the <a href="/tools/llm-cost-calculator/" class="text-brand-gold hover:underline">LLM Cost Calculator</a> to sanity-check your AI API spend.</li>
            <li>• Update assumptions monthly; even small revenue growth changes the zero-cash date.</li>
            <li>• Start investor conversations {milestones.fundraise_start_months_before_zero} months before you need the check.</li>
          </ul>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/tools/ai-startup-cost-calculator/" class="btn-primary text-sm">AI Startup Cost Calculator →</a>
        <a href="/tools/local-llm-roi-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Local LLM ROI Calc →</a>
      </div>
    </div>
  </section>

  <script define:vars={{ defaults, scenarios, milestones }}>
    const fmt = n => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
    const fmtK = n => n >= 1000 ? (n / 1000).toFixed(1) + 'K' : n;

    const cash = document.getElementById('cash');
    const burn = document.getElementById('burn');
    const revenue = document.getElementById('revenue');
    const fundraise = document.getElementById('fundraise');
    const burnGrowth = document.getElementById('burnGrowth');
    const revenueGrowth = document.getElementById('revenueGrowth');
    const targetRunway = document.getElementById('targetRunway');
    const fundraiseMonths = document.getElementById('fundraiseMonths');
    const calcBtn = document.getElementById('calcBtn');
    const resetBtn = document.getElementById('resetBtn');
    const scenarioBtns = document.querySelectorAll('.scenario-btn');

    const netBurnEl = document.getElementById('netBurn');
    const runwayEl = document.getElementById('runway');
    const runwayVerdictEl = document.getElementById('runwayVerdict');
    const zeroDateEl = document.getElementById('zeroDate');
    const afterRaiseEl = document.getElementById('afterRaise');
    const startFundraiseByEl = document.getElementById('startFundraiseBy');
    const forecastTable = document.getElementById('forecastTable');

    function monthLabel(offset) {
      const d = new Date();
      d.setMonth(d.getMonth() + offset);
      return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    }

    function calculate() {
      let cashNow = parseFloat(cash.value) || 0;
      let monthlyBurn = parseFloat(burn.value) || 0;
      let monthlyRevenue = parseFloat(revenue.value) || 0;
      const raiseTarget = parseFloat(fundraise.value) || 0;
      const raiseInMonths = parseInt(fundraiseMonths.value, 10) || 0;
      const bGrowth = parseFloat(burnGrowth.value) / 100 || 0;
      const rGrowth = parseFloat(revenueGrowth.value) / 100 || 0;
      const target = parseInt(targetRunway.value, 10) || 18;

      const netNow = monthlyBurn - monthlyRevenue;
      netBurnEl.textContent = fmt(netNow);

      const rows = [];
      let remaining = cashNow;
      let zeroMonth = null;
      let currentBurn = monthlyBurn;
      let currentRevenue = monthlyRevenue;
      let maxMonths = 120;

      for (let m = 1; m <= maxMonths; m++) {
        if (raiseTarget > 0 && m === raiseInMonths) {
          remaining += raiseTarget;
        }
        const netBurn = currentBurn - currentRevenue;
        remaining -= netBurn;
        const status = remaining <= 0 ? 'critical' : remaining <= netBurn * milestones.cash_low_warning_months ? 'warning' : 'safe';
        rows.push({ month: m, label: monthLabel(m), burn: currentBurn, revenue: currentRevenue, netBurn, cash: remaining, status });
        if (remaining <= 0 && zeroMonth === null) zeroMonth = m;
        if (remaining <= 0 && m >= 60) break; // avoid infinite long tables
        currentBurn *= (1 + bGrowth);
        currentRevenue *= (1 + rGrowth);
      }

      const runwayMonths = zeroMonth !== null ? zeroMonth : maxMonths;
      runwayEl.textContent = runwayMonths + (runwayMonths >= maxMonths ? '+' : '') + ' months';

      if (runwayMonths >= target) {
        runwayVerdictEl.textContent = `Meets ${target}-month target`;
        runwayVerdictEl.className = 'text-sm text-emerald-400 mt-1';
      } else {
        runwayVerdictEl.textContent = `Below ${target}-month target by ${target - runwayMonths} months`;
        runwayVerdictEl.className = 'text-sm text-red-400 mt-1';
      }

      if (zeroMonth !== null) {
        zeroDateEl.textContent = monthLabel(zeroMonth);
        const startFundraise = Math.max(0, zeroMonth - milestones.fundraise_start_months_before_zero);
        startFundraiseByEl.textContent = monthLabel(startFundraise);
      } else {
        zeroDateEl.textContent = 'No runway cap';
        startFundraiseByEl.textContent = 'Not urgent';
      }

      // After raise: simulate the same trajectory but add raise at month raiseInMonths
      if (raiseTarget > 0 && raiseInMonths > 0) {
        let cash2 = cashNow;
        let b2 = monthlyBurn;
        let r2 = monthlyRevenue;
        let z2 = null;
        for (let m = 1; m <= maxMonths; m++) {
          if (m === raiseInMonths) cash2 += raiseTarget;
          cash2 -= (b2 - r2);
          if (cash2 <= 0) { z2 = m; break; }
          b2 *= (1 + bGrowth);
          r2 *= (1 + rGrowth);
        }
        afterRaiseEl.textContent = z2 !== null ? monthLabel(z2) : '60+ months';
      } else {
        afterRaiseEl.textContent = 'No raise modeled';
      }

      // Render table
      forecastTable.innerHTML = rows.slice(0, 24).map(r => {
        const statusClass = r.status === 'safe' ? 'text-emerald-400' : r.status === 'warning' ? 'text-amber-400' : 'text-red-400';
        const statusText = r.status === 'safe' ? 'Safe' : r.status === 'warning' ? 'Low cash' : 'Critical';
        return `
          <tr class="hover:bg-neutral-800/30">
            <td class="py-2">${r.label}</td>
            <td class="py-2 text-right font-mono">${fmt(r.burn)}</td>
            <td class="py-2 text-right font-mono">${fmt(r.revenue)}</td>
            <td class="py-2 text-right font-mono">${fmt(r.netBurn)}</td>
            <td class="py-2 text-right font-mono">${fmt(Math.max(0, r.cash))}</td>
            <td class="py-2 pl-4 ${statusClass}">${statusText}</td>
          </tr>
        `;
      }).join('');
    }

    scenarioBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const s = scenarios.find(x => x.slug === btn.dataset.slug);
        if (!s) return;
        cash.value = s.cash_on_hand;
        burn.value = s.monthly_burn;
        revenue.value = s.monthly_revenue;
        fundraise.value = s.fundraising_target;
        burnGrowth.value = s.burn_growth_rate_pct_per_month;
        revenueGrowth.value = s.revenue_growth_rate_pct_per_month;
        targetRunway.value = s.target_runway_months;
        calculate();
      });
    });

    calcBtn.addEventListener('click', calculate);
    resetBtn.addEventListener('click', () => {
      cash.value = defaults.cash_on_hand;
      burn.value = defaults.monthly_burn;
      revenue.value = defaults.monthly_revenue;
      fundraise.value = defaults.fundraising_target;
      burnGrowth.value = defaults.burn_growth_rate_pct_per_month;
      revenueGrowth.value = defaults.revenue_growth_rate_pct_per_month;
      targetRunway.value = defaults.target_runway_months;
      fundraiseMonths.value = 0;
      calculate();
    });

    calculate();
  </script>

  

  

  <AgentCodeBlock
    toolName="Startup Runway Calculator"
    toolPath="/tools/startup-runway-calculator/"
    description="Copy-paste Hermes Agent script for startup runway calculator."
    scriptPath="/hermes-tools/startup_runway_calculator.py"
    locked={false}
  />
</Layout>