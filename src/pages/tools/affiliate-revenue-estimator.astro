---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/affiliate_revenue_estimator.json';

const title = "Affiliate Link Revenue Estimator | Hermes Dispatch";
const description = "Estimate monthly affiliate revenue from clicks, conversion rate, average order value, commission rate, returns, and network fees. Compare CPA vs percentage payout.";
const { defaults, scenarios, networks, faq, note, last_updated } = data;
---

<Layout title={title} description={description}>
  <ToolSchema name="Affiliate Link Revenue Estimator" description={description} url="https://hermesdispatch.dev/tools/affiliate-revenue-estimator/" applicationCategory="FinanceApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(f => ({"@type": "Question", "name": f.question, "acceptedAnswer": {"@type": "Answer", "text": f.answer}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">💰</div>
      <h1 class="display-heading mb-4">Affiliate Link Revenue Estimator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate monthly affiliate earnings from traffic, click-through rate, conversion, AOV, commission rate, returns, and network fees.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario preset</h2>
      <div class="flex flex-wrap gap-3" id="scenario-buttons">
        {scenarios.map((s, i) => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)} data-index={i}>
            <span class="mr-1">{s.icon}</span>{s.name}
          </button>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold flex items-center gap-2"><span>📊</span> Traffic & conversion</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Monthly visitors / sessions</span><input id="visitors" type="number" min="0" step="100" value={defaults.monthly_visitors} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Click-through rate (%)</span><input id="ctr" type="number" min="0" max="100" step="0.1" value={defaults.ctr_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Conversion rate (% of clicks)</span><input id="conversion" type="number" min="0" max="100" step="0.1" value={defaults.conversion_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Average order value ($)</span><input id="aov" type="number" min="0" step="1" value={defaults.aov} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>

        <h2 class="text-xl font-bold mt-8 mb-6 text-brand-gold flex items-center gap-2"><span>💵</span> Payout & costs</h2>
        <div class="space-y-4">
          <label class="flex items-center gap-2 cursor-pointer mb-2">
            <input id="useCpa" type="checkbox" checked={defaults.use_cpa} class="w-4 h-4 rounded bg-neutral-900 border-neutral-700 text-brand-gold" />
            <span class="text-neutral-400 text-sm">Use CPA (flat payout per conversion) instead of % commission</span>
          </label>
          <label class="block" id="commissionWrap"><span class="text-neutral-400 text-sm">Commission rate (% of sale)</span><input id="commission" type="number" min="0" max="100" step="0.1" value={defaults.commission_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block hidden" id="cpaWrap"><span class="text-neutral-400 text-sm">CPA payout ($ per conversion)</span><input id="cpa" type="number" min="0" step="1" value={defaults.cpa_amount} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Return / clawback rate (%)</span><input id="returns" type="number" min="0" max="100" step="0.1" value={defaults.return_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Network / platform fee (%)</span><input id="networkFee" type="number" min="0" max="100" step="0.1" value={defaults.network_fee_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>
      </div>

      <div class="space-y-6">
        <section id="summary" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Monthly clicks</p><p id="clicks" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Conversions</p><p id="conversions" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Gross revenue</p><p id="gross" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">After returns & fees</p><p id="net" class="text-2xl font-bold text-brand-gold">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Revenue per visitor</p><p id="rpv" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Annual net revenue</p><p id="annual" class="text-2xl font-bold text-white">—</p></div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">Revenue at different CTRs</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-neutral-500 border-b border-neutral-800">
                  <th class="py-2 pr-2">CTR</th>
                  <th class="py-2 pr-2 text-right">Clicks</th>
                  <th class="py-2 pr-2 text-right">Conversions</th>
                  <th class="py-2 text-right">Net revenue</th>
                </tr>
              </thead>
              <tbody id="sensitivityTable" class="divide-y divide-neutral-800"></tbody>
            </table>
          </div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">Typical network commissions</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-neutral-500 border-b border-neutral-800">
                  <th class="py-2 pr-2">Network</th>
                  <th class="py-2 text-right">Typical rate</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-800">
                {networks.map(n => (
                  <tr>
                    <td class="py-2 pr-2">{n.name}<br><span class="text-xs text-neutral-500">{n.notes}</span></td>
                    <td class="py-2 text-right font-semibold">{n.typical_commission_pct}%</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">How the math works</h2>
      <ul class="list-disc pl-5 text-neutral-300 space-y-2">
        <li><strong>Clicks</strong> = visitors × click-through rate (CTR).</li>
        <li><strong>Conversions</strong> = clicks × conversion rate.</li>
        <li><strong>Gross revenue</strong> = conversions × (AOV × commission %) or conversions × CPA, whichever model is selected.</li>
        <li><strong>Return clawback</strong> = gross revenue × return rate. Most affiliate programs reverse commission on refunded orders.</li>
        <li><strong>Network fee</strong> = (gross − clawback) × network fee %, if the platform charges a fee.</li>
        <li><strong>Net revenue</strong> = gross − clawback − network fee.</li>
        <li><strong>Revenue per visitor (RPV)</strong> = net revenue ÷ visitors.</li>
      </ul>
      <p class="text-neutral-500 text-sm mt-6">Last updated: {last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faq.map(f => (
          <details class="group bg-neutral-900/50 rounded-xl border border-neutral-800">
            <summary class="p-4 cursor-pointer font-medium text-neutral-200 flex justify-between items-center">{f.question}<span class="text-brand-gold group-open:rotate-180 transition-transform">▼</span></summary>
            <p class="p-4 pt-0 text-neutral-400">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/tools/ai-hardware-deal-tracker/" class="btn-primary text-sm">AI Hardware Deal Tracker →</a>
      <a href="/tools/agent-marketplace-fee-comparator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Agent Marketplace Fee Comparator →</a>
      <a href="/tools/newsletter-revenue-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Newsletter Revenue Calculator →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm mt-10">{note}</p>
  </main>

  <script is:inline define:vars={{ defaults, scenarios }}>
    function $(id) { return document.getElementById(id); }
    function val(id) { return parseFloat($(id).value) || 0; }
    function pct(id) { return Math.min(100, Math.max(0, val(id) / 100)); }
    function checked(id) { return $(id).checked; }
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtMoney2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
    const fmtNum = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    const scenarioBtns = document.querySelectorAll('.scenario-btn');

    function applyScenario(s) {
      $('visitors').value = s.monthly_visitors;
      $('ctr').value = s.ctr_pct;
      $('conversion').value = s.conversion_pct;
      $('aov').value = s.aov;
      $('commission').value = s.commission_pct;
      $('returns').value = s.return_pct;
      $('networkFee').value = s.network_fee_pct;
      $('useCpa').checked = s.use_cpa;
      $('cpa').value = s.cpa_amount;
      updateMode();
      calc();
    }

    scenarioBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        scenarioBtns.forEach(b => b.classList.remove('bg-brand-gold/20', 'border-brand-gold/50', 'text-brand-gold'));
        btn.classList.add('bg-brand-gold/20', 'border-brand-gold/50', 'text-brand-gold');
        applyScenario(JSON.parse(btn.dataset.scenario));
      });
    });

    function updateMode() {
      const useCpa = checked('useCpa');
      $('commissionWrap').classList.toggle('hidden', useCpa);
      $('cpaWrap').classList.toggle('hidden', !useCpa);
    }

    $('useCpa').addEventListener('change', () => { updateMode(); calc(); });

    ['visitors','ctr','conversion','aov','commission','returns','networkFee','cpa'].forEach(id => {
      $(id).addEventListener('input', calc);
    });

    function calc() {
      const visitors = Math.max(0, val('visitors'));
      const ctr = pct('ctr');
      const conversion = pct('conversion');
      const aov = Math.max(0, val('aov'));
      const commission = pct('commission');
      const returns = pct('returns');
      const networkFee = pct('networkFee');
      const cpa = Math.max(0, val('cpa'));
      const useCpa = checked('useCpa');

      const clicks = visitors * ctr;
      const conversions = clicks * conversion;
      const gross = useCpa ? conversions * cpa : conversions * aov * commission;
      const clawback = gross * returns;
      const afterReturns = gross - clawback;
      const fee = afterReturns * networkFee;
      const net = Math.max(0, afterReturns - fee);
      const rpv = visitors > 0 ? net / visitors : 0;
      const annual = net * 12;

      $('clicks').textContent = fmtNum(clicks);
      $('conversions').textContent = fmtNum(conversions);
      $('gross').textContent = fmtMoney(gross);
      $('net').textContent = fmtMoney(net);
      $('rpv').textContent = fmtMoney2(rpv);
      $('annual').textContent = fmtMoney(annual);

      const baseCtr = pct('ctr');
      const tbody = $('sensitivityTable');
      tbody.innerHTML = [0.5, 1.0, 1.5, 2.0, 3.0, 5.0, 7.0, 10.0].map(testCtr => {
        const testClicks = visitors * (testCtr / 100);
        const testConversions = testClicks * conversion;
        const testGross = useCpa ? testConversions * cpa : testConversions * aov * commission;
        const testNet = Math.max(0, testGross * (1 - returns) * (1 - networkFee));
        const active = Math.abs(testCtr - baseCtr * 100) < 0.05;
        return `<tr class="${active ? 'text-brand-gold font-semibold' : 'text-neutral-300'}">
          <td class="py-2 pr-2">${testCtr.toFixed(1)}%</td>
          <td class="py-2 pr-2 text-right">${fmtNum(testClicks)}</td>
          <td class="py-2 pr-2 text-right">${fmtNum(testConversions)}</td>
          <td class="py-2 text-right">${fmtMoney(testNet)}</td>
        </tr>`;
      }).join('');
    }

    updateMode();
    calc();
  </script>
</Layout>
