---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_prompt_injection_scanner.json';
import AgentCodeBlock from '../../components/AgentCodeBlock.astro';

const title = "AI Agent Prompt Injection & Security Risk Scanner | Hermes Dispatch";
const description = "Score your AI agent's system prompt and tool setup for prompt injection, jailbreak, data exfiltration, tool hijacking, and indirect injection risks. Get prioritized fixes and estimated mitigation cost.";

const categories = data.risk_categories;
const checklist = data.checklist;
const profiles = data.exposure_profiles;
const riskLevels = data.risk_levels;

const faqs = [
  { q: "What is prompt injection in an AI agent?", a: "Prompt injection is an attack where user input overrides or leaks the system instructions. In agents it is especially dangerous because injected prompts can also trigger tool calls, exfiltrate data, or manipulate workflows." },
  { q: "What is indirect prompt injection?", a: "Indirect prompt injection hides malicious instructions inside content the agent retrieves — web pages, emails, documents, or tool outputs. The LLM then follows those instructions as if they were part of the task." },
  { q: "Why is tool hijacking a separate risk?", a: "Even if the LLM itself is well-behaved, an attacker can coerce it into calling tools with bad arguments. Without schema validation and confirmation gates, the agent can send emails, delete data, or make purchases on the attacker's behalf." },
  { q: "How reliable is this scanner?", a: "It is a heuristic / checklist scanner, not a live red-team. It finds structural weaknesses and estimates relative risk. For a production launch, pair it with automated tools such as Garak or PyRIT and a manual security review." },
  { q: "What should I fix first?", a: "Start with the highest-weight P0 items: strict tool-call schema validation, removing secrets from prompts, adding per-user rate limits, and ensuring retrieved content cannot directly trigger tools." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Prompt Injection & Security Risk Scanner" description={description} url="https://hermesdispatch.dev/tools/agent-prompt-injection-scanner/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🔐</div>
      <h1 class="display-heading mb-4">AI Agent Prompt Injection &amp; Security Risk Scanner</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Score your agent's system prompt and tool setup for injection, jailbreak, exfiltration, and tool-hijack risks. Get a prioritized fix list and estimated mitigation cost.</p>
    </div>

    <!-- Exposure profile -->
    <section class="glass-card rounded-2xl p-6 mb-6 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Exposure profile</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="profileGrid">
        {profiles.map(p => (
          <label class="profile-card glass-card rounded-xl p-4 cursor-pointer hover:border-brand-gold/50 transition-all flex items-start gap-3">
            <input type="radio" name="exposure" value={p.slug} class="mt-1 accent-brand-gold" checked={p.slug === 'public'} />
            <div>
              <div class="font-semibold text-sm">{p.name}</div>
              <div class="text-xs text-neutral-400 mt-1">{p.description}</div>
            </div>
          </label>
        ))}
      </div>
    </section>

    <!-- Checklist -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-brand-gold">Security checklist</h2>
        <span class="text-sm text-neutral-400">Check every control your agent already has.</span>
      </div>
      <div class="space-y-2" id="checklistContainer">
        {checklist.map(item => (
          <label class="check-item flex items-start gap-3 p-3 rounded-lg bg-neutral-900/50 border border-neutral-800 hover:bg-neutral-800/50 transition cursor-pointer" data-category={item.category} data-weight={item.weight}>
            <input type="checkbox" class="check-box mt-0.5 w-5 h-5 accent-brand-gold" data-id={item.id} />
            <div class="flex-1">
              <div class="text-sm font-medium">{item.text}</div>
              <div class="text-xs text-neutral-500 mt-0.5">{categories.find(c => c.slug === item.category)?.name} • weight {item.weight}</div>
            </div>
          </label>
        ))}
      </div>
    </section>

    <!-- Summary -->
    <section id="summary" class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/30 text-center">
      <p class="text-xs text-neutral-500 uppercase mb-1">Overall security risk score</p>
      <p id="scoreLine" class="text-4xl font-bold text-brand-gold">0 / 100</p>
      <p id="riskLabel" class="text-lg font-semibold mt-2">Select controls to score</p>
      <p id="riskMessage" class="text-sm text-neutral-400 mt-1">—</p>
    </section>

    <!-- Results by category -->
    <section class="grid md:grid-cols-2 gap-4 mb-12" id="categoryResults">
      {categories.map(cat => (
        <div class="glass-card rounded-xl p-5 border border-neutral-800" data-cat={cat.slug}>
          <div class="flex items-center gap-3 mb-3">
            <div class="text-2xl">{cat.emoji}</div>
            <div>
              <h3 class="font-semibold">{cat.name}</h3>
              <div class="text-xs text-neutral-400">{cat.description}</div>
            </div>
          </div>
          <div class="mb-3">
            <div class="flex justify-between text-xs text-neutral-400 mb-1">
              <span>Risk</span>
              <span class="cat-score">0%</span>
            </div>
            <div class="w-full bg-neutral-800 rounded-full h-2">
              <div class="cat-bar bg-brand-gold h-2 rounded-full transition-all" style="width: 0%"></div>
            </div>
          </div>
          <div class="space-y-2">
            <div>
              <p class="text-xs font-semibold text-cyan-400 mb-1">Likely signals in your setup</p>
              <ul class="text-xs text-neutral-400 list-disc list-inside space-y-0.5">
                {cat.signals.slice(0, 3).map(s => <li>{s}</li>)}
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold text-emerald-400 mb-1">Top mitigations</p>
              <ul class="text-xs text-neutral-400 list-disc list-inside space-y-0.5">
                {cat.mitigations.slice(0, 3).map(m => <li>{m}</li>)}
              </ul>
            </div>
          </div>
          <p class="text-xs text-neutral-500 mt-3">Estimated mitigation cost: <span class="cat-cost text-brand-gold font-mono">—</span></p>
        </div>
      ))}
    </section>

    <!-- Priority fix list -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Priority fix list</h2>
      <div id="priorityList" class="space-y-2">
        <p class="text-neutral-400 text-sm">Check controls above to generate a prioritized fix list.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/agent-redteam-cost-calculator/" class="btn-primary text-sm">Red Team Cost Calculator →</a>
      <a href="/tools/agent-evaluation-planner/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Evaluation Planner →</a>
      <a href="/tools/ai-agent-compliance-checker/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Compliance Checker →</a>
      <a href="/tools/agent-deployment-scorecard/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Deployment Readiness Scorecard →</a>
    </div>

    <p class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ categoriesJson: JSON.stringify(categories), checklistJson: JSON.stringify(checklist), profilesJson: JSON.stringify(profiles), levelsJson: JSON.stringify(riskLevels) }}>
    const categories = JSON.parse(categoriesJson);
    const checklistItems = JSON.parse(checklistJson);
    const profiles = JSON.parse(profilesJson);
    const levels = JSON.parse(levelsJson);

    function getExposureMultiplier() {
      const selected = document.querySelector('input[name="exposure"]:checked');
      const p = profiles.find(x => x.slug === selected?.value) || profiles.find(x => x.slug === 'public');
      return p?.multiplier || 1;
    }

    function compute() {
      const multiplier = getExposureMultiplier();
      const checkedIds = new Set();
      document.querySelectorAll('.check-box:checked').forEach(cb => checkedIds.add(cb.dataset.id));

      // Map each checklist item to its category and weight
      const categoryScores = {};
      const categoryMax = {};
      categories.forEach(c => { categoryScores[c.slug] = 0; categoryMax[c.slug] = 0; });

      checklistItems.forEach(item => {
        categoryMax[item.category] = (categoryMax[item.category] || 0) + item.weight;
        if (checkedIds.has(item.id)) {
          categoryScores[item.category] = (categoryScores[item.category] || 0) + item.weight;
        }
      });

      // Per-category risk %
      const catRisk = {};
      let totalScore = 0;
      let totalWeight = 0;
      categories.forEach(cat => {
        const max = categoryMax[cat.slug] || cat.base_weight;
        const score = categoryScores[cat.slug] || 0;
        const missing = Math.max(0, max - score);
        // Weighted by category base_weight and exposure multiplier
        const risk = Math.min(100, Math.round((missing / (max || 1)) * 100));
        catRisk[cat.slug] = risk;
        totalScore += missing * (cat.base_weight / 100);
        totalWeight += max * (cat.base_weight / 100);
      });

      const rawScore = totalWeight > 0 ? (totalScore / totalWeight) * 100 : 0;
      const finalScore = Math.min(100, Math.round(rawScore * multiplier));

      // Update summary
      document.getElementById('scoreLine').textContent = finalScore + ' / 100';
      const level = levels.find(l => finalScore <= l.max) || levels[levels.length - 1];
      const labelEl = document.getElementById('riskLabel');
      labelEl.textContent = level.label;
      labelEl.className = 'text-lg font-semibold mt-2 status-badge border ' +
        (level.color === 'emerald' ? 'status-active' :
         level.color === 'amber' ? 'status-learning' :
         level.color === 'orange' ? 'bg-orange-500/15 text-orange-400 border-orange-500/30' :
         'bg-red-500/15 text-red-400 border-red-500/30');
      document.getElementById('riskMessage').textContent = level.message;

      // Update category cards
      categories.forEach(cat => {
        const card = document.querySelector(`#categoryResults div[data-cat="${cat.slug}"]`);
        if (!card) return;
        const risk = catRisk[cat.slug] || 0;
        card.querySelector('.cat-score').textContent = risk + '%';
        const bar = card.querySelector('.cat-bar');
        bar.style.width = risk + '%';
        bar.className = 'cat-bar h-2 rounded-full transition-all ' +
          (risk < 25 ? 'bg-emerald-500' : risk < 50 ? 'bg-amber-500' : risk < 75 ? 'bg-orange-500' : 'bg-red-500');

        // Estimated mitigation cost scales with risk
        const cost = cat.cost_low + (cat.cost_high - cat.cost_low) * (risk / 100);
        card.querySelector('.cat-cost').textContent = '$' + Math.round(cost).toLocaleString();
      });

      // Priority list: unchecked high-weight items, sorted by weight desc
      const unchecked = checklistItems.filter(i => !checkedIds.has(i.id)).sort((a, b) => b.weight - a.weight);
      const list = document.getElementById('priorityList');
      if (unchecked.length === 0) {
        list.innerHTML = '<p class="text-emerald-400 text-sm">🎉 All checklist controls are in place. Continue monitoring and periodic red-teaming.</p>';
      } else {
        list.innerHTML = unchecked.slice(0, 8).map(item => {
          const cat = categories.find(c => c.slug === item.category);
          return `<div class="flex items-start gap-3 p-3 rounded-lg bg-neutral-900/50 border border-neutral-800">
            <div class="text-lg">${cat?.emoji || '•'}</div>
            <div class="flex-1">
              <div class="text-sm font-medium">${item.text}</div>
              <div class="text-xs text-neutral-500">${cat?.name} • priority weight ${item.weight}</div>
            </div>
          </div>`;
        }).join('');
      }
    }

    document.querySelectorAll('input[name="exposure"], .check-box').forEach(el => {
      el.addEventListener('change', compute);
      el.addEventListener('input', compute);
    });

    compute();
  </script>

  

  

  <AgentCodeBlock
    toolName="Agent Prompt Injection Scanner"
    toolPath="/tools/agent-prompt-injection-scanner/"
    description="Copy-paste Hermes Agent script for agent prompt injection scanner."
    scriptPath="/hermes-tools/agent_prompt_injection_scanner.py"
    locked={false}
  />
</Layout>