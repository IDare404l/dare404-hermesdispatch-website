---
import Layout from '../../layouts/Layout.astro';

const title = "AI Hardware Tools — Calculators, Comparisons, and Recommenders";
const description = "Free tools for local AI builders: VRAM calculator, GPU comparison table, GPU recommender, and mini PC for AI comparisons.";

const tools = [
  {
    name: "LLM VRAM Calculator",
    path: "/tools/vram-calculator/",
    description: "Estimate GPU memory for any model size and quantization.",
    tags: ["VRAM", "LLM", "GPU"],
  },
  {
    name: "GPU Comparison Table",
    path: "/compare/gpus/",
    description: "Sort local-LLM benchmarks by tokens/sec, VRAM, TDP, and price.",
    tags: ["GPU", "benchmarks", "LLM"],
  },
  {
    name: "GPU Recommender",
    path: "/compare/recommend/",
    description: "Pick a GPU by model size, budget, and power constraints.",
    tags: ["GPU", "recommender"],
  },
  {
    name: "AI Hardware Directory",
    path: "/directory/",
    description: "Curated GPUs, mini PCs, wallets, miners, and exchanges.",
    tags: ["directory", "affiliate"],
  },
  {
    name: "Mini PC for AI Comparison",
    path: "/compare/mini-pcs/",
    description: "Mac Mini M4 vs Beelink GTR9 Pro, GMKtec EVO-X2, GEEKOM A8. Sort by RAM, bandwidth, tok/s.",
    tags: ["mini PC", "AI", "compare"],
  },
  {
    name: "Mini PC Recommender",
    path: "/tools/mini-pc-recommender/",
    description: "Pick the best compact AI workstation by model size, budget, and noise tolerance.",
    tags: ["mini PC", "recommender"],
  },
  {
    name: "Miner Pivot Calculator",
    path: "/tools/miner-pivot-calculator/",
    description: "Compare crypto mining profit vs local LLM inference revenue for your GPU.",
    tags: ["crypto", "mining", "inference", "pivot"],
  },
  {
    name: "LLM Cost Calculator",
    path: "/tools/llm-cost-calculator/",
    description: "Compare cloud API token prices vs local GPU cost per 1M tokens.",
    tags: ["LLM", "API", "cost", "inference"],
  },
  {
    name: "AI Agent Stack Builder",
    path: "/tools/agent-stack-builder/",
    description: "Pick a use case and get the full LLM, framework, hosting, and cost stack.",
    tags: ["AI agents", "stack", "framework", "LLM"],
  },
  {
    name: "AI Startup Cost Calculator",
    path: "/tools/ai-startup-cost-calculator/",
    description: "Estimate monthly and first-year burn for an AI agent startup.",
    tags: ["startup", "cost", "AI agents", "business"],
  },
  {
    name: "Local LLM ROI Calculator",
    path: "/tools/local-llm-roi-calculator/",
    description: "Compare 3-year total cost of ownership for local GPU vs cloud API inference.",
    tags: ["ROI", "TCO", "local LLM", "GPU"],
  },
  {
    name: "Answer Engine Citation Tracker",
    path: "/tools/answer-engine-citation-tracker/",
    description: "Track whether Perplexity, ChatGPT, Gemini, and Copilot cite your pages.",
    tags: ["AEO", "citations", "Perplexity", "SEO"],
  },
  {
    name: "AI PC Build Configurator",
    path: "/tools/ai-pc-build-configurator/",
    description: "Preconfigured AI PC builds from budget to pro workstation.",
    tags: ["AI PC", "hardware", "build", "GPU"],
  },
];
---

<Layout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": tools.map((t, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": t.name,
      "url": `https://hermesdispatch.dev${t.path}`,
      "description": t.description,
    })),
  })} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-gray-400">Free, practical tools for building a local AI rig or crypto-mining-to-AI pivot.</p>
    </header>

    <div class="grid md:grid-cols-2 gap-6">
      {tools.map((tool) => (
        <a href={tool.path} class="block bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-cyan-400 transition">
          <h2 class="text-xl font-semibold mb-2">{tool.name}</h2>
          <p class="text-gray-400 mb-4">{tool.description}</p>
          <div class="flex flex-wrap gap-2">
            {tool.tags.map((tag) => (
              <span class="text-xs bg-neutral-800 text-gray-300 px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </article>
</Layout>
