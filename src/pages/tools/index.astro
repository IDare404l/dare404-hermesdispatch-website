---
import Layout from '../../layouts/Layout.astro';

const title = "AI, Crypto, and Investing Tools | Hermes Dispatch";
const description = "Free tools for AI builders, crypto miners, and investors. Calculators, comparisons, recommenders, and cost estimators.";

const categories = [
  {
    name: "AI Tools",
    description: "Calculators, comparators, and builders for local AI, agents, and LLM infrastructure.",
    tools: [
      { name: "LLM VRAM Calculator", path: "/tools/vram-calculator/", description: "Estimate GPU memory for any model size and quantization.", tags: ["VRAM", "LLM", "GPU"] },
      { name: "GPU Comparison Table", path: "/compare/gpus/", description: "Sort local-LLM benchmarks by tokens/sec, VRAM, TDP, and price.", tags: ["GPU", "benchmarks", "LLM"] },
      { name: "Mini PC for AI Comparison", path: "/compare/mini-pcs/", description: "Mac Mini M4 vs Beelink GTR9 Pro, GMKtec EVO-X2, GEEKOM A8. Sort by RAM, bandwidth, tok/s.", tags: ["mini PC", "AI", "compare"] },
      { name: "GPU Recommender", path: "/compare/recommend/", description: "Pick a GPU by model size, budget, and power constraints.", tags: ["GPU", "recommender"] },
      { name: "Mini PC Recommender", path: "/tools/mini-pc-recommender/", description: "Pick the best compact AI workstation by model size, budget, and noise tolerance.", tags: ["mini PC", "recommender"] },
      { name: "Agent Hardware Sizer", path: "/tools/agent-hardware-sizer/", description: "Find the exact mini PC, GPU, and RAM config for local LLMs and AI agents.", tags: ["hardware", "sizing", "mini PC", "GPU"] },
      { name: "LLM Cost Calculator", path: "/tools/llm-cost-calculator/", description: "Compare cloud API token prices vs local GPU cost per 1M tokens.", tags: ["LLM", "API", "cost", "inference"] },
      { name: "Local LLM ROI Calculator", path: "/tools/local-llm-roi-calculator/", description: "Compare 3-year total cost of ownership for local GPU vs cloud API.", tags: ["ROI", "TCO", "local LLM", "GPU"] },
      { name: "AI Agent Stack Builder", path: "/tools/agent-stack-builder/", description: "Pick a use case and get the full LLM, framework, hosting, and cost stack.", tags: ["AI agents", "stack", "framework", "LLM"] },
      { name: "AI Agent Memory / RAG Cost Calculator", path: "/tools/agent-memory-cost-calculator/", description: "Estimate embedding, vector storage, query, and reranker costs for AI agent memory and RAG.", tags: ["AI agents", "RAG", "vector DB", "embeddings", "memory", "cost"] },
      { name: "AI Agent Benchmark Selector", path: "/tools/agent-benchmark-selector/", description: "Pick the right benchmark for coding, reasoning, web, desktop, multi-agent, and domain-specific agents.", tags: ["AI agents", "benchmarks", "evaluation"] },
      { name: "AI Agent Privacy / Compliance Checker", path: "/tools/ai-agent-compliance-checker/", description: "Check which privacy and compliance requirements apply to your AI agent.", tags: ["AI agents", "privacy", "GDPR", "SOC 2", "compliance"] },
      { name: "AI Agent Marketplace Fee Comparator", path: "/tools/agent-marketplace-fee-comparator/", description: "Compare platform take rates, revenue share, and audience fit across AI agent marketplaces.", tags: ["AI agents", "marketplace", "fees", "revenue share", "monetization"] },
      { name: "AI Startup Cost Calculator", path: "/tools/ai-startup-cost-calculator/", description: "Estimate monthly and first-year burn for an AI agent startup.", tags: ["startup", "cost", "AI agents", "business"] },
      { name: "AI PC Build Configurator", path: "/tools/ai-pc-build-configurator/", description: "Preconfigured AI PC builds from budget to pro workstation.", tags: ["AI PC", "hardware", "build", "GPU"] },
      { name: "Context Window Cheat Sheet", path: "/tools/context-window-cheat-sheet/", description: "Compare input and output token limits across major LLM providers.", tags: ["LLM", "context window", "tokens", "cheat sheet"] },
      { name: "AI Agent API Pricing Comparator", path: "/tools/agent-api-pricing-comparator/", description: "Compare per-token pricing across OpenAI, Anthropic, Google, Groq, Together AI, and Cohere.", tags: ["API", "pricing", "LLM", "agents", "cost"] },
      { name: "Prompt Tokenizer & Pricing Estimator", path: "/tools/prompt-tokenizer-pricing-estimator/", description: "Paste a prompt, estimate token count, and see per-request and monthly cost across major LLM APIs.", tags: ["tokens", "pricing", "LLM", "API", "estimator"] },
      { name: "Prompt Cache Savings Calculator", path: "/tools/prompt-cache-savings-calculator/", description: "Estimate how much repeated system prompts and context caching saves on monthly LLM API spend.", tags: ["LLM", "API", "cache", "cost", "savings"] },
      { name: "GPU Cloud Rental vs Buy Calculator", path: "/tools/gpu-cloud-vs-buy-calculator/", description: "Compare hourly cloud GPU rental against buying local hardware.", tags: ["GPU", "cloud", "rental", "buy", "TCO"] },
      { name: "Local LLM Hosting Revenue Estimator", path: "/tools/local-llm-hosting-revenue-estimator/", description: "Estimate monthly profit from renting your GPU for LLM inference on Vast.ai, RunPod, Lambda, and other marketplaces.", tags: ["GPU", "hosting", "LLM", "inference", "revenue", "Vast.ai", "RunPod"] },
      { name: "AI Agent Observability Cost Calculator", path: "/tools/agent-observability-cost-calculator/", description: "Estimate monthly spend for LLM observability, error tracking, infrastructure APM, and uptime monitoring.", tags: ["AI agents", "observability", "monitoring", "cost", "Langfuse", "Sentry", "Datadog"] },
      { name: "AI Agent Latency Budget Calculator", path: "/tools/agent-latency-budget-calculator/", description: "Estimate end-to-end AI agent response latency across providers, architectures, and deployment models.", tags: ["AI agents", "latency", "TTFT", "performance", "benchmarks"] },
      { name: "AI Agent SLA / Uptime Calculator", path: "/tools/agent-sla-calculator/", description: "Convert uptime targets into allowed downtime, compare provider SLAs, and estimate revenue at risk.", tags: ["AI agents", "SLA", "uptime", "availability", "revenue"] },
      { name: "AI Agent Hosting Cost Comparator", path: "/tools/agent-hosting-cost-comparator/", description: "Compare self-hosted, cloud GPU rental, and managed marketplace hosting costs for AI agents.", tags: ["AI agents", "hosting", "cost", "cloud GPU", "marketplace", "self-hosted"] },
      { name: "AI Voice Agent Cost Calculator", path: "/tools/ai-voice-agent-cost-calculator/", description: "Estimate per-minute and monthly cost for AI voice agents across Bland, Retell, Vapi, Synthflow, OpenAI Realtime, and self-hosted stacks.", tags: ["AI agents", "voice", "cost", "pricing", "Bland", "Retell", "Vapi", "Synthflow"] },
      { name: "Voice-to-Text Cost Comparator", path: "/tools/voice-transcription-cost-comparator/", description: "Compare transcription costs across OpenAI Whisper, Deepgram, AssemblyAI, Google Cloud, Azure, AWS Transcribe, Rev AI, and Gladia.", tags: ["AI agents", "voice", "ASR", "transcription", "cost", "Deepgram", "AssemblyAI", "Whisper"] },
      { name: "Prompt Cache Savings Calculator", path: "/tools/prompt-cache-savings-calculator/", description: "Estimate how much repeated system prompts and context caching saves on monthly LLM API spend.", tags: ["LLM", "API", "cache", "cost", "savings"] },
      { name: "AI Agent Context Window Budgeter", path: "/tools/context-window-budgeter/", description: "Plan how system prompts, few-shot examples, RAG chunks, chat history, output reserve, and safety buffer consume a model's context window.", tags: ["LLM", "context window", "tokens", "RAG", "planning"] },
      { name: "LLM Fine-Tuning Cost Calculator", path: "/tools/llm-fine-tuning-cost-calculator/", description: "Estimate training and hosting cost to fine-tune an LLM across OpenAI, Together AI, Fireworks, Replicate, Google, and local GPU routes.", tags: ["LLM", "fine-tuning", "cost", "training", "GPU", "OpenAI", "Together AI"] },
      { name: "Local LLM Inference Engine Selector", path: "/tools/inference-engine-selector/", description: "Pick the best local LLM backend for your model, hardware, OS, and use case: Ollama, llama.cpp, vLLM, TensorRT-LLM, SGLang, MLX, and more.", tags: ["LLM", "inference", "engine", "backend", "Ollama", "vLLM", "llama.cpp", "MLX"] },
      { name: "AI Agent Deployment Readiness Scorecard", path: "/tools/agent-deployment-scorecard/", description: "Score your AI agent's production readiness across architecture, model, privacy, security, reliability, observability, cost, and go-live plan.", tags: ["AI agents", "deployment", "readiness", "scorecard", "launch", "compliance"] },
      { name: "AI Agent Evaluation Planner", path: "/tools/agent-evaluation-planner/", description: "Choose the right benchmark, budget, and timeline for evaluating an AI agent.", tags: ["AI agents", "benchmarks", "evaluation", "planning", "cost", "timeline"] },
      { name: "AI Agent Red Team Cost Calculator", path: "/tools/agent-redteam-cost-calculator/", description: "Estimate the cost of automated LLM red-team and adversarial testing for AI agents.", tags: ["AI agents", "security", "red team", "adversarial", "cost", "prompt injection"] },
      { name: "AI Agent Multi-Step Workflow Cost Calculator", path: "/tools/agent-workflow-cost-calculator/", description: "Estimate per-run and monthly cost for multi-step AI agent workflows across model providers.", tags: ["AI agents", "workflow", "cost", "multi-step", "LLM"] },
      { name: "AI Agent Observability Cost Calculator", path: "/tools/agent-observability-cost-calculator/", description: "Estimate monthly spend for LLM observability, error tracking, infrastructure APM, and uptime monitoring across popular providers.", tags: ["AI agents", "observability", "monitoring", "cost", "Langfuse", "Sentry", "Datadog"] },
      { name: "AI Agent Prompt Injection & Security Risk Scanner", path: "/tools/agent-prompt-injection-scanner/", description: "Score an AI agent's system prompt and tool setup for prompt injection, jailbreak, data exfiltration, tool hijacking, and indirect injection risks.", tags: ["AI agents", "security", "prompt injection", "red team", "risk"] },
      { name: "AI Agent Security Audit Cost Calculator", path: "/tools/agent-security-audit-cost-calculator/", description: "Estimate the cost to audit an AI agent for prompt injection, data exfiltration, tool hijacking, PII handling, and access control.", tags: ["AI agents", "security", "audit", "cost", "compliance"] },
      { name: "AI Agent Human Escalation Cost Calculator", path: "/tools/agent-escalation-cost-calculator/", description: "Estimate the monthly cost of handing off AI-agent conversations or tasks to human agents, including labor, API fallback, SLA impact, and resolution-time scenarios.", tags: ["AI agents", "human-in-the-loop", "escalation", "cost", "support", "operations"] },
      { name: "AI Agent Output Value Calculator", path: "/tools/agent-output-value-calculator/", description: "Estimate the monthly business value, API cost, and ROI of an AI agent based on how many outputs it produces and what each output is worth.", tags: ["AI agents", "ROI", "value", "cost", "business case", "productivity"] },
      { name: "AI Agent Task Fit Selector", path: "/tools/agent-task-fit-selector/", description: "Pick the right agent architecture for a business task: RAG, coding agent, multi-agent, workflow, voice, browser, or data extraction.", tags: ["AI agents", "architecture", "RAG", "workflow", "voice", "browser", "task fit"] },
      { name: "No-Code AI Agent Builder Selector", path: "/tools/no-code-agent-builder-selector/", description: "Pick the best no-code or low-code AI agent builder for your use case, budget, hosting, and team.", tags: ["AI agents", "no-code", "low-code", "builder", "selector", "n8n", "Zapier", "Relevance AI"] },
      { name: "AI Agent vs Human Hire Calculator", path: "/tools/agent-vs-hire-calculator/", description: "Compare the cost of deploying an AI agent versus hiring a human employee for the same task.", tags: ["AI agents", "ROI", "hiring", "cost", "automation", "business case"] },
      { name: "AI Agent Model Router / Fallback Cost Calculator", path: "/tools/agent-model-router-cost-calculator/", description: "Compare the cost and reliability of routing AI agent requests across multiple LLM providers with fallback logic, cache hits, and retry penalties.", tags: ["AI agents", "routing", "fallback", "cost", "reliability", "multi-provider"] },
      { name: "AI Agent Outage Cost Calculator", path: "/tools/agent-outage-cost-calculator/", description: "Estimate revenue loss, SLA penalties, support surge cost, and churn impact when an AI agent goes offline.", tags: ["AI agents", "outage", "downtime", "SLA", "churn", "cost", "reliability"] },
      { name: "AI Agent Support Deflection ROI Calculator", path: "/tools/agent-deflection-roi-calculator/", description: "Estimate how many support tickets an AI agent can deflect, the human support cost saved, and the net monthly ROI.", tags: ["AI agents", "support", "deflection", "ROI", "cost savings", "tickets", "customer service"] },
      { name: "AI Agent Document Processing Cost Calculator", path: "/tools/agent-document-processing-cost-calculator/", description: "Estimate per-page and monthly cost for document extraction, OCR, classification, and summarization across cloud APIs and local GPU stacks.", tags: ["AI agents", "documents", "OCR", "extraction", "classification", "cost", "RAG"] },
      { name: "AI Agent Data Labeling Cost Calculator", path: "/tools/agent-data-labeling-cost-calculator/", description: "Estimate cost, timeline, and review overhead for AI agent training data: image classification, NER, RLHF rankings, and synthetic labels with human validation.", tags: ["AI agents", "data labeling", "training data", "NER", "RLHF", "synthetic labels", "cost"] },
      { name: "AI Agent Knowledge Graph / Ontology Cost Calculator", path: "/tools/agent-knowledge-graph-cost-calculator/", description: "Estimate the cost to build, store, embed, and query a knowledge graph or ontology for AI agent memory.", tags: ["AI agents", "knowledge graph", "ontology", "embeddings", "storage", "cost", "RAG"] },
      { name: "AI Agent Prompt Cost Forecaster", path: "/tools/agent-prompt-cost-forecaster/", description: "Forecast monthly LLM API spend from prompt length, output tokens, request volume, and cached-input percentage.", tags: ["AI agents", "prompt", "cost", "forecast", "API", "tokens", "cache"] },
      { name: "AI Agent Outreach Campaign Cost Calculator", path: "/tools/agent-outreach-cost-calculator/", description: "Estimate per-contact and monthly cost for AI-powered email, SMS, LinkedIn, and voice outreach. Includes list cost, deliverability, LLM API, human SDR review, reply value, and ROI.", tags: ["AI agents", "outreach", "SDR", "email", "SMS", "LinkedIn", "voice", "ROI", "campaign"] },
      { name: "AI Agent Tool Call Cost Calculator", path: "/tools/agent-tool-call-cost-calculator/", description: "Estimate monthly cost for AI agents that call tools: web search, databases, code interpreters, browser actions, and external APIs.", tags: ["AI agents", "tools", "cost", "API", "retrieval", "browser", "code interpreter"] },
      { name: "GPU Power Supply & Cooling Sizer", path: "/tools/gpu-power-cooling-sizer/", description: "Calculate PSU wattage, PCIe/EPS cables, heat output, and case airflow for multi-GPU AI or mining rigs.", tags: ["GPU", "PSU", "power", "cooling", "airflow", "AI PC", "mining", "hardware"] },
      { name: "AI Agent LLM Router Benchmarker", path: "/tools/agent-llm-router-benchmarker/", description: "Benchmark and score multi-provider LLM routing strategies for an AI agent by cost, latency, quality, and fallback reliability.", tags: ["AI agents", "routing", "fallback", "benchmark", "cost", "latency", "quality", "multi-provider"] },
      { name: "AI Agent Multi-Modal Cost Calculator", path: "/tools/agent-multimodal-cost-calculator/", description: "Estimate monthly cost for AI agents that process text, images, audio, and video across OpenAI, Anthropic, and Google multimodal APIs.", tags: ["AI agents", "multimodal", "vision", "audio", "video", "cost", "API"] },
      { name: "AI Agent MCP Cost Calculator", path: "/tools/agent-mcp-cost-calculator/", description: "Estimate monthly cost for Model Context Protocol (MCP) servers powering AI agents: web search, databases, browsers, code execution, and custom integrations.", tags: ["AI agents", "MCP", "Model Context Protocol", "tools", "cost", "servers"] },
      { name: "Open Source LLM Selector for Agents", path: "/tools/open-source-llm-selector/", description: "Pick the best open-weight model for an AI agent use case: coding, reasoning, RAG, tool use, vision, multilingual, or cost-sensitive workloads.", tags: ["LLM", "open source", "agents", "model selection", "Llama", "Qwen", "Mistral", "DeepSeek"] },
      { name: "AI Hardware Resale Value Estimator", path: "/tools/hardware-resale-estimator/", description: "Estimate resale value, net proceeds, and recovery percentage for GPUs, mini PCs, CPUs, RAM, and storage used in AI builds.", tags: ["hardware", "resale", "GPU", "mini PC", "depreciation", "recovery"] },
      { name: "AI Agent Inference Capacity Planner", path: "/tools/agent-inference-capacity-planner/", description: "Size GPU or API capacity for an AI agent workload: requests/minute, tokens, latency, and monthly cost across cloud rental, self-host, and managed APIs.", tags: ["AI agents", "inference", "capacity", "GPU", "latency", "throughput", "sizing"] },
      { name: "Answer Engine Citation Tracker", path: "/tools/answer-engine-citation-tracker/", description: "Track whether Perplexity, ChatGPT, Gemini, and Copilot cite your pages.", tags: ["AEO", "citations", "Perplexity", "SEO"] },
      { name: "AI Account Setup Assistant", path: "/tools/ai-account-setup-assistant/", description: "Generate signup checklists and autofill profiles for AI, cloud, and dev accounts.", tags: ["accounts", "signup", "AI tools", "checklist"] },
      { name: "Prompt Reliability Checker", path: "/tools/prompt-reliability-checker/", description: "Run a system prompt multiple times against a local LLM and score consistency.", tags: ["prompt", "LLM", "testing", "reliability", "Ollama"] },
      { name: "Claim Verifier", path: "/tools/claim-verifier/", description: "Verify a claim against web search results and get a confidence score plus a citable verdict.", tags: ["claim", "verification", "sources", "trust", "AI agents"] },
    ]
  },
  {
    name: "Crypto Tools",
    description: "Mining, pivot, and tax tools for crypto-native operators moving into AI.",
    tools: [
      { name: "Miner Pivot Calculator", path: "/tools/miner-pivot-calculator/", description: "Compare crypto mining profit vs local LLM inference revenue for your GPU.", tags: ["crypto", "mining", "inference", "pivot"] },
      { name: "GPU Hashrate to Inference Capacity Converter", path: "/tools/hashrate-to-inference-converter/", description: "Convert crypto-mining hashrate into estimated local LLM inference capacity and power cost.", tags: ["crypto", "mining", "hashrate", "LLM", "inference", "GPU"] },
      { name: "Crypto Mining Rig Repurposing Guide", path: "/tools/rig-repurposing-guide/", description: "Five ways to turn crypto mining hardware into AI, heat, render, or cash.", tags: ["crypto", "mining", "repurpose", "GPU"] },
      { name: "Crypto Tax Loss Harvesting Calculator", path: "/tools/crypto-tax-loss-harvester/", description: "Estimate how much you can save by harvesting crypto losses against gains and income.", tags: ["crypto", "taxes", "harvesting", "portfolio"] },
    ]
  },
  {
    name: "Investing Tools",
    description: "Cost, revenue, and portfolio tools for AI, crypto, and trading investors.",
    tools: [
      { name: "AI Hardware Deal Tracker", path: "/tools/ai-hardware-deal-tracker/", description: "Watch prices on GPUs, mini PCs, CPUs, RAM, and SSDs for AI builds.", tags: ["deals", "GPU", "mini PC", "hardware"] },
      { name: "Startup Runway Calculator", path: "/tools/startup-runway-calculator/", description: "Calculate months of cash runway based on burn, revenue growth, and fundraising target.", tags: ["startup", "runway", "burn", "fundraising", "cash"] },
      { name: "Affiliate Link Revenue Estimator", path: "/tools/affiliate-revenue-estimator/", description: "Estimate affiliate earnings from monthly clicks, conversion rate, AOV, and commission rate.", tags: ["affiliate", "revenue", "earnings", "traffic", "monetization"] },
      { name: "Newsletter Topic Finder", path: "/tools/newsletter-topic-finder/", description: "High-intent topic ideas for AI hardware, agents, crypto pivots, investing, and AEO.", tags: ["newsletter", "topics", "AI", "crypto", "investing"] },
      { name: "Daily Newsletter Prompt Generator", path: "/tools/newsletter-prompt-generator/", description: "Generate a DOC-id prompt draft for today's Hermes Dispatch issue.", tags: ["newsletter", "prompt", "writing", "AI agents", "AEO"] },
      { name: "Newsletter Revenue & Growth Calculator", path: "/tools/newsletter-revenue-calculator/", description: "Estimate sponsorship, affiliate, and paid-subscription revenue for a newsletter.", tags: ["newsletter", "revenue", "sponsorships", "affiliate", "paid subscriptions", "ARPU"] },
      { name: "Newsletter Sponsorship ROI Calculator", path: "/tools/newsletter-sponsorship-roi/", description: "Estimate sponsor ROI, CPM, CPC, cost per conversion, and suggested rate card for newsletter ad placements.", tags: ["newsletter", "sponsorship", "ROI", "CPM", "advertising", "rate card"] },
    ]
  },
  {
    name: "Directory",
    description: "Curated hardware, software, and exchange listings.",
    tools: [
      { name: "AI Hardware Directory", path: "/directory/", description: "Curated GPUs, mini PCs, wallets, miners, and exchanges.", tags: ["directory", "affiliate"] },
    ]
  },
];

const allTools = categories.flatMap(c => c.tools.map(t => ({ ...t, category: c.name })));
---

<Layout title={title} description={description}>
  <div class="bg-cyan-400/10 border border-cyan-400/30 rounded-lg p-4 mb-8">
    <p class="text-cyan-400 text-sm m-0">🤖 <strong>For AI agents:</strong> This page and every tool below are also listed in <a href="/llms.txt" class="underline">/llms.txt</a> with inputs, outputs, and URLs.</p>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": allTools.map((t, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": t.name,
      "url": `https://hermesdispatch.dev${t.path}`,
      "description": t.description,
    })),
  })} />

  <article class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-gray-400">Free, practical tools for AI builders, crypto miners, and investors.</p>
    </header>

    <div class="flex flex-wrap gap-2 mb-10">
      {categories.map((category) => (
        <a href={`#${category.name.toLowerCase().replace(/\s+/g, '-')}`} class="px-4 py-2 rounded-lg bg-neutral-900 border border-neutral-700 text-gray-300 hover:border-cyan-400 hover:text-cyan-400 transition">
          {category.name}
        </a>
      ))}
    </div>

    {categories.map((category) => (
      <section id={category.name.toLowerCase().replace(/\s+/g, '-')} class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-2xl font-bold">{category.name}</h2>
          <span class="text-sm text-gray-500">{category.tools.length} tool{category.tools.length !== 1 ? 's' : ''}</span>
        </div>
        <p class="text-gray-400 mb-6">{category.description}</p>
        <div class="grid md:grid-cols-2 gap-6">
          {category.tools.map((tool) => (
            <a href={tool.path} class="block bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-cyan-400 transition">
              <h3 class="text-xl font-semibold mb-2">{tool.name}</h3>
              <p class="text-gray-400 mb-4">{tool.description}</p>
              <div class="flex flex-wrap gap-2">
                {tool.tags.map((tag) => (
                  <span class="text-xs bg-neutral-800 text-gray-300 px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</Layout>
