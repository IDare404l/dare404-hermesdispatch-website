---
import Layout from '../../layouts/Layout.astro';

const title = "AI Hardware Tools — Calculators, Comparisons, and Recommenders";
const description = "Free tools for local AI builders: VRAM calculator, GPU comparison table, GPU recommender, and mini PC for AI comparisons.";

const tools = [
  { name: "LLM VRAM Calculator", path: "/tools/vram-calculator/", description: "Estimate GPU memory for any model size and quantization.", tags: ["VRAM", "LLM", "GPU"] },
  { name: "GPU Comparison Table", path: "/compare/gpus/", description: "Sort local-LLM benchmarks by tokens/sec, VRAM, TDP, and price.", tags: ["GPU", "benchmarks", "LLM"] },
  { name: "GPU Recommender", path: "/compare/recommend/", description: "Pick a GPU by model size, budget, and power constraints.", tags: ["GPU", "recommender"] },
  { name: "AI Hardware Directory", path: "/directory/", description: "Curated GPUs, mini PCs, wallets, miners, and exchanges.", tags: ["directory", "affiliate"] },
  { name: "Mini PC for AI Comparison", path: "/compare/mini-pcs/", description: "Mac Mini M4 vs Beelink GTR9 Pro, GMKtec EVO-X2, GEEKOM A8. Sort by RAM, bandwidth, tok/s.", tags: ["mini PC", "AI", "compare"] },
  { name: "Mini PC Recommender", path: "/tools/mini-pc-recommender/", description: "Pick the best compact AI workstation by model size, budget, and noise tolerance.", tags: ["mini PC", "recommender"] },
  { name: "Miner Pivot Calculator", path: "/tools/miner-pivot-calculator/", description: "Compare crypto mining profit vs local LLM inference revenue for your GPU.", tags: ["crypto", "mining", "inference", "pivot"] },
  { name: "LLM Cost Calculator", path: "/tools/llm-cost-calculator/", description: "Compare cloud API token prices vs local GPU cost per 1M tokens.", tags: ["LLM", "API", "cost", "inference"] },
  { name: "AI Agent Stack Builder", path: "/tools/agent-stack-builder/", description: "Pick a use case and get the full LLM, framework, hosting, and cost stack.", tags: ["AI agents", "stack", "framework", "LLM"] },
  { name: "AI Startup Cost Calculator", path: "/tools/ai-startup-cost-calculator/", description: "Estimate monthly and first-year burn for an AI agent startup.", tags: ["startup", "cost", "AI agents", "business"] },
  { name: "Local LLM ROI Calculator", path: "/tools/local-llm-roi-calculator/", description: "Compare 3-year total cost of ownership for local GPU vs cloud API inference.", tags: ["ROI", "TCO", "local LLM", "GPU"] },
  { name: "Answer Engine Citation Tracker", path: "/tools/answer-engine-citation-tracker/", description: "Track whether Perplexity, ChatGPT, Gemini, and Copilot cite your pages.", tags: ["AEO", "citations", "Perplexity", "SEO"] },
  { name: "AI PC Build Configurator", path: "/tools/ai-pc-build-configurator/", description: "Preconfigured AI PC builds from budget to pro workstation.", tags: ["AI PC", "hardware", "build", "GPU"] },
  { name: "Rig Repurposing Guide", path: "/tools/rig-repurposing-guide/", description: "Five ways to turn crypto mining hardware into AI, heat, render, or cash.", tags: ["crypto", "mining", "repurpose", "GPU"] },
  { name: "AI Hardware Deal Tracker", path: "/tools/ai-hardware-deal-tracker/", description: "Watch prices on GPUs, mini PCs, CPUs, RAM, and SSDs for AI builds.", tags: ["deals", "GPU", "mini PC", "hardware"] },
  { name: "Newsletter Topic Finder", path: "/tools/newsletter-topic-finder/", description: "High-intent topic ideas for AI hardware, agents, crypto pivots, investing, and AEO.", tags: ["newsletter", "topics", "AI", "crypto", "investing"] },
  { name: "AI Agent Benchmark Selector", path: "/tools/agent-benchmark-selector/", description: "Pick the right benchmark for coding, reasoning, web, desktop, multi-agent, and domain-specific agents.", tags: ["AI agents", "benchmarks", "evaluation", "SWE-bench", "GAIA"] },
  { name: "Crypto Tax Loss Harvester", path: "/tools/crypto-tax-loss-harvester/", description: "Estimate how much you can save by harvesting crypto losses against gains and income.", tags: ["crypto", "taxes", "harvesting", "portfolio"] },
  { name: "Context Window Cheat Sheet", path: "/tools/context-window-cheat-sheet/", description: "Compare input and output token limits across OpenAI, Anthropic, Google, Meta, Mistral, DeepSeek, xAI, and local quantized models.", tags: ["LLM", "context window", "tokens", "cheat sheet"] },
  { name: "Affiliate Link Revenue Estimator", path: "/tools/affiliate-revenue-estimator/", description: "Estimate affiliate earnings from monthly clicks, conversion rate, AOV, commission rate, refunds, network fees, and CPA.", tags: ["affiliate", "revenue", "earnings", "traffic", "monetization"] },
  { name: "GPU Hashrate to Inference Capacity Converter", path: "/tools/hashrate-to-inference-converter/", description: "Convert crypto-mining hashrate into estimated local LLM inference capacity, tok/s, and power cost.", tags: ["crypto", "mining", "hashrate", "LLM", "inference", "GPU"] },
  { name: "AI Agent Privacy / Compliance Checker", path: "/tools/ai-agent-compliance-checker/", description: "Check which privacy and compliance requirements apply to your AI agent based on region, use case, and data type.", tags: ["AI agents", "privacy", "GDPR", "SOC 2", "compliance"] },
  { name: "Daily Newsletter Prompt Generator", path: "/tools/newsletter-prompt-generator/", description: "Generate a DOC-id prompt draft for today's Hermes Dispatch issue with category, angle, tone, and cross-links.", tags: ["newsletter", "prompt", "writing", "AI agents", "AEO"] },
  { name: "Startup Runway Calculator", path: "/tools/startup-runway-calculator/", description: "Calculate months of cash runway based on burn, revenue growth, fundraising target, and zero-cash date.", tags: ["startup", "runway", "burn", "fundraising", "cash"] },
  { name: "AI Agent Memory / RAG Cost Calculator", path: "/tools/agent-memory-cost-calculator/", description: "Estimate embedding, vector storage, query, and reranker costs for AI agent memory and RAG. Compare managed vs self-hosted vector databases.", tags: ["AI agents", "RAG", "vector DB", "embeddings", "memory", "cost"] },
  { name: "AI Agent Marketplace Fee Comparator", path: "/tools/agent-marketplace-fee-comparator/", description: "Compare platform take rates, revenue share, and audience fit across AI agent marketplaces.", tags: ["AI agents", "marketplace", "fees", "revenue share", "monetization"] },
];
---

<Layout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": tools.map((t, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": t.name,
      "url": `https://hermesdispatch.dev${t.path}`,
      "description": t.description,
    })),
  })} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-gray-400">Free, practical tools for building a local AI rig or crypto-mining-to-AI pivot.</p>
    </header>

    <div class="grid md:grid-cols-2 gap-6">
      {tools.map((tool) => (
        <a href={tool.path} class="block bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-cyan-400 transition">
          <h2 class="text-xl font-semibold mb-2">{tool.name}</h2>
          <p class="text-gray-400 mb-4">{tool.description}</p>
          <div class="flex flex-wrap gap-2">
            {tool.tags.map((tag) => (
              <span class="text-xs bg-neutral-800 text-gray-300 px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </article>
</Layout>
