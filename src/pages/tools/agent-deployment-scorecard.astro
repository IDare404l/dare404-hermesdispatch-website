---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_deployment_scorecard.json';

const title = "AI Agent Deployment Readiness Scorecard | Hermes Dispatch";
const description = "Score your AI agent's production readiness across architecture, model, privacy, security, reliability, observability, cost, and go-live plan.";

const faqs = [
  { q: "What score is considered production-ready?", a: "A score of 90+ with zero open P0 items is our Production ready threshold. 75–89 means Launch candidate, 60–74 Needs hardening, and below 60 is High risk or Not ready." },
  { q: "What is a P0 item?", a: "P0 items are blocking gaps that can cause safety, compliance, or outage issues. The scorecard counts how many P0 checklist items are still unchecked and surfaces them as open P0s." },
  { q: "Does this replace a security or compliance audit?", a: "No. This scorecard is a directional self-assessment. Regulated or high-risk deployments still need legal, security, and compliance review before launch." },
  { q: "Which dimensions matter most?", a: "Architecture, model fit, privacy/security, reliability, and cost are usually the highest-leverage dimensions. Observability and go-live planning become critical once you move beyond internal prototypes." },
  { q: "How do I improve a low score quickly?", a: "Start by closing every open P0, then harden the dimension with the lowest progress. Use the cross-linked cost and security calculators to budget the work." }
];

const dimensions = data.dimensions;
const scenarios = data.scenarios;
const levels = data.levels;
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Deployment Readiness Scorecard" description={description} url="https://hermesdispatch.dev/tools/agent-deployment-scorecard/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">✅</div>
      <h1 class="display-heading mb-4">AI Agent Deployment Readiness Scorecard</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Score production readiness across 8 dimensions and get a launch verdict with open P0 tracking.</p>
    </div>

    <!-- Scenario presets -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Start from a scenario</h2>
      <div class="flex flex-wrap gap-3">
        {scenarios.map(s => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors text-left" data-scenario={JSON.stringify(s)}>
            <span class="font-medium">{s.name}</span>
            <span class="block text-xs text-neutral-500 font-normal">{s.description}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Score summary -->
    <section id="scoreSummary" class="glass-card rounded-2xl p-8 mb-10 border-2 border-brand-gold/40 glow-gold">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
        <div class="text-center md:text-left">
          <p class="text-sm text-neutral-500 uppercase tracking-wide mb-1">Readiness score</p>
          <div class="flex items-end justify-center md:justify-start gap-2">
            <span id="scoreValue" class="text-6xl font-extrabold text-brand-gold">0</span>
            <span class="text-2xl text-neutral-400">/ 100</span>
          </div>
        </div>
        <div class="text-center">
          <p class="text-sm text-neutral-500 uppercase tracking-wide mb-2">Maturity</p>
          <span id="maturityBadge" class="status-badge bg-red-500/15 text-red-400 border-red-500/30">Not ready</span>
        </div>
        <div class="text-center md:text-right">
          <p class="text-sm text-neutral-500 uppercase tracking-wide mb-2">Open P0s</p>
          <span id="p0Count" class="text-3xl font-bold text-white">0</span>
        </div>
      </div>
      <div class="mt-6">
        <div class="w-full bg-neutral-800 rounded-full h-3 overflow-hidden">
          <div id="scoreBar" class="h-full bg-gradient-to-r from-red-500 via-amber-500 to-emerald-500 transition-all duration-500" style="width: 0%"></div>
        </div>
        <p id="verdictText" class="text-lg text-neutral-200 mt-4">Check the items below to see your readiness score.</p>
      </div>
    </section>

    <!-- Dimension checklists -->
    <section class="grid md:grid-cols-2 gap-6 mb-12">
      {dimensions.map(dim => (
        <div class="glass-card rounded-2xl p-6 border border-brand-gold/20" data-dimension={dim.id}>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">{dim.icon}</span>
            <div>
              <h2 class="text-lg font-bold text-white">{dim.name}</h2>
              <p class="text-xs text-neutral-500 dim-progress">0 / {dim.items.length} checks</p>
            </div>
            <span class="ml-auto text-sm font-bold dim-score text-brand-gold">0%</span>
          </div>
          <div class="space-y-3">
            {dim.items.map(item => (
              <label class="flex items-start gap-3 p-3 rounded-lg bg-neutral-900/60 border border-neutral-800 hover:border-neutral-700 cursor-pointer transition-colors">
                <input type="checkbox" class="check-item mt-1 w-4 h-4 rounded border-neutral-600 bg-neutral-800 text-brand-gold focus:ring-brand-gold" data-id={item.id} data-weight={item.weight} data-p0={item.p0 ? '1' : '0'} data-dimension={dim.id} />
                <div class="flex-1">
                  <p class="text-sm text-neutral-200 leading-snug">{item.text}</p>
                  {item.p0 && <span class="inline-block mt-1 text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-red-500/15 text-red-400 border border-red-500/30">P0</span>}
                </div>
              </label>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Per-dimension summary table -->
    <section class="overflow-x-auto mb-12">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Dimension breakdown</h2>
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
            <th class="py-3 pr-4">Dimension</th>
            <th class="py-3 pr-4">Progress</th>
            <th class="py-3 pr-4">Score</th>
            <th class="py-3 pr-4">Open P0s</th>
            <th class="py-3 pr-4">Status</th>
          </tr>
        </thead>
        <tbody id="dimensionTableBody" class="text-neutral-200">
          {dimensions.map(dim => (
            <tr class="border-b border-neutral-800/50" data-dim-row={dim.id}>
              <td class="py-3 pr-4 font-medium text-white">{dim.icon} {dim.name}</td>
              <td class="py-3 pr-4">
                <div class="w-24 bg-neutral-800 rounded-full h-2">
                  <div class="dim-row-bar h-2 rounded-full bg-brand-gold transition-all" style="width: 0%"></div>
                </div>
              </td>
              <td class="py-3 pr-4 dim-row-score">0%</td>
              <td class="py-3 pr-4 dim-row-p0">0</td>
              <td class="py-3 pr-4"><span class="dim-row-status status-badge bg-red-500/15 text-red-400 border-red-500/30">Not ready</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/ai-agent-compliance-checker/" class="btn-primary text-sm">Compliance Checker →</a>
      <a href="/tools/agent-redteam-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Red Team Cost Calc →</a>
      <a href="/tools/agent-observability-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Observability Cost Calc →</a>
      <a href="/tools/agent-outage-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Outage Cost Calc →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ dimensionsJson: JSON.stringify(dimensions), levelsJson: JSON.stringify(levels) }}>
    const dimensions = JSON.parse(dimensionsJson);
    const levels = JSON.parse(levelsJson);

    function getLevel(score) {
      return levels.slice().sort((a, b) => b.min - a.min).find(l => score >= l.min) || levels[levels.length - 1];
    }

    function colorClass(color) {
      return {
        emerald: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
        amber: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
        orange: 'bg-orange-500/15 text-orange-400 border-orange-500/30',
        red: 'bg-red-500/15 text-red-400 border-red-500/30'
      }[color] || 'bg-neutral-800 text-neutral-300 border-neutral-700';
    }

    function compute() {
      let totalWeight = 0;
      let checkedWeight = 0;
      let openP0 = 0;

      const dimStats = {};
      dimensions.forEach(dim => {
        dimStats[dim.id] = { total: dim.items.reduce((s, i) => s + i.weight, 0), checked: 0, p0: 0, items: dim.items.length, checkedItems: 0 };
      });

      document.querySelectorAll('.check-item').forEach(cb => {
        const id = cb.dataset.id;
        const weight = parseInt(cb.dataset.weight, 10) || 1;
        const isP0 = cb.dataset.p0 === '1';
        const dimId = cb.dataset.dimension;
        totalWeight += weight;
        if (cb.checked) {
          checkedWeight += weight;
          dimStats[dimId].checked += weight;
          dimStats[dimId].checkedItems += 1;
        } else if (isP0) {
          openP0 += 1;
          dimStats[dimId].p0 += 1;
        }
      });

      const score = totalWeight ? Math.round((checkedWeight / totalWeight) * 100) : 0;
      const level = getLevel(score);

      // Update summary
      document.getElementById('scoreValue').textContent = score;
      document.getElementById('scoreBar').style.width = score + '%';
      const maturityBadge = document.getElementById('maturityBadge');
      maturityBadge.textContent = level.label;
      maturityBadge.className = 'status-badge ' + colorClass(level.color);
      document.getElementById('p0Count').textContent = openP0;
      const verdictText = document.getElementById('verdictText');
      if (openP0 > 0) {
        verdictText.textContent = `${level.summary} You have ${openP0} open P0 item${openP0 === 1 ? '' : 's'} to close before launch.`;
      } else {
        verdictText.textContent = level.summary;
      }

      // Update dimension cards
      dimensions.forEach(dim => {
        const stats = dimStats[dim.id];
        const dimScore = stats.total ? Math.round((stats.checked / stats.total) * 100) : 0;
        const card = document.querySelector(`[data-dimension="${dim.id}"]`);
        if (card) {
          card.querySelector('.dim-score').textContent = dimScore + '%';
          card.querySelector('.dim-progress').textContent = `${stats.checkedItems} / ${stats.items} checks`;
        }
        const row = document.querySelector(`tr[data-dim-row="${dim.id}"]`);
        if (row) {
          row.querySelector('.dim-row-bar').style.width = dimScore + '%';
          row.querySelector('.dim-row-score').textContent = dimScore + '%';
          row.querySelector('.dim-row-p0').textContent = stats.p0;
          const rowStatus = row.querySelector('.dim-row-status');
          const rowLevel = getLevel(dimScore);
          rowStatus.textContent = rowLevel.label;
          rowStatus.className = 'dim-row-status status-badge ' + colorClass(rowLevel.color);
        }
      });
    }

    function setScenario(checks) {
      document.querySelectorAll('.check-item').forEach(cb => {
        cb.checked = checks.includes(cb.dataset.id);
      });
      compute();
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const s = JSON.parse(btn.dataset.scenario);
          setScenario(s.checks || []);
        });
      });

      document.querySelectorAll('.check-item').forEach(cb => {
        cb.addEventListener('change', compute);
      });

      compute();
    });
  </script>
</Layout>
