---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_vs_hire.json';

const title = "AI Agent vs Human Hire Calculator | Hermes Dispatch";
const description = "Compare the cost of deploying an AI agent versus hiring a human employee for the same task. See break-even month, 1-year savings, and which roles agents handle best.";
const roles = data.roles;
const stacks = data.stacks;
const defaults = data.defaults;

const faqs = [
  { q: "When does an AI agent become cheaper than a human hire?", a: "Most agents break even within 1–4 months once setup costs are recovered, provided the task is repetitive, high-volume, and has a low per-output API cost. The calculator shows the exact month based on your salary, benefits, and review overhead." },
  { q: "What is included in the human cost?", a: "Base salary plus benefits and payroll overhead, expressed as a monthly fully-loaded cost. You can adjust the benefits percentage to match your region or company policy." },
  { q: "What is included in the agent cost?", a: "One-time setup labor, ongoing maintenance, tool/platform subscription, API inference spend, and the cost of human review for any outputs that need a human check." },
  { q: "Does this calculator account for quality differences?", a: "It uses a human-review rate to model outputs that still need a person. Higher review rates lower net savings. Use the verdict and quality warning as guardrails, not a replacement for pilot testing." },
  { q: "Which roles are usually the best fit for an AI agent?", a: "Data entry, first-line support, ticket triage, SDR outreach, meeting scheduling, and document processing tend to have the fastest payback. Creative, strategic, and heavily regulated roles usually need a human-in-the-loop design." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent vs Human Hire Calculator" description={description} url="https://hermesdispatch.dev/tools/agent-vs-hire-calculator/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">⚖️</div>
      <h1 class="display-heading mb-4">AI Agent vs Human Hire Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Compare the cost of deploying an AI agent versus hiring a human employee for the same task. See break-even month, 1-year savings, and which roles agents handle best.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Role preset</h2>
      <div class="flex flex-wrap gap-3">
        {roles.map(r => (
          <button type="button" class="role-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-role={JSON.stringify(r)}>
            {r.name}
          </button>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold">Human hire</h2>
        <div class="space-y-4">
          <label class="block">
            <span class="text-neutral-400 text-sm">Annual salary ($)</span>
            <input id="salary" type="number" min="0" step="1000" value={roles[1].annual_salary} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Benefits + overhead (%)</span>
            <input id="benefitsPct" type="number" min="0" max="100" step="1" value={Math.round(roles[1].benefits_pct * 100)} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Monthly outputs ({roles[1].output_label})</span>
            <input id="humanOutputs" type="number" min="1" step="10" value={roles[1].monthly_outputs} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
        </div>
        <div class="mt-6 p-4 rounded-xl bg-neutral-900/50 border border-neutral-800">
          <p class="text-xs text-neutral-500 uppercase mb-1">Monthly fully-loaded cost</p>
          <p id="humanMonthly" class="text-2xl font-bold text-white">—</p>
        </div>
      </div>

      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold">AI agent</h2>
        <div class="space-y-4">
          <label class="block">
            <span class="text-neutral-400 text-sm">Agent stack</span>
            <select id="stackSelect" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {stacks.map(s => <option value={s.id} selected={s.id === defaults.stack_id}>{s.name}</option>)}
            </select>
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Monthly tooling / platform cost ($)</span>
            <input id="toolingCost" type="number" min="0" step="10" value={stacks.find(s => s.id === defaults.stack_id).monthly_tooling} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">API cost per output ($)</span>
            <input id="apiCost" type="number" min="0" step="0.01" value={roles[1].agent_api_cost_per_output} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Human review rate (%)</span>
            <input id="reviewPct" type="number" min="0" max="100" step="1" value={roles[1].human_review_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Review minutes per output</span>
            <input id="reviewMinutes" type="number" min="0" step="0.5" value={defaults.review_minutes_per_output} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Review hourly rate ($)</span>
            <input id="reviewRate" type="number" min="0" step="5" value={defaults.review_hourly_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Setup hours</span>
            <input id="setupHours" type="number" min="0" step="1" value={roles[1].agent_setup_hours} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Setup hourly rate ($)</span>
            <input id="setupRate" type="number" min="0" step="5" value={defaults.setup_hourly_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
          <label class="block">
            <span class="text-neutral-400 text-sm">Maintenance hours / month</span>
            <input id="maintenanceHours" type="number" min="0" step="0.5" value={roles[1].agent_maintenance_hours} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
          </label>
        </div>
        <div class="mt-6 p-4 rounded-xl bg-neutral-900/50 border border-neutral-800">
          <p class="text-xs text-neutral-500 uppercase mb-1">Monthly agent cost</p>
          <p id="agentMonthly" class="text-2xl font-bold text-white">—</p>
        </div>
      </div>
    </section>

    <section id="summary" class="grid md:grid-cols-4 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Human 1-year cost</p>
        <p id="humanYear" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Agent 1-year cost</p>
        <p id="agentYear" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">1-year savings</p>
        <p id="yearSavings" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Break-even month</p>
        <p id="breakEven" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Monthly cost projection</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
              <th class="py-3 pr-4">Month</th>
              <th class="py-3 pr-4 text-right">Human cost</th>
              <th class="py-3 pr-4 text-right">Agent cost</th>
              <th class="py-3 pr-4 text-right">Cumulative savings</th>
              <th class="py-3 pr-4 text-center">Status</th>
            </tr>
          </thead>
          <tbody id="projectionBody" class="text-neutral-200"></tbody>
        </table>
      </div>
    </section>

    <section id="verdict" class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-2 text-brand-gold">Verdict</h2>
      <p id="verdictText" class="text-lg text-neutral-200">—</p>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/agent-output-value-calculator/" class="btn-primary text-sm">Agent Output Value Calc →</a>
      <a href="/tools/agent-escalation-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Human Escalation Cost Calc →</a>
      <a href="/tools/ai-startup-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Startup Cost Calc →</a>
      <a href="/tools/agent-api-pricing-comparator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">API Pricing Comparator →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ stacksJson: JSON.stringify(stacks) }}>
    const stacks = JSON.parse(stacksJson);
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtMoney2 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function getInputs() {
      return {
        salary: Math.max(0, parseFloat(document.getElementById('salary').value) || 0),
        benefitsPct: Math.min(100, Math.max(0, parseFloat(document.getElementById('benefitsPct').value) || 0)) / 100,
        humanOutputs: Math.max(1, parseFloat(document.getElementById('humanOutputs').value) || 1),
        toolingCost: Math.max(0, parseFloat(document.getElementById('toolingCost').value) || 0),
        apiCost: Math.max(0, parseFloat(document.getElementById('apiCost').value) || 0),
        reviewPct: Math.min(100, Math.max(0, parseFloat(document.getElementById('reviewPct').value) || 0)) / 100,
        reviewMinutes: Math.max(0, parseFloat(document.getElementById('reviewMinutes').value) || 0),
        reviewRate: Math.max(0, parseFloat(document.getElementById('reviewRate').value) || 0),
        setupHours: Math.max(0, parseFloat(document.getElementById('setupHours').value) || 0),
        setupRate: Math.max(0, parseFloat(document.getElementById('setupRate').value) || 0),
        maintenanceHours: Math.max(0, parseFloat(document.getElementById('maintenanceHours').value) || 0),
      };
    }

    function compute() {
      const i = getInputs();
      const humanMonthly = (i.salary * (1 + i.benefitsPct)) / 12;
      const apiMonthly = i.humanOutputs * i.apiCost;
      const reviewHours = i.humanOutputs * i.reviewPct * (i.reviewMinutes / 60);
      const reviewMonthly = reviewHours * i.reviewRate;
      const maintenanceMonthly = i.maintenanceHours * i.setupRate;
      const agentMonthly = i.toolingCost + apiMonthly + reviewMonthly + maintenanceMonthly;
      const setupCost = i.setupHours * i.setupRate;

      document.getElementById('humanMonthly').textContent = fmtMoney(humanMonthly);
      document.getElementById('agentMonthly').textContent = fmtMoney(agentMonthly);

      const months = 12;
      const humanYear = humanMonthly * months;
      const agentYear = agentMonthly * months + setupCost;
      const yearSavings = humanYear - agentYear;
      const monthlySavings = humanMonthly - agentMonthly;
      const breakEven = monthlySavings > 0 ? Math.ceil(setupCost / monthlySavings) : Infinity;

      document.getElementById('humanYear').textContent = fmtMoney(humanYear);
      document.getElementById('agentYear').textContent = fmtMoney(agentYear);
      const savingsEl = document.getElementById('yearSavings');
      savingsEl.textContent = fmtMoney(yearSavings);
      savingsEl.className = 'text-2xl font-bold ' + (yearSavings > 0 ? 'text-green-400' : 'text-red-400');
      const breakEl = document.getElementById('breakEven');
      breakEl.textContent = isFinite(breakEven) ? breakEven : '∞';
      breakEl.className = 'text-2xl font-bold ' + (isFinite(breakEven) && breakEven <= 6 ? 'text-green-400' : isFinite(breakEven) && breakEven <= 12 ? 'text-brand-gold' : 'text-red-400');

      // Projection table
      let tbody = '';
      let cumulative = 0;
      for (let m = 1; m <= 24; m++) {
        const h = humanMonthly * m;
        const a = agentMonthly * m + setupCost;
        cumulative = h - a;
        const status = cumulative > 0
          ? '<span class="text-xs bg-green-500/20 text-green-400 px-2 py-1 rounded">Saving</span>'
          : '<span class="text-xs bg-red-500/20 text-red-400 px-2 py-1 rounded">Investing</span>';
        tbody += `<tr class="border-b border-neutral-800/50">
          <td class="py-3 pr-4">${m}</td>
          <td class="py-3 pr-4 text-right font-mono">${fmtMoney(h)}</td>
          <td class="py-3 pr-4 text-right font-mono">${fmtMoney(a)}</td>
          <td class="py-3 pr-4 text-right font-mono ${cumulative > 0 ? 'text-green-400' : 'text-red-400'}">${fmtMoney(cumulative)}</td>
          <td class="py-3 pr-4 text-center">${status}</td>
        </tr>`;
      }
      document.getElementById('projectionBody').innerHTML = tbody;

      // Verdict
      let verdict = '';
      if (!isFinite(breakEven) || breakEven > 24) {
        verdict = `The agent does not break even within 24 months at these assumptions. Human hire is likely cheaper unless the agent's output volume rises or its API/review costs fall significantly.`;
      } else if (breakEven <= 6 && yearSavings > 0) {
        verdict = `Strong case for the agent: it breaks even in month ${breakEven} and saves ${fmtMoney(yearSavings)} in the first year. This role is highly automatable at the current output volume and review rate.`;
      } else if (breakEven <= 12 && yearSavings > 0) {
        verdict = `Good case for the agent: break-even in month ${breakEven} with first-year savings of ${fmtMoney(yearSavings)}. Run a 90-day pilot to confirm quality and review rate before full rollout.`;
      } else {
        verdict = `Marginal case. The agent breaks even in month ${breakEven} but saves only ${fmtMoney(yearSavings)} in year one. Consider a hybrid: agent handles the repetitive portion, human focuses on exceptions and quality control.`;
      }
      document.getElementById('verdictText').textContent = verdict;
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.role-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const r = JSON.parse(btn.dataset.role);
          document.getElementById('salary').value = r.annual_salary;
          document.getElementById('benefitsPct').value = Math.round(r.benefits_pct * 100);
          document.getElementById('humanOutputs').value = r.monthly_outputs;
          document.getElementById('apiCost').value = r.agent_api_cost_per_output;
          document.getElementById('reviewPct').value = r.human_review_pct;
          document.getElementById('setupHours').value = r.agent_setup_hours;
          document.getElementById('maintenanceHours').value = r.agent_maintenance_hours;
          compute();
        });
      });

      document.getElementById('stackSelect').addEventListener('change', e => {
        const s = stacks.find(x => x.id === e.target.value);
        if (s) document.getElementById('toolingCost').value = s.monthly_tooling;
        compute();
      });

      ['salary','benefitsPct','humanOutputs','toolingCost','apiCost','reviewPct','reviewMinutes','reviewRate','setupHours','setupRate','maintenanceHours'].forEach(id => {
        document.getElementById(id).addEventListener('input', compute);
      });

      compute();
    });
  </script>
</Layout>
