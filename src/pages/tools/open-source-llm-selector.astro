---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/open_source_llm_selector.json';

const title = "Open Source LLM Selector for Agents | Hermes Dispatch";
const description = "Pick the best open-weight LLM for your AI agent: coding, reasoning, RAG, tool use, vision, multilingual chat, or cost-sensitive workloads. Compare Llama, Qwen, Mistral, DeepSeek, Gemma, Phi, and more by use-case fit, VRAM, context, and speed.";
const useCases = data.use_cases;
const models = data.models;
const defaults = data.defaults;

const faqs = [
  { q: "Which open-source model is best for coding agents?", a: "DeepSeek Coder V2 and DeepSeek V3 lead open-weight coding benchmarks. Llama 3.1 405B and Qwen 2.5 72B are strong generalist alternatives with good code performance. For local hardware, Llama 3.1 70B and Qwen 2.5 32B offer the best quality/speed trade-offs." },
  { q: "What is the best open model for tool-using agents?", a: "Look for models with strong function-calling scores and long context. Mistral Large 2, Llama 3.1 70B/405B, Qwen 2.5 72B, and Llama 3.1 8B (for lightweight tasks) all have robust tool support in modern inference engines." },
  { q: "Can I run these models locally?", a: "Many fit consumer hardware at 4-bit quantization: Llama 3.1 8B, Llama 3.2 3B, Gemma 2 9B, Qwen 2.5 14B, Mistral NeMo 12B, and Phi 4 all run on 8-24 GB GPUs. Larger models like Llama 3.1 70B, Qwen 2.5 72B, or DeepSeek V3 need multi-GPU or cloud API hosting." },
  { q: "How accurate are the use-case scores?", a: "Scores are relative (0-10) directional ratings based on public benchmarks and community reports as of mid-2026. They help narrow the field; always benchmark the final candidates on your own prompts and agent traces." },
  { q: "Which model is best for non-English agents?", a: "Qwen 2.5 models excel at multilingual coverage, followed by Mistral Large 2 and Llama 3.1. For primarily English workloads, Gemma 2 and Llama 3.1 are excellent." },
  { q: "What about vision agents?", a: "Qwen2-VL 72B is the strongest open vision-language model for document and image understanding. Llama 3.2 Vision 11B is a practical, consumer-GPU-friendly alternative." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="Open Source LLM Selector for Agents" description={description} url="https://hermesdispatch.dev/tools/open-source-llm-selector/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">🦙</div>
      <h1 class="display-heading mb-4">Open Source LLM Selector for Agents</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Pick the best open-weight model for your AI agent use case. Compare Llama, Qwen, Mistral, DeepSeek, Gemma, Phi, and more by fit, VRAM, context, and speed.</p>
    </div>

    <!-- Inputs -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Agent requirements</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <label class="block">
          <span class="text-neutral-400 text-sm">Primary use case</span>
          <select id="useCaseSelect" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            {useCases.map(u => <option value={JSON.stringify(u)} selected={u.slug === defaults.use_case}>{u.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Max available VRAM (GB)</span>
          <input id="maxVram" type="number" min="1" step="1" value={defaults.max_vram} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Minimum context (k tokens)</span>
          <input id="minContext" type="number" min="1" step="1" value={defaults.min_context} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Deployment preference</span>
          <select id="deployPref" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
            <option value="local" selected={defaults.prefer_local}>Local / self-hosted</option>
            <option value="api">Cloud API or managed</option>
            <option value="either">Either</option>
          </select>
        </label>
      </div>
      <div class="flex items-center gap-3 mt-5">
        <input id="requireVision" type="checkbox" class="w-5 h-5 accent-brand-gold rounded bg-neutral-900 border-neutral-700" />
        <label for="requireVision" class="text-neutral-300 text-sm">Only show models with native vision support</label>
      </div>
      <p class="text-neutral-500 text-sm mt-6">Estimates are directional. Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <!-- Results -->
    <section class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold text-brand-gold">Ranked recommendations</h2>
        <span id="resultCount" class="text-neutral-500 text-sm">—</span>
      </div>
      <div id="results" class="space-y-4">
        <p class="text-neutral-400">Select a use case to see ranked models.</p>
      </div>
    </section>

    <!-- Comparison table -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20 overflow-x-auto">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Model comparison</h2>
      <table class="w-full text-left border-collapse min-w-[800px]">
        <thead>
          <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
            <th class="py-3 pr-4">Model</th>
            <th class="py-3 pr-4">Family</th>
            <th class="py-3 pr-4 text-right">Params</th>
            <th class="py-3 pr-4 text-right">Context</th>
            <th class="py-3 pr-4 text-right">Q4 VRAM</th>
            <th class="py-3 pr-4 text-right">Score</th>
            <th class="py-3 pr-4">Best fit</th>
          </tr>
        </thead>
        <tbody id="compareBody" class="text-neutral-200 text-sm">
          <tr><td colspan="7" class="py-4 text-neutral-500">Select a use case to populate the table.</td></tr>
        </tbody>
      </table>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/vram-calculator/" class="btn-primary text-sm">VRAM Calculator →</a>
      <a href="/tools/inference-engine-selector/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Inference Engine Selector →</a>
      <a href="/tools/agent-api-pricing-comparator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">API Pricing Comparator →</a>
      <a href="/tools/agent-benchmark-selector/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Agent Benchmark Selector →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ useCasesJSON: JSON.stringify(useCases), modelsJSON: JSON.stringify(models), defaultsJSON: JSON.stringify(defaults) }}>
    const useCases = JSON.parse(useCasesJSON);
    const models = JSON.parse(modelsJSON);
    const defaults = JSON.parse(defaultsJSON);

    const fmtInt = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    function getInputs() {
      return {
        useCase: JSON.parse(document.getElementById('useCaseSelect').value),
        maxVram: Math.max(1, parseFloat(document.getElementById('maxVram').value) || 24),
        minContext: Math.max(1, parseFloat(document.getElementById('minContext').value) || 1),
        deployPref: document.getElementById('deployPref').value,
        requireVision: document.getElementById('requireVision').checked
      };
    }

    function scoreModel(model, weights) {
      const dims = ['coding','reasoning','function_calling','context','vision','multilingual','speed','cost'];
      let total = 0;
      let weightSum = 0;
      dims.forEach(d => {
        total += (model.scores[d] || 0) * (weights[d] || 0);
        weightSum += weights[d] || 0;
      });
      return weightSum > 0 ? total / weightSum : 0;
    }

    function fitsFilters(model, inps) {
      if (inps.requireVision && (model.scores.vision || 0) <= 0) return false;
      if (model.context_k < inps.minContext) return false;
      if (inps.deployPref === 'local' && model.vram_gb.q4 > inps.maxVram * 1.15) return false;
      return true;
    }

    function getSizeBadge(vram, maxVram) {
      if (vram <= maxVram * 0.6) return `<span class="text-xs bg-green-500/20 text-green-400 px-2 py-1 rounded">Fits easily</span>`;
      if (vram <= maxVram * 1.05) return `<span class="text-xs bg-yellow-500/20 text-yellow-400 px-2 py-1 rounded">Tight fit</span>`;
      return `<span class="text-xs bg-red-500/20 text-red-400 px-2 py-1 rounded">Too large</span>`;
    }

    function compute() {
      const inps = getInputs();
      const weights = inps.useCase.weights;

      const scored = models.map(m => {
        const fitScore = scoreModel(m, weights);
        const fits = fitsFilters(m, inps);
        return { ...m, fitScore, fits };
      }).sort((a, b) => b.fitScore - a.fitScore);

      const visible = scored.filter(m => m.fits);
      const resultCount = document.getElementById('resultCount');
      resultCount.textContent = `${visible.length} of ${models.length} models match your filters`;

      const container = document.getElementById('results');
      if (visible.length === 0) {
        container.innerHTML = `<div class="glass-card rounded-2xl p-6 border border-red-500/30 text-center"><p class="text-red-400 font-medium">No models match your filters.</p><p class="text-neutral-400 text-sm mt-1">Try increasing VRAM, lowering minimum context, allowing API deployment, or unchecking vision.</p></div>`;
      } else {
        const top = visible.slice(0, 5);
        container.innerHTML = top.map((m, i) => {
          const badge = getSizeBadge(m.vram_gb.q4, inps.maxVram);
          return `
            <div class="glass-card rounded-2xl p-6 border ${i === 0 ? 'border-brand-gold/50' : 'border-neutral-800'} flex flex-col md:flex-row md:items-start gap-5">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-2xl font-bold ${i === 0 ? 'text-brand-gold' : 'text-neutral-500'}">#${i + 1}</span>
                  <h3 class="text-xl font-semibold text-white">${m.name}</h3>
                  <span class="text-xs bg-neutral-800 text-neutral-300 px-2 py-1 rounded">${m.family}</span>
                  ${badge}
                </div>
                <p class="text-neutral-400 text-sm mb-3">${m.best_for}</p>
                <div class="flex flex-wrap gap-2 mb-3">
                  ${m.pros.map(p => `<span class="text-xs bg-green-500/10 text-green-400 px-2 py-1 rounded">+ ${p}</span>`).join('')}
                  ${m.cons.map(c => `<span class="text-xs bg-red-500/10 text-red-400 px-2 py-1 rounded">− ${c}</span>`).join('')}
                </div>
                <div class="flex flex-wrap gap-4 text-sm text-neutral-300">
                  <span><strong>${m.params_b}B</strong> params</span>
                  <span><strong>${m.context_k}k</strong> context</span>
                  <span><strong>${m.vram_gb.q4} GB</strong> @ Q4</span>
                  <span><strong>${m.vram_gb.fp16} GB</strong> @ FP16</span>
                </div>
              </div>
              <div class="text-center md:text-right min-w-[120px]">
                <p class="text-xs text-neutral-500 uppercase mb-1">Use-case score</p>
                <p class="text-3xl font-bold text-brand-gold">${m.fitScore.toFixed(1)}</p>
                <div class="mt-3 flex flex-col gap-1">
                  <a href="${m.links.ollama}" target="_blank" rel="noopener" class="text-xs text-cyan-400 underline">Ollama</a>
                  <a href="${m.links.hf}" target="_blank" rel="noopener" class="text-xs text-cyan-400 underline">Hugging Face</a>
                </div>
              </div>
            </div>
          `;
        }).join('');
      }

      const tbody = document.getElementById('compareBody');
      tbody.innerHTML = scored.map(m => {
        const sizeBadge = getSizeBadge(m.vram_gb.q4, inps.maxVram);
        const rowClass = m.fits ? '' : 'opacity-50';
        return `
          <tr class="border-b border-neutral-800/50 ${rowClass}">
            <td class="py-3 pr-4 font-medium text-white">${m.name}</td>
            <td class="py-3 pr-4 text-neutral-400">${m.family}</td>
            <td class="py-3 pr-4 text-right font-mono">${m.params_b}B</td>
            <td class="py-3 pr-4 text-right font-mono">${m.context_k}k</td>
            <td class="py-3 pr-4 text-right font-mono">${m.vram_gb.q4} GB</td>
            <td class="py-3 pr-4 text-right font-mono text-brand-gold">${m.fitScore.toFixed(1)}</td>
            <td class="py-3 pr-4">${sizeBadge}</td>
          </tr>
        `;
      }).join('');
    }

    document.addEventListener('DOMContentLoaded', function() {
      ['useCaseSelect','maxVram','minContext','deployPref','requireVision'].forEach(id => {
        document.getElementById(id).addEventListener('input', compute);
        document.getElementById(id).addEventListener('change', compute);
      });
      compute();
    });
  </script>
</Layout>
