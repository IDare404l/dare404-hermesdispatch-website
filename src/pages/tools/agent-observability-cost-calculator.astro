---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/agent_observability_cost.json';

const title = "AI Agent Observability Cost Calculator | Hermes Dispatch";
const description = "Estimate monthly spend for LLM observability, error tracking, infrastructure APM, and uptime monitoring across Langfuse, Sentry, Datadog, New Relic, Grafana Cloud, Honeycomb, and Axiom.";
const providers = data.providers;
const presets = data.presets;
const defaults = data.defaults;

const faqs = [
  { q: "What counts as an observability 'event' or 'observation' for an AI agent?", a: "In this calculator an observation is roughly one sampled trace/span worth of data per request. LLM-specific observability tools (Langfuse, Honeycomb) price by observations or events; APM tools (Sentry, Datadog) price by spans and errors; log-centric tools price by ingested GB." },
  { q: "How does sampling affect cost?", a: "You rarely need to trace 100% of production traffic. Setting a 10% sample still gives you representative latency and error data while cutting observability volume by 90%. Enter your sample rate to see the impact." },
  { q: "Does this include LLM token cost?", a: "No. This calculator covers observability and monitoring only. Combine it with the API Pricing Comparator or Prompt Cost Forecaster for total agent spend." },
  { q: "Which provider is cheapest?", a: "It depends on what you emit. Honeycomb and Axiom have large free data tiers; Langfuse has a free observability tier for small agents; Sentry is cheap for error tracking but span volume can add up; Datadog and New Relic are powerful but typically the most expensive at scale." },
  { q: "Are these prices exact?", a: "No. Provider pricing changes and depends on commitments, retention, and add-ons. Use these numbers for directional comparison, then confirm with the provider's pricing page." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="AI Agent Observability Cost Calculator" description={description} url="https://hermesdispatch.dev/tools/agent-observability-cost-calculator/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">👁️</div>
      <h1 class="display-heading mb-4">AI Agent Observability Cost Calculator</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Estimate monthly spend for LLM observability, error tracking, infrastructure APM, and uptime monitoring across popular providers.</p>
    </div>

    <!-- Scenario presets -->
    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario presets</h2>
      <div class="flex flex-wrap gap-3">
        {presets.map(p => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(p)}>
            {p.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Inputs -->
    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Workload</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <label class="block">
          <span class="text-neutral-400 text-sm">Agent requests / month</span>
          <input id="requestsPerMonth" type="number" min="0" step="1000" value={defaults.requests_per_month} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Traces or observations / request</span>
          <input id="tracesPerRequest" type="number" min="0" step="0.5" value={defaults.traces_per_request} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Sampling (%)</span>
          <input id="samplingPct" type="number" min="0" max="100" step="5" value={defaults.sampling_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Average trace size (KB)</span>
          <input id="traceSizeKb" type="number" min="1" step="1" value={defaults.avg_trace_size_kb} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Error events / month</span>
          <input id="errorEvents" type="number" min="0" step="100" value={defaults.error_events_per_month} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Uptime / synthetic checks / month</span>
          <input id="uptimeChecks" type="number" min="0" step="10" value={defaults.uptime_checks_per_month} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Team seats</span>
          <input id="teamSeats" type="number" min="0" step="1" value={defaults.team_seats} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
        <label class="block">
          <span class="text-neutral-400 text-sm">Projection (months)</span>
          <input id="projectionMonths" type="number" min="1" max="60" value={defaults.projection_months} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" />
        </label>
      </div>
      <p class="text-neutral-500 text-sm mt-6">Estimates are directional. Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <!-- Summary -->
    <section id="summary" class="grid md:grid-cols-3 gap-5 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Cheapest provider</p>
        <p id="cheapestProvider" class="text-xl font-bold text-brand-gold">—</p>
        <p id="cheapestCost" class="text-sm text-neutral-400 mt-1">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Cost per 1M requests</p>
        <p id="costPer1m" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/30 text-center">
        <p class="text-xs text-neutral-500 uppercase mb-1">Projected period cost</p>
        <p id="periodCost" class="text-2xl font-bold text-brand-gold">—</p>
      </div>
    </section>

    <!-- Results table -->
    <section class="overflow-x-auto mb-12">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-neutral-700 text-neutral-400 text-sm uppercase tracking-wide">
            <th class="py-3 pr-4">Provider</th>
            <th class="py-3 pr-4">Category</th>
            <th class="py-3 pr-4 text-right">Observations cost</th>
            <th class="py-3 pr-4 text-right">Log/ingest cost</th>
            <th class="py-3 pr-4 text-right">Errors cost</th>
            <th class="py-3 pr-4 text-right">Uptime checks</th>
            <th class="py-3 pr-4 text-right">Seat cost</th>
            <th class="py-3 pr-4 text-right">Monthly</th>
          </tr>
        </thead>
        <tbody id="resultsBody" class="text-neutral-200">
          {providers.map(p => (
            <tr class="border-b border-neutral-800/50" data-slug={p.slug}>
              <td class="py-3 pr-4 font-medium">{p.name}</td>
              <td class="py-3 pr-4 text-sm text-neutral-400">{p.category}</td>
              <td class="py-3 pr-4 text-right font-mono obs-cost">—</td>
              <td class="py-3 pr-4 text-right font-mono log-cost">—</td>
              <td class="py-3 pr-4 text-right font-mono error-cost">—</td>
              <td class="py-3 pr-4 text-right font-mono uptime-cost">—</td>
              <td class="py-3 pr-4 text-right font-mono seat-cost">—</td>
              <td class="py-3 pr-4 text-right font-mono total-cost">—</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- Verdict -->
    <section id="verdict" class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-2 text-brand-gold">Verdict</h2>
      <p id="verdictText" class="text-lg text-neutral-200">—</p>
    </section>

    <!-- FAQ -->
    <section class="glass-card rounded-2xl p-6 mb-12 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="text-cyan-400 font-medium">{f.q}</h3>
            <p class="text-neutral-300 text-sm mt-1">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cross-links -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/tools/agent-workflow-cost-calculator/" class="btn-primary text-sm">Workflow Cost Calc →</a>
      <a href="/tools/agent-api-pricing-comparator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">API Pricing Comparator →</a>
      <a href="/tools/agent-tool-call-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Tool Call Cost Calc →</a>
      <a href="/tools/ai-startup-cost-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Startup Cost Calc →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm">{data.note}</p>
  </main>

  <script is:inline define:vars={{ providersJson: JSON.stringify(providers), defaultsJson: JSON.stringify(defaults) }}>
    const providers = JSON.parse(providersJson);
    const defaults = JSON.parse(defaultsJson);
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
    const fmtMoney0 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtNum = n => n.toLocaleString('en-US', { maximumFractionDigits: 1 });
    const fmtInt = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    function getInputs() {
      return {
        requests: Math.max(0, parseFloat(document.getElementById('requestsPerMonth').value) || 0),
        tracesPerReq: Math.max(0, parseFloat(document.getElementById('tracesPerRequest').value) || 0),
        sampling: Math.min(100, Math.max(0, parseFloat(document.getElementById('samplingPct').value) || 0)),
        traceSizeKb: Math.max(1, parseFloat(document.getElementById('traceSizeKb').value) || 1),
        errors: Math.max(0, parseFloat(document.getElementById('errorEvents').value) || 0),
        uptime: Math.max(0, parseFloat(document.getElementById('uptimeChecks').value) || 0),
        seats: Math.max(0, parseFloat(document.getElementById('teamSeats').value) || 0),
        projection: Math.max(1, parseFloat(document.getElementById('projectionMonths').value) || 1)
      };
    }

    function setInputs(obj) {
      if (obj.requests_per_month !== undefined) document.getElementById('requestsPerMonth').value = obj.requests_per_month;
      if (obj.traces_per_request !== undefined) document.getElementById('tracesPerRequest').value = obj.traces_per_request;
      if (obj.sampling_pct !== undefined) document.getElementById('samplingPct').value = obj.sampling_pct;
      if (obj.avg_trace_size_kb !== undefined) document.getElementById('traceSizeKb').value = obj.avg_trace_size_kb;
      if (obj.error_events_per_month !== undefined) document.getElementById('errorEvents').value = obj.error_events_per_month;
      if (obj.uptime_checks_per_month !== undefined) document.getElementById('uptimeChecks').value = obj.uptime_checks_per_month;
      if (obj.team_seats !== undefined) document.getElementById('teamSeats').value = obj.team_seats;
      if (obj.projection_months !== undefined) document.getElementById('projectionMonths').value = obj.projection_months;
    }

    function compute() {
      const inps = getInputs();
      const sampledTraces = inps.requests * inps.tracesPerReq * (inps.sampling / 100);
      const observationsMillions = sampledTraces / 1_000_000;
      const logGb = (sampledTraces * inps.traceSizeKb) / (1024 * 1024);
      const errorsThousands = inps.errors / 1000;
      const uptimeHundreds = inps.uptime / 100;

      const results = providers.map(p => {
        const obsCost = Math.max(0, observationsMillions - p.included_observations_millions) * p.cost_per_1m_observations;
        const logCost = Math.max(0, logGb - p.included_log_gb) * p.log_cost_per_gb;
        const errorCost = Math.max(0, errorsThousands - p.included_errors_1k) * p.error_cost_per_1k;
        const uptimeCost = Math.max(0, uptimeHundreds - p.included_uptime_checks_100) * p.uptime_check_cost_per_100;
        const seatCost = Math.max(0, inps.seats - p.included_seats) * p.seat_cost_monthly;
        const monthly = p.base_monthly + obsCost + logCost + errorCost + uptimeCost + seatCost;
        return { slug: p.slug, name: p.name, obsCost, logCost, errorCost, uptimeCost, seatCost, monthly };
      });

      results.sort((a, b) => a.monthly - b.monthly);
      const cheapest = results[0];
      const costPer1m = inps.requests > 0 ? cheapest.monthly / (inps.requests / 1_000_000) : 0;
      const periodCost = cheapest.monthly * inps.projection;

      document.getElementById('cheapestProvider').textContent = cheapest.name;
      document.getElementById('cheapestCost').textContent = fmtMoney0(cheapest.monthly) + ' / mo';
      document.getElementById('costPer1m').textContent = fmtMoney(costPer1m);
      document.getElementById('periodCost').textContent = fmtMoney0(periodCost);

      providers.forEach(p => {
        const r = results.find(x => x.slug === p.slug);
        const tr = document.querySelector(`#resultsBody tr[data-slug="${p.slug}"]`);
        if (!tr || !r) return;
        tr.querySelector('.obs-cost').textContent = fmtMoney(r.obsCost);
        tr.querySelector('.log-cost').textContent = fmtMoney(r.logCost);
        tr.querySelector('.error-cost').textContent = fmtMoney(r.errorCost);
        tr.querySelector('.uptime-cost').textContent = fmtMoney(r.uptimeCost);
        tr.querySelector('.seat-cost').textContent = fmtMoney(r.seatCost);
        tr.querySelector('.total-cost').textContent = fmtMoney0(r.monthly);
        if (r.slug === cheapest.slug) {
          tr.classList.add('bg-brand-gold/10');
        } else {
          tr.classList.remove('bg-brand-gold/10');
        }
      });

      const top3 = results.slice(0, 3).map((r, i) => `${i + 1}. ${r.name} (${fmtMoney0(r.monthly)}/mo)`).join(', ');
      document.getElementById('verdictText').textContent =
        `At ${fmtInt(inps.requests)} requests/mo with ${fmtNum(inps.sampling)}% sampling, the cheapest stack is ${cheapest.name} at ${fmtMoney0(cheapest.monthly)}/mo (${fmtMoney(costPer1m)} per 1M requests). ` +
        `Top 3: ${top3}. If you are still in early development, start with a free-tier provider and add paid retention only when trace volume grows.`;
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const s = JSON.parse(btn.dataset.scenario);
          setInputs(s);
          compute();
        });
      });

      ['requestsPerMonth','tracesPerRequest','samplingPct','traceSizeKb','errorEvents','uptimeChecks','teamSeats','projectionMonths'].forEach(id => {
        document.getElementById(id).addEventListener('input', compute);
      });

      compute();
    });
  </script>
</Layout>
