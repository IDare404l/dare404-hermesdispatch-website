---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import data from '../../data/hashrate_to_inference_converter.json';

const title = "GPU Hashrate to Inference Capacity Converter | Hermes Dispatch";
const description = "Convert crypto-mining hashrate into estimated local LLM inference tokens per second. Compare mining power cost with potential inference value for miner pivots.";
const algorithms = data.algorithms;
const models = data.inference_models;
const profiles = data.gpu_profiles;
const scenarios = data.scenarios;
const defaults = data.defaults;

const faqs = [
  { q: "How does mining hashrate relate to LLM inference speed?", a: "Both depend on GPU memory bandwidth, compute, and power. A card that hashes faster on memory-bound algorithms usually also runs LLMs faster, but the correlation is rough because different algorithms stress different parts of the chip. This tool scales measured hashrate against known benchmarks to estimate tok/s." },
  { q: "Which algorithm gives the best proxy for LLM inference?", a: "Memory-bound algorithms like Etchash, ZelHash, and Octopus are closer to LLM inference than compute-bound algorithms like KawPow. Use the algorithm you are actually mining for the most relevant pivot estimate." },
  { q: "Can I use this for multi-GPU rigs?", a: "Yes. Enter the total measured hashrate of the whole rig and set the power draw and hours to match the full system. The converter scales linearly, so a rig with 2x the hashrate of a single card is estimated to deliver roughly 2x the tok/s." },
  { q: "Why does the 70B model show zero tok/s for some cards?", a: "A 70B parameter model at 4-bit quantization needs roughly 40 GB of VRAM. Cards with 16 GB or less cannot run it without aggressive offloading, which is usually too slow to be useful, so the calculator marks them as unsupported." },
  { q: "Is this a guarantee of actual inference revenue?", a: "No. The cloud-equivalent value is a benchmark, not a price you will automatically earn. Rental pricing, demand, downtime, and model quality all affect real hosting revenue. Use the Local LLM Hosting Revenue Estimator for a full business model." }
];
---

<Layout title={title} description={description}>
  <ToolSchema name="GPU Hashrate to Inference Capacity Converter" description={description} url="https://hermesdispatch.dev/tools/hashrate-to-inference-converter/" applicationCategory="DeveloperApplication" operatingSystem="Any" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({"@type": "Question", "name": f.q, "acceptedAnswer": {"@type": "Answer", "text": f.a}}))
  })} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-6 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">⛏️</div>
      <h1 class="display-heading mb-4">GPU Hashrate to Inference Capacity Converter</h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">Turn your crypto-mining hashrate into an estimated local LLM tok/s number. Compare electricity cost with cloud-equivalent inference value.</p>
    </div>

    <section class="glass-card rounded-2xl p-6 mb-8 border border-brand-gold/20">
      <h2 class="text-lg font-bold mb-4 text-brand-gold">Scenario preset</h2>
      <div class="flex flex-wrap gap-3" id="scenario-buttons">
        {scenarios.map((s, i) => (
          <button type="button" class="scenario-btn px-4 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-sm transition-colors" data-scenario={JSON.stringify(s)} data-index={i}>
            {s.name}
          </button>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-6 mb-10">
      <div class="glass-card rounded-2xl p-6 border border-brand-gold/20">
        <h2 class="text-xl font-bold mb-6 text-brand-gold flex items-center gap-2"><span>⛏️</span> Mining input</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">GPU / rig profile</span>
            <select id="gpuProfile" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {profiles.map(p => <option value={JSON.stringify(p)} selected={p.name === defaults.gpu}>{p.name} {p.vram_gb ? `(${p.vram_gb} GB)` : ''}</option>)}
            </select>
          </label>
          <label class="block hidden" id="referenceGpuLabel"><span class="text-neutral-400 text-sm">Reference GPU for scaling</span>
            <select id="referenceGpu" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {profiles.filter(p => !p.is_custom).map(p => <option value={JSON.stringify(p)} selected={p.name === (profiles.find(x => x.is_custom)?.reference_gpu || defaults.gpu)}>{p.name}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">Algorithm</span>
            <select id="algorithm" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {algorithms.map(a => <option value={a.id} selected={a.id === defaults.algorithm}>{a.name}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-neutral-400 text-sm">Measured hashrate (<span id="hashrateUnit">MH/s</span>)</span><input id="hashrate" type="number" min="0" step="0.1" value={defaults.hashrate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Inference model</span>
            <select id="inferenceModel" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1">
              {models.map(m => <option value={m.id} selected={m.id === defaults.inference_model}>{m.name}</option>)}
            </select>
          </label>
        </div>

        <h2 class="text-xl font-bold mt-8 mb-6 text-brand-gold flex items-center gap-2"><span>⚡</span> Power & economics</h2>
        <div class="space-y-4">
          <label class="block"><span class="text-neutral-400 text-sm">Power draw (W)</span><input id="powerW" type="number" min="0" step="10" value={defaults.power_w} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Electricity rate ($/kWh)</span><input id="electricityRate" type="number" min="0" step="0.01" value={defaults.electricity_rate} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Hours online / day</span><input id="hoursPerDay" type="number" min="0" max="24" step="0.5" value={defaults.hours_per_day} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Inference utilization (%)</span><input id="inferenceUtil" type="number" min="0" max="100" step="1" value={defaults.inference_utilization_pct} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
          <label class="block"><span class="text-neutral-400 text-sm">Cloud API price ($/1M tokens)</span><input id="apiPrice" type="number" min="0" step="0.1" value={defaults.api_price_per_1m_tokens} class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white mt-1" /></label>
        </div>
      </div>

      <div class="space-y-6">
        <section id="summary" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Estimated tok/s</p><p id="tokPerSec" class="text-2xl font-bold text-brand-gold">—</p><p id="modelSupport" class="text-sm text-neutral-400 mt-1">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Tokens / day</p><p id="tokPerDay" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Tokens / month</p><p id="tokPerMonth" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Electricity cost / mo</p><p id="powerCost" class="text-2xl font-bold text-white">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Cloud-equivalent value / mo</p><p id="cloudValue" class="text-2xl font-bold text-brand-gold">—</p></div>
          <div class="glass-card rounded-2xl p-5 text-center border border-brand-gold/20"><p class="text-xs text-neutral-500 uppercase mb-1">Net value vs power</p><p id="netValue" class="text-2xl font-bold text-white">—</p></div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">GPU comparison for this algorithm & model</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-neutral-500 border-b border-neutral-800">
                  <th class="py-2 pr-2">GPU</th>
                  <th class="py-2 pr-2 text-right">VRAM</th>
                  <th class="py-2 pr-2 text-right">Hashrate</th>
                  <th class="py-2 pr-2 text-right">Tok/s</th>
                  <th class="py-2 text-right">Tokens/day</th>
                </tr>
              </thead>
              <tbody id="comparisonTable" class="divide-y divide-neutral-800"></tbody>
            </table>
          </div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">Sensitivity to hashrate</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-neutral-500 border-b border-neutral-800">
                  <th class="py-2 pr-2">% of reference</th>
                  <th class="py-2 pr-2 text-right">Hashrate</th>
                  <th class="py-2 pr-2 text-right">Tok/s</th>
                  <th class="py-2 text-right">Tokens / mo</th>
                </tr>
              </thead>
              <tbody id="sensitivityTable" class="divide-y divide-neutral-800"></tbody>
            </table>
          </div>
        </section>

        <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
          <h2 class="text-xl font-bold mb-4 text-brand-gold">Verdict</h2>
          <p id="verdictText" class="text-neutral-300">—</p>
        </section>
      </div>
    </section>

    <section class="glass-card rounded-2xl p-6 mb-10 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-4 text-brand-gold">How the math works</h2>
      <ul class="list-disc pl-5 text-neutral-300 space-y-2">
        <li>The converter looks up the selected GPU's reference hashrate for the chosen algorithm and its reference tok/s for the chosen model.</li>
        <li>It computes a ratio = your measured hashrate ÷ reference hashrate, then multiplies reference tok/s by that ratio.</li>
        <li>For custom GPUs, the same ratio is applied using the reference GPU you select.</li>
        <li>Monthly tokens assume the selected inference utilization % applied to the hours-per-day the rig is online.</li>
        <li>Cloud-equivalent value = monthly tokens ÷ 1,000,000 × your chosen API price per 1M tokens. It shows what you would pay for the same output at that API rate.</li>
      </ul>
      <p class="text-neutral-500 text-sm mt-6">Last updated: {data.last_updated}. <a href="#note" class="text-cyan-400 underline">See notes</a>.</p>
    </section>

    <section class="glass-card rounded-2xl p-6 border border-brand-gold/20">
      <h2 class="text-xl font-bold mb-6 text-brand-gold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-neutral-900/50 rounded-xl border border-neutral-800">
            <summary class="p-4 cursor-pointer font-medium text-neutral-200 flex justify-between items-center">{f.q}<span class="text-brand-gold group-open:rotate-180 transition-transform">▼</span></summary>
            <p class="p-4 pt-0 text-neutral-400">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/tools/miner-pivot-calculator/" class="btn-primary text-sm">Miner Pivot Calculator →</a>
      <a href="/tools/local-llm-roi-calculator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Local LLM ROI Calculator →</a>
      <a href="/tools/local-llm-hosting-revenue-estimator/" class="px-4 py-2 rounded-lg border border-neutral-700 hover:bg-neutral-800 text-sm transition-colors">Hosting Revenue Estimator →</a>
    </div>

    <p id="note" class="text-neutral-500 text-sm mt-10">{data.note}</p>
  </main>

  <script is:inline define:vars={{ algorithms, models, profiles, scenarios, defaults }}>
    function $(id) { return document.getElementById(id); }
    function val(id) { return parseFloat($(id).value) || 0; }
    function pct(id) { return Math.min(100, Math.max(0, val(id) / 100)); }
    const fmtMoney = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
    const fmtMoney0 = n => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const fmtNum = n => n.toLocaleString('en-US', { maximumFractionDigits: 1 });
    const fmtInt = n => n.toLocaleString('en-US', { maximumFractionDigits: 0 });

    function getSelectedProfile() { return JSON.parse($('gpuProfile').value); }
    function getReferenceProfile() { return JSON.parse($('referenceGpu').value); }
    function getAlgorithm() { return algorithms.find(a => a.id === $('algorithm').value); }
    function getModel() { return models.find(m => m.id === $('inferenceModel').value); }

    function referenceTpsAndHashrate(profile, algoId, modelId) {
      const refHash = profile.hashrates[algoId] || 0;
      const refTps = profile.inference_tps[modelId];
      return { refHash, refTps };
    }

    function computeEstimates() {
      const profile = getSelectedProfile();
      const algo = getAlgorithm();
      const model = getModel();
      const hashrate = Math.max(0, val('hashrate'));
      const powerW = Math.max(0, val('powerW'));
      const rate = Math.max(0, val('electricityRate'));
      const hours = Math.min(24, Math.max(0, val('hoursPerDay')));
      const util = pct('inferenceUtil');
      const apiPrice = Math.max(0, val('apiPrice'));

      $('hashrateUnit').textContent = algo.unit;

      const custom = !!profile.is_custom;
      $('referenceGpuLabel').classList.toggle('hidden', !custom);

      let refProfile = profile;
      if (custom) refProfile = getReferenceProfile();

      const { refHash, refTps } = referenceTpsAndHashrate(refProfile, algo.id, model.id);
      const ratio = refHash > 0 ? hashrate / refHash : 0;
      let tps = refTps === undefined ? 0 : (refTps * ratio);
      const supported = refTps > 0;

      const secondsPerDay = hours * 3600;
      const tokensPerDay = supported ? tps * secondsPerDay * util : 0;
      const tokensPerMonth = tokensPerDay * 30.44;
      const kwhPerDay = (powerW / 1000) * hours;
      const kwhPerMonth = kwhPerDay * 30.44;
      const powerCost = kwhPerMonth * rate;
      const cloudValue = (tokensPerMonth / 1000000) * apiPrice;
      const netValue = cloudValue - powerCost;

      return { tps, supported, tokensPerDay, tokensPerMonth, powerCost, cloudValue, netValue, ratio, refProfile, algo, model, util };
    }

    function render() {
      const est = computeEstimates();
      const { tps, supported, tokensPerDay, tokensPerMonth, powerCost, cloudValue, netValue, ratio, refProfile, algo, model, util } = est;

      if (!supported) {
        $('tokPerSec').textContent = 'N/A';
        $('modelSupport').textContent = 'Model likely does not fit this GPU profile';
        $('modelSupport').className = 'text-sm text-red-400 mt-1';
      } else {
        $('tokPerSec').textContent = fmtNum(tps) + ' tok/s';
        $('modelSupport').textContent = `Scaled from ${refProfile.name} at ${util * 100}% utilization`;
        $('modelSupport').className = 'text-sm text-neutral-400 mt-1';
      }
      $('tokPerDay').textContent = fmtInt(tokensPerDay);
      $('tokPerMonth').textContent = fmtInt(tokensPerMonth);
      $('powerCost').textContent = fmtMoney(powerCost) + '/mo';
      $('cloudValue').textContent = fmtMoney(cloudValue) + '/mo';
      $('netValue').textContent = fmtMoney(netValue) + '/mo';
      $('netValue').className = 'text-2xl font-bold ' + (netValue >= 0 ? 'text-emerald-400' : 'text-red-400');

      // Comparison table
      const tbody = $('comparisonTable');
      tbody.innerHTML = '';
      profiles.filter(p => !p.is_custom).forEach(p => {
        const { refHash, refTps } = referenceTpsAndHashrate(p, algo.id, model.id);
        const dayTokens = refTps > 0 ? refTps * 24 * 3600 : 0;
        const selected = p.name === getSelectedProfile().name;
        const tr = document.createElement('tr');
        tr.className = selected ? 'text-brand-gold font-semibold' : 'text-neutral-300';
        tr.innerHTML = `
          <td class="py-2 pr-2">${p.name}</td>
          <td class="py-2 pr-2 text-right">${p.vram_gb} GB</td>
          <td class="py-2 pr-2 text-right">${refHash > 0 ? refHash + ' ' + algo.unit : '—'}</td>
          <td class="py-2 pr-2 text-right">${refTps > 0 ? fmtNum(refTps) : 'N/A'}</td>
          <td class="py-2 text-right">${dayTokens > 0 ? fmtInt(dayTokens) : '—'}</td>
        `;
        tbody.appendChild(tr);
      });

      // Sensitivity table
      const sens = $('sensitivityTable');
      sens.innerHTML = '';
      const profile = getSelectedProfile();
      const ref = profile.is_custom ? getReferenceProfile() : profile;
      const refHash = ref.hashrates[algo.id] || 1;
      const refTps = ref.inference_tps[model.id] || 0;
      [0.25, 0.5, 0.75, 1.0, 1.25, 1.5, 2.0].forEach(mult => {
        const h = refHash * mult;
        const t = refTps * mult;
        const mo = t * 24 * 3600 * 30.44;
        const active = Math.abs(mult - ratio) < 0.05;
        const tr = document.createElement('tr');
        tr.className = active ? 'text-brand-gold font-semibold' : 'text-neutral-300';
        tr.innerHTML = `
          <td class="py-2 pr-2">${(mult * 100).toFixed(0)}%</td>
          <td class="py-2 pr-2 text-right">${fmtNum(h)} ${algo.unit}</td>
          <td class="py-2 pr-2 text-right">${refTps > 0 ? fmtNum(t) : 'N/A'}</td>
          <td class="py-2 text-right">${refTps > 0 ? fmtInt(mo) : '—'}</td>
        `;
        sens.appendChild(tr);
      });

      // Verdict
      let verdict = '';
      if (!supported) {
        verdict = `The selected model likely does not fit on ${getSelectedProfile().name} (${getSelectedProfile().vram_gb} GB VRAM). Pick a smaller model or a card with more memory to see throughput estimates.`;
      } else {
        verdict = `At ${fmtNum(est.tps)} tok/s, this rig could generate about ${fmtInt(tokensPerDay)} tokens per day and ${fmtInt(tokensPerMonth)} per month while running inference ${util * 100}% of the time. `;
        if (netValue > 0) {
          verdict += `That output would cost roughly ${fmtMoney(cloudValue)} at the chosen API price, leaving an estimated ${fmtMoney(netValue)} after ${fmtMoney(powerCost)} in electricity. `;
        } else {
          verdict += `The cloud-equivalent value is ${fmtMoney(cloudValue)}, which is below the ${fmtMoney(powerCost)} electricity cost at these assumptions. `;
        }
        if (tokensPerMonth > 100000000) {
          verdict += 'This is serious inference capacity—consider load balancing, cooling headroom, and a hosting marketplace.';
        } else if (tokensPerMonth > 10000000) {
          verdict += 'This is solid hobby-to-small-SaaS capacity. Compare the numbers in the Local LLM ROI and Hosting Revenue calculators next.';
        } else {
          verdict += 'This is a modest inference node. It is best suited for personal agents, experiments, or low-traffic services.';
        }
      }
      $('verdictText').textContent = verdict;
    }

    function applyScenario(s) {
      const profileMatch = Array.from($('gpuProfile').options).find(o => JSON.parse(o.value).name === s.gpu);
      if (profileMatch) $('gpuProfile').value = profileMatch.value;
      $('algorithm').value = s.algorithm;
      $('hashrate').value = s.hashrate;
      $('inferenceModel').value = s.inference_model;
      $('powerW').value = s.power_w;
      $('electricityRate').value = s.electricity_rate;
      $('hoursPerDay').value = s.hours_per_day;
      $('inferenceUtil').value = s.inference_utilization_pct;
      $('apiPrice').value = s.api_price_per_1m_tokens;
      render();
    }

    function setDefaultsFromProfile() {
      const profile = getSelectedProfile();
      const algo = getAlgorithm();
      if (!profile.is_custom && profile.hashrates[algo.id]) {
        $('hashrate').value = profile.hashrates[algo.id];
      }
      $('powerW').value = profile.tdp_w;
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('bg-brand-gold', 'text-neutral-950', 'border-brand-gold'));
          btn.classList.add('bg-brand-gold', 'text-neutral-950', 'border-brand-gold');
          applyScenario(JSON.parse(btn.dataset.scenario));
        });
      });

      $('gpuProfile').addEventListener('change', () => {
        setDefaultsFromProfile();
        render();
      });
      $('algorithm').addEventListener('change', () => {
        const profile = getSelectedProfile();
        if (!profile.is_custom && profile.hashrates[$('algorithm').value]) {
          $('hashrate').value = profile.hashrates[$('algorithm').value];
        }
        render();
      });
      $('referenceGpu').addEventListener('change', render);
      ['inferenceModel','hashrate','powerW','electricityRate','hoursPerDay','inferenceUtil','apiPrice'].forEach(id => {
        $(id).addEventListener('input', render);
      });

      setDefaultsFromProfile();
      render();
    });
  </script>
</Layout>
