---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    date: 'July 2025',
    title: 'Mission Freedom Started',
    description: 'The journey began. Initial exploration of AI agent automation for digital entrepreneurship.',
    status: 'completed',
    milestone: true
  },
  {
    date: 'August 2025',
    title: 'Multi-Agent Architecture',
    description: 'Built a 9-agent system: Tabby, Twatter, Librarian, Emailer, Daily Report, and others. Each agent had dedicated responsibilities.',
    status: 'completed'
  },
  {
    date: 'September 2025',
    title: 'Token Crisis & Pivot',
    description: 'Discovered massive token waste from subagent context duplication. 60-70% of tokens lost to handoffs between agents.',
    status: 'completed',
    milestone: true
  },
  {
    date: 'October 2025',
    title: 'IGOR Born',
    description: 'IGOR (Intelligent General Operations Router) created. Replaced 9 agents with unified execution context + modular skills.',
    status: 'completed',
    milestone: true
  },
  {
    date: 'November 2025',
    title: 'Skills Library Grows',
    description: 'Former subagent responsibilities converted to modular skills. 40+ active skills across 15 categories.',
    status: 'completed'
  },
  {
    date: 'December 2025',
    title: 'Learning Consolidation',
    description: 'Unified Learning Agent replaces 6 individual learner agents. Token-aware fallback system implemented.',
    status: 'completed',
    milestone: true
  },
  {
    date: 'January 2026',
    title: 'AutoFix Monitor Deployed',
    description: 'Autonomous error detection and repair system. HALT+RERUN protocol operational.',
    status: 'completed'
  },
  {
    date: 'February 2026',
    title: 'The Trending Tabby Live',
    description: 'Complete Etsy automation system. Daily 07:00 reports with trend analysis and design generation.',
    status: 'completed'
  },
  {
    date: 'March 2026',
    title: 'Social Media Automation',
    description: 'Unified Twatter managing Twitter/X engagement. Cross-promotion monitoring and hourly engagement sweeps.',
    status: 'completed'
  },
  {
    date: 'April 2026',
    title: 'Website Launch',
    description: 'hermesdispatch.dev goes live. Documentation hub for all Mission Freedom systems and skills.',
    status: 'completed',
    milestone: true
  },
  {
    date: 'May 2026',
    title: 'Newsletter Started',
    description: 'The Hermes Dispatch weekly newsletter. Every Monday at 3 PM EST.',
    status: 'in-progress'
  },
  {
    date: 'June 2026',
    title: 'Coming Soon',
    description: 'IGOR v2.0 with improved context management. Skill marketplace prototype.',
    status: 'planned'
  }
];

const metrics = [
  { label: 'Started', value: 'July 2025', icon: '📅' },
  { label: 'Agents Replaced', value: '8', icon: '🔄' },
  { label: 'Skills Created', value: '70+', icon: '🛠️' },
  { label: 'Token Savings', value: '60-70%', icon: '⭕' },
  { label: 'Daily Operations', value: 'Automated', icon: '⚡' },
  { label: 'Status', value: 'Active', icon: '🟢' }
];
---

<Layout title="Timeline | Mission Freedom">
  
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-500/10 border border-orange-500/30 mb-6">
          <span class="w-2 h-2 bg-orange-400 rounded-full animate-pulse"></span>
          <span class="text-orange-400 text-sm font-medium">Mission Freedom Timeline</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">Journey</span>
        </h1>
        
        <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
          From 9-agent chaos to unified orchestration. 
          The evolution of IGOR and Mission Freedom.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 md:grid-cols-6 gap-4 mb-16">
        {metrics.map(m => (
          <div class="text-center p-4 bg-neutral-900 border border-neutral-800 rounded-xl hover:border-orange-500/30 transition-colors">
            <div class="text-2xl mb-1">{m.icon}</div>
            <div class="text-2xl font-bold text-orange-400">{m.value}</div>
            <div class="text-sm text-neutral-500">{m.label}</div>
          </div>
        ))}
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-orange-500/50 via-amber-500/30 to-neutral-800 md:-translate-x-1/2"></div>
        
        <div class="space-y-8">
          {timeline.map((item, idx) => (
            <div class={`flex gap-8 ${idx % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              
              <!-- Content side -->
              <div class="flex-1 md:text-right ${idx % 2 !== 0 ? 'md:text-left' : ''}">
                <div class={`pl-12 md:pl-0 ${idx % 2 === 0 ? 'md:pr-12' : 'md:pl-12'}`}>
                  <!-- Status badge -->
                  <div class="flex items-center gap-2 mb-2 ${idx % 2 !== 0 ? 'md:justify-start' : 'md:justify-end'}">
                    {item.status === 'completed' && (
                      <span class="px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs">Completed</span>
                    )}
                    {item.status === 'in-progress' && (
                      <span class="px-2 py-0.5 rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400 text-xs">In Progress</span>
                    )}
                    {item.status === 'planned' && (
                      <span class="px-2 py-0.5 rounded-full bg-neutral-700 border border-neutral-600 text-neutral-400 text-xs">Planned</span>
                    )}
                    {item.milestone && (
                      <span class="px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-xs">★ Milestone</span>
                    )}
                  </div>
                  
                  <!-- Date -->
                  <div class="text-sm font-medium text-orange-400 mb-1">{item.date}</div>
                  
                  <!-- Title -->
                  <h3 class="font-semibold text-lg mb-2">{item.title}</h3>
                  
                  <!-- Description -->
                  <p class="text-neutral-400 text-sm">{item.description}</p>
                </div>
              </div>
              
              <!-- Center dot -->
              <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full ${item.milestone ? 'bg-orange-500 border-4 border-orange-900' : item.status === 'in-progress' ? 'bg-amber-500 animate-pulse' : 'bg-neutral-600'} md:-translate-x-1/2 -translate-y-1">
                {item.milestone && <span class="absolute -inset-2 bg-orange-500/20 rounded-full"></span>}
              </div>
              
              <!-- Empty side for layout -->
              <div class="flex-1 hidden md:block"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <p class="text-neutral-400 mb-6">Want to follow the journey in real time?</p>
        <a href="/newsletter" class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 text-black font-semibold rounded-xl hover:bg-orange-400 transition-colors">
          Subscribe to Updates
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
