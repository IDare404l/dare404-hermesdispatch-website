---
import Layout from '../layouts/Layout.astro';
import { milestones, phases, categoryLabels, statusLabels } from '../data/timeline';
const title = "Timeline | Mission Freedom";
const description = "The complete journey of Mission Freedom - from inception to expansion. Milestones, phases, and what's next.";
---

<Layout title={title} description={description}>
  <main class="min-h-screen bg-slate-950">
    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Mission Freedom <span class="bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">Timeline</span>
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl mx-auto">
            From inception to expansion. Every milestone on the journey to autonomy.
          </p>
        </div>
        
        <!-- Phase Legend -->
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          {phases.map(phase => (
            <div class="flex items-center gap-2 px-4 py-2 bg-slate-800 rounded-full">
              <div class="w-3 h-3 rounded-full" style={{ backgroundColor: phase.color }} />
              <span class="text-sm font-medium text-slate-300">{phase.name}</span>
            </div>
          ))}
        </div>
      </div>
    </header>

    <!-- Timeline Content -->
    <section class="py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <!-- Vertical Line -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-400 via-purple-400 to-pink-400 md:-translate-x-1/2" />
          
          {[...milestones].reverse().map((milestone, index) => {
            const status = statusLabels[milestone.status];
            const isLeft = index % 2 === 0;
            
            return (
              <div class="relative flex md:items-start mb-8 md:mb-12">
                <!-- Timeline Dot -->
                <div class="absolute left-4 md:left-1/2 w-8 h-8 rounded-full border-4 border-slate-900 flex items-center justify-center z-10 md:-translate-x-1/2"
                  style={{ backgroundColor: status.color }}>
                  <span class="text-xs">{status.icon}</span>
                </div>
                
                <!-- Content Card -->
                <div class={`ml-16 md:ml-0 md:w-5/12 ${isLeft ? 'md:mr-auto md:pr-12' : 'md:ml-auto md:pl-12'} md:text-${isLeft ? 'right' : 'left'}`}>
                  <article class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-colors group">
                    <!-- Header -->
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        {new Date(milestone.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                      </span>
                      <span class="text-slate-600">•</span>
                      <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">
                        {categoryLabels[milestone.category]}
                      </span>
                    </div>
                    
                    <!-- Title -->
                    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">
                      {milestone.title}
                    </h3>
                    
                    <!-- Description -->
                    <p class="text-slate-400 mb-4">
                      {milestone.description}
                    </p>
                    
                    <!-- Deliverables -->
                    <div class="flex flex-wrap gap-2 mb-4">
                      {milestone.deliverables.map(deliverable => (
                        <span class="text-xs px-2 py-1 bg-slate-800 text-slate-300 rounded">
                          {deliverable}
                        </span>
                      ))}
                    </div>
                    
                    <!-- Metrics -->
                    {milestone.metrics && (
                      <div class="bg-slate-950 rounded-lg p-3">
                        <div class="flex flex-wrap gap-4">
                          {Object.entries(milestone.metrics).map(([key, value]) => (
                            <div class="text-center">
                              <span class="block text-lg font-bold text-white">{value}</span>
                              <span class="text-xs text-slate-500 capitalize">{key.replace('_', ' ')}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </article>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Status Legend -->
    <section class="py-12 px-6 border-t border-slate-800">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">Status Legend</h2>
        <div class="flex flex-wrap justify-center gap-6">
          {Object.entries(statusLabels).map(([status, config]) => (
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full" style={{ backgroundColor: config.color }} />
              <span class="text-lg">{config.icon}</span>
              <span class="text-slate-400 capitalize">{status.replace('-', ' ')}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-6 bg-slate-900">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Join the Journey</h2>
        <p class="text-slate-400 mb-8">
          Get daily dispatches documenting every milestone, failure, and breakthrough as we build Mission Freedom.
        </p>
        <a href="/#subscribe" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
          Subscribe to The Hermes Dispatch
        </a>
      </div>
    </section>
  </main>
</Layout>
