---
// Newsletter CTA Component v4 — API-Free Mailto Subscribe
// No server-side worker needed. Opens user's email client with pre-filled subscribe request.
---

<section class="relative py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-accent/5 via-transparent to-brand-gold/5"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-gold/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="glass-card rounded-3xl p-8 md:p-12 text-center border border-brand-gold/20">
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg shadow-brand-gold/30">
        📧
      </div>
    
      <h2 class="section-heading text-white mb-4">
        Join the <span class="text-gradient">Dispatch</span>
      </h2>

      <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-8">
        Get <span class="text-brand-gold">Hermes Dispatch</span> — tactical insights on AI agent automation,
        multi-agent orchestration, and building autonomous systems. Delivered daily at 3 PM MST.
      </p>

      <a 
        href="mailto:derekkosakura@gmail.com?subject=Subscribe&body=Please%20subscribe%20me%20to%20the%20Mission%20Freedom%20Dispatch.%0A%0AEmail%3A%20"
        class="btn-primary inline-block whitespace-nowrap"
        id="subscribe-btn"
      >
        Join the Dispatch
      </a>

      <div class="mt-8 space-y-3 text-sm text-gray-400">
        <p>Or manually: send an email to <code class="bg-brand-card px-2 py-1 rounded text-brand-gold">derekkosakura@gmail.com</code> with subject <code class="bg-brand-card px-2 py-1 rounded text-brand-gold">Subscribe</code></p>
      </div>
      
      <p class="text-gray-500 text-sm mt-6">
        API-free. No external services. Your email client handles the request.
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-6 mt-8 text-gray-500 text-xs">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          No spam, ever
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          One-click unsubscribe
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Privacy-first (no tracking)
        </span>
      </div>
      
    </div>
  </div>
</section>

<script>
  // Track clicks for analytics (localStorage only, no external services)
  document.getElementById('subscribe-btn')?.addEventListener('click', () => {
    const clicks = parseInt(localStorage.getItem('dispatch-subscribe-clicks') || '0');
    localStorage.setItem('dispatch-subscribe-clicks', (clicks + 1).toString());
  });
</script>