---
// Floating yellow balls animation - full page background effect
---

<div class="floating-balls-container" aria-hidden="true">
  <div class="balls-wrapper">
    {[...Array(25)].map((_, i) => (
      <div 
        class="floating-ball"
        style={{
          left: `${Math.random() * 100}%`,
          width: `${Math.random() * 12 + 8}px`,
          height: `${Math.random() * 12 + 8}px`,
          animationDuration: `${Math.random() * 10 + 15}s`,
          animationDelay: `${Math.random() * 15}s`,
          opacity: `${Math.random() * 0.4 + 0.2}`
        }}
      />
    ))}
  </div>
</div>

<style>
  .floating-balls-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  
  .balls-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }
  
  .floating-ball {
    position: absolute;
    bottom: -30px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #fbbf24, #f59e0b, #b45309);
    box-shadow: 0 0 20px rgba(251, 191, 36, 0.4),
                0 0 40px rgba(251, 191, 36, 0.2),
                0 0 60px rgba(251, 191, 36, 0.1);
    animation: floatUp linear infinite;
  }
  
  @keyframes floatUp {
    0% {
      transform: translateY(100vh) scale(0.8);
      opacity: 0;
    }
    5% {
      opacity: var(--opacity, 0.4);
    }
    95% {
      opacity: var(--opacity, 0.4);
    }
    100% {
      transform: translateY(-100px) scale(1);
      opacity: 0;
    }
  }
  
  /* Add subtle sway to some balls */
  .floating-ball:nth-child(3n) {
    animation-name: floatUpSway;
  }
  
  @keyframes floatUpSway {
    0% {
      transform: translateY(100vh) translateX(0) scale(0.8);
      opacity: 0;
    }
    10% {
      opacity: 0.5;
    }
    25% {
      transform: translateY(75vh) translateX(30px) scale(1);
    }
    50% {
      transform: translateY(50vh) translateX(-20px) scale(1);
    }
    75% {
      transform: translateY(25vh) translateX(25px) scale(1);
    }
    90% {
      opacity: 0.5;
    }
    100% {
      transform: translateY(-100px) translateX(0) scale(0.9);
      opacity: 0;
    }
  }
  
  /* Smaller balls with fade */
  .floating-ball:nth-child(2n) {
    background: radial-gradient(circle at 30% 30%, #fbbf24, #d97706);
    box-shadow: 0 0 15px rgba(251, 191, 36, 0.3),
                0 0 30px rgba(251, 191, 36, 0.15);
  }
  
  /* Occasional glow pulse */
  .floating-ball:nth-child(5n) {
    animation-name: floatUpGlow;
  }
  
  @keyframes floatUpGlow {
    0% {
      transform: translateY(100vh) scale(0.8);
      opacity: 0;
      box-shadow: 0 0 10px rgba(251, 191, 36, 0.3);
    }
    10% {
      opacity: 0.6;
    }
    30% {
      box-shadow: 0 0 30px rgba(251, 191, 36, 0.5),
                  0 0 60px rgba(251, 191, 36, 0.3);
    }
    50% {
      box-shadow: 0 0 20px rgba(251, 191, 36, 0.4);
    }
    70% {
      box-shadow: 0 0 40px rgba(251, 191, 36, 0.5),
                  0 0 80px rgba(251, 191, 36, 0.2);
    }
    90% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(-100px) scale(1);
      opacity: 0;
      box-shadow: 0 0 10px rgba(251, 191, 36, 0.2);
    }
  }
</style>
