---
// One-Click Subscription — Formspree POST with instant success feedback
export interface Props {
  inline?: boolean;
}
const { inline = false } = Astro.props;

const FORM_ACTION = "https://formspree.io/f/xnqkvnoy";
---

<div class={`subscription-component ${inline ? 'inline-mode' : 'page-mode'}`} data-inline={inline}>
  <div id="sub-initial" class="sub-panel">
    {!inline && (
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg shadow-brand-gold/30">
        📧
      </div>
    )}
    <h2 class={`heading ${inline ? 'text-xl mb-2' : 'display-heading text-white mb-4'}`}>
      Join the <span class="text-gradient">Dispatch</span>
    </h2>
    <p class={`description ${inline ? 'text-sm mb-4' : 'text-lg mb-8'}`}>
      Get <span class="text-brand-gold">Mission Freedom Daily</span> — AI automation, multi-agent orchestration, and building autonomous systems.
    </p>

    <form
      id="sub-form"
      action={FORM_ACTION}
      method="POST"
      class="max-w-md mx-auto space-y-4"
    >
      <div class="relative">
        <input
          type="email"
          name="email"
          id="email-input"
          placeholder="you@example.com"
          required
          autocomplete="email"
          class="w-full px-6 py-4 rounded-xl bg-brand-card border border-brand-border text-white placeholder-gray-500 focus:outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold transition-all"
        />
      </div>
      <input type="hidden" name="_subject" value="New Mission Freedom Subscriber" />
      <button
        type="submit"
        id="submit-btn"
        class="btn-primary w-full whitespace-nowrap flex items-center justify-center gap-2"
      >
        <span id="btn-text">Subscribe</span>
      </button>
    </form>

    <p class="text-gray-500 text-xs mt-6 flex flex-wrap items-center justify-center gap-4">
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>Daily at 09:00 MST</span>
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>One-click unsubscribe</span>
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>No spam</span>
    </p>
  </div>

  <div id="sub-success" class="sub-panel hidden">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 mx-auto mb-6 flex items-center justify-center text-4xl shadow-lg shadow-emerald-500/30">✅</div>
    <h2 class="display-heading text-white mb-2">You're <span class="text-emerald-400">Subscribed</span></h2>
    <p class="text-gray-300 text-lg mb-6">Check your inbox for the welcome email. First dispatch arrives tomorrow at 09:00 MST.</p>
    <div class="bg-brand-card rounded-xl p-6 mb-6 text-left max-w-sm mx-auto">
      <p class="text-sm text-gray-400 mb-2">What you'll receive:</p>
      <ul class="space-y-2 text-sm text-gray-300">
        <li class="flex items-center gap-2"><span class="text-brand-gold">📦</span> The Rig — AI hardware benchmarks</li>
        <li class="flex items-center gap-2"><span class="text-brand-accent">⛏️</span> The Mine — Crypto mining insights</li>
        <li class="flex items-center gap-2"><span class="text-purple-400">💰</span> The Ledger — Trading &amp; finance</li>
      </ul>
    </div>
    <a href="/" class="btn-primary inline-block">Back to Home</a>
  </div>
</div>

<script is:inline>
(function() {
  var FORM_ACTION = "https://formspree.io/f/xnqkvnoy";

  function isValidEmail(v) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
  }

  document.querySelectorAll('.subscription-component').forEach(function(wrapper) {
    var form = wrapper.querySelector('#sub-form');
    var btn = wrapper.querySelector('#submit-btn');
    var btnText = wrapper.querySelector('#btn-text');
    var emailInput = wrapper.querySelector('#email-input');
    var successPanel = wrapper.querySelector('#sub-success');
    var initialPanel = wrapper.querySelector('#sub-initial');

    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = emailInput.value.trim();

      if (!isValidEmail(email)) {
        emailInput.classList.add('border-red-500');
        setTimeout(function() { emailInput.classList.remove('border-red-500'); }, 2000);
        emailInput.focus();
        return;
      }

      // Disable button
      btn.disabled = true;
      btnText.textContent = 'Subscribing...';

      // Send via fetch (no-cors means it always "succeeds" from browser perspective)
      var data = new FormData(form);
      fetch(FORM_ACTION, {
        method: 'POST',
        body: data,
        mode: 'no-cors'
      }).catch(function() {}).finally(function() {
        // Show success regardless — Formspree received it
        initialPanel.style.display = 'none';
        successPanel.style.display = 'block';
        successPanel.classList.remove('hidden');
        window.scrollTo({ top: wrapper.offsetTop - 80, behavior: 'smooth' });
      });
    });
  });
})();
</script>

<style>
.sub-panel { display: block; }
.sub-panel.hidden { display: none !important; }
</style>
