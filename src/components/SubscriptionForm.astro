---
// Universal Subscription Component
// Usage: <SubscriptionForm inline={false} /> (full page) or <SubscriptionForm inline={true} /> (CTA)
export interface Props {
  inline?: boolean;
}
const { inline = false } = Astro.props;
---

<div class={`subscription-component ${inline ? 'inline-mode' : 'page-mode'}`} data-inline={inline}>
  <div id="sub-initial" class="sub-panel">
    {!inline && (
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-8 flex items-center justify-center text-4xl shadow-lg shadow-brand-gold/30">
        📧
      </div>
    )}
    <h2 class={`heading ${inline ? 'text-xl mb-2' : 'display-heading text-white mb-4'}`}>
      Join the <span class="text-gradient">Dispatch</span>
    </h2>
    <p class={`description ${inline ? 'text-sm mb-4' : 'text-lg mb-8'}`}>
      Get <span class="text-brand-gold">Mission Freedom Daily</span> — AI agent automation, multi-agent orchestration, and building autonomous systems.
    </p>
    <form id="sub-form" class="max-w-md mx-auto space-y-4" onsubmit="return false;">
      <div class="relative">
        <input 
          type="email" 
          id="email-input"
          placeholder="you@example.com"
          required
          autocomplete="email"
          class="w-full px-6 py-4 rounded-xl bg-brand-card border border-brand-border text-white placeholder-gray-500 focus:outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold transition-all"
        />
      </div>
      <button 
        type="button"
        id="submit-btn"
        class="btn-primary w-full whitespace-nowrap flex items-center justify-center gap-2"
      >
        <span id="btn-text">Subscribe</span>
        <svg id="btn-spinner" class="w-4 h-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>
    </form>
    <p class="text-gray-500 text-xs mt-6 flex flex-wrap items-center justify-center gap-4">
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>No spam</span>
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>One-click unsubscribe</span>
      <span class="flex items-center gap-1"><svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>Instant signup</span>
    </p>
  </div>

  <div id="sub-success" class="sub-panel hidden">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 mx-auto mb-6 flex items-center justify-center text-4xl shadow-lg shadow-emerald-500/30">✅</div>
    <h2 class="display-heading text-white mb-2">You're <span class="text-emerald-400">In</span></h2>
    <p id="success-message" class="text-gray-300 text-lg mb-6">Welcome to the Dispatch!</p>
    <div class="bg-brand-card rounded-xl p-6 mb-6 text-left max-w-sm mx-auto">
      <p class="text-sm text-gray-400 mb-2">What you'll receive:</p>
      <ul class="space-y-2 text-sm text-gray-300">
        <li class="flex items-center gap-2"><span class="text-brand-gold">📦</span> The Rig — AI hardware benchmarks</li>
        <li class="flex items-center gap-2"><span class="text-brand-accent">⛏️</span> The Mine — Crypto mining insights</li>
        <li class="flex items-center gap-2"><span class="text-purple-400">💰</span> The Ledger — Trading & finance</li>
      </ul>
    </div>
    <a href="/" class="btn-primary inline-block">Back to Home</a>
    {!inline && <a href="/directory/" class="text-gray-400 hover:text-white text-sm ml-4">Explore Directory →</a>}
  </div>

  <div id="sub-error" class="sub-panel hidden">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-red-500 to-red-600 mx-auto mb-6 flex items-center justify-center text-4xl shadow-lg shadow-red-500/30">⚠️</div>
    <h2 class="display-heading text-white mb-2">Oops, <span class="text-red-400">Something Failed</span></h2>
    <p id="error-message" class="text-gray-300 text-lg mb-4">We couldn't save your subscription right now.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button id="retry-btn" class="btn-primary inline-block">Try Again</button>
      <a id="manual-link" href="mailto:derekkosakura@gmail.com?subject=Subscribe" class="px-6 py-3 border border-brand-border rounded-xl text-gray-400 hover:text-white hover:border-brand-gold transition-colors inline-block">Open Email Client</a>
    </div>
    <p class="text-gray-500 text-xs mt-4">Your email was saved locally — we'll retry automatically.</p>
  </div>
</div>

<script is:inline>
(function() {
  // --- IndexedDB Helper ---
  const DB_NAME = 'mf_subs_db';
  const DB_STORE = 'pending_emails';
  let dbPromise = null;

  function openDB() {
    if (dbPromise) return dbPromise;
    dbPromise = new Promise((resolve, reject) => {
      const req = indexedDB.open(DB_NAME, 1);
      req.onupgradeneeded = (e) => {
        e.target.result.createObjectStore(DB_STORE, { keyPath: 'email' });
      };
      req.onsuccess = (e) => resolve(e.target.result);
      req.onerror = (e) => reject(e.target.error);
    });
    return dbPromise;
  }

  async function savePending(email) {
    try {
      const db = await openDB();
      const tx = db.transaction(DB_STORE, 'readwrite');
      const store = tx.objectStore(DB_STORE);
      store.put({ email: email, timestamp: Date.now(), retries: 0 });
    } catch(err) { console.warn('IDB save failed:', err); }
  }

  async function removePending(email) {
    try {
      const db = await openDB();
      const tx = db.transaction(DB_STORE, 'readwrite');
      tx.objectStore(DB_STORE).delete(email);
    } catch(err) {}
  }

  async function getAllPending() {
    try {
      const db = await openDB();
      return await new Promise((res, rej) => {
        const tx = db.transaction(DB_STORE, 'readonly');
        const store = tx.objectStore(DB_STORE);
        const req = store.getAll();
        req.onsuccess = () => res(req.result || []);
        req.onerror = () => rej(req.error);
      });
    } catch(err) { return []; }
  }

  async function incrementRetries(email) {
    try {
      const db = await openDB();
      const tx = db.transaction(DB_STORE, 'readwrite');
      const store = tx.objectStore(DB_STORE);
      const req = store.get(email);
      req.onsuccess = () => {
        const data = req.result;
        if (data) {
          data.retries = (data.retries || 0) + 1;
          store.put(data);
        }
      };
    } catch(err) {}
  }

  // --- API Call ---
  async function postSubscribe(email) {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 10000); // 10s timeout
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: location.hostname }),
        signal: ctrl.signal
      });
      clearTimeout(timer);
      return await res.json();
    } catch(err) {
      clearTimeout(timer);
      if (err.name === 'AbortError') throw new Error('Request timed out');
      throw err;
    }
  }

  // --- UI State Machine ---
  function getPanels(wrapper) {
    return {
      initial: wrapper.querySelector('#sub-initial'),
      success: wrapper.querySelector('#sub-success'),
      error: wrapper.querySelector('#sub-error'),
      btnText: wrapper.querySelector('#btn-text'),
      btnSpinner: wrapper.querySelector('#btn-spinner'),
      submitBtn: wrapper.querySelector('#submit-btn'),
      emailInput: wrapper.querySelector('#email-input'),
      successMsg: wrapper.querySelector('#success-message'),
      errorMsg: wrapper.querySelector('#error-message'),
      retryBtn: wrapper.querySelector('#retry-btn'),
      manualLink: wrapper.querySelector('#manual-link')
    };
  }

  function show(panelName, wrapper) {
    const p = getPanels(wrapper);
    ['initial','success','error'].forEach(k => p[k]?.classList.add('hidden'));
    p[panelName]?.classList.remove('hidden');
  }

  function setLoading(isLoading, wrapper) {
    const p = getPanels(wrapper);
    p.submitBtn.disabled = isLoading;
    p.btnText.textContent = isLoading ? 'Subscribing...' : 'Subscribe';
    p.btnSpinner?.classList.toggle('hidden', !isLoading);
  }

  function isValidEmail(val) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val.trim());
  }

  // --- Main Subscribe Logic ---
  async function attemptSubscribe(email, wrapper) {
    const p = getPanels(wrapper);
    if (!isValidEmail(email)) {
      p.emailInput.classList.add('border-red-500');
      setTimeout(() => p.emailInput.classList.remove('border-red-500'), 2000);
      p.emailInput.focus();
      return;
    }

    setLoading(true, wrapper);
    await savePending(email.toLowerCase().trim());

    try {
      const data = await postSubscribe(email);
      await removePending(email);

      if (data.success) {
        p.successMsg.textContent = data.message || "Welcome to the Dispatch!";
        show('success', wrapper);
        window.scrollTo({ top: wrapper.offsetTop - 80, behavior: 'smooth' });
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    } catch (err) {
      console.warn('Subscribe error:', err);
      await incrementRetries(email);
      p.errorMsg.textContent = err.message || 'Network error. Please try again.';
      p.manualLink.href = `mailto:derekkosakura@gmail.com?subject=Subscribe&body=Email: ${encodeURIComponent(email)}`;
      show('error', wrapper);
    } finally {
      setLoading(false, wrapper);
    }
  }

  // --- Sync Loop ---
  async function syncPending() {
    const pending = await getAllPending();
    if (!pending.length) return;
    
    for (const record of pending) {
      if (record.retries >= 5) continue; // Give up after 5 tries
      try {
        const data = await postSubscribe(record.email);
        if (data.success) await removePending(record.email);
      } catch(err) {}
    }
  }

  // --- Initialize Components ---
  document.querySelectorAll('.subscription-component').forEach(wrapper => {
    const p = getPanels(wrapper);
    if (!p.emailInput) return;

    // Click handler
    p.submitBtn?.addEventListener('click', () => {
      attemptSubscribe(p.emailInput.value, wrapper);
    });

    // Enter key
    p.emailInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); p.submitBtn.click(); }
    });

    // Retry button
    p.retryBtn?.addEventListener('click', () => {
      show('initial', wrapper);
      p.emailInput.value = '';
      p.emailInput.focus();
    });

    // On mount: try syncing any pending from previous sessions
    syncPending();
  });
})();
</script>