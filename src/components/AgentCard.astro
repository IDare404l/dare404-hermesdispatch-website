---
export interface Props {
  name: string;
  role: string;
  description: string;
  image?: string;
  status?: 'online' | 'busy' | 'offline' | 'away';
  skills?: string[];
  href?: string;
}

const { 
  name, 
  role, 
  description, 
  image = "/agents/default.png",
  status = 'online',
  skills = [],
  href = "#"
} = Astro.props;

const statusColors = {
  online: 'bg-emerald-500',
  busy: 'bg-amber-500',
  offline: 'bg-slate-500',
  away: 'bg-blue-500'
};

const statusLabels = {
  online: 'Online',
  busy: 'Busy',
  offline: 'Offline',
  away: 'Away'
};
---

<a
  href={href}
  class="group relative block p-6 rounded-2xl bg-slate-900/50 border border-slate-800 backdrop-blur-sm overflow-hidden transition-all duration-500 hover:border-amber-500/30 hover:bg-slate-900/70 hover:-translate-y-1"
>
  <!-- Hover glow effect -->
  <div class="absolute inset-0 bg-gradient-to-br from-amber-500/0 via-amber-500/0 to-amber-500/0 group-hover:from-amber-500/5 group-hover:via-transparent group-hover:to-amber-500/5 transition-all duration-500"></div>
  
  <div class="relative z-10">
    <!-- Header with avatar and status -->
    <div class="flex items-start gap-4 mb-4">
      <div class="relative">
        <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 p-[2px] overflow-hidden">
          <div class="w-full h-full rounded-xl bg-slate-900 flex items-center justify-center">
            {image && image !== "/agents/default.png" ? (
              <img src={image} alt={name} class="w-full h-full object-cover rounded-xl" />
            ) : (
              <span class="text-2xl">🤖</span>
            )}
          </div>
        </div>
        
        <!-- Status indicator -->
        <div class={`absolute -bottom-1 -right-1 w-5 h-5 rounded-full ${statusColors[status]} border-2 border-slate-900 flex items-center justify-center`} title={statusLabels[status]}>
          {status === 'online' && (
            <span class="w-2 h-2 rounded-full bg-white/50 animate-pulse"></span>
          )}
        </div>
      </div>
      
      <div class="flex-1">
        <h3 class="text-lg font-bold text-slate-100 group-hover:text-amber-400 transition-colors">
          {name}
        </h3>
        <p class="text-sm text-amber-500/80 font-medium">
          {role}
        </p>
      </div>
    </div>
    
    <!-- Description -->
    <p class="text-slate-400 text-sm leading-relaxed mb-4">
      {description}
    </p>
    
    <!-- Skills tags -->
    {skills.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-slate-800 text-slate-300 border border-slate-700">
            {skill}
          </span>
        ))}
      </div>
    )}
    
    <!-- CTA -->
    <div class="mt-4 pt-4 border-t border-slate-800 flex items-center justify-between">
      <span class="text-sm text-slate-500 flex items-center gap-1">
        <span class={`w-2 h-2 rounded-full ${statusColors[status]}`}></span>
        {statusLabels[status]}
      </span>
      
      <span class="text-amber-500 opacity-0 group-hover:opacity-100 transition-opacity">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>
