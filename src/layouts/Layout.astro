        "@type": "Organization",
        "name": "The Hermes Dispatch by Mission Freedom",
        "url": "https://hermesdispatch.dev"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://hermesdispatch.dev/directory?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    <script src="/js/tool-tracker.js" defer></script>
