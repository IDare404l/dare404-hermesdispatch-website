---
import '../styles/global.css';
import versionData from '../config/version.json';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The Hermes Dispatch - Daily AI automation insights, Hermes skills, and tools from dare404" } = Astro.props;
const buildTime = new Date().toISOString().slice(0,19).replace('T',' ') + ' UTC';
const commitHash = versionData?.commit?.slice(0,7) || 'local';
const buildNum = versionData?.build || 'DEV';
const fullCommit = versionData?.commit || 'local';
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Hermes Mission Freedom</title>
    <meta property="og:title" content=`${title} | Hermes Mission Freedom` />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Organization Schema (AEO) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Mission Freedom - The Hermes Dispatch",
      "url": "https://hermesdispatch.dev",
      "logo": "https://hermesdispatch.dev/favicon.svg",
      "founder": {
        "@type": "Person",
        "name": "dare404"
      },
      "description": "AI agent automation systems for digital entrepreneurship. One person + 7 coordinated AI agents.",
      "sameAs": [
        "https://twitter.com/Dare__404"
      ]
    }
    </script>
    <!-- WebSite Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "The Hermes Dispatch",
      "url": "https://hermesdispatch.dev",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://hermesdispatch.dev/skills?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100">
    <nav class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center font-bold text-white">H</div>
            <span class="font-semibold text-lg">HermesDispatch</span>
          </a>
          <div class="hidden md:flex items-center gap-1">
            <a href="/" class="px-4 py-2 rounded-lg hover:bg-neutral-800 transition-colors">Home</a>
            <!-- Dropdown for Directory -->
            <div class="relative group">
              <a href="/directory" class="px-4 py-2 rounded-lg hover:bg-neutral-800 transition-colors">Directory</a>
              <div class="absolute top-full left-0 mt-1 w-48 bg-neutral-900 border border-neutral-800 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                <a href="/hardware" class="block px-4 py-2 hover:bg-neutral-800 transition-colors rounded-t-lg">🔧 Upgrades</a>
                <a href="/crypto" class="block px-4 py-2 hover:bg-neutral-800 transition-colors">⛏️ The Mine</a>
                <a href="/invest" class="block px-4 py-2 hover:bg-neutral-800 transition-colors rounded-b-lg">💰 The Ledger</a>
              </div>
            </div>
            <a href="/about" class="px-4 py-2 rounded-lg hover:bg-neutral-800 transition-colors">About</a>
            <a href="/newsletter" class="px-4 py-2 rounded-lg hover:bg-neutral-800 transition-colors">Newsletter</a>
          </div>
          <a href="/subscribe" class="btn-primary text-sm">Subscribe</a>
        </div>
      </div>
    </nav>
    
    <main>
      <slot />
    </main>
    
    <!-- Sticky Mobile Subscribe CTA -->
    <div id="mobile-cta" class="fixed bottom-0 left-0 right-0 z-50 bg-neutral-900/95 border-t border-neutral-700 backdrop-blur-sm md:hidden translate-y-full transition-transform duration-300">
      <div class="flex items-center gap-3 px-4 py-3 max-w-7xl mx-auto">
        <div class="flex-1 min-w-0">
          <p class="text-xs text-neutral-300 truncate">🚀 Get AI automation insights daily</p>
          <p class="text-[10px] text-neutral-500">15:00 MST. One-click unsubscribe.</p>
        </div>
        <a href="/subscribe" class="btn-primary text-xs px-4 py-2 flex-shrink-0">Subscribe</a>
        <button onclick="document.getElementById('mobile-cta').classList.add('translate-y-full')" class="text-neutral-500 text-lg leading-none flex-shrink-0 px-1">×</button>
      </div>
    </div>
    
    <!-- Exit-Intent Popup -->
    <div id="exit-popup" class="fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm hidden items-center justify-center p-4">
      <div class="bg-neutral-900 border border-neutral-700 rounded-2xl p-8 max-w-md w-full shadow-2xl relative">
        <button onclick="document.getElementById('exit-popup').classList.add('hidden');document.getElementById('exit-popup').classList.remove('flex')" class="absolute top-4 right-4 text-neutral-500 hover:text-white text-xl">×</button>
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-4 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">📧</div>
        <h3 class="text-xl font-bold text-center mb-2">Wait — Don't Miss Tomorrow's Dispatch</h3>
        <p class="text-sm text-neutral-400 text-center mb-6">AI agent automation insights. Delivered daily at 15:00 MST. No spam. One-click unsubscribe.</p>
        <form action="/api/subscribe/" method="POST" class="flex flex-col gap-3">
          <input type="email" name="email" placeholder="you@example.com" required class="w-full px-4 py-3 rounded-xl bg-neutral-800 border border-neutral-600 text-white placeholder-neutral-500 focus:border-brand-gold focus:outline-none">
          <button type="submit" class="btn-primary w-full">Subscribe Now</button>
        </form>
        <button onclick="document.getElementById('exit-popup').classList.add('hidden');document.getElementById('exit-popup').classList.remove('flex')" class="w-full mt-3 text-xs text-neutral-500 hover:text-neutral-300">No thanks, I'll browse</button>
      </div>
    </div>
    
    <script>
      // Exit-intent detection
      (function() {
        let shown = false;
        document.addEventListener('mouseleave', function(e) {
          if (e.clientY < 0 && !shown && !window.location.pathname.includes('/subscribe')) {
            shown = true;
            var popup = document.getElementById('exit-popup');
            if (popup) { popup.classList.remove('hidden'); popup.classList.add('flex'); }
          }
        });
        
        // Mobile CTA: show after 15s scroll
        if (window.innerWidth < 768) {
          setTimeout(function() {
            var cta = document.getElementById('mobile-cta');
            if (cta) cta.classList.remove('translate-y-full');
          }, 15000);
        }
      })();
    </script>
    
    <footer class="border-t border-neutral-800 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-6 h-6 rounded bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-xs font-bold">H</div>
              <span class="font-semibold">HermesDispatch</span>
            </div>
            <p class="text-neutral-400 text-sm max-w-sm">Documenting the journey of building AI agent automation systems. One person + AI skills toward Mission Freedom.</p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Resources</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="/about-igor" class="hover:text-neutral-200 transition-colors">About IGOR</a></li>
              <li><a href="/skills" class="hover:text-neutral-200 transition-colors">Skills</a></li>
              <li><a href="/tools" class="hover:text-neutral-200 transition-colors">Tools</a></li>
              <li><a href="/blog" class="hover:text-neutral-200 transition-colors">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Connect</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="https://github.com/IDare404l" class="hover:text-neutral-200 transition-colors">GitHub</a></li>
              <li><a href="https://twitter.com/Dare__404" class="hover:text-neutral-200 transition-colors">Twitter</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-neutral-800 mt-8 pt-8 text-center text-sm text-neutral-400">
          <p>Insights from IGOR • Generated by Hermes</p>
          <p class="mt-2 font-mono text-xs text-neutral-500" title={`Full commit: ${fullCommit}`}>
            Build #{buildNum} • {buildTime} • {commitHash}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>