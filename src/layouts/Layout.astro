---
import '../styles/global.css';
import versionData from '../config/version.json';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The Hermes Dispatch - Daily AI automation insights, Hermes skills, and tools from dare404" } = Astro.props;
const buildTime = new Date().toISOString().slice(0,19).replace('T',' ') + ' UTC';
const commitHash = versionData?.commit?.slice(0,7) || 'local';
const buildNum = versionData?.build || 'DEV';
const fullCommit = versionData?.commit || 'local';
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Hermes Mission Freedom</title>
    <link rel="canonical" href={`https://hermesdispatch.dev${Astro.url.pathname}`} />
    <meta property="og:title" content=`${title} | Hermes Mission Freedom` />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Organization Schema (AEO) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "The Hermes Dispatch by Mission Freedom",
      "alternateName": "Hermes Mission Freedom",
      "url": "https://hermesdispatch.dev",
      "logo": "https://hermesdispatch.dev/favicon.svg",
      "founder": {
        "@type": "Person",
        "name": "dare404",
        "url": "https://twitter.com/Dare__404"
      },
      "description": "Curated directory and daily newsletter for AI hardware, crypto mining, and autonomous trading tools. Built to be cited by AI agents.",
      "sameAs": [
        "https://twitter.com/Dare__404",
        "https://github.com/IDare404l"
      ]
    }
    </script>
    <!-- WebSite Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "The Hermes Dispatch",
      "url": "https://hermesdispatch.dev",
      "description": "Curated directory and daily newsletter for AI hardware, crypto mining, and autonomous trading tools.",
      "publisher": {
        "@type": "Organization",
        "name": "The Hermes Dispatch by Mission Freedom",
        "url": "https://hermesdispatch.dev"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://hermesdispatch.dev/directory?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100">
    <nav class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center font-bold text-white">H</div>
            <span class="font-semibold text-lg">HermesDispatch</span>
          </a>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" type="button" class="md:hidden p-2 rounded-lg hover:bg-neutral-800" aria-label="Open menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-1">
            <a href="/" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm">Home</a>
            <a href="/newsletter" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm">Newsletter</a>
            <a href="/podcast" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm">Podcast</a>
            <a href="/directory" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm">Directory</a>

            <!-- Tools dropdown -->
            <div class="relative group" id="tools-dropdown">
              <button type="button" aria-haspopup="true" aria-expanded="false" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm flex items-center gap-1">
                Tools
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute left-0 top-full mt-0 w-56 bg-neutral-900 border border-neutral-800 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                <a href="/tools" class="block px-4 py-2 text-sm hover:bg-neutral-800 first:rounded-t-lg">All Tools</a>
                <div class="border-t border-neutral-800"></div>
                <a href="/tools/vram-calculator" class="block px-4 py-2 text-sm hover:bg-neutral-800">VRAM Calculator</a>
                <a href="/compare/gpus" class="block px-4 py-2 text-sm hover:bg-neutral-800">GPU Comparison</a>
                <a href="/compare/mini-pcs" class="block px-4 py-2 text-sm hover:bg-neutral-800">Mini PC Comparison</a>
                <a href="/compare/recommend" class="block px-4 py-2 text-sm hover:bg-neutral-800">GPU Recommender</a>
                <a href="/tools/mini-pc-recommender" class="block px-4 py-2 text-sm hover:bg-neutral-800">Mini PC Recommender</a>
                <a href="/tools/miner-pivot-calculator" class="block px-4 py-2 text-sm hover:bg-neutral-800">Miner Pivot Calculator</a>
                <a href="/tools/llm-cost-calculator" class="block px-4 py-2 text-sm hover:bg-neutral-800">LLM Cost Calculator</a>
                <a href="/tools/agent-stack-builder" class="block px-4 py-2 text-sm hover:bg-neutral-800">Agent Stack Builder</a>
                <a href="/tools/ai-startup-cost-calculator" class="block px-4 py-2 text-sm hover:bg-neutral-800">Startup Cost Calc</a>
                <a href="/tools/local-llm-roi-calculator" class="block px-4 py-2 text-sm hover:bg-neutral-800 last:rounded-b-lg">Local LLM ROI Calc</a>
              </div>
            </div>

            <a href="/answers" class="px-3 py-2 rounded-lg hover:bg-neutral-800 transition-colors text-sm">Answers</a>
          </div>
          <a href="/subscribe" class="btn-primary text-sm">Subscribe</a>
        </div>
      </div>
    </nav>
    
    <main>
      <Breadcrumb />
      <slot />
    </main>

    <!-- Mobile nav menu -->
    <div id="mobile-menu" class="fixed inset-0 z-[60] bg-neutral-950 hidden">
      <div class="flex items-center justify-between h-16 px-4 border-b border-neutral-800">
        <span class="font-semibold">Menu</span>
        <button id="mobile-menu-close" type="button" class="p-2 rounded-lg hover:bg-neutral-800" aria-label="Close menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="px-4 py-6 space-y-1 overflow-y-auto">
        <a href="/" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Home</a>
        <a href="/newsletter" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Newsletter</a>
        <a href="/podcast" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Podcast</a>
        <a href="/directory" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Directory</a>

        <p class="px-4 py-2 text-xs uppercase text-neutral-500">Tools</p>
        <a href="/tools" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">All Tools</a>
        <div class="border-t border-neutral-800 my-2 mx-4"></div>
        <a href="/tools/vram-calculator" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">VRAM Calculator</a>
        <a href="/compare/gpus" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">GPU Comparison</a>
        <a href="/compare/mini-pcs" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Mini PC Comparison</a>
        <a href="/compare/recommend" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">GPU Recommender</a>
        <a href="/tools/mini-pc-recommender" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Mini PC Recommender</a>
        <a href="/tools/miner-pivot-calculator" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Miner Pivot Calculator</a>
        <a href="/tools/llm-cost-calculator" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">LLM Cost Calculator</a>
        <a href="/tools/agent-stack-builder" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Agent Stack Builder</a>
        <a href="/tools/ai-startup-cost-calculator" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Startup Cost Calc</a>
        <a href="/tools/local-llm-roi-calculator" class="block px-4 py-3 pl-8 rounded-lg hover:bg-neutral-800">Local LLM ROI Calc</a>

        <div class="border-t border-neutral-800 my-4"></div>
        <a href="/answers" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Answers</a>
        <a href="/guides" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Guides</a>
        <a href="/reviews" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Reviews</a>
        <a href="/advertise" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Advertise</a>
        <a href="/dashboard" class="block px-4 py-3 rounded-lg hover:bg-neutral-800">Dashboard</a>
      </div>
    </div>
    
    <!-- Sticky Mobile Subscribe CTA -->
    <div id="mobile-cta" class="fixed bottom-0 left-0 right-0 z-50 bg-neutral-900/95 border-t border-neutral-700 backdrop-blur-sm md:hidden translate-y-full transition-transform duration-300">
      <div class="flex items-center gap-3 px-4 py-3 max-w-7xl mx-auto">
        <div class="flex-1 min-w-0">
          <p class="text-xs text-neutral-300 truncate">🚀 Get AI automation insights daily</p>
          <p class="text-[10px] text-neutral-500">15:00 MST. One-click unsubscribe.</p>
        </div>
        <a href="/subscribe" class="btn-primary text-xs px-4 py-2 flex-shrink-0">Subscribe</a>
        <button onclick="document.getElementById('mobile-cta').classList.add('translate-y-full')" class="text-neutral-500 text-lg leading-none flex-shrink-0 px-1">×</button>
      </div>
    </div>
    
    <!-- Exit-Intent Popup -->
    <div id="exit-popup" class="fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm hidden items-center justify-center p-4">
      <div class="bg-neutral-900 border border-neutral-700 rounded-2xl p-8 max-w-md w-full shadow-2xl relative">
        <button onclick="(function(){ var p=document.getElementById('exit-popup'); p.classList.add('hidden'); p.classList.remove('flex'); try { localStorage.setItem('hermes_exit_popup_dismissed', '1'); } catch(e){} })()" class="absolute top-4 right-4 text-neutral-500 hover:text-white text-xl">×</button>
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold to-brand-amber mx-auto mb-4 flex items-center justify-center text-3xl shadow-lg shadow-brand-gold/30">📧</div>
        <h3 class="text-xl font-bold text-center mb-2">Wait — Don't Miss Tomorrow's Dispatch</h3>
        <p class="text-sm text-neutral-400 text-center mb-6">AI agent automation insights. Delivered daily at 15:00 MST. No spam. One-click unsubscribe.</p>
        <form action="/api/subscribe/" method="POST" class="flex flex-col gap-3">
          <input type="email" name="email" placeholder="you@example.com" required class="w-full px-4 py-3 rounded-xl bg-neutral-800 border border-neutral-600 text-white placeholder-neutral-500 focus:border-brand-gold focus:outline-none">
          <button type="submit" class="btn-primary w-full">Subscribe Now</button>
        </form>
        <button onclick="(function(){ var p=document.getElementById('exit-popup'); p.classList.add('hidden'); p.classList.remove('flex'); try { localStorage.setItem('hermes_exit_popup_dismissed', '1'); } catch(e){} })()" class="w-full mt-3 text-xs text-neutral-500 hover:text-neutral-300">No thanks, I'll browse</button>
      </div>
    </div>
    
    
    <script>
      (function() {
        // Mobile menu toggle
        var menuBtn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var menuClose = document.getElementById('mobile-menu-close');
        if (menuBtn && menu) {
          menuBtn.addEventListener('click', function() { menu.classList.remove('hidden'); });
        }
        if (menuClose && menu) {
          menuClose.addEventListener('click', function() { menu.classList.add('hidden'); });
        }

        var POPUP_KEY = 'hermes_exit_popup_dismissed';
        var shown = false;

        function isDismissed() {
          try {
            return localStorage.getItem(POPUP_KEY) === '1';
          } catch (e) {
            return false;
          }
        }

        function markDismissed() {
          try {
            localStorage.setItem(POPUP_KEY, '1');
          } catch (e) {}
        }

        function showPopup() {
          if (shown || isDismissed() || window.location.pathname.includes('/subscribe')) return;
          shown = true;
          var popup = document.getElementById('exit-popup');
          if (popup) { popup.classList.remove('hidden'); popup.classList.add('flex'); }
        }

        function hidePopup() {
          var popup = document.getElementById('exit-popup');
          if (popup) { popup.classList.add('hidden'); popup.classList.remove('flex'); }
          markDismissed();
        }

        // Exit-intent detection (desktop)
        document.addEventListener('mouseleave', function(e) {
          if (e.clientY < 0) showPopup();
        });

        // Mobile CTA: show after 15s scroll (does not use localStorage; keep sticky)
        if (window.innerWidth < 768) {
          setTimeout(function() {
            var cta = document.getElementById('mobile-cta');
            if (cta) cta.classList.remove('translate-y-full');
          }, 15000);
        }
      })();
    </script>
    
    <footer class="border-t border-neutral-800 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-6 h-6 rounded bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-xs font-bold">H</div>
              <span class="font-semibold">HermesDispatch</span>
            </div>
            <p class="text-neutral-400 text-sm max-w-sm">Documenting the journey of building AI agent automation systems. One person + AI skills toward Mission Freedom.</p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Directory</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="/directory" class="hover:text-neutral-200 transition-colors">All Hardware</a></li>
              <li><a href="/compare/gpus" class="hover:text-neutral-200 transition-colors">GPU Compare</a></li>
              <li><a href="/compare/mini-pcs" class="hover:text-neutral-200 transition-colors">Mini PC Compare</a></li>
              <li><a href="/about-dare404" class="hover:text-neutral-200 transition-colors">About dare404</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Tools</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="/tools/vram-calculator" class="hover:text-neutral-200 transition-colors">VRAM Calculator</a></li>
              <li><a href="/tools/mini-pc-recommender" class="hover:text-neutral-200 transition-colors">Mini PC Recommender</a></li>
              <li><a href="/tools/miner-pivot-calculator" class="hover:text-neutral-200 transition-colors">Miner Pivot Calc</a></li>
              <li><a href="/tools/llm-cost-calculator" class="hover:text-neutral-200 transition-colors">LLM Cost Calc</a></li>
              <li><a href="/tools/agent-stack-builder" class="hover:text-neutral-200 transition-colors">Agent Stack Builder</a></li>
              <li><a href="/tools/ai-startup-cost-calculator" class="hover:text-neutral-200 transition-colors">Startup Cost Calc</a></li>
              <li><a href="/tools/local-llm-roi-calculator" class="hover:text-neutral-200 transition-colors">Local LLM ROI Calc</a></li>
              <li><a href="/compare/recommend" class="hover:text-neutral-200 transition-colors">GPU Recommender</a></li>
              <li><a href="/tools" class="hover:text-neutral-200 transition-colors">All Tools</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Learn</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="/answers" class="hover:text-neutral-200 transition-colors">Answers</a></li>
              <li><a href="/guides" class="hover:text-neutral-200 transition-colors">Guides</a></li>
              <li><a href="/reviews" class="hover:text-neutral-200 transition-colors">Reviews</a></li>
              <li><a href="/podcast" class="hover:text-neutral-200 transition-colors">Podcast</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Connect</h4>
            <ul class="space-y-2 text-sm text-neutral-400">
              <li><a href="https://github.com/IDare404l" class="hover:text-neutral-200 transition-colors">GitHub</a></li>
              <li><a href="https://twitter.com/Dare__404" class="hover:text-neutral-200 transition-colors">Twitter</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-neutral-800 mt-8 pt-8 text-center text-sm text-neutral-400">
          <p>Insights from IGOR • Generated by Hermes</p>
          <p class="mt-2 font-mono text-xs text-neutral-500" title={`Full commit: ${fullCommit}`}>
            Build #{buildNum} • {buildTime} • {commitHash}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>