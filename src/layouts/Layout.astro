---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Mission Freedom - AI Automation for Digital Entrepreneurs | Multi-agent orchestration, print on demand AI, and affiliate marketing automation", 
  image = "/og-image.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Tailwind -->
  </head>
  <body class="bg-brand-dark text-gray-100 min-h-screen antialiased">
    <div class="noise fixed inset-0 z-0 pointer-events-none"></div>
    
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
      <div class="backdrop-blur-xl bg-brand-dark/70 border-b border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <nav class="flex items-center justify-between h-16 md:h-20">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-gold to-brand-amber flex items-center justify-center text-brand-dark font-bold text-xl group-hover:scale-110 transition-transform">
                M
              </div>
              <span class="text-xl font-bold hidden sm:block">
                <span class="text-gradient">Mission</span>
                <span class="text-white">Freedom</span>
              </span>
            </a>
            
            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-1">
              <a href="/" class="nav-link px-4 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-all">Home</a>
              <a href="/agents" class="nav-link px-4 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-all">Agents</a>
              <a href="/skills" class="nav-link px-4 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-all">Skills</a>
              <a href="/about" class="nav-link px-4 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-all">About</a>
              <a href="/newsletter" class="nav-link px-4 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-all">Newsletter</a>
            </div>
            
            <!-- CTA Button -->
            <div class="hidden md:block">
              <a href="https://twitter.com/Dare__404" target="_blank" class="px-5 py-2.5 bg-brand-gold/10 border border-brand-gold/50 text-brand-gold font-medium rounded-lg hover:bg-brand-gold hover:text-brand-dark transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Follow
              </a>
            </div>
            
            <!-- Mobile Menu Button -->
            <button class="md:hidden p-2 text-gray-400 hover:text-white" id="mobileMenuBtn" aria-label="Toggle menu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </nav>
        </div>
      </div>
      
      <!-- Mobile Menu -->
      <div class="md:hidden hidden bg-brand-dark/95 backdrop-blur-xl border-b border-white/10" id="mobileMenu">
        <div class="px-4 py-4 space-y-2">
          <a href="/" class="block px-4 py-3 text-base font-medium text-gray-300 hover:text-white hover:bg-white/5 rounded-lg">Home</a>
          <a href="/agents" class="block px-4 py-3 text-base font-medium text-gray-300 hover:text-white hover:bg-white/5 rounded-lg">Agents</a>
          <a href="/skills" class="block px-4 py-3 text-base font-medium text-gray-300 hover:text-white hover:bg-white/5 rounded-lg">Skills</a>
          <a href="/about" class="block px-4 py-3 text-base font-medium text-gray-300 hover:text-white hover:bg-white/5 rounded-lg">About</a>
          <a href="/newsletter" class="block px-4 py-3 text-base font-medium text-gray-300 hover:text-white hover:bg-white/5 rounded-lg">Newsletter</a>
        </div>
      </div>
    </header>
    
    <!-- Main Content -->
    <main class="relative z-10 pt-20 md:pt-24">
      <slot />
    </main>
    
    <!-- Footer -->
    <footer class="relative z-10 border-t border-white/10 mt-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid md:grid-cols-4 gap-12">
          <!-- Brand -->
          <div class="col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-gold to-brand-amber flex items-center justify-center text-brand-dark font-bold">
                M
              </div>
              <span class="text-xl font-bold">
                <span class="text-gradient">Mission</span>
                <span class="text-white">Freedom</span>
              </span>
            </div>
            <p class="text-gray-400 max-w-sm leading-relaxed">
              Building automated systems for digital entrepreneurship. Multi-agent orchestration, AI-powered SEO, and print on demand automation.
            </p>
            <div class="flex items-center gap-4 mt-6">
              <a href="https://twitter.com/Dare__404" target="_blank" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-brand-gold hover:border-brand-gold/50 transition-all">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://github.com" target="_blank" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-brand-gold hover:border-brand-gold/50 transition-all">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>
          
          <!-- Links -->
          <div>
            <h3 class="text-white font-semibold mb-4">Navigation</h3>
            <ul class="space-y-3">
              <li><a href="/" class="text-gray-400 hover:text-brand-gold transition-colors">Home</a></li>
              <li><a href="/agents" class="text-gray-400 hover:text-brand-gold transition-colors">Agents</a></li>
              <li><a href="/skills" class="text-gray-400 hover:text-brand-gold transition-colors">Skills</a></li>
              <li><a href="/about" class="text-gray-400 hover:text-brand-gold transition-colors">Our Story</a></li>
            </ul>
          </div>
          
          <div>
            <h3 class="text-white font-semibold mb-4">Resources</h3>
            <ul class="space-y-3">
              <li><a href="/newsletter" class="text-gray-400 hover:text-brand-gold transition-colors">Newsletter</a></li>
              <li><a href="/team" class="text-gray-400 hover:text-brand-gold transition-colors">Team</a></li>
              <li><a href="https://twitter.com/Dare__404" target="_blank" class="text-gray-400 hover:text-brand-gold transition-colors">Twitter</a></li>
            </ul>
          </div>
        </div>
        
        <!-- Bottom Bar -->
        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-gray-500 text-sm">
            &copy; {new Date().getFullYear()} Mission Freedom. Built with AI + Determination.
          </p>
          <div class="flex items-center gap-6">
            <span class="text-gray-500 text-sm flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
              Systems Active
            </span>
          </div>
        </div>
      </div>
    </footer>
    
    <script>
      // Navbar scroll effect
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
          navbar?.classList.add('bg-brand-dark/80', 'backdrop-blur-xl');
        } else {
          navbar?.classList.remove('bg-brand-dark/80', 'backdrop-blur-xl');
        }
      });
      
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      const mobileMenu = document.getElementById('mobileMenu');
      
      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
      
      // Active nav link highlighting
      const currentPath = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        if (link.getAttribute('href') === currentPath) {
          link.classList.add('text-white', 'bg-white/10');
        }
      });
    </script>
  </body>
</html>
